@model List<pharaohsLegacy.Models.ShopOrder>
@using pharaohsLegacy.Extensions
@{
    ViewData["Title"] = "My Orders";
    var lang = Context.Session.GetString("Lang") ?? "en";
}

<div class="shop-wrap">
    <h1 class="shop-page-title">@Html.L("Shop_MyOrders")</h1>

    @if (!Model.Any())
    {
        <p class="shop-empty">@Html.L("Shop_NoOrders")</p>
    }
    else
    {
        <div class="orders-list">
            @foreach (var o in Model)
            {
                <div class="order-row">
                    <img src="@o.ProductImage" alt="@o.ProductName" />
                    <div class="order-info">
                        <h4>@o.ProductName</h4>
                        <span>@Html.L("Shop_Quantity_Label"): @Html.Digits((object)o.Quantity)</span>
                        <span>@Html.Digits((object)o.TotalPrice) @Html.L("Common_EGP")</span>
                    </div>
                    <span class="order-status status-@o.Status.ToLower()">@o.Status</span>
                </div>
            }
        </div>
    }
</div>

<style>
    .orders-list { display: flex; flex-direction: column; gap: 1rem; max-width: 700px; margin: 0 auto; }
    .order-row { display: flex; align-items: center; gap: 1rem; background: var(--dark3); border: 1px solid var(--border); border-radius: 8px; padding: 1rem; }
    .order-row img { width: 64px; height: 64px; object-fit: cover; border-radius: 6px; }
    .order-info { flex: 1; display: flex; flex-direction: column; gap: .2rem; }
    .order-info h4 { margin: 0; font-family: 'Cinzel', serif; color: var(--text); font-size: .9rem; }
    .order-info span { font-size: .8rem; color: var(--muted); }
    .order-status { font-size: .75rem; padding: .3rem .7rem; border-radius: 20px; font-family: 'Cinzel', serif; letter-spacing: 1px; }
    .status-confirmed { background: rgba(63,174,90,.15); color: #3fae5a; }
    .status-cancelled, .status-refunded { background: rgba(192,57,43,.15); color: #c0392b; }
</style>
