@using pharaohsLegacy.Extensions

@model List<pharaohsLegacy.Models.Artifact>
@{
    ViewData["Title"] = "Artifacts";
    var lang = Context.Session.GetString("Lang") ?? "en";
    var arrowNext = lang == "ar" ? "←" : "→";
}

@section Styles {
    <style>
        .art-page {
            max-width: 1200px;
            margin: 0 auto;
            padding: 3rem 2rem 5rem;
        }

        .art-hero {
            text-align: center;
            margin-bottom: 3rem;
        }

        .art-hero-tag {
            font-family: 'Cinzel', serif;
            font-size: .65rem;
            letter-spacing: 4px;
            text-transform: uppercase;
            color: var(--gold);
            margin-bottom: 1rem;
            display: block;
        }

        .art-hero-title {
            font-family: 'Cinzel', serif;
            font-size: clamp(2rem, 5vw, 3rem);
            font-weight: 700;
            color: var(--text);
            margin-bottom: 1rem;
        }

        .art-hero-line {
            width: 80px;
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--gold), transparent);
            margin: 0 auto;
        }

        .art-search-wrap { max-width: 480px; margin: 2rem auto 0; position: relative; }
        .art-search {
            width: 100%;
            background: rgba(var(--gold-rgb),.05);
            border: 1px solid var(--border);
            border-radius: 50px;
            padding-block: .85rem;
            padding-inline: 3rem 1.5rem;
            color: var(--text);
            font-family: 'Crimson Pro', serif;
            font-size: 1rem;
            outline: none;
            transition: border-color .3s;
        }
        .art-search:focus { border-color: var(--gold); }
        .art-search::placeholder { color: var(--muted); }
        .art-search-icon { position: absolute; inset-inline-start: 1.1rem; top: 50%; transform: translateY(-50%); color: var(--muted); pointer-events: none; }

        .art-count { text-align: center; font-family: 'Cinzel', serif; font-size: .65rem; letter-spacing: 3px; text-transform: uppercase; color: var(--muted); margin: 1.5rem 0 .5rem; }

        /* Filters */
        .art-filters {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            justify-content: center;
            margin-bottom: 2.5rem;
        }

        .art-filter-btn {
            font-family: 'Cinzel', serif;
            font-size: .62rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            padding: 7px 16px;
            border-radius: 20px;
            border: 1px solid var(--border);
            background: transparent;
            color: var(--muted);
            cursor: pointer;
            transition: all .25s;
        }

            .art-filter-btn:hover,
            .art-filter-btn.active {
                border-color: var(--gold);
                color: var(--gold);
                background: rgba(var(--gold-rgb),0.08);
            }

        /* Grid */
        .art-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 1.5rem;
        }

        /* Card */
        .art-card {
            background: var(--dark3);
            border: 1px solid var(--border);
            border-radius: 12px;
            overflow: hidden;
            text-decoration: none;
            display: block;
            box-shadow: var(--card-shadow);
            transition: transform .3s, border-color .3s, box-shadow .3s;
            animation: fadeUp .5s ease both;
        }

            .art-card:hover {
                transform: translateY(-4px);
                border-color: var(--gold);
                box-shadow: var(--card-shadow-hover);
            }

        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(16px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .art-card-img {
            height: 200px;
            overflow: hidden;
            background: var(--dark2);
            position: relative;
        }

            .art-card-img img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                transition: transform .4s;
                filter: brightness(.8);
            }

        .art-card:hover .art-card-img img {
            transform: scale(1.05);
            filter: brightness(1);
        }

        .art-card-category {
            position: absolute;
            top: 10px;
            right: 10px;
            font-family: 'Cinzel', serif;
            font-size: .55rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: #0d0702;
            background: var(--gold);
            padding: 4px 10px;
            border-radius: 12px;
        }

        .art-card-body {
            padding: 1.2rem;
        }

        .art-card-origin {
            font-family: 'Cinzel', serif;
            font-size: .6rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--gold);
            margin-bottom: .4rem;
        }

        .art-card-name {
            font-family: 'Cinzel', serif;
            font-size: 1rem;
            font-weight: 700;
            color: var(--text);
            margin-bottom: .3rem;
        }

        .art-card-period {
            font-size: .85rem;
            color: var(--muted);
            margin-bottom: .5rem;
        }

        .art-card-museum {
            font-size: .8rem;
            color: var(--muted);
            font-style: italic;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .art-card-footer {
            padding: .75rem 1.2rem;
            border-top: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

            .art-card-footer span {
                font-size: .75rem;
                color: var(--muted);
                font-family: 'Cinzel', serif;
                letter-spacing: 1px;
            }

        .art-card-arrow {
            color: var(--gold);
        }

        /* Empty */
        .art-empty {
            text-align: center;
            padding: 4rem 2rem;
            color: var(--muted);
            font-family: 'Cinzel', serif;
            font-size: .85rem;
            letter-spacing: 2px;
            display: none;
            grid-column: 1/-1;
        }

        @@media (max-width: 768px) {
            .art-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
}

<div class="art-page">

    <!-- Hero -->
    <div class="art-hero">
        <span class="art-hero-tag">𓏏 @Html.L("Art_Hero_Tag")</span>
        <h1 class="art-hero-title">@Html.L("Art_Hero_Title")</h1>
        <div class="art-hero-line"></div>
        <div class="art-search-wrap">
            <span class="art-search-icon">🔍</span>
            <input class="art-search" type="text" placeholder="@Html.L("Art_Search_Placeholder")"
                   oninput="filterArt()" id="artSearchInput" />
        </div>
    </div>

    <div class="art-count" id="artCount" data-unit="@Html.L("Art_Count_Label")">@Html.Digits(Model.Count) @Html.L("Art_Count_Label")</div>

    <!-- Filters -->
    <div class="art-filters">
        <button class="art-filter-btn active" onclick="setCategory('all', this)">@Html.L("Booking_Filter_All")</button>
        @{
            var categoryList = Model
                .Select(a => string.IsNullOrWhiteSpace(a.Category) ? "Uncategorized" : a.Category)
                .Distinct()
                .OrderBy(c => c == "Uncategorized" ? 1 : 0)
                .ThenBy(c => c)
                .ToList();
        }
        @foreach (var cat in categoryList)
        {
            var catAr = Model.Where(a => (string.IsNullOrWhiteSpace(a.Category) ? "Uncategorized" : a.Category) == cat)
                              .Select(a => a.CategoryAr).FirstOrDefault(c => !string.IsNullOrEmpty(c));
            var catDisplay = cat == "Uncategorized"
                ? Html.L("Art_Category_Uncategorized")
                : Html.Digits((lang == "ar" && !string.IsNullOrEmpty(catAr)) ? catAr : cat);
            <button class="art-filter-btn" onclick="setCategory('@cat', this)">@catDisplay</button>
        }
    </div>

    <!-- Grid -->
    <div class="art-grid" id="artGrid">
        @if (!Model.Any())
        {
            <div class="art-empty" style="display:block;">𓏏 @Html.L("Art_Empty_Text")</div>
        }
        @foreach (var a in Model)
        {
            var aName = Html.Digits((lang == "ar" && !string.IsNullOrEmpty(a.NameAr)) ? a.NameAr : a.Name);
            var aMuseum = Html.Digits((lang == "ar" && !string.IsNullOrEmpty(a.MuseumAr)) ? a.MuseumAr : a.Museum);
            var aOrigin = Html.Digits((lang == "ar" && !string.IsNullOrEmpty(a.OriginAr)) ? a.OriginAr : a.Origin);
            var aPeriod = Html.Digits((lang == "ar" && !string.IsNullOrEmpty(a.PeriodAr)) ? a.PeriodAr : a.Period);
            var aCategoryRaw = string.IsNullOrWhiteSpace(a.Category) ? "Uncategorized" : a.Category;
            var aCategory = aCategoryRaw == "Uncategorized"
                ? Html.L("Art_Category_Uncategorized")
                : Html.Digits((lang == "ar" && !string.IsNullOrEmpty(a.CategoryAr)) ? a.CategoryAr : aCategoryRaw);
            var aCurrentLocation = Html.Digits((lang == "ar" && !string.IsNullOrEmpty(a.CurrentLocationAr)) ? a.CurrentLocationAr : a.CurrentLocation);
            var aSearchName = $"{a.Name} {a.NameAr}".ToLower();
            var aSearchSub = $"{a.Origin} {a.OriginAr} {a.Museum} {a.MuseumAr}".ToLower();
            <a href="/Artifact/Details/@a.Id" class="art-card" data-category="@aCategoryRaw"
               data-name="@aSearchName" data-sub="@aSearchSub">
                <div class="art-card-img">
                    <img src="@a.ImageUrl" alt="@aName"
                         onerror="this.src='https://via.placeholder.com/400x200/2d1a08/c9a227?text=@aName'" />
                    <span class="art-card-category">@aCategory</span>
                </div>
                <div class="art-card-body">
                    <div class="art-card-origin">@aOrigin</div>
                    <div class="art-card-name">@aName</div>
                    <div class="art-card-period">@aPeriod</div>
                    @if (!string.IsNullOrEmpty(a.Museum))
                    {
                        <div class="art-card-museum">𓏠 @aMuseum</div>
                    }
                </div>
                <div class="art-card-footer">
                    <span>@aCurrentLocation</span>
                    <span class="art-card-arrow">@arrowNext</span>
                </div>
            </a>
        }
    </div>

</div>

@section Scripts {
    <script>
        var currentLang = '@lang';
        var arabicDigitsMap = ['٠', '١', '٢', '٣', '٤', '٥', '٦', '٧', '٨', '٩'];
        function toLocalDigits(input) {
            var str = String(input);
            if (currentLang !== 'ar') return str;
            return str.replace(/[0-9]/g, function (d) { return arabicDigitsMap[+d]; });
        }

        var currentCategory = 'all';

        function setCategory(category, btn) {
            currentCategory = category;
            document.querySelectorAll('.art-filter-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            filterArt();
        }

        function filterArt() {
            const q = document.getElementById('artSearchInput').value.trim().toLowerCase();
            const cards = document.querySelectorAll('.art-card');
            let count = 0;

            cards.forEach(card => {
                const matchesCategory = currentCategory === 'all' || card.dataset.category === currentCategory;
                const matchesSearch = q === '' || card.dataset.name.includes(q) || card.dataset.sub.includes(q);
                const match = matchesCategory && matchesSearch;
                card.style.display = match ? '' : 'none';
                if (match) count++;
            });

            const empty = document.querySelector('.art-empty');
            if (empty) empty.style.display = count === 0 ? 'block' : 'none';

            const countEl = document.getElementById('artCount');
            countEl.textContent = toLocalDigits(count) + ' ' + countEl.dataset.unit;
        }
    </script>
}
