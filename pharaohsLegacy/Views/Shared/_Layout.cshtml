        }

        .aichat-msg.user .aichat-bubble {
        background: linear-gradient(135deg, #c9a227, #8a6b14);
        color: #0d0702;
        font-weight: 600;
        border-radius: 16px 4px 16px 16px;
        box-shadow: 0 2px 12px rgba(201,162,39,0.2);
        }

        /* Typing dots */
        .aichat-typing .aichat-bubble {
        display: flex;
        gap: 5px;
        align-items: center;
        padding: 13px 16px;
        }

        .aichat-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: rgba(201,162,39,0.5);
        animation: aiDot 1.3s infinite;
        }

        .aichat-dot:nth-child(2) {
        animation-delay: 0.2s;
        }

        .aichat-dot:nth-child(3) {
        animation-delay: 0.4s;
        }

        @@keyframes aiDot {
        0%, 60%, 100% {
        transform: translateY(0);
        opacity: 0.5;
        }

        30% {
        transform: translateY(-6px);
        opacity: 1;
        }
        }

        /* Suggestions */
        .aichat-suggestions {
        padding: 0 14px 10px;
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        }

        .aichat-sug {
        background: rgba(var(--gold-rgb),0.07);
        border: 1px solid rgba(var(--gold-rgb),0.2);
        border-radius: 20px;
        padding: 5px 12px;
        font-family: 'Cinzel', serif;
        font-size: 0.62rem;
        color: var(--muted);
        cursor: pointer;
        transition: all 0.2s;
        letter-spacing: 0.5px;
        }

        .aichat-sug:hover {
        background: rgba(var(--gold-rgb),0.14);
        color: var(--gold);
        border-color: rgba(var(--gold-rgb),0.4);
        }

        /* Input */
        .aichat-input-wrap {
        padding: 12px 14px;
        border-top: 1px solid rgba(var(--gold-rgb),0.12);
        background: var(--well-bg);
        display: flex;
        gap: 8px;
        align-items: flex-end;
        }

        .aichat-input {
        flex: 1;
        background: var(--surface-tint);
        border: 1px solid rgba(var(--gold-rgb),0.2);
        border-radius: 10px;
        padding: 10px 13px;
        font-family: 'Crimson Pro', serif;
        font-size: 0.9rem;
        color: var(--text);
        outline: none;
        resize: none;
        transition: border-color 0.25s, background 0.25s;
        line-height: 1.5;
        max-height: 80px;
        }

        .aichat-input::placeholder {
        color: var(--muted);
        }

        .aichat-input:focus {
        border-color: rgba(var(--gold-rgb),0.45);
        background: var(--surface-tint-strong);
        }

        .aichat-send {
        background: linear-gradient(135deg, #c9a227, #7a5e10);
        border: none;
        border-radius: 10px;
        width: 40px;
        height: 40px;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: #0d0702;
        font-size: 1rem;
        transition: all 0.2s;
        box-shadow: 0 2px 10px rgba(201,162,39,0.2);
        }

        .aichat-send:hover {
        opacity: 0.88;
        transform: scale(1.06);
        }

        .aichat-send:disabled {
        opacity: 0.35;
        cursor: not-allowed;
        transform: none;
        }

        .aichat-footer {
        text-align: center;
        padding: 6px;
        font-size: 0.6rem;
        color: var(--border);
        font-family: 'Cinzel', serif;
        letter-spacing: 1px;
        border-top: 1px solid rgba(201,162,39,0.06);
        }

        @@media (max-width: 480px) {
        .aichat-popup {
        width: calc(100vw - 32px);
        right: 16px;
        }

        .aichat-btn {
        right: 16px;
        bottom: 20px;
        }
        }
    </style>

    <!-- Floating Button -->
    <div style="position:fixed; bottom:28px; right:28px; z-index:9999; display:flex; flex-direction:column; align-items:center; gap:6px;">
        <span style="font-family:'Cinzel',serif; font-size:0.55rem; color:#c9a227; letter-spacing:2px; text-shadow:0 0 10px rgba(201,162,39,0.5);">@Html.L("Widget_AIGuideLabel")</span>
        <button class="aichat-btn" id="aichatBtn" onclick="aiToggle()" title="@Html.L("Widget_AITourGuideTitle")">𓁹</button>
    </div>

    <!-- Popup -->
    <div class="aichat-popup" id="aichatPopup">
        <div class="aichat-header">
            <div class="aichat-avatar-wrap">
                <div class="aichat-avatar">𓁹</div>
                <div class="aichat-online-dot"></div>
            </div>
            <div class="aichat-info">
                <span class="aichat-name">@Html.L("Widget_AITourGuideTitle")</span>
                <span class="aichat-sub">@Html.L("Widget_OnlineStatus")</span>
            </div>
            <button class="aichat-close" onclick="aiExpand()" title="@Html.L("Common_Expand")" style="margin-inline-end:4px;">⛶</button>
            <button class="aichat-close" onclick="aiToggle()">✕</button>
        </div>

        <div class="aichat-messages" id="aichatMsgs">
            <div class="aichat-msg bot">
                <div class="aichat-msg-av">𓁹</div>
                <div class="aichat-bubble">
                    @Html.L("Widget_WelcomeMessage")
                </div>
            </div>
        </div>

        <div class="aichat-suggestions" id="aichatSugs">
            <button class="aichat-sug" onclick="aiAsk('@Html.L("Chat_Suggestion_Ramesses_Q")')">@Html.L("Widget_Suggestion_Ramesses")</button>
            <button class="aichat-sug" onclick="aiAsk('@Html.L("Chat_Suggestion_Pyramid_Q")')">@Html.L("Chat_Suggestion_Pyramid")</button>
            <button class="aichat-sug" onclick="aiAsk('@Html.L("Chat_Suggestion_Ra_Q")')">@Html.L("Chat_Suggestion_Ra")</button>
            <button class="aichat-sug" onclick="aiAsk('@Html.L("Chat_Suggestion_Cleopatra_Q")')">@Html.L("Chat_Suggestion_Cleopatra")</button>
        </div>

        <div class="aichat-input-wrap">
            <textarea class="aichat-input" id="aichatInput" rows="1"
                      placeholder="@Html.L("Chat_Input_Placeholder")"
                      onkeydown="aiKey(event)"
                      oninput="aiResize(this)"></textarea>
            <button class="aichat-send" id="aichatSend" onclick="aiSend()">➤</button>
        </div>
        <div class="aichat-footer">𓂀 @Html.L("Widget_Footer")</div>
    </div>

    <script>
        // 🆕 اختفاء تلقائي للـ Toast بعد 5 ثواني
        document.addEventListener('DOMContentLoaded', function () {
            var toast = document.getElementById('plToast');
            if (toast) {
                setTimeout(function () {
                    toast.style.animation = 'pl-toast-out .3s ease forwards';
                    setTimeout(function () { toast.remove(); }, 300);
                }, 5000);
            }

            // 🆕 السلة — بيجيب العدد الحالي من السيرفر عند فتح أي صفحة في الموقع
            var navBadge = document.getElementById('navCartBadge');
            if (navBadge) {
                fetch('/Shop/CartCount', { credentials: 'same-origin' })
                    .then(function (res) { return res.json(); })
                    .then(function (data) {
                        var count = data.count || 0;
                        navBadge.textContent = count;
                        navBadge.style.display = count > 0 ? 'inline-flex' : 'none';
                    })
                    .catch(function () { /* silent — أيقونة السلة تفضل من غير عدد لو الطلب فشل */ });
            }
        });

        const aiErrorMsg = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Html.L("Chat_ErrorMessage")));
        // 🆕 Dropdown — كل القوائم (Explore + More) بتتقفل بنفس المنطق دلوقتي عن طريق
        // closeAllNavMenus تحت، بما فيها تصفير aria-expanded
        document.addEventListener('click', function (e) {
            if (!e.target.closest('.nav-dropdown')) {
                closeAllNavMenus(null);
            }
        });

        // 🆕 نقطة واحدة بتقفل أي قايمة مفتوحة في الناف بار — سواء dropdown عادي (More)
        // أو الـ Explore Mega Menu. قبل كده كل واحدة كانت بتتقفل بطريقتها لوحدها
        // (More بيتخبى بـ display:none، Explore بيتشال منه كلاس show)، فلو فتحت
        // واحدة والتانية شغالة، محدش كان بيقفل التاني وبيحصل تراكب/overlap بينهم.
        // دلوقتي فتح أي قايمة بيقفل كل القوائم التانية أول حاجة.
        function closeAllNavMenus(except) {
            document.querySelectorAll('.nav-dropdown-menu').forEach(function (m) {
                if (m !== except) {
                    m.style.display = 'none';
                    var t = m.previousElementSibling;
                    if (t && t.classList.contains('nav-dropdown-toggle')) t.setAttribute('aria-expanded', 'false');
                }
            });
            var mega = document.getElementById('exploreMegaMenu');
            var megaToggle = document.getElementById('exploreMegaToggle');
            if (mega && mega !== except) {
                mega.classList.remove('show');
                if (megaToggle) megaToggle.setAttribute('aria-expanded', 'false');
            }
        }

        // مستثنى هنا exploreMegaToggle عشان ليه سلوك خاص تحت (hover/click على الـ Mega Menu)
        // 🆕 كل توجل هنا بقى قابل للتنقل بالـ Tab وفتحه بـ Enter/Space زي أي زرار عادي
        // (قبل كده "More" كانت <a> من غير href ولا tabindex، يعني متش شغالة بالكيبورد خالص)
        document.querySelectorAll('.nav-dropdown:not(.nav-mega-parent) > .nav-dropdown-toggle').forEach(function (toggle) {
            function toggleMenu() {
                const menu = toggle.nextElementSibling;
                const willOpen = menu.style.display !== 'block';
                closeAllNavMenus(willOpen ? menu : null);
                menu.style.display = willOpen ? 'block' : 'none';
                toggle.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
            }
            toggle.addEventListener('click', function (e) {
                e.stopPropagation();
                toggleMenu();
            });
            toggle.addEventListener('keydown', function (e) {
                if (e.key === 'Enter' || e.key === ' ') {
                    e.preventDefault();
                    e.stopPropagation();
                    toggleMenu();
                }
            });
        });

        // 🆕 Explore Mega Menu — مخفي افتراضيًا، بيتفتح بالـ hover على الكمبيوتر (CSS)
        // وبالـ click/tap على الموبايل وبالـ لوحة المفاتيح هنا (JS). الاتنين شغالين مع بعض
        // من غير تعارض لأن الـ hover مربوط بـ media query (hover: hover) بس
        (function () {
            var toggle = document.getElementById('exploreMegaToggle');
            var menu = document.getElementById('exploreMegaMenu');
            if (!toggle || !menu) return;

            function closeMega() {
                menu.classList.remove('show');
                toggle.setAttribute('aria-expanded', 'false');
            }
            function openMega() {
                closeAllNavMenus(menu);
                menu.classList.add('show');
                toggle.setAttribute('aria-expanded', 'true');
            }

            // بيقفل الـ Mega Menu لو الماوس بقى فوق More (أو أي دروب داون تاني) وهو لسه فاتح بالـ hover
            document.querySelectorAll('.nav-dropdown:not(.nav-mega-parent)').forEach(function (otherDropdown) {
                otherDropdown.addEventListener('mouseenter', function () { closeMega(); });
            });

            // 🆕 والعكس: لو "More" كانت مفتوحة بالكليك وبعدين الماوس راح على Explore،
            // الـ CSS hover كان بيفتح Explore لوحده من غير ما حد يقفل "More" (لأنها مش
            // متجابة بالكليك ولا بالكيبورد، هي CSS hover بحت)، فتفضل "More" فاتحة فوقيها.
            // هنا بنقفل أي dropdown-menu تاني لحظة ما الماوس يدخل منطقة Explore
            document.querySelectorAll('.nav-mega-parent').forEach(function (megaParent) {
                megaParent.addEventListener('mouseenter', function () { closeAllNavMenus(menu); });
            });

            toggle.addEventListener('click', function (e) {
                e.preventDefault();
                e.stopPropagation();
                menu.classList.contains('show') ? closeMega() : openMega();
            });
            toggle.addEventListener('keydown', function (e) {
                if (e.key === 'Enter' || e.key === ' ') {
                    e.preventDefault();
                    menu.classList.contains('show') ? closeMega() : openMega();
                }
            });
            document.addEventListener('click', function (e) {
                if (!e.target.closest('.nav-mega-parent')) closeMega();
            });
            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') closeAllNavMenus(null);
            });
        })();

        function aiToggle() {
        const popup = document.getElementById('aichatPopup');
        const btn = document.getElementById('aichatBtn');
        popup.classList.toggle('open');
        btn.classList.toggle('active');
        if (popup.classList.contains('open'))
        document.getElementById('aichatInput').focus();
        }

        function aiKey(e) {
        if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); aiSend(); }
        }

        function aiResize(el) {
        el.style.height = 'auto';
        el.style.height = Math.min(el.scrollHeight, 80) + 'px';
        }

        function aiAsk(text) {
        document.getElementById('aichatSugs').style.display = 'none';
        document.getElementById('aichatInput').value = text;
        aiSend();
        }

        function aiAddMsg(text, role) {
        const area = document.getElementById('aichatMsgs');
        const div = document.createElement('div');
        div.className = `aichat-msg ${role}`;
        div.innerHTML = `
        <div class="aichat-msg-av">${role === 'bot' ? '𓁹' : '𓀀'}</div>
        <div class="aichat-bubble">${text}</div>`;
        area.appendChild(div);
        area.scrollTop = area.scrollHeight;
        }

        function aiTyping() {
        const area = document.getElementById('aichatMsgs');
        const div = document.createElement('div');
        div.className = 'aichat-msg bot aichat-typing';
        div.id = 'aichatTyping';
        div.innerHTML = `<div class="aichat-msg-av">𓁹</div>
        <div class="aichat-bubble">
        <span class="pl-ankh-spinner">𓋹</span>
        </div>`;
        area.appendChild(div);
        area.scrollTop = area.scrollHeight;
        }

       function aiExpand() {
    const popup = document.getElementById('aichatPopup');
    const isExpanded = popup.style.width === '520px';
    popup.style.width = isExpanded ? '380px' : '520px';
    popup.style.bottom = isExpanded ? '102px' : '20px';
}
        
        
        
        async function aiSend() {
        const input = document.getElementById('aichatInput');
        const text = input.value.trim();
        if (!text) return;
        input.value = '';
        input.style.height = 'auto';
        document.getElementById('aichatSend').disabled = true;
        document.getElementById('aichatSugs').style.display = 'none';
        aiAddMsg(text, 'user');
        aiTyping();
        try {
        const res = await fetch('/Chatbot/Ask', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: text })
        });
        const data = await res.json();
        document.getElementById('aichatTyping')?.remove();
        aiAddMsg(data.reply, 'bot');
        } catch {
        document.getElementById('aichatTyping')?.remove();
        aiAddMsg(aiErrorMsg, 'bot');
        }
        document.getElementById('aichatSend').disabled = false;
        input.focus();
        }
    </script>
    <!-- ═══════════════════════════════════════════ -->

</body>
</html>
