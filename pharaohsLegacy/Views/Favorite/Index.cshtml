@using pharaohsLegacy.Extensions
@{
    ViewData["Title"] = "My Favorites";

    var pharaohs = ViewBag.Pharaohs as List<pharaohsLegacy.Models.Pharaoh>;
    var temples = ViewBag.Temples as List<pharaohsLegacy.Models.Temple>;
    var gods = ViewBag.Gods as List<pharaohsLegacy.Models.God>;
    var museums = ViewBag.Museums as List<pharaohsLegacy.Models.Museum>;

    var lang = Context.Session.GetString("Lang") ?? "en";
    var arrowNext = lang == "ar" ? "←" : "→";
}

<div class="section">
    <div class="section-header">
        <span class="section-tag">@Html.L("Fav_SectionTag")</span>
        <h2 class="section-title">@Html.L("Fav_Title")</h2>
        <div class="section-line"></div>
    </div>

    
    @if ((pharaohs == null || pharaohs.Count == 0) &&
         (temples == null || temples.Count == 0) &&
         (gods == null || gods.Count == 0) &&
         (museums == null || museums.Count == 0))
    {
        <div style="text-align:center; padding:4rem; color:#8a7055;">
            <p style="font-size:3rem; margin-bottom:1rem;">🤍</p>
            <p style="font-family:'Cinzel',serif; font-size:1rem;">@Html.L("Fav_Empty_Text")</p>
            <p style="font-style:italic; margin-top:.5rem;">@Html.L("Fav_Empty_Sub")</p>
            <br />
            <a href="/Home/Index" class="btn-gold" style="margin-top:1rem;">@Html.L("Fav_StartExploring_Link")</a>
        </div>
    }

    
    @if (pharaohs != null && pharaohs.Count > 0)
    {
        <h3 style="font-family:'Cinzel',serif; color:#c9a227; margin-bottom:1.5rem;">
            ❤️ @Html.L("Common_PharaohsPlural") (@Html.Digits(pharaohs.Count))
        </h3>

        <div class="cards-grid">
            @foreach (var p in pharaohs)
            {
                var pName = (lang == "ar" && !string.IsNullOrEmpty(p.NameAr)) ? p.NameAr : p.Name;
                var pDynasty = (lang == "ar" && !string.IsNullOrEmpty(p.DynastyAr)) ? p.DynastyAr : p.Dynasty;
                var pPeriod = (lang == "ar" && !string.IsNullOrEmpty(p.PeriodAr)) ? p.PeriodAr : p.Period;
                <a href="/Pharaoh/Details/@p.Id" class="card">
                    <div class="card-img">
                        <img src="@p.ImageUrl" alt="@pName" />
                    </div>
                    <div class="card-body">
                        <span class="card-tag">@pDynasty</span>
                        <h3 class="card-title">@pName</h3>
                        <p class="card-desc">@pPeriod</p>
                    </div>
                    <div class="card-footer">
                        <span>@Html.L("Common_ViewDetails")</span>
                        <span class="card-arrow">@arrowNext</span>
                    </div>
                </a>
            }
        </div>
    }

    
    @if (temples != null && temples.Count > 0)
    {
        <h3 style="font-family:'Cinzel',serif; color:#c9a227; margin:3rem 0 1.5rem;">
            ❤️ @Html.L("Common_TemplesPlural") (@Html.Digits(temples.Count))
        </h3>

        <div class="cards-grid">
            @foreach (var t in temples)
            {
                var tName = (lang == "ar" && !string.IsNullOrEmpty(t.NameAr)) ? t.NameAr : t.Name;
                var tLocation = (lang == "ar" && !string.IsNullOrEmpty(t.LocationAr)) ? t.LocationAr : t.Location;
                var tPeriod = (lang == "ar" && !string.IsNullOrEmpty(t.PeriodAr)) ? t.PeriodAr : t.Period;
                <a href="/Temple/Details/@t.Id" class="card">
                    <div class="card-img">
                        <img src="@t.ImageUrl" alt="@tName" />
                    </div>
                    <div class="card-body">
                        <span class="card-tag">@tLocation</span>
                        <h3 class="card-title">@tName</h3>
                        <p class="card-desc">@tPeriod</p>
                    </div>
                    <div class="card-footer">
                        <span>@Html.L("Common_ViewDetails")</span>
                        <span class="card-arrow">@arrowNext</span>
                    </div>
                </a>
            }
        </div>
    }

    
    @if (gods != null && gods.Count > 0)
    {
        <h3 style="font-family:'Cinzel',serif; color:#c9a227; margin:3rem 0 1.5rem;">
            ❤️ @Html.L("Common_GodsPlural") (@Html.Digits(gods.Count))
        </h3>

        <div class="cards-grid">
            @foreach (var g in gods)
            {
                var gName = (lang == "ar" && !string.IsNullOrEmpty(g.NameAr)) ? g.NameAr : g.Name;
                var gRole = (lang == "ar" && !string.IsNullOrEmpty(g.RoleAr)) ? g.RoleAr : g.Role;
                <a href="/God/Details/@g.Id" class="card">
                    <div class="card-img">
                        <img src="@g.ImageUrl" alt="@gName" />
                    </div>
                    <div class="card-body">
                        <span class="card-tag">@g.Symbol</span>
                        <h3 class="card-title">@gName</h3>
                        <p class="card-desc">@gRole</p>
                    </div>
                    <div class="card-footer">
                        <span>@Html.L("Common_ViewDetails")</span>
                        <span class="card-arrow">@arrowNext</span>
                    </div>
                </a>
            }
        </div>
    }

  
    @if (museums != null && museums.Count > 0)
    {
        <h3 style="font-family:'Cinzel',serif; color:#c9a227; margin:3rem 0 1.5rem;">
            ❤️ @Html.L("Common_MuseumsPlural") (@Html.Digits(museums.Count))
        </h3>

        <div class="cards-grid">
            @foreach (var m in museums)
            {
                var mName = (lang == "ar" && !string.IsNullOrEmpty(m.NameAr)) ? m.NameAr : m.Name;
                var mLocation = (lang == "ar" && !string.IsNullOrEmpty(m.LocationAr)) ? m.LocationAr : m.Location;
                var mDescription = (lang == "ar" && !string.IsNullOrEmpty(m.DescriptionAr)) ? m.DescriptionAr : m.Description;
                <a href="/Museum/Details/@m.Id" class="card">
                    <div class="card-img">
                        <img src="@m.ImageUrl" alt="@mName" />
                    </div>
                    <div class="card-body">
                        <span class="card-tag">@mLocation</span>
                        <h3 class="card-title">@mName</h3>
                        <p class="card-desc">@mDescription</p>
                    </div>
                    <div class="card-footer">
                        <span>@Html.L("Common_ViewDetails")</span>
                        <span class="card-arrow">@arrowNext</span>
                    </div>
                </a>
            }
        </div>
    }
</div>