    @{
        var pins = ViewBag.JourneyPins as List<pharaohsLegacy.Models.JourneyPin> ?? new List<pharaohsLegacy.Models.JourneyPin>();
    }
    <div id="tab-journey" class="db-panel">
        <div class="journey-header">
            <h2><i class="fas fa-map-marked-alt"></i> @Html.L("Journey_Title")</h2>
            <p>@Html.L("Journey_Subtitle")</p>
            <div class="journey-legend">
                <span class="legend-item booking"><i class="fas fa-bookmark"></i> @Html.L("Journey_Booked")</span>
                <span class="legend-item favorite"><i class="fas fa-heart"></i> @Html.L("Journey_Favourite")</span>
                <span class="legend-item both"><i class="fas fa-star"></i> @Html.L("Journey_Both")</span>
                <span class="legend-item Visited"><i class="fas fa-check-circle"></i> @Html.L("Status_Visited")</span>
            </div>
        </div>
        @if (!pins.Any())
        {
            <div class="journey-empty">
                <div class="empty-icon"><i class="fas fa-map"></i></div>
                <h3>@Html.L("Journey_NotStarted")</h3>
                <p>@Html.L("Journey_NotStartedDesc")</p>
                <div class="empty-actions">
                    <a href="/Temple" class="btn-gold"><i class="fas fa-archway"></i> @Html.L("Dash_ExploreTemples")</a>
                    <a href="/Museum" class="btn-outline"><i class="fas fa-landmark"></i> @Html.L("Dash_ExploreMuseums")</a>
                </div>
            </div>
        }
        else
        {
            <div class="journey-stats">
                <div class="jstat">
                    <span class="jstat-num">@Html.Digits(pins.Count(p => p.PinType == "booking" || p.PinType == "both"))</span>
                    <span class="jstat-label">@Html.L("Journey_PlacesBooked")</span>
                </div>
                <div class="jstat">
                    <span class="jstat-num">@Html.Digits(pins.Count(p => p.PinType == "favorite" || p.PinType == "both"))</span>
                    <span class="jstat-label">@Html.L("Journey_Favourite")</span>
                </div>
                <div class="jstat">
                    <span class="jstat-num">@Html.Digits(pins.Count(p => p.Type == "temple"))</span>
                    <span class="jstat-label">@Html.L("Nav_Temples")</span>
                </div>
                <div class="jstat">
                    <span class="jstat-num">@Html.Digits(pins.Count(p => p.Type == "museum"))</span>
                    <span class="jstat-label">@Html.L("Nav_Museums")</span>
                </div>
            </div>
            <div class="journey-map-wrapper">
                <div id="journeyMap"></div>
            </div>
            <div class="journey-cards">
                @foreach (var pin in pins)
                {
                    var pinName = (lang == "ar" && !string.IsNullOrEmpty(pin.NameAr)) ? pin.NameAr : pin.Name;
                    var pinDescription = (lang == "ar" && !string.IsNullOrEmpty(pin.DescriptionAr)) ? pin.DescriptionAr : pin.Description;
                    <div class="jcard @pin.PinType fade-up"
                         onclick="focusPin(@pin.Latitude.ToString(System.Globalization.CultureInfo.InvariantCulture), @pin.Longitude.ToString(System.Globalization.CultureInfo.InvariantCulture))">
                        <div class="jcard-img">
                            <img src="@pin.ImageUrl" onerror="this.src='/images/placeholder.jpg'" />
                            <span class="jcard-badge @pin.PinType">
                                @(pin.PinType == "booking" ? Html.L("Journey_Booked") : pin.PinType == "favorite" ? Html.L("Journey_Favourite") : "⭐ " + Html.L("Journey_Both"))
                            </span>
                        </div>
                        <div class="jcard-body">
                            <span class="jcard-type">
                                <i class="fas @(pin.Type == "temple" ? "fa-archway" : "fa-landmark")"></i> @(pin.Type == "temple" ? Html.L("Common_Temple") : Html.L("Common_Museum"))
                            </span>
                            <h4>@pinName</h4>
                            <p>@pinDescription</p>
                            @if (!string.IsNullOrEmpty(pin.VisitDate))
                            {
                                <div class="jcard-date">
                                    <i class="fas fa-calendar-alt"></i> @Html.Digits(pin.VisitDate)
                                    <span class="status-badge @pin.Status.ToLower()">@Html.L("Status_" + pin.Status)</span>
                                </div>
                            }
                            <a href="/@(pin.Type == "temple" ? "Temple" : "Museum")/Details/@pin.ItemId" class="jcard-link">
                                @Html.L("Dash_ViewDetails") <i class="fas fa-arrow-right"></i>
                            </a>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

