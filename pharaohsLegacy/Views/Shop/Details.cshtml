@model pharaohsLegacy.Models.Product
@using pharaohsLegacy.Extensions
@using Microsoft.AspNetCore.Html
@{
    ViewData["Title"] = "Shop";
    var lang = Context.Session.GetString("Lang") ?? "en";
    var arrowBack = lang == "ar" ? "→" : "←";

    Func<string, IHtmlContent> js = key => Html.Raw(System.Text.Json.JsonSerializer.Serialize(Html.L(key)));
}

<div class="details-wrap">
    @{
        var prodCategoryName = Model.Category != null
            ? ((lang == "ar" && !string.IsNullOrEmpty(Model.Category.NameAr)) ? Model.Category.NameAr : Model.Category.Name)
            : null;
    }
    <nav class="breadcrumbs">
        <a href="/Shop/Index">@Html.L("Shop_Title")</a>
        @if (Model.CategoryId.HasValue && prodCategoryName != null)
        {
            <span class="crumb-sep">/</span>
            <a href="/Shop/Index?categoryId=@Model.CategoryId">@prodCategoryName</a>
        }
        <span class="crumb-sep">/</span>
        <span class="crumb-current">@ViewBag.ProductName</span>
    </nav>

    <div class="details-top-row">
        <a href="javascript:history.back()" class="btn-back">@arrowBack @Html.L("Common_Back")</a>
        <a href="/Shop/Cart" class="cart-icon-link" title="@Html.L("Shop_Cart_Title")">
            <span class="cart-icon-glyph"><svg class="icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="20" r="1.3"/><circle cx="17.5" cy="20" r="1.3"/><path d="M2.5 3h2l2.1 12a2 2 0 0 0 2 1.6h8a2 2 0 0 0 2-1.6L20.5 7H6.2"/></svg></span>
            <span id="cartCountBadge" class="cart-count-badge" style="display:@((int)ViewBag.CartCount > 0 ? "inline-flex" : "none")">@Html.Digits((object)ViewBag.CartCount)</span>
        </a>
    </div>

    <div class="details-card">
        @{
            var hasDiscount = Model.OriginalPrice.HasValue && Model.OriginalPrice.Value > Model.Price;
            var discountPct = hasDiscount ? (int)Math.Round((1 - (Model.Price / Model.OriginalPrice.Value)) * 100) : 0;
            const int lowStockThreshold = 5;
        }
        <div class="details-img">
            <img src="@ViewBag.ProductImage" alt="@ViewBag.ProductName" />
            <div class="details-badges">
                @if (hasDiscount)
                {
                    <span class="shop-badge badge-sale">-@discountPct%</span>
                }
                @if (Model.IsNew)
                {
                    <span class="shop-badge badge-new">@Html.L("Shop_Badge_New")</span>
                }
                @if (Model.IsBestSeller)
                {
                    <span class="shop-badge badge-bestseller">@Html.L("Shop_Badge_BestSeller")</span>
                }
                @if (Model.IsFeatured)
                {
                    <span class="shop-badge badge-featured">@Html.L("Shop_Badge_Featured")</span>
                }
            </div>
            @{
                bool isFav = ViewBag.IsFav == true;
                int? favId = ViewBag.FavoriteId;
            }
            <button type="button" class="shop-fav-btn details-fav-btn @(isFav ? "active" : "")"
                    data-product-id="@Model.Id" data-fav-id="@favId"
                    data-title-add="@Html.L("Fav_Add_Title")" data-title-remove="@Html.L("Fav_Remove_Title")"
                    onclick="toggleWishlist(event, this)"
                    title="@Html.L(isFav ? "Fav_Remove_Title" : "Fav_Add_Title")">@(isFav ? "♥" : "♡")</button>
        </div>
        <div class="details-body">
            <span class="card-tag">@Html.L("Shop_Title")</span>
            <h1 class="details-title">@ViewBag.ProductName</h1>
            <p>@(lang == "ar" && !string.IsNullOrEmpty(Model.DescriptionAr) ? Model.DescriptionAr : Model.Description)</p>

            <div class="details-meta">
                <div class="meta-item">
                    <span class="meta-label">@Html.L("Shop_UnitPrice")</span>
                    <span class="meta-value">
                        @if (hasDiscount)
                        {
                            <span class="details-price-old">@Html.Digits((object)Model.OriginalPrice) @Html.L("Common_EGP")</span>
                        }
                        @Html.Digits((object)ViewBag.UnitPrice) @Html.L("Common_EGP")
                    </span>
                </div>
                <div class="meta-item">
                    <span class="meta-label">@Html.L("Shop_InStock")</span>
                    <span class="meta-value">
                        @Html.Digits((object)Model.StockQuantity)
                        @if (Model.StockQuantity > 0 && Model.StockQuantity <= lowStockThreshold)
                        {
                            <span class="details-lowstock">— @Html.L("Shop_LowStock")!</span>
                        }
                    </span>
                </div>
            </div>

            @{
                var material = lang == "ar" && !string.IsNullOrEmpty(Model.MaterialAr) ? Model.MaterialAr : Model.Material;
                var dimensions = lang == "ar" && !string.IsNullOrEmpty(Model.DimensionsAr) ? Model.DimensionsAr : Model.Dimensions;
                var origin = lang == "ar" && !string.IsNullOrEmpty(Model.OriginRegionAr) ? Model.OriginRegionAr : Model.OriginRegion;
                var hasSpecs = !string.IsNullOrEmpty(material) || !string.IsNullOrEmpty(dimensions) || !string.IsNullOrEmpty(origin) || !string.IsNullOrEmpty(Model.SKU);
            }
            @if (hasSpecs)
            {
                <div class="details-specs">
                    <span class="specs-title">@Html.L("Shop_Specs_Title")</span>
                    <div class="specs-grid">
                        @if (!string.IsNullOrEmpty(material))
                        {
                            <div class="spec-item"><span class="spec-label">@Html.L("Shop_Specs_Material")</span><span class="spec-value">@material</span></div>
                        }
                        @if (!string.IsNullOrEmpty(dimensions))
                        {
                            <div class="spec-item"><span class="spec-label">@Html.L("Shop_Specs_Dimensions")</span><span class="spec-value">@dimensions</span></div>
                        }
                        @if (!string.IsNullOrEmpty(origin))
                        {
                            <div class="spec-item"><span class="spec-label">@Html.L("Shop_Specs_Origin")</span><span class="spec-value">@origin</span></div>
                        }
                        @if (!string.IsNullOrEmpty(Model.SKU))
                        {
                            <div class="spec-item"><span class="spec-label">@Html.L("Shop_Specs_SKU")</span><span class="spec-value">@Model.SKU</span></div>
                        }
                    </div>
                </div>
            }

            @if (Model.StockQuantity <= 0)
            {
                <p class="coupon-msg error">@Html.L("Shop_OutOfStock")</p>
            }
            else
            {
                <div class="book-field">
                    <label>@Html.L("Shop_Quantity_Label")</label>
                    <div class="ticket-counter">
                        <button type="button" onclick="changeQty(-1)">−</button>
                        <span id="qtyCount">@Html.Digits(1)</span>
                        <button type="button" onclick="changeQty(1)">+</button>
                    </div>
                </div>

                <div class="total-price">
                    <span>@Html.L("Booking_Total_Label")</span>
                    <span id="totalPrice">@Html.Digits((object)ViewBag.UnitPrice) @Html.L("Common_EGP")</span>
                </div>

                <div class="book-field" style="margin-top:1rem;">
                    <button type="button" id="addToCartBtn" class="btn-outline" style="width:100%;">
                        <svg class="icon" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="20" r="1.3"/><circle cx="17.5" cy="20" r="1.3"/><path d="M2.5 3h2l2.1 12a2 2 0 0 0 2 1.6h8a2 2 0 0 0 2-1.6L20.5 7H6.2"/></svg> @Html.L("Shop_AddToCart")
                    </button>
                    <div id="addToCartMsg" class="coupon-msg"></div>
                </div>

                <button type="button" id="buyNowBtn" class="btn-gold" style="width:100%;">
                    <svg class="icon" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 12.5l5 5L20 6"/></svg> @Html.L("Shop_BuyNow")
                </button>

                <form style="display:none">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="productId" value="@ViewBag.ProductId" />
                </form>
            }
        </div>
    </div>

    @{
        var similarProducts = (List<pharaohsLegacy.Models.Product>)ViewBag.SimilarProducts;
    }
    @if (similarProducts != null && similarProducts.Any())
    {
        <div class="similar-products">
            <span class="specs-title">@Html.L("Shop_Similar_Title")</span>
            <div class="similar-grid">
                @foreach (var sp in similarProducts)
                {
                    var spName = (lang == "ar" && !string.IsNullOrEmpty(sp.NameAr)) ? sp.NameAr : sp.Name;
                    <a class="similar-card" href="/Shop/Details/@sp.Id">
                        <div class="similar-img">
                            <img src="@(sp.ImageUrl ?? "/images/placeholder.jpg")" alt="@spName" onerror="this.src='/images/placeholder.jpg'" />
                        </div>
                        <div class="similar-name">@spName</div>
                        <div class="similar-price">@Html.Digits((object)sp.Price) @Html.L("Common_EGP")</div>
                    </a>
                }
            </div>
        </div>
    }

    @await Html.PartialAsync("_Reviews", (
        Reviews: (List<pharaohsLegacy.Models.Review>)ViewBag.Reviews,
        Type: "product",
        ItemId: Model.Id,
        UserReviewed: (bool)ViewBag.UserReviewed
    ))
</div>

<style>
    .details-wrap { max-width: 1180px; margin: 0 auto; padding: 2.5rem 2rem 4rem; }

    /* نفس الأنماط المستخدمة في Booking/Create.cshtml — إبقاء الشكل موحّد على مستوى الموقع كله، بس بمقاس أرقى */
    .book-field { margin-bottom: 1.35rem; }
    .book-field label { display: block; font-family: 'Cinzel', serif; font-size: .68rem; letter-spacing: 2px; text-transform: uppercase; color: var(--muted); margin-bottom: .6rem; }
    .ticket-counter { display: flex; align-items: center; gap: 1.1rem; }
    .ticket-counter button { width: 40px; height: 40px; background: var(--dark3); border: 1px solid var(--border); border-radius: 50%; color: var(--gold); font-size: 1.3rem; cursor: pointer; transition: all .25s; display: flex; align-items: center; justify-content: center; }
    .ticket-counter button:hover { border-color: var(--gold); background: rgba(var(--gold-rgb),.1); }
    .ticket-counter span { font-family: 'Cinzel', serif; font-size: 1.6rem; color: var(--text); min-width: 34px; text-align: center; }
    .total-price { display: flex; justify-content: space-between; align-items: center; padding: 1.25rem 1.4rem; background: rgba(var(--gold-rgb),.08); border: 1px solid var(--border); border-radius: 10px; font-family: 'Cinzel', serif; margin-top: 1.2rem; }
    .total-price span:first-child { color: var(--muted); font-size: .82rem; letter-spacing: 2px; }
    .total-price span:last-child  { color: var(--gold); font-size: 1.5rem; font-weight: 800; }
    .book-field input[type="text"] { width: 100%; background: var(--dark); border: 1px solid var(--border); border-radius: 8px; padding: .85rem 1.1rem; color: var(--text); font-family: 'Crimson Pro', serif; font-size: 1.02rem; outline: none; transition: border-color .3s; }
    .book-field input[type="text"]:focus { border-color: var(--gold); }
    .card-row { display: grid; grid-template-columns: 1.4fr 1fr .8fr; gap: .85rem; }
    .card-row label { margin-bottom: .6rem; }
    .coupon-row { display: flex; gap: .7rem; }
    .coupon-row input { flex: 1; }
    .coupon-row .btn-outline { padding: 0 1.3rem; white-space: nowrap; font-family: 'Cinzel', serif; font-size: .74rem; font-weight: 600; letter-spacing: 1px; border-radius: 8px; background: transparent; cursor: pointer; }
    .coupon-row .btn-outline:disabled { opacity: .5; cursor: not-allowed; }
    .coupon-msg { margin-top: .6rem; font-size: .88rem; min-height: 1.2em; }
    .coupon-msg.success { color: #3fae5a; }
    .coupon-msg.error { color: #e0685a; }
    .confirm-hint { display: block; text-align: center; margin-top: .6rem; font-size: .82rem; color: var(--muted); }
    @@media (max-width: 560px) { .card-row { grid-template-columns: 1fr; } }

    /* 🎨 كارت المنتج — لاي آوت أكبر وأرقى */
    .details-card { display: grid; grid-template-columns: minmax(0, 460px) 1fr; gap: 2.5rem; background: linear-gradient(160deg, var(--dark3), var(--dark)); border: 1px solid var(--border); border-radius: 16px; padding: 2rem; box-shadow: 0 20px 50px -20px rgba(0,0,0,.5); }
    .details-img { position: relative; border-radius: 12px; overflow: hidden; aspect-ratio: 1/1; background: var(--dark); }
    .details-img img { width: 100%; height: 100%; object-fit: cover; }
    .details-body { display: flex; flex-direction: column; }
    .card-tag { font-family: 'Cinzel', serif; font-size: .7rem; letter-spacing: 2.5px; text-transform: uppercase; color: var(--gold); opacity: .85; margin-bottom: .6rem; }
    .details-title { font-family: 'Cinzel', serif; font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 600; color: var(--text); margin: 0 0 .9rem; line-height: 1.3; }
    .details-body > p { font-family: 'Crimson Pro', serif; font-size: 1.05rem; line-height: 1.75; color: var(--muted); margin: 0 0 1.4rem; }

    .details-meta { display: flex; gap: 1.5rem; flex-wrap: wrap; padding: 1.2rem 0; margin-bottom: .5rem; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
    .meta-item { display: flex; flex-direction: column; gap: .3rem; }
    .meta-label { font-family: 'Cinzel', serif; font-size: .66rem; letter-spacing: 1.5px; text-transform: uppercase; color: var(--muted); }
    .meta-value { font-family: 'Cinzel', serif; font-size: 1.15rem; color: var(--gold); font-weight: 700; }

    /* 🆕 المواصفات — بتاع "لوحة أثرية" (provenance plaque) */
    .details-specs { margin: 1.4rem 0; padding: 1.3rem 1.4rem; background: rgba(var(--gold-rgb),.05); border: 1px solid rgba(var(--gold-rgb),.25); border-radius: 10px; }
    .specs-title { display: block; font-family: 'Cinzel', serif; font-size: .72rem; letter-spacing: 2.5px; text-transform: uppercase; color: var(--gold); margin-bottom: 1rem; }
    .specs-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 1rem; }
    .spec-item { display: flex; flex-direction: column; gap: .3rem; }
    .spec-label { font-family: 'Cinzel', serif; font-size: .64rem; letter-spacing: 1px; text-transform: uppercase; color: var(--muted); }
    .spec-value { font-family: 'Crimson Pro', serif; font-size: 1.05rem; color: var(--text); }

    /* 🆕 منتجات مشابهة */
    .similar-products { margin-top: 3rem; }
    .similar-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 1.25rem; margin-top: 1rem; }
    .similar-card { display: block; background: linear-gradient(160deg, var(--dark3), var(--dark)); border: 1px solid var(--border); border-radius: 10px; overflow: hidden; text-decoration: none; transition: border-color .3s, transform .3s, box-shadow .3s; }
    .similar-card:hover { border-color: var(--gold); transform: translateY(-4px); box-shadow: 0 14px 30px -14px rgba(0,0,0,.5); }
    .similar-img { width: 100%; aspect-ratio: 1 / 1; overflow: hidden; background: var(--dark); }
    .similar-img img { width: 100%; height: 100%; object-fit: cover; }
    .similar-name { padding: .75rem .85rem 0; font-family: 'Crimson Pro', serif; font-size: .95rem; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .similar-price { padding: .3rem .85rem .85rem; font-family: 'Cinzel', serif; font-size: .9rem; color: var(--gold); font-weight: 700; }

    /* 🆕 المرحلة 3 — عروض وخصومات وشارات */
    .details-badges { position: absolute; top: 14px; left: 14px; display: flex; flex-direction: column; gap: 6px; z-index: 1; }
    .shop-badge { padding: 5px 12px; border-radius: 20px; font-size: .7rem; font-weight: 800; letter-spacing: .5px; color: #fff; text-transform: uppercase; box-shadow: 0 3px 10px rgba(0,0,0,.35); }
    .badge-sale { background: linear-gradient(135deg, #c23f2e, #7f2318); }
    .badge-new { background: linear-gradient(135deg, #3d6fa8, #1f3f66); }
    .badge-bestseller { background: linear-gradient(135deg, #1f8f7a, #0f5a4c); }
    .badge-featured { background: linear-gradient(135deg, #f0c96e, #c9a227); color: #1a0a00; }
    .icon { display: inline-block; vertical-align: -3px; flex-shrink: 0; }
    #addToCartBtn, #buyNowBtn { display: flex; align-items: center; justify-content: center; gap: 7px; }
    .btn-loading-dots { letter-spacing: 2px; opacity: .7; }
    .details-price-old { display: block; text-decoration: line-through; color: var(--muted); font-size: .9rem; font-weight: 400; }
    .details-lowstock { color: #e0a733; font-size: .88rem; margin-inline-start: .5rem; font-weight: 600; }

    /* 🆕 المرحلة 4 — Breadcrumbs */
    .breadcrumbs { font-size: .82rem; color: var(--muted); margin-bottom: 1.5rem; display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
    .breadcrumbs a { color: var(--muted); text-decoration: none; transition: color .2s; }
    .breadcrumbs a:hover { color: var(--gold); }
    .breadcrumbs .crumb-sep { color: var(--border); }
    .breadcrumbs .crumb-current { color: var(--gold); font-weight: 600; }

    /* 🆕 المرحلة 4 — Wishlist heart */
    .shop-fav-btn { position: absolute; top: 10px; right: 10px; width: 34px; height: 34px; display: flex; align-items: center; justify-content: center; background: rgba(10,8,4,.6); backdrop-filter: blur(3px); border: 1px solid rgba(255,255,255,.12); border-radius: 50%; font-size: 1.2rem; color: #fff; text-decoration: none; z-index: 2; cursor: pointer; padding: 0; font-family: inherit; line-height: 1; transition: transform .2s, color .2s, background .2s; }
    .shop-fav-btn:hover { transform: scale(1.15); background: rgba(10,8,4,.8); }
    .shop-fav-btn.active { color: #e0435b; }
    .details-fav-btn { top: 16px; right: 16px; width: 42px; height: 42px; font-size: 1.5rem; }

    /* 🎨 السلة — أيقونة فوق الصفحة */
    .details-top-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
    .btn-back { font-family: 'Cinzel', serif; font-size: .85rem; letter-spacing: .5px; }
    .cart-icon-link { text-decoration: none; color: var(--text); display: inline-flex; align-items: center; width: 46px; height: 46px; justify-content: center; border-radius: 50%; background: rgba(var(--gold-rgb),.08); border: 1px solid var(--border); transition: border-color .25s, background .25s, transform .25s; position: relative; }
    .cart-icon-link:hover { border-color: var(--gold); background: rgba(var(--gold-rgb),.14); transform: translateY(-2px); }
    .cart-icon-glyph { font-size: 1.3rem; }
    .cart-count-badge { position: absolute; top: -4px; right: -4px; background: var(--gold); color: #1a0a00; font-size: .68rem; font-weight: 800; border-radius: 999px; min-width: 19px; height: 19px; display: inline-flex; align-items: center; justify-content: center; padding: 0 4px; border: 2px solid var(--dark); }

    @@media (max-width: 800px) {
        .details-wrap { padding: 1.75rem 1.1rem 3rem; }
        .details-card { grid-template-columns: 1fr; padding: 1.4rem; gap: 1.5rem; }
    }
</style>

<script>
    // 🆕 المرحلة 4 — Wishlist toggle بـ AJAX من غير أي Refresh للصفحة
    async function toggleWishlist(e, btn) {
        e.preventDefault();
        e.stopPropagation();
        if (btn.disabled) return;
        btn.disabled = true;

        const productId = btn.getAttribute('data-product-id');
        const favId = btn.getAttribute('data-fav-id');
        const isFav = btn.classList.contains('active');
        const titleAdd = btn.getAttribute('data-title-add');
        const titleRemove = btn.getAttribute('data-title-remove');

        const url = isFav
            ? `/Favorite/Remove/${favId}`
            : `/Favorite/Add?type=product&itemId=${productId}`;

        try {
            const res = await fetch(url, {
                headers: { 'X-Requested-With': 'XMLHttpRequest' },
                credentials: 'same-origin'
            });
            const data = await res.json();

            if (data.success) {
                if (isFav) {
                    btn.classList.remove('active');
                    btn.textContent = '♡';
                    btn.setAttribute('data-fav-id', '');
                    btn.title = titleAdd;
                } else {
                    btn.classList.add('active');
                    btn.textContent = '♥';
                    btn.setAttribute('data-fav-id', data.favoriteId);
                    btn.title = titleRemove;
                }
            }
        } catch (err) {
            console.error('Wishlist toggle failed:', err);
        } finally {
            btn.disabled = false;
        }
    }

    var unitPrice = @ViewBag.UnitPrice;
    var maxQty = @ViewBag.MaxQuantity;
    var qty = 1;
    var currentLang = '@lang';
    var currencyLabel = @js("Common_EGP");
    var arabicDigitsMap = ['٠', '١', '٢', '٣', '٤', '٥', '٦', '٧', '٨', '٩'];

    function toLocalDigits(num) {
        var str = String(num);
        if (currentLang !== 'ar') return str;
        return str.replace(/[0-9]/g, function (d) { return arabicDigitsMap[+d]; });
    }

    function updateTotal() {
        var raw = unitPrice * qty;
        document.getElementById('totalPrice').textContent = toLocalDigits(Math.round(raw * 100) / 100) + ' ' + currencyLabel;
    }

    function changeQty(val) {
        qty = Math.max(1, Math.min(maxQty || 10, qty + val));
        document.getElementById('qtyCount').textContent = toLocalDigits(qty);
        updateTotal();
    }

    // 🆕 إضافة للسلة من صفحة التفاصيل — بتستخدم نفس عداد الكمية الموجود فوق
    async function addToCartFromDetails(silent) {
        var btn = document.getElementById('addToCartBtn');
        var msgEl = document.getElementById('addToCartMsg');
        var token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        var body = new URLSearchParams();
        body.append('productId', document.getElementById('productId').value);
        body.append('quantity', qty);
        body.append('__RequestVerificationToken', token);

        var res = await fetch('/Shop/AddToCart', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: body.toString()
        });
        var data = await res.json();

        if (data.success) {
            var badge = document.getElementById('cartCountBadge');
            if (badge) {
                badge.textContent = toLocalDigits(data.cartCount);
                badge.style.display = 'inline-flex';
            }
            var navBadge = document.getElementById('navCartBadge');
            if (navBadge) {
                navBadge.textContent = toLocalDigits(data.cartCount);
                navBadge.style.display = 'inline-flex';
            }
        }
        if (!silent && msgEl) {
            msgEl.textContent = data.message || '';
            msgEl.className = data.success ? 'coupon-msg success' : 'coupon-msg error';
        }
        return data;
    }

    document.getElementById('addToCartBtn').addEventListener('click', async function () {
        var btn = this;
        if (btn.disabled) return;
        btn.disabled = true;
        var originalHtml = btn.innerHTML;
        try {
            await addToCartFromDetails(false);
        } catch (err) {
            console.error('Add to cart failed:', err);
        } finally {
            btn.disabled = false;
            btn.innerHTML = originalHtml;
        }
    });

    // 🆕 "اشترِ الآن" — بتضيف المنتج للسلة بنفس الكمية المختارة، وبعدين توديك على صفحة الـ Checkout مباشرة
    document.getElementById('buyNowBtn').addEventListener('click', async function () {
        var btn = this;
        if (btn.disabled) return;
        btn.disabled = true;
        var originalHtml = btn.innerHTML;
        btn.innerHTML = '<span class="btn-loading-dots">···</span>';
        try {
            var data = await addToCartFromDetails(true);
            if (data.success) {
                window.location.href = '/Shop/Checkout';
            } else {
                var msgEl = document.getElementById('addToCartMsg');
                msgEl.textContent = data.message || '';
                msgEl.className = 'coupon-msg error';
                btn.disabled = false;
                btn.innerHTML = originalHtml;
            }
        } catch (err) {
            console.error('Buy now failed:', err);
            btn.disabled = false;
            btn.innerHTML = originalHtml;
        }
    });
</script>
