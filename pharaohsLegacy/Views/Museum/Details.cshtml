@model pharaohsLegacy.Models.Museum
@using pharaohsLegacy.Extensions

    @{
    var userEmail = Context.Session.GetString("UserEmail");
    var isGuest   = userEmail == null || userEmail == "guest";
    var isFav     = !isGuest && Context.RequestServices
        .GetService<pharaohsLegacy.Models.AppDbContext>()!
        .Favorites.Any(f => f.UserEmail == userEmail && f.Type == "museum" && f.ItemId == Model.Id);
    var lang = Context.Session.GetString("Lang") ?? "en";
    var arrowBack = lang == "ar" ? "→" : "←";
    var mName = (lang == "ar" && !string.IsNullOrEmpty(Model.NameAr)) ? Model.NameAr : Model.Name;
    var mLocation = (lang == "ar" && !string.IsNullOrEmpty(Model.LocationAr)) ? Model.LocationAr : Model.Location;
    var mDescription = (lang == "ar" && !string.IsNullOrEmpty(Model.DescriptionAr)) ? Model.DescriptionAr : Model.Description;
    var mCategory = (lang == "ar" && !string.IsNullOrEmpty(Model.CategoryAr)) ? Model.CategoryAr : Model.Category;
    ViewData["Title"] = mName;
}


@section Styles {
<style>
.det-wrap { max-width: 1100px; margin: 0 auto; padding: 2rem 2rem 5rem; }

.det-banner {
    position: relative; height: 380px;
    border-radius: 16px; overflow: hidden;
            margin-bottom: 2rem;
            border: 1px solid var(--border);
}
.det-banner img { width: 100%; height: 100%; object-fit: cover; filter: brightness(.55); }
.det-banner-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(13,7,2,.95) 0%, rgba(13,7,2,.3) 60%, transparent 100%);
}
.det-banner-content {
    position: absolute; bottom: 2rem; left: 2rem; right: 2rem;
    display: flex; align-items: flex-end; justify-content: space-between; gap: 1rem;
}
.det-banner-tag { font-family: 'Cinzel', serif; font-size: .65rem; letter-spacing: 3px; text-transform: uppercase; color: #c9a227; margin-bottom: .5rem; }
.det-banner-name { font-family: 'Cinzel', serif; font-size: clamp(2rem, 5vw, 3.2rem); font-weight: 700; color: #e8d5b0; line-height: 1.1; text-shadow: 0 2px 20px rgba(0,0,0,.5); }

.det-content { display: grid; grid-template-columns: 1fr 320px; gap: 2rem; align-items: start; }

.det-section-title { font-family: 'Cinzel', serif; font-size: .65rem; letter-spacing: 3px; text-transform: uppercase; color: var(--gold); margin-bottom: .75rem; display: flex; align-items: center; gap: .75rem; }
            .det-section-title::after {
                content: '';
                flex: 1;
                height: 1px;
                background: linear-gradient(90deg, var(--border), transparent);
            }

.det-description { color: var(--muted); font-size: 1.05rem; line-height: 1.9; margin-bottom: 2rem; }

.det-sidebar { display: flex; flex-direction: column; gap: 1rem; }

        .det-info-card {
            background: var(--dark3);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 1.5rem;
        }
        .det-info-card-title {
            font-family: 'Cinzel', serif;
            font-size: .65rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--gold);
            margin-bottom: 1rem;
            padding-bottom: .75rem;
            border-bottom: 1px solid var(--border);
        }
.det-info-row { display: flex; align-items: center; gap: .75rem; padding: .6rem 0; border-bottom: 1px solid rgba(var(--border-rgb),.5); }
.det-info-row:last-child { border-bottom: none; }
.det-info-icon { font-size: 1.1rem; width: 24px; text-align: center; flex-shrink: 0; }
.det-info-label { font-size: .75rem; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; font-family: 'Cinzel', serif; }
.det-info-value { font-size: .95rem; color: var(--text); margin-top: 2px; }

.det-btn { width: 100%; padding: .9rem; border-radius: 8px; font-family: 'Cinzel', serif; font-size: .7rem; letter-spacing: 2px; text-transform: uppercase; cursor: pointer; transition: all .3s; border: 1px solid; display: flex; align-items: center; justify-content: center; gap: .6rem; text-decoration: none; }

        .det-btn-book {
            background: linear-gradient(135deg, var(--gold-dark), var(--gold));
            border-color: transparent;
            color: #0d0702;
            font-weight: 700;
        }
            .det-btn-book:hover {
                filter: brightness(1.1);
                color: #0d0702;
            }

        .det-btn-website {
            background: transparent;
            border-color: var(--border);
            color: var(--muted);
        }
.det-btn-website:hover { border-color: var(--gold); color: var(--gold); }

.det-nav { display: flex; gap: 1rem; margin-top: 2rem; flex-wrap: wrap; }

.det-price-badge {
    background: rgba(var(--gold-rgb),.08); border: 1px solid rgba(var(--gold-rgb),.25);
    border-radius: 8px; padding: 1rem 1.25rem;
    display: flex; align-items: center; justify-content: space-between;
}
.det-price-label { font-family: 'Cinzel', serif; font-size: .6rem; letter-spacing: 2px; text-transform: uppercase; color: var(--muted); }
.det-price-val { font-family: 'Cinzel', serif; font-size: 1.4rem; font-weight: 700; color: var(--gold); }

@@media (max-width: 900px) {
    .det-content { grid-template-columns: 1fr; }
    .det-sidebar { order: -1; }
    .det-banner { height: 280px; }
    .det-banner-name { font-size: 2rem; }
}
@@media (max-width: 480px) {
    .det-wrap { padding: 1rem 1rem 4rem; }
    .det-banner { height: 220px; }
}
</style>
}

<div class="det-wrap">
    <a href="/Museum/Index" class="btn-back">@arrowBack @Html.L("Museum_Back_Link")</a>

    <div class="det-banner">
        <img src="@Model.ImageUrl" alt="@mName"
             onerror="this.src='https://via.placeholder.com/1200x400/2d1a08/c9a227?text=@mName'" />
        <div class="det-banner-overlay"></div>
        <div class="det-banner-content">
            <div>
                <div class="det-banner-tag">🏛️ @mCategory @Html.L("Common_Museum")</div>
                <div class="det-banner-name">@mName</div>
            </div>
        </div>
    </div>

    <div class="det-content">

        <div>
            <div class="det-section-title">@Html.L("Common_About") @mName</div>
            <p class="det-description">@mDescription</p>
            <div class="det-nav">
                <a href="/Museum/Index" class="btn-outline">@arrowBack @Html.L("Museum_AllMuseums_Link")</a>
            </div>
        </div>

        <div class="det-sidebar">

            <div class="det-price-badge">
                <div>
                    <div class="det-price-label">@Html.L("Common_TicketPrice")</div>
                    <div class="det-price-val">@Html.Digits(100) @Html.L("Common_EGP")</div>
                </div>
                <span style="font-size:1.5rem;">🎟</span>
            </div>

            <div class="det-info-card">
                <div class="det-info-card-title">@Html.L("Common_QuickFacts")</div>
                <div class="det-info-row">
                    <span class="det-info-icon">🏛️</span>
                    <div>
                        <div class="det-info-label">@Html.L("Common_Name")</div>
                        <div class="det-info-value">@mName</div>
                    </div>
                </div>
                <div class="det-info-row">
                    <span class="det-info-icon">📍</span>
                    <div>
                        <div class="det-info-label">@Html.L("Common_Location")</div>
                        <div class="det-info-value">@mLocation</div>
                    </div>
                </div>
                <div class="det-info-row">
                    <span class="det-info-icon">📅</span>
                    <div>
                        <div class="det-info-label">@Html.L("Museum_Founded_Label")</div>
                        <div class="det-info-value">@Html.Digits(Model.Founded)</div>
                    </div>
                </div>
                <div class="det-info-row">
                    <span class="det-info-icon">🏷️</span>
                    <div>
                        <div class="det-info-label">@Html.L("Common_Category")</div>
                        <div class="det-info-value">@mCategory</div>
                    </div>
                </div>
            </div>

            @if (!isGuest)
            {
                <a href="/Booking/Create?placeType=Museum&placeId=@Model.Id" class="det-btn det-btn-book">
                    🎟 @Html.L("Common_BookVisit")
                </a>

                @if (isFav)
                {
                    <a href="/Favorite/Remove/@ViewBag.FavId?returnUrl=/Museum/Details/@Model.Id"
                       class="det-btn det-btn-website" style="border-color: var(--gold); color: var(--gold);">
                        ★ @Html.L("Common_RemoveFavorite")
                    </a>
                }
                else
                {
                    <a href="/Favorite/Add?type=museum&itemId=@Model.Id&returnUrl=/Museum/Details/@Model.Id"
                       class="det-btn det-btn-website">
                        ☆ @Html.L("Common_AddFavorite")
                    </a>
                }
            }
            else
            {
                <a href="/User/Login" class="det-btn det-btn-book">🎟 @Html.L("Common_LoginToBook")</a>
                <a href="/User/Login" class="det-btn det-btn-website">🔒 @Html.L("Common_LoginToSave")</a>
            }

        </div>
    </div>
    @await Html.PartialAsync("_Reviews", (
    Reviews: (List<pharaohsLegacy.Models.Review>)ViewBag.Reviews,
    Type: "museum",
    ItemId: Model.Id,
    UserReviewed: (bool)ViewBag.HasReviewed
))
</div>