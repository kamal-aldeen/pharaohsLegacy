@model pharaohsLegacy.Models.God
@using pharaohsLegacy.Extensions

@{
    var isFav = (bool)(ViewBag.IsFav ?? false);
    var email = Context.Session.GetString("UserEmail");
    var isGuest = email == "guest";
    var lang = Context.Session.GetString("Lang") ?? "en";
    var arrowBack = lang == "ar" ? "→" : "←";
    var godName = (lang == "ar" && !string.IsNullOrEmpty(Model.NameAr)) ? Model.NameAr : Model.Name;
    var godRole = (lang == "ar" && !string.IsNullOrEmpty(Model.RoleAr)) ? Model.RoleAr : Model.Role;
    var godDescription = (lang == "ar" && !string.IsNullOrEmpty(Model.DescriptionAr)) ? Model.DescriptionAr : Model.Description;
    var godSymbol = (lang == "ar" && !string.IsNullOrEmpty(Model.SymbolAr)) ? Model.SymbolAr : Model.Symbol;
    ViewData["Title"] = godName;
}

@section Styles {
<style>
.god-details-wrap { max-width: 1100px; margin: 0 auto; padding: 2rem 2rem 5rem; }

/* Hero Banner */
.god-banner {
    position: relative;
    height: 380px;
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 2rem;
    border: 1px solid var(--border);
}
.god-banner img {
    width: 100%; height: 100%;
    object-fit: cover;
    filter: brightness(.6);
}
.god-banner-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(13,7,2,.95) 0%, rgba(13,7,2,.3) 60%, transparent 100%);
}
.god-banner-content {
    position: absolute;
    bottom: 2rem; left: 2rem; right: 2rem;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
}
.god-banner-tag {
    font-family: 'Cinzel', serif;
    font-size: .65rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #c9a227;
    margin-bottom: .5rem;
    display: flex;
    align-items: center;
    gap: .5rem;
}
.god-banner-name {
    font-family: 'Cinzel', serif;
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 700;
    color: #e8d5b0;
    line-height: 1.1;
    text-shadow: 0 2px 20px rgba(0,0,0,.5);
}
.god-banner-symbol {
    font-size: 3rem;
    opacity: .8;
    flex-shrink: 0;
}

/* Content Grid */
.god-content {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 2rem;
    align-items: start;
}

/* Main Info */
.god-main { }
.god-section-title {
    font-family: 'Cinzel', serif;
    font-size: .65rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: .75rem;
    display: flex;
    align-items: center;
    gap: .75rem;
}
.god-section-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, var(--border), transparent);
}
.god-description {
    color: var(--muted);
    font-size: 1.05rem;
    line-height: 1.9;
    margin-bottom: 2rem;
}

/* Role Pills */
.god-roles {
    display: flex;
    flex-wrap: wrap;
    gap: .6rem;
    margin-bottom: 2rem;
}
.god-role-pill {
    background: rgba(var(--gold-rgb),.08);
    border: 1px solid rgba(var(--gold-rgb),.25);
    border-radius: 50px;
    padding: .4rem 1rem;
    font-family: 'Cinzel', serif;
    font-size: .65rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--gold);
}

/* Sidebar Card */
.god-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}
.god-info-card {
    background: var(--dark3);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.5rem;
}
.god-info-card-title {
    font-family: 'Cinzel', serif;
    font-size: .65rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1rem;
    padding-bottom: .75rem;
    border-bottom: 1px solid var(--border);
}
.god-info-row {
    display: flex;
    align-items: center;
    gap: .75rem;
    padding: .6rem 0;
    border-bottom: 1px solid rgba(var(--border-rgb),.5);
}
.god-info-row:last-child { border-bottom: none; }
.god-info-icon { font-size: 1.1rem; width: 24px; text-align: center; flex-shrink: 0; }
.god-info-label { font-size: .75rem; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; font-family: 'Cinzel', serif; }
.god-info-value { font-size: .95rem; color: var(--text); margin-top: 2px; }

/* Fav Button */
.btn-fav {
    width: 100%;
    padding: .9rem;
    border-radius: 8px;
    font-family: 'Cinzel', serif;
    font-size: .7rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all .3s;
    border: 1px solid;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: .6rem;
    text-decoration: none;
}
.btn-fav-add {
    background: transparent;
    border-color: var(--border);
    color: var(--muted);
}
.btn-fav-add:hover { border-color: var(--gold); color: var(--gold); }
.btn-fav-remove {
    background: rgba(var(--gold-rgb),.1);
    border-color: rgba(var(--gold-rgb),.4);
    color: var(--gold);
}
.btn-fav-remove:hover { background: rgba(var(--gold-rgb),.2); }

/* Nav Buttons */
.god-nav {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
    flex-wrap: wrap;
}

@@media (max-width: 900px) {
    .god-content { grid-template-columns: 1fr; }
    .god-sidebar { order: -1; }
    .god-banner { height: 280px; }
    .god-banner-name { font-size: 2rem; }
}
@@media (max-width: 480px) {
    .god-details-wrap { padding: 1rem 1rem 4rem; }
    .god-banner { height: 240px; }
}
</style>
}

<div class="god-details-wrap">
    <a href="/God/Index" class="btn-back">@arrowBack @Html.L("God_Back_Link")</a>

    <!-- Banner -->
    <div class="god-banner">
        <img src="@(Model.ImageUrl.Length > 0 ? Model.ImageUrl : "/images/placeholder.jpg")"
             alt="@godName"
             onerror="this.src='https://via.placeholder.com/1200x400/2d1a08/c9a227?text=@godName'" />
        <div class="god-banner-overlay"></div>
        <div class="god-banner-content">
            <div>
                <div class="god-banner-tag">𓂀 @Html.L("Common_EgyptianDeity")</div>
                <div class="god-banner-name">@godName</div>
            </div>
            @if (!string.IsNullOrEmpty(Model.Symbol))
            {
                <div class="god-banner-symbol">@godSymbol</div>
            }
        </div>
    </div>

    <!-- Content -->
    <div class="god-content">

        <!-- Main -->
        <div class="god-main">
            <div class="god-section-title">@Html.L("Common_About") @godName</div>
            <p class="god-description">@godDescription</p>

            @if (!string.IsNullOrEmpty(Model.Role))
            {
                <div class="god-section-title">@Html.L("God_DomainsOfPower")</div>
                <div class="god-roles">
                    @foreach (var role in godRole.Split(','))
                    {
                        <span class="god-role-pill">@role.Trim()</span>
                    }
                </div>
            }

            <div class="god-nav">
                <a href="/God/Index" class="btn-outline">@arrowBack @Html.L("God_AllGods_Link")</a>

            </div>
        </div>

        <!-- Sidebar -->
        <div class="god-sidebar">

            <!-- Info Card -->
            <div class="god-info-card">
                <div class="god-info-card-title">@Html.L("Common_QuickFacts")</div>
                <div class="god-info-row">
                    <span class="god-info-icon">𓂀</span>
                    <div>
                        <div class="god-info-label">@Html.L("Common_Name")</div>
                        <div class="god-info-value">@godName</div>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(Model.Role))
                {
                    <div class="god-info-row">
                        <span class="god-info-icon">⚡</span>
                        <div>
                            <div class="god-info-label">@Html.L("Common_Domains")</div>
                            <div class="god-info-value">@godRole</div>
                        </div>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.Symbol))
                {
                    <div class="god-info-row">
                        <span class="god-info-icon">𓋹</span>
                        <div>
                            <div class="god-info-label">@Html.L("Common_Symbol")</div>
                            <div class="god-info-value">@godSymbol</div>
                        </div>
                    </div>
                }
                <div class="god-info-row">
                    <span class="god-info-icon">🏛️</span>
                    <div>
                        <div class="god-info-label">@Html.L("Common_Origin")</div>
                        <div class="god-info-value">@Html.L("Common_AncientEgypt")</div>
                    </div>
                </div>
            </div>

            <!-- Favorite Button -->
            @if (!isGuest && email != null)
            {
                if (isFav)
                {
                    <form asp-controller="Favorite" asp-action="Remove" method="post">
                        <input type="hidden" name="id" value="@ViewBag.FavId" />
                        <input type="hidden" name="returnUrl" value="/God/Details/@Model.Id" />
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-fav btn-fav-remove">
                            ❤️ @Html.L("God_SavedToFavorites")
                        </button>
                    </form>
                }
                else
                {
                    <form asp-controller="Favorite" asp-action="Add" method="post">
                        <input type="hidden" name="type" value="god" />
                        <input type="hidden" name="itemId" value="@Model.Id" />
                        <input type="hidden" name="returnUrl" value="/God/Details/@Model.Id" />
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-fav btn-fav-add">
                            🤍 @Html.L("Common_AddFavorite")
                        </button>
                    </form>
                }
            }
            else
            {
                <a href="/User/Login" class="btn-fav btn-fav-add">
                    🔒 @Html.L("Common_LoginToSave")
                </a>
            }

        </div>
    </div>
    @await Html.PartialAsync("_Reviews", (
    Reviews: (List<pharaohsLegacy.Models.Review>)ViewBag.Reviews,
    Type: "god",
    ItemId: Model.Id,
    UserReviewed: (bool)ViewBag.HasReviewed
))
</div>