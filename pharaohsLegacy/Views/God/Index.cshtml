@model List<pharaohsLegacy.Models.God>
@using pharaohsLegacy.Extensions

@{
    ViewData["Title"] = "Egyptian Gods";
}

@section Styles {
<style>
.gods-hero {
    text-align: center;
    padding: 4rem 2rem 3rem;
    position: relative;
    overflow: hidden;
}
.gods-hero::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 70% 60% at 50% 0%, rgba(var(--gold-rgb),.1) 0%, transparent 70%);
    pointer-events: none;
}
.gods-hero-symbol {
    font-size: 3rem;
    display: block;
    margin-bottom: 1rem;
    animation: floatSym 3s ease-in-out infinite;
}
@@keyframes floatSym {
    0%,100% { transform: translateY(0); }
    50%      { transform: translateY(-8px); }
}
.gods-hero h1 {
    font-family: 'Cinzel', serif;
    font-size: clamp(2rem, 5vw, 3.5rem);
    color: var(--text);
    margin-bottom: .75rem;
    font-weight: 700;
    letter-spacing: 2px;
}
.gods-hero h1 span { color: var(--gold); }
.gods-hero p {
    color: var(--muted);
    font-size: 1.1rem;
    font-style: italic;
    max-width: 500px;
    margin: 0 auto 2rem;
}
.gods-divider {
    width: 120px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    margin: 0 auto;
}


.gods-search-wrap {
    max-width: 480px;
    margin: 2rem auto 0;
    position: relative;
}
.gods-search {
    width: 100%;
    background: rgba(var(--gold-rgb),.05);
    border: 1px solid var(--border);
    border-radius: 50px;
    padding-block: .85rem;
    padding-inline: 3rem 1.5rem;
    color: var(--text);
    font-family: 'Crimson Pro', serif;
    font-size: 1rem;
    outline: none;
    transition: border-color .3s;
}
.gods-search:focus { border-color: var(--gold); }
.gods-search::placeholder { color: var(--muted); }
.gods-search-icon {
    position: absolute;
    inset-inline-start: 1.1rem; top: 50%;
    transform: translateY(-50%);
    color: var(--muted);
    font-size: 1rem;
    pointer-events: none;
}


.gods-count {
    text-align: center;
    font-family: 'Cinzel', serif;
    font-size: .65rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--muted);
    margin: 2rem 0 .5rem;
}


.gods-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.5rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem 4rem;
}


.god-card {
    background: var(--dark3);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    display: block;
    transition: transform .3s, border-color .3s, box-shadow .3s;
    position: relative;
    opacity: 0;
    transform: translateY(20px);
}
.god-card.visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity .5s ease, transform .5s ease, border-color .3s, box-shadow .3s;
}
.god-card:hover {
    transform: translateY(-6px);
    border-color: var(--gold);
    box-shadow: 0 12px 40px rgba(var(--gold-rgb),.15);
}


.god-card-img {
    position: relative;
    height: 220px;
    overflow: hidden;
    background: var(--dark2);
}
.god-card-img img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform .5s;
}
.god-card:hover .god-card-img img { transform: scale(1.08); }
.god-card-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(13,7,2,.9) 0%, transparent 50%);
}
.god-card-symbol {
    position: absolute;
    top: 12px; right: 12px;
    background: rgba(13,7,2,.75);
    backdrop-filter: blur(4px);
    border: 1px solid rgba(var(--gold-rgb),.3);
    border-radius: 8px;
    padding: 6px 10px;
    font-size: 1.1rem;
    color: var(--gold);
    font-family: 'Cinzel', serif;
    font-size: .7rem;
    letter-spacing: 1px;
}

/* Card Body */
.god-card-body { padding: 1.25rem; }
.god-card-tag {
    font-family: 'Cinzel', serif;
    font-size: .6rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: .4rem;
    display: block;
}
.god-card-name {
    font-family: 'Cinzel', serif;
    font-size: 1.1rem;
    color: var(--text);
    margin-bottom: .4rem;
    font-weight: 600;
}
.god-card-role {
    color: var(--muted);
    font-size: .9rem;
    font-style: italic;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}
.god-card-footer {
    padding: .75rem 1.25rem;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
}
.god-card-footer span {
    font-size: .75rem;
    color: var(--muted);
    font-style: italic;
}
.god-card-arrow { color: var(--gold); }


.gods-empty {
    text-align: center;
    padding: 4rem 2rem;
    color: var(--muted);
    display: none;
}
.gods-empty-icon { font-size: 3rem; margin-bottom: 1rem; }
.gods-empty-text {
    font-family: 'Cinzel', serif;
    font-size: 1rem;
}

@@media (max-width: 768px) {
    .gods-grid { padding: 0 1rem 3rem; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); }
    .gods-hero { padding: 3rem 1.5rem 2rem; }
}
</style>
}

<div class="gods-hero">
    <span class="gods-hero-symbol">𓂀</span>
    <h1>@Html.L("God_Hero_Title") <span>@Html.L("God_Hero_Subtitle_Span")</span></h1>
    <p>@Html.L("God_Hero_Subtitle")</p>
    <div class="gods-divider"></div>
    <div class="gods-search-wrap">
        <span class="gods-search-icon">🔍</span>
        <input class="gods-search" type="text" placeholder="@Html.L("God_Search_Placeholder")" id="godSearch" oninput="filterGods(this.value)" />
    </div>
</div>

<div class="gods-count" id="godsCount" data-unit="@Html.L("God_Count_Label")">@Html.Digits(Model.Count) @Html.L("God_Count_Label")</div>

<div class="gods-grid" id="godsGrid">
    @{
        var lang = Context.Session.GetString("Lang") ?? "en";
        var arrowNext = lang == "ar" ? "←" : "→";
    }
    @foreach (var g in Model)
    {
        var gName = (lang == "ar" && !string.IsNullOrEmpty(g.NameAr)) ? g.NameAr : g.Name;
        var gRole = (lang == "ar" && !string.IsNullOrEmpty(g.RoleAr)) ? g.RoleAr : g.Role;
        var gSymbol = (lang == "ar" && !string.IsNullOrEmpty(g.SymbolAr)) ? g.SymbolAr : g.Symbol;
        var gSearchName = $"{g.Name} {g.NameAr}".ToLower();
        var gSearchRole = $"{g.Role} {g.RoleAr}".ToLower();
        <a href="/God/Details/@g.Id" class="god-card" data-name="@gSearchName" data-role="@gSearchRole">
            <div class="god-card-img">
                <img src="@(g.ImageUrl.Length > 0 ? g.ImageUrl : "/images/placeholder.jpg")"
                     alt="@gName"
                     onerror="this.src='https://via.placeholder.com/400x300/2d1a08/c9a227?text=@g.Name'" />
                <div class="god-card-overlay"></div>
                @if (!string.IsNullOrEmpty(g.Symbol))
                {
                    <div class="god-card-symbol">@gSymbol</div>
                }
            </div>
            <div class="god-card-body">
                <span class="god-card-tag">𓂀 @Html.L("Common_EgyptianGod")</span>
                <div class="god-card-name">@gName</div>
                <div class="god-card-role">@gRole</div>
            </div>
            <div class="god-card-footer">
                <span>@Html.L("God_Of_Label") @gRole.Split(',')[0].Trim()</span>
                <span class="god-card-arrow">@arrowNext</span>
            </div>
        </a>
    }
</div>

<div class="gods-empty" id="godsEmpty">
    <div class="gods-empty-icon">𓂀</div>
    <div class="gods-empty-text">@Html.L("God_Empty_Text")</div>
</div>

@section Scripts {
<script>

var currentLang = '@lang';
var arabicDigitsMap = ['٠', '١', '٢', '٣', '٤', '٥', '٦', '٧', '٨', '٩'];
function toLocalDigits(input) {
    var str = String(input);
    if (currentLang !== 'ar') return str;
    return str.replace(/[0-9]/g, function (d) { return arabicDigitsMap[+d]; });
}

const cards = document.querySelectorAll('.god-card');
const obs = new IntersectionObserver((entries) => {
    entries.forEach((e, i) => {
        if (e.isIntersecting) {
            setTimeout(() => e.target.classList.add('visible'), i * 80);
            obs.unobserve(e.target);
        }
    });
}, { threshold: 0.1 });
cards.forEach(c => obs.observe(c));


function filterGods(q) {
    q = q.toLowerCase();
    let visible = 0;
    document.querySelectorAll('.god-card').forEach(card => {
        const match = card.dataset.name.includes(q) || card.dataset.role.includes(q);
        card.style.display = match ? '' : 'none';
        if (match) visible++;
    });
    const godsCountEl = document.getElementById('godsCount');
    godsCountEl.textContent = toLocalDigits(visible) + ' ' + godsCountEl.dataset.unit;
    document.getElementById('godsEmpty').style.display = visible === 0 ? 'block' : 'none';
}
</script>
}
