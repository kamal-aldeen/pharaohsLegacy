<div class="adm-overlay" id="modalBookingStatus">
  <div class="adm-modal" style="max-width:440px; padding:0; overflow:hidden;">

    <!-- Header -->
    <div style="background:linear-gradient(135deg,#1a1200,#2d1f00); padding:24px 28px 20px; border-bottom:1px solid rgba(212,175,55,0.2); position:relative;">
      <div style="font-family:'Cinzel',serif; font-size:17px; color:#c9a227; letter-spacing:1px;">
        ✏ Change Booking Status
      </div>
      <div style="font-size:12px; color:var(--text-dim); margin-top:4px;">
        Update the status for: <span id="bookingStatusName" style="color:var(--gold-light); font-weight:600;"></span>
      </div>
      <div class="adm-modal-close" onclick="closeModal('modalBookingStatus')"
           style="position:absolute; top:18px; right:18px; width:30px; height:30px; border-radius:50%; background:rgba(255,255,255,0.05); display:flex; align-items:center; justify-content:center; cursor:pointer; color:#aaa; font-size:14px; transition:.2s;"
           onmouseover="this.style.background='rgba(212,175,55,0.15)'; this.style.color='#c9a227'"
           onmouseout="this.style.background='rgba(255,255,255,0.05)'; this.style.color='#aaa'">✕</div>
    </div>

    <form method="post" action="/Admin/ChangeBookingStatus">
      @Html.AntiForgeryToken()
      <input type="hidden" name="id" id="bookingStatusId" />

      <div style="padding:24px 28px;">

        <!-- Status Options -->
        <label style="font-size:12px; color:var(--text-dim); text-transform:uppercase; letter-spacing:1px; display:block; margin-bottom:12px;">Select New Status</label>

        <div style="display:flex; flex-direction:column; gap:10px;" id="statusOptions">

          <label id="opt-Confirmed" onclick="selectStatus('Confirmed')"
                 style="display:flex; align-items:center; gap:14px; padding:14px 16px; border-radius:10px; border:1.5px solid rgba(212,175,55,0.15); background:rgba(212,175,55,0.04); cursor:pointer; transition:.2s;">
            <div style="width:36px; height:36px; border-radius:50%; background:rgba(39,174,96,0.15); display:flex; align-items:center; justify-content:center; font-size:16px;">✅</div>
            <div>
              <div style="color:#2ecc71; font-weight:600; font-size:14px;">Confirmed</div>
              <div style="color:var(--text-dim); font-size:11px; margin-top:2px;">Booking is active and confirmed</div>
            </div>
          </label>

          <label id="opt-Cancelled" onclick="selectStatus('Cancelled')"
                 style="display:flex; align-items:center; gap:14px; padding:14px 16px; border-radius:10px; border:1.5px solid rgba(212,175,55,0.15); background:rgba(212,175,55,0.04); cursor:pointer; transition:.2s;">
            <div style="width:36px; height:36px; border-radius:50%; background:rgba(231,76,60,0.15); display:flex; align-items:center; justify-content:center; font-size:16px;">✖</div>
            <div>
              <div style="color:#e74c3c; font-weight:600; font-size:14px;">Cancelled</div>
              <div style="color:var(--text-dim); font-size:11px; margin-top:2px;">Booking has been cancelled</div>
            </div>
          </label>

          <label id="opt-Refunded" onclick="selectStatus('Refunded')"
                 style="display:flex; align-items:center; gap:14px; padding:14px 16px; border-radius:10px; border:1.5px solid rgba(212,175,55,0.15); background:rgba(212,175,55,0.04); cursor:pointer; transition:.2s;">
            <div style="width:36px; height:36px; border-radius:50%; background:rgba(52,152,219,0.15); display:flex; align-items:center; justify-content:center; font-size:16px;">💙</div>
            <div>
              <div style="color:#3498db; font-weight:600; font-size:14px;">Refunded</div>
              <div style="color:var(--text-dim); font-size:11px; margin-top:2px;">Payment has been refunded</div>
            </div>
          </label>

        </div>

        <input type="hidden" name="status" id="bookingStatusSelect" />
      </div>

      <!-- Footer -->
      <div style="padding:16px 28px 24px; display:flex; gap:10px; justify-content:flex-end; border-top:1px solid rgba(212,175,55,0.1);">
        <button type="button" onclick="closeModal('modalBookingStatus')"
                style="padding:10px 22px; border-radius:8px; border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.05); color:#aaa; cursor:pointer; font-size:13px; transition:.2s;"
                onmouseover="this.style.background='rgba(255,255,255,0.1)'"
                onmouseout="this.style.background='rgba(255,255,255,0.05)'">
          Discard
        </button>
        <button type="submit"
                style="padding:10px 24px; border-radius:8px; border:none; background:linear-gradient(135deg,#c9a227,#b8860b); color:#000; font-weight:700; font-size:13px; cursor:pointer; font-family:'Cinzel',serif; letter-spacing:.5px; transition:.2s;"
                onmouseover="this.style.opacity='.85'"
                onmouseout="this.style.opacity='1'">
          Update Status
        </button>
      </div>
    </form>
  </div>
</div>

