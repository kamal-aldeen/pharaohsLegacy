@using pharaohsLegacy.Extensions

@{
    ViewData["Title"] = "Welcome";
    Layout = null;
    var lang = Context.Session.GetString("Lang") ?? "en";
    var dir = lang == "ar" ? "rtl" : "ltr";
}
<!DOCTYPE html>
<html lang="@lang" dir="@dir">
<head>
    <script>
        // لازم يشتغل هنا فوق قبل أي CSS، عشان الصفحة متفتحش بالوضع الغلط لحظة ثانية قبل ما JS يلحق يغيره
        (function () {
            var saved = localStorage.getItem('plTheme');
            if (saved === 'light') {
                document.documentElement.setAttribute('data-theme', 'light');
            }
        })();
    </script>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Pharaohs Legacy — Enter</title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Crimson+Pro:ital,wght@0,300;0,400;1,300&display=swap" rel="stylesheet" />
    <style>
        :root {
            --gold: #c9a227;
            --gold-rgb: 201,162,39;
            --gold-light: #e8c96a;
            --gold-dark: #9a7a2e;
            --dark: #0d0702;
            --dark-rgb: 13,7,2;
            --dark2: #1a0e05;
            --dark3: #2d1a08;
            --border: #3d2a15;
            --border-rgb: 61,42,21;
            --text: #e8d5b0;
            --muted: #8a7055;
            --red: #e05252;
            --red-rgb: 224,82,82;
            --red-dark: #c0392b;
            --green: #4caf80;
            --on-gold: #1a1206;
        }

        html[data-theme="light"] {
            --gold: #b8860b;
            --gold-light: #a9780f;
            --gold-dark: #8b6508;
            --gold-rgb: 184,134,11;
            --dark: #f3e8d0;
            --dark-rgb: 243,232,208;
            --dark2: #fffaf0;
            --dark3: #ece0bc;
            --border: #dcc78f;
            --border-rgb: 220,199,143;
            --text: #3b2411;
            --muted: #8a6f45;
            --red: #c0392b;
            --red-rgb: 192,57,43;
            --red-dark: #922b21;
            --green: #2e8b57;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            min-height: 100vh;
                background: var(--dark2);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Crimson Pro', serif;
            background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23c9a227' fill-opacity='0.04'%3E%3Cpath d='M30 0l30 52H0z'/%3E%3C/g%3E%3C/svg%3E");
            transition: background-color .25s ease, color .25s ease;
        }
        .auth-box {
            width: 100%;
            max-width: 420px;
            padding: 2.5rem 2rem;
            background: rgba(var(--dark-rgb), 0.85);
            border: 1px solid var(--border);
            border-radius: 8px;
            margin: 2rem;
            transition: background-color .25s ease, border-color .25s ease;
        }
        .auth-logo { text-align: center; margin-bottom: 2rem; }
        .auth-logo .eye { font-size: 3rem; display: block; margin-bottom: .5rem; }
        .auth-logo h1 {
                    font-family: 'Cinzel', serif;
                    color: var(--gold);
            font-size: 1.5rem; font-weight: 600;
            letter-spacing: 4px; text-transform: uppercase;
        }

                .auth-logo p {
                    color: var(--muted);
                    font-size: .9rem;
                    letter-spacing: 1px;
                    margin-top: .4rem;
                    font-style: italic;
                }

     
        .tabs { display: flex; margin-bottom: 1.8rem; border-bottom: 1px solid var(--border); }
        .tab {
            flex: 1; padding: .75rem; text-align: center;
            font-family: 'Cinzel', serif; font-size: .75rem;
            letter-spacing: 2px; text-transform: uppercase;
                color: var(--muted);
                cursor: pointer;
            border-bottom: 2px solid transparent; transition: all .3s;
            background: none; border-top: none; border-left: none; border-right: none;
        }

                .tab.active {
                    color: var(--gold);
                    border-bottom-color: var(--gold);
                }
        .form-section { display: none; }
        .form-section.active { display: block; }

      
        .field { margin-bottom: 1rem; position: relative; }
        .field label {
            display: block; font-family: 'Cinzel', serif; font-size: .65rem;
                    letter-spacing: 2px;
                    color: var(--muted);
            text-transform: uppercase; margin-bottom: .5rem;
        }
        .input-wrap { position: relative; }
        .field input {
                width: 100%;
                background: var(--dark);
            border: 1px solid var(--border); border-radius: 4px;
            padding: .75rem 2.5rem .75rem 1rem;
                color: var(--text);
                font-family: 'Crimson Pro', serif;
            font-size: 1rem; outline: none; transition: border-color .3s;
        }

                .field input:focus {
                    border-color: var(--gold);
                }

        .field input.input-error { border-color: var(--red-dark); }
        .field input.input-ok { border-color: var(--green); }

        
        .field-icon {
            position: absolute; right: .75rem; top: 50%;
            transform: translateY(-50%);
            font-size: 1rem; pointer-events: none;
            opacity: 0; transition: opacity .3s;
        }
        .field-icon.ok  { color: var(--green); opacity: 1; }
        .field-icon.err { color: var(--red); opacity: 1; }

        
        .toggle-pw {
            position: absolute; right: .75rem; top: 50%;
            transform: translateY(-50%);
            background: none; border: none;
                color: var(--muted);
                cursor: pointer;
                font-size: .9rem;
            padding: 0; line-height: 1;
        }
                .toggle-pw:hover {
                    color: var(--gold);
                }

      
        .val-msg { font-size: .8rem; margin-top: .35rem; font-style: italic; display: none; }
        .val-msg.error  { color: var(--red); display: block; }
        .val-msg.ok     { color: var(--green); display: block; }

        
        .strength-wrap { margin-top: .5rem; }
        .strength-bar {
            height: 4px; border-radius: 2px;
            background: var(--border); overflow: hidden;
        }
        .strength-fill {
            height: 100%; width: 0%; border-radius: 2px;
            transition: width .4s, background .4s;
        }
        .strength-label {
            font-size: .75rem; margin-top: .3rem;
                font-style: italic;
                color: var(--muted);
        }

        
        .match-msg { font-size: .8rem; margin-top: .35rem; font-style: italic; display: none; }
        .match-msg.ok  { color: var(--green); display: block; }
        .match-msg.err { color: var(--red); display: block; }

        
        .alert-error {
            background: rgba(var(--red-rgb),.15); border: 1px solid var(--red-dark);
            border-radius: 4px; padding: .75rem 1rem;
            color: var(--red); font-size: .9rem;
            margin-bottom: 1rem; font-style: italic;
        }

        
        .btn-primary {
            width: 100%; padding: .9rem;
                background: linear-gradient(135deg, var(--gold), var(--gold-dark));
                border: none;
                border-radius: 4px;
                color: var(--dark2);
            font-family: 'Cinzel', serif; font-size: .8rem;
            font-weight: 700; letter-spacing: 2px; text-transform: uppercase;
            cursor: pointer; transition: opacity .3s; margin-top: .5rem;
        }
        .btn-primary:hover { opacity: .85; }
        .btn-primary:disabled { opacity: .4; cursor: not-allowed; }

        .divider {
            text-align: center; margin: 1.2rem 0;
            color: var(--muted); font-size: .85rem; position: relative;
        }
        .divider::before, .divider::after {
            content: ''; position: absolute; top: 50%;
            width: 43%; height: 1px; background: var(--border);
        }
        .divider::before { left: 0; } .divider::after { right: 0; }

        .btn-guest {
            width: 100%; padding: .75rem; background: transparent;
            border: 1px solid var(--border); border-radius: 4px;
                color: var(--muted);
                font-family: 'Cinzel', serif;
            font-size: .7rem; letter-spacing: 2px; text-transform: uppercase;
            cursor: pointer; transition: all .3s;
            text-decoration: none; display: block; text-align: center;
        }

                .btn-guest:hover {
                    border-color: var(--muted);
                    color: var(--gold);
                }

        .guest-note { text-align: center; color: var(--muted); font-size: .8rem; margin-top: .6rem; font-style: italic; }
    </style>
</head>
<body>
    @using pharaohsLegacy.Extensions
<div class="auth-box">

        <div class="auth-logo">
            <span class="eye">&#x132C0;</span>
            <h1>Pharaohs Legacy</h1>
            <p>@Html.L("Auth_Tagline")</p>
        </div>

        <div class="tabs">
            <button class="tab active" onclick="switchTab('login', this)">@Html.L("Btn_Login")</button>
            <button class="tab" onclick="switchTab('register', this)">@Html.L("Btn_Register")</button>
        </div>


        <div id="login" class="form-section active">
            @if (ViewBag.LoginError != null)
            {
                <div class="alert-error">@ViewBag.LoginError</div>
            }
            <form method="post" action="/User/Login" id="loginForm" novalidate>
                @Html.AntiForgeryToken()

                <div class="field">
                    <label>@Html.L("Auth_Email")</label>
                    <div class="input-wrap">
                        <input type="email" id="loginEmail" name="Email" placeholder="your@email.com" />
                        <span class="field-icon" id="loginEmailIcon"></span>
                    </div>
                    <div class="val-msg" id="loginEmailMsg"></div>
                </div>

                <div class="field">
                    <label>@Html.L("Auth_Password")</label>
                    <div class="input-wrap">
                        <input type="password" id="loginPassword" name="Password" placeholder="••••••••" />
                        <button type="button" class="toggle-pw" onclick="togglePw('loginPassword', this)">👁</button>
                    </div>
                    <div class="val-msg" id="loginPasswordMsg"></div>
                </div>

                <button type="submit" class="btn-primary">@Html.L("Auth_Go")</button>
            </form>
        </div>


        <div id="register" class="form-section">
            @if (ViewBag.RegError != null)
            {
                <div class="alert-error">@ViewBag.RegError</div>
            }
            <form method="post" action="/User/Register" id="registerForm" novalidate>
                @Html.AntiForgeryToken()


                <div class="field">
                    <label>@Html.L("Auth_FullName")</label>
                    <div class="input-wrap">
                        <input type="text" id="regName" name="Name" placeholder="@Html.L("Auth_YourName")" />
                        <span class="field-icon" id="regNameIcon"></span>
                    </div>
                    <div class="val-msg" id="regNameMsg"></div>
                </div>


                <div class="field">
                    <label>@Html.L("Auth_Email")</label>
                    <div class="input-wrap">
                        <input type="email" id="regEmail" name="Email" placeholder="your@email.com" />
                        <span class="field-icon" id="regEmailIcon"></span>
                    </div>
                    <div class="val-msg" id="regEmailMsg"></div>
                </div>


                <div class="field">
                    <label>@Html.L("Auth_Password")</label>
                    <div class="input-wrap">
                        <input type="password" id="regPassword" name="Password" placeholder="@Html.L("Auth_MinChars")" />
                        <button type="button" class="toggle-pw" onclick="togglePw('regPassword', this)">👁</button>
                    </div>
                    <div class="strength-wrap">
                        <div class="strength-bar"><div class="strength-fill" id="strengthFill"></div></div>
                        <div class="strength-label" id="strengthLabel"></div>
                    </div>
                    <div class="val-msg" id="regPasswordMsg"></div>
                </div>

                <div class="field">
                    <label>@Html.L("Auth_ConfirmPassword")</label>
                    <div class="input-wrap">
                        <input type="password" id="regConfirm" name="ConfirmPassword" placeholder="@Html.L("Auth_RepeatPassword")" />
                        <button type="button" class="toggle-pw" onclick="togglePw('regConfirm', this)">👁</button>
                    </div>
                    <div class="match-msg" id="matchMsg"></div>
                </div>

                <button type="submit" class="btn-primary" id="regSubmitBtn">@Html.L("Auth_BeginJourney")</button>
            </form>
        </div>

        <div class="divider">@Html.L("Auth_Or")</div>
        <a href="/User/Guest" class="btn-guest">@Html.L("Auth_ContinueGuest")</a>
        <p class="guest-note">@Html.L("Auth_GuestNote")</p>

        @if (ViewBag.ShowRegister == true)
        {
            <input type="hidden" id="showRegister" value="true" />
        }

    </div>

<script>
    const loginI18n = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new
    {
        veryWeak = Html.L("Login_Strength_VeryWeak"),
        weak = Html.L("Login_Strength_Weak"),
        fair = Html.L("Login_Strength_Fair"),
        strong = Html.L("Login_Strength_Strong"),
        veryStrong = Html.L("Login_Strength_VeryStrong"),
        emailRequired = Html.L("Login_Val_EmailRequired"),
        emailInvalid = Html.L("Login_Val_EmailInvalid"),
        passwordRequired = Html.L("Login_Val_PasswordRequired"),
        nameRequired = Html.L("Login_Val_NameRequired"),
        nameMinLength = Html.L("Login_Val_NameMinLength"),
        looksGood = Html.L("Login_Val_LooksGood"),
        validEmail = Html.L("Login_Val_ValidEmail"),
        passwordMinLength = Html.L("Login_Val_PasswordMinLength"),
        passwordsMatch = Html.L("Login_Val_PasswordsMatch"),
        passwordsNoMatch = Html.L("Login_Val_PasswordsNoMatch")
    }));

    function switchTab(id, el) {
        document.querySelectorAll('.tab').forEach(function(t) { t.classList.remove('active'); });
        document.querySelectorAll('.form-section').forEach(function(s) { s.classList.remove('active'); });
        el.classList.add('active');
        document.getElementById(id).classList.add('active');
    }

    
    function togglePw(inputId, btn) {
        var input = document.getElementById(inputId);
        if (input.type === 'password') {
            input.type = 'text';
            btn.textContent = '🙈';
        } else {
            input.type = 'password';
            btn.textContent = '👁';
        }
    }

   
    function setOk(input, icon, msg, text) {
        input.classList.remove('input-error'); input.classList.add('input-ok');
        if (icon) { icon.textContent = '✔'; icon.className = 'field-icon ok'; }
        if (msg)  { msg.textContent = text || ''; msg.className = text ? 'val-msg ok' : 'val-msg'; }
    }
    function setErr(input, icon, msg, text) {
        input.classList.remove('input-ok'); input.classList.add('input-error');
        if (icon) { icon.textContent = '✖'; icon.className = 'field-icon err'; }
        if (msg)  { msg.textContent = text; msg.className = 'val-msg error'; }
    }
    function clearState(input, icon, msg) {
        input.classList.remove('input-ok', 'input-error');
        if (icon) { icon.className = 'field-icon'; icon.textContent = ''; }
        if (msg)  { msg.className = 'val-msg'; msg.textContent = ''; }
    }
    function isValidEmail(email) {
        return /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email);
    }


    function checkStrength(pw) {
        var score = 0;
        if (pw.length >= 6)  score++;
        if (pw.length >= 10) score++;
        if (/[A-Z]/.test(pw)) score++;
        if (/[0-9]/.test(pw)) score++;
        if (/[^A-Za-z0-9]/.test(pw)) score++;
        return score;
    }
    function updateStrengthBar(pw) {
        var fill  = document.getElementById('strengthFill');
        var label = document.getElementById('strengthLabel');
        if (!pw) { fill.style.width = '0%'; label.textContent = ''; return; }
        var score = checkStrength(pw);
        var levels = [
            { w: '20%', color: '#e74c3c', text: loginI18n.veryWeak },
            { w: '40%', color: '#e67e22', text: loginI18n.weak },
            { w: '60%', color: '#f1c40f', text: loginI18n.fair },
            { w: '80%', color: 'var(--green)', text: loginI18n.strong },
            { w: '100%',color: '#27ae60', text: loginI18n.veryStrong }
        ];
        var lvl = levels[Math.min(score - 1, 4)] || levels[0];
        fill.style.width = lvl.w;
        fill.style.background = lvl.color;
        label.textContent = lvl.text;
        label.style.color = lvl.color;
    }

    
    var lEmail   = document.getElementById('loginEmail');
    var lPw      = document.getElementById('loginPassword');
    var lEmailI  = document.getElementById('loginEmailIcon');
    var lEmailM  = document.getElementById('loginEmailMsg');
    var lPwM     = document.getElementById('loginPasswordMsg');

    lEmail.addEventListener('input', function() {
        if (!this.value) setErr(this, lEmailI, lEmailM, loginI18n.emailRequired);
        else if (!isValidEmail(this.value)) setErr(this, lEmailI, lEmailM, loginI18n.emailInvalid);
        else setOk(this, lEmailI, lEmailM);
    });
    lPw.addEventListener('input', function() {
        if (!this.value) setErr(this, null, lPwM, loginI18n.passwordRequired);
        else setOk(this, null, lPwM);
    });

    document.getElementById('loginForm').addEventListener('submit', function(e) {
        var valid = true;
        if (!lEmail.value || !isValidEmail(lEmail.value)) {
            setErr(lEmail, lEmailI, lEmailM, !lEmail.value ? loginI18n.emailRequired : loginI18n.emailInvalid);
            valid = false;
        }
        if (!lPw.value) { setErr(lPw, null, lPwM, loginI18n.passwordRequired); valid = false; }
        if (!valid) e.preventDefault();
    });

    
    var rName    = document.getElementById('regName');
    var rEmail   = document.getElementById('regEmail');
    var rPw      = document.getElementById('regPassword');
    var rConfirm = document.getElementById('regConfirm');
    var rNameI   = document.getElementById('regNameIcon');
    var rEmailI  = document.getElementById('regEmailIcon');
    var rNameM   = document.getElementById('regNameMsg');
    var rEmailM  = document.getElementById('regEmailMsg');
    var rPwM     = document.getElementById('regPasswordMsg');
    var matchMsg = document.getElementById('matchMsg');

    rName.addEventListener('input', function() {
        if (!this.value) setErr(this, rNameI, rNameM, loginI18n.nameRequired);
        else if (this.value.length < 3) setErr(this, rNameI, rNameM, loginI18n.nameMinLength);
        else setOk(this, rNameI, rNameM, loginI18n.looksGood);
    });

    rEmail.addEventListener('input', function() {
        if (!this.value) setErr(this, rEmailI, rEmailM, loginI18n.emailRequired);
        else if (!isValidEmail(this.value)) setErr(this, rEmailI, rEmailM, loginI18n.emailInvalid);
        else setOk(this, rEmailI, rEmailM, loginI18n.validEmail);
    });

    rPw.addEventListener('input', function() {
        updateStrengthBar(this.value);
        if (!this.value) setErr(this, null, rPwM, loginI18n.passwordRequired);
        else if (this.value.length < 6) setErr(this, null, rPwM, loginI18n.passwordMinLength);
        else setOk(this, null, rPwM);
        
        if (rConfirm.value) checkConfirm();
    });

    function checkConfirm() {
        if (!rConfirm.value) {
            rConfirm.classList.remove('input-ok', 'input-error');
            matchMsg.className = 'match-msg';
            return false;
        }
        if (rConfirm.value === rPw.value) {
            rConfirm.classList.add('input-ok'); rConfirm.classList.remove('input-error');
            matchMsg.textContent = '✔ ' + loginI18n.passwordsMatch;
            matchMsg.className = 'match-msg ok';
            return true;
        } else {
            rConfirm.classList.add('input-error'); rConfirm.classList.remove('input-ok');
            matchMsg.textContent = '✖ ' + loginI18n.passwordsNoMatch;
            matchMsg.className = 'match-msg err';
            return false;
        }
    }
    rConfirm.addEventListener('input', checkConfirm);

    document.getElementById('registerForm').addEventListener('submit', function(e) {
        var valid = true;
        if (!rName.value || rName.value.length < 3) {
            setErr(rName, rNameI, rNameM, !rName.value ? loginI18n.nameRequired : loginI18n.nameMinLength);
            valid = false;
        }
        if (!rEmail.value || !isValidEmail(rEmail.value)) {
            setErr(rEmail, rEmailI, rEmailM, !rEmail.value ? loginI18n.emailRequired : loginI18n.emailInvalid);
            valid = false;
        }
        if (!rPw.value || rPw.value.length < 6) {
            setErr(rPw, null, rPwM, !rPw.value ? loginI18n.passwordRequired : loginI18n.passwordMinLength);
            valid = false;
        }
        if (!checkConfirm()) valid = false;
        if (!valid) e.preventDefault();
    });

  
    window.onload = function() {
        var flag = document.getElementById('showRegister');
        if (flag) document.querySelectorAll('.tab')[1].click();
    };
</script>
</body>
</html>
