@using pharaohsLegacy.Extensions

@{
    ViewData["Title"] = "Museums";
    var egyptian = ViewBag.Egyptian as List<pharaohsLegacy.Models.Museum>;
    var lang = Context.Session.GetString("Lang") ?? "en";
    var arrowNext = lang == "ar" ? "←" : "→";
}

@section Styles {
<style>
.pg-hero {
    text-align: center; padding: 4rem 2rem 3rem;
    position: relative; overflow: hidden;
}
.pg-hero::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse 70% 60% at 50% 0%, rgba(var(--gold-rgb),.1) 0%, transparent 70%);
    pointer-events: none;
}
.pg-hero-symbol { font-size: 3rem; display: block; margin-bottom: 1rem; animation: floatSym 3s ease-in-out infinite; }
@@keyframes floatSym { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-8px); } }
.pg-hero h1 { font-family: 'Cinzel', serif; font-size: clamp(2rem, 5vw, 3.5rem); color: var(--text); margin-bottom: .75rem; font-weight: 700; letter-spacing: 2px; }
.pg-hero h1 span { color: var(--gold); }
.pg-hero p { color: var(--muted); font-size: 1.1rem; font-style: italic; max-width: 500px; margin: 0 auto 2rem; }
.pg-divider { width: 120px; height: 1px; background: linear-gradient(90deg, transparent, var(--gold), transparent); margin: 0 auto; }

.pg-search-wrap { max-width: 480px; margin: 2rem auto 0; position: relative; }
        .pg-search {
            width: 100%;
            background: rgba(var(--gold-rgb),.05);
            border: 1px solid var(--border);
            border-radius: 50px;
            padding-block: .85rem;
            padding-inline: 3rem 1.5rem;
            color: var(--text);
            font-family: 'Crimson Pro', serif;
            font-size: 1rem;
            outline: none;
            transition: border-color .3s;
        }
.pg-search:focus { border-color: var(--gold); }
.pg-search::placeholder { color: var(--muted); }
.pg-search-icon { position: absolute; inset-inline-start: 1.1rem; top: 50%; transform: translateY(-50%); color: var(--muted); pointer-events: none; }

.pg-count { text-align: center; font-family: 'Cinzel', serif; font-size: .65rem; letter-spacing: 3px; text-transform: uppercase; color: var(--muted); margin: 2rem 0 .5rem; }

.pg-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; max-width: 1200px; margin: 0 auto; padding: 0 2rem 4rem; }

        .pg-card {
            background: var(--dark3);
            border: 1px solid var(--border);
            border-radius: 12px;
            overflow: hidden;
            text-decoration: none;
            color: inherit;
            display: block;
            position: relative;
            opacity: 0;
            transform: translateY(20px);
            transition: border-color .3s, box-shadow .3s, transform .3s;
        }
.pg-card.visible { opacity: 1; transform: translateY(0); }
.pg-card:hover { transform: translateY(-6px); border-color: var(--gold); box-shadow: 0 12px 40px rgba(var(--gold-rgb),.15); }

        .pg-card-img {
            position: relative;
            height: 220px;
            overflow: hidden;
            background: var(--dark2);
        }
.pg-card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform .5s; }
.pg-card:hover .pg-card-img img { transform: scale(1.08); }
.pg-card-img-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(13,7,2,.85) 0%, transparent 50%); }

.pg-card-location { position: absolute; bottom: 12px; left: 12px; background: rgba(13,7,2,.75); backdrop-filter: blur(4px); border: 1px solid rgba(var(--gold-rgb),.3); border-radius: 20px; padding: 4px 12px; font-family: 'Cinzel', serif; font-size: .6rem; letter-spacing: 1px; color: var(--gold); }
.pg-card-ticket { position: absolute; top: 12px; right: 12px; background: rgba(var(--gold-rgb),.15); backdrop-filter: blur(4px); border: 1px solid rgba(var(--gold-rgb),.3); border-radius: 20px; padding: 4px 10px; font-size: .7rem; color: var(--gold); }

.pg-card-body { padding: 1.25rem; }
.pg-card-tag { font-family: 'Cinzel', serif; font-size: .6rem; letter-spacing: 2px; text-transform: uppercase; color: var(--gold); margin-bottom: .4rem; display: block; }
.pg-card-name { font-family: 'Cinzel', serif; font-size: 1.1rem; color: var(--text); margin-bottom: .4rem; font-weight: 600; }
.pg-card-desc { color: var(--muted); font-size: .9rem; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

        .pg-card-footer {
            padding: .75rem 1.25rem;
            border-top: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
.pg-card-footer span { font-size: .8rem; color: var(--muted); font-style: italic; }
.pg-card-arrow { color: var(--gold); }

.pg-empty { text-align: center; padding: 4rem 2rem; color: var(--muted); display: none; }
.pg-empty-icon { font-size: 3rem; margin-bottom: 1rem; }
.pg-empty-text { font-family: 'Cinzel', serif; font-size: 1rem; }

@@media (max-width: 768px) {
    .pg-grid { padding: 0 1rem 3rem; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); }
}
</style>
}

<div class="pg-hero">
    <span class="pg-hero-symbol">🏛️</span>
    <h1>@Html.L("Museum_Hero_Title") <span>@Html.L("Museum_Hero_Subtitle_Span")</span></h1>
    <p>@Html.L("Museum_Hero_Subtitle")</p>
    <div class="pg-divider"></div>
    <div class="pg-search-wrap">
        <span class="pg-search-icon">🔍</span>
        <input class="pg-search" type="text" placeholder="@Html.L("Museum_Search_Placeholder")"
               oninput="filterCards(this.value)" />
    </div>
</div>

<div class="pg-count" id="pgCount" data-unit="@Html.L("Museum_Count_Label")">@Html.Digits(egyptian?.Count ?? 0) @Html.L("Museum_Count_Label")</div>

<div class="pg-grid" id="pgGrid">
    @foreach (var m in egyptian ?? new List<pharaohsLegacy.Models.Museum>())
    {
        var mName = (lang == "ar" && !string.IsNullOrEmpty(m.NameAr)) ? m.NameAr : m.Name;
        var mLocation = (lang == "ar" && !string.IsNullOrEmpty(m.LocationAr)) ? m.LocationAr : m.Location;
        var mDescription = (lang == "ar" && !string.IsNullOrEmpty(m.DescriptionAr)) ? m.DescriptionAr : m.Description;
        var mCategory = (lang == "ar" && !string.IsNullOrEmpty(m.CategoryAr)) ? m.CategoryAr : m.Category;
        var mSearchName = $"{m.Name} {m.NameAr}".ToLower();
        var mSearchSub = $"{m.Location} {m.LocationAr}".ToLower();
        <a href="/Museum/Details/@m.Id" class="pg-card"
           data-name="@mSearchName" data-sub="@mSearchSub">
            <div class="pg-card-img">
                <img src="@m.ImageUrl" alt="@mName"
                     onerror="this.src='https://via.placeholder.com/400x300/2d1a08/c9a227?text=@mName'" />
                <div class="pg-card-img-overlay"></div>
                <span class="pg-card-location">📍 @mLocation</span>
                <span class="pg-card-ticket">🎟 @Html.Digits(100) @Html.L("Common_EGP")</span>
            </div>
            <div class="pg-card-body">
                <span class="pg-card-tag">🏛️ @mCategory</span>
                <div class="pg-card-name">@mName</div>
                <div class="pg-card-desc">@mDescription</div>
            </div>
            <div class="pg-card-footer">
                <span>@Html.L("Museum_Est_Label") @Html.Digits(m.Founded)</span>
                <span class="pg-card-arrow">@arrowNext</span>
            </div>
        </a>
    }
</div>

<div class="pg-empty" id="pgEmpty">
    <div class="pg-empty-icon">🏛️</div>
    <div class="pg-empty-text">@Html.L("Museum_Empty_Text")</div>
</div>

@section Scripts {
<script>
var currentLang = '@lang';
var arabicDigitsMap = ['٠', '١', '٢', '٣', '٤', '٥', '٦', '٧', '٨', '٩'];
function toLocalDigits(input) {
    var str = String(input);
    if (currentLang !== 'ar') return str;
    return str.replace(/[0-9]/g, function (d) { return arabicDigitsMap[+d]; });
}

const pgCards = document.querySelectorAll('.pg-card');
const obs = new IntersectionObserver((entries) => {
    entries.forEach((e, i) => {
        if (e.isIntersecting) {
            setTimeout(() => e.target.classList.add('visible'), i * 60);
            obs.unobserve(e.target);
        }
    });
}, { threshold: 0.1 });
pgCards.forEach(c => obs.observe(c));

function filterCards(q) {
    q = q.toLowerCase();
    let visible = 0;
    pgCards.forEach(card => {
        const match = card.dataset.name.includes(q) || card.dataset.sub.includes(q);
        card.style.display = match ? '' : 'none';
        if (match) visible++;
    });
    const pgCountEl = document.getElementById('pgCount');
    pgCountEl.textContent = toLocalDigits(visible) + ' ' + pgCountEl.dataset.unit;
    document.getElementById('pgEmpty').style.display = visible === 0 ? 'block' : 'none';
}
</script>
}
