@using pharaohsLegacy.Extensions
@{
    var currentLang = Context.Session.GetString("Lang") ?? "en";
    var currentDir = currentLang == "ar" ? "rtl" : "ltr";
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
}
<!DOCTYPE html>
<html lang="@currentLang" dir="@currentDir">
<head>
    <script>
        // لازم يشتغل هنا فوق قبل أي CSS، عشان الصفحة متفتحش بالوضع الغلط لحظة ثانية قبل ما JS يلحق يغيره
        (function () {
            var saved = localStorage.getItem('plTheme');
            if (saved === 'light') {
                document.documentElement.setAttribute('data-theme', 'light');
            }
        })();
    </script>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Pharaohs Legacy</title>

    @{
        var pageDescription = ViewData["Description"] as string
            ?? (currentLang == "ar"
                ? "استكشف تاريخ مصر القديمة: الفراعنة، الآلهة، المعابد، المتاحف، والقطع الأثرية في منصة تفاعلية متكاملة."
                : "Explore ancient Egypt: pharaohs, gods, temples, museums, and artifacts on one interactive platform.");
    }
    <meta name="description" content="@pageDescription" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Pharaohs Legacy" />
    <meta property="og:title" content="@ViewData["Title"] - Pharaohs Legacy" />
    <meta property="og:description" content="@pageDescription" />
    <meta property="og:image" content="@Url.Content("~/images/og-cover.jpg")" />
    <meta property="og:locale" content="@(currentLang == "ar" ? "ar_EG" : "en_US")" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@ViewData["Title"] - Pharaohs Legacy" />
    <meta name="twitter:description" content="@pageDescription" />

    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' fill='%230d0702'/%3E%3Ctext x='50' y='68' font-size='60' text-anchor='middle' fill='%23c9a227'%3E%F0%93%82%80%3C/text%3E%3C/svg%3E" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Crimson+Pro:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Noto+Sans+Egyptian+Hieroglyphs&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/pharaoh.css" asp-append-version="true" />
    <style>
        :root {
            --gold: #c9a227;
            --gold-rgb: 201,162,39;
                --gold-light: #e8c96a;
                --gold-dark: #9a7a2e;
            --dark: #0d0702;
            --dark-rgb: 13,7,2;
            --dark2: #1a0e05;
            --dark3: #2d1a08;
            --border: #3d2a15;
            --border-rgb: 61,42,21;
            --text: #e8d5b0;
            --muted: #8a7055;
            --surface-tint: rgba(255,255,255,0.04);
            --surface-tint-strong: rgba(255,255,255,0.06);
            --well-bg: rgba(0,0,0,0.3);
            --card-shadow: none;
            --card-shadow-hover: none;

            /* Semantic status colors — shared across all pages (Dashboard, badges, alerts...) */
            --red: #e05252;
            --red-rgb: 224,82,82;
            --red-dark: #c0392b;
            --green: #4caf80;
            --green-rgb: 76,175,128;
            --blue: #5b8dd9;
            --blue-rgb: 91,141,217;
            --purple: #a78bfa;
            --purple-rgb: 167,139,250;
            /* Text placed directly on a gold surface (buttons, badges) — stays near-black in both themes for contrast */
            --on-gold: #1a1206;
        }

        /* ── Light Mode Overrides ── (Phase 1: Navbar + Footer + AI Widget only) */
        html[data-theme="light"] {
            --gold: #b8860b;
            --gold-light: #a9780f;
             --gold-dark: #8b6508;
            --gold-rgb: 184,134,11;
            --dark: #f3e8d0;
            --dark-rgb: 243,232,208;
            --dark2: #fffaf0;
            --dark3: #ece0bc;
            --border: #dcc78f;
            --border-rgb: 220,199,143;
            --text: #3b2411;
            --muted: #8a6f45;
            --surface-tint: rgba(0,0,0,0.035);
            --surface-tint-strong: rgba(0,0,0,0.06);
            --well-bg: rgba(0,0,0,0.045);
            --card-shadow: 0 2px 14px rgba(59,36,17,.06);
            --card-shadow-hover: 0 10px 28px rgba(59,36,17,.12);

            --red: #c0392b;
            --red-rgb: 192,57,43;
            --red-dark: #922b21;
            --green: #2e8b57;
            --green-rgb: 46,139,87;
            --blue: #2f6fb8;
            --blue-rgb: 47,111,184;
            --purple: #7c5cd6;
            --purple-rgb: 124,92,214;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }

        /* 🆕 في وضع اللايت، --border و--dark3 قريبين جدًا من لون خلفية الصفحة
           (كلهم كريمي)، فعناصر شريط الأدوات (بحث/لغة/ثيم/خروج) كانت بتدوب في
           الخلفية بدل ما تبان كصناديق واضحة. هنا بنديهم خلفية بيضاء وحدود بنية
           أوضح — في وضع اللايت بس، الدارك مود مش متأثر خالص */
        html[data-theme="light"] .nav-search,
        html[data-theme="light"] .nav-logout,
        html[data-theme="light"] .lang-switch,
        html[data-theme="light"] .theme-toggle {
            background: #ffffff;
            border-color: rgba(59,36,17,.22);
            box-shadow: 0 1px 3px rgba(59,36,17,.12);
        }
        /* ── Theme Toggle: Circle Reveal Animation ──
           بنلغي الـ cross-fade الافتراضي بتاع الـ View Transitions API
           عشان الدايرة الذهبية اللي بنعملها بالـ JS تبان بوضوح من غير
           أي fade تاني فوقها */
        ::view-transition-old(root),
        ::view-transition-new(root) {
            animation: none;
            mix-blend-mode: normal;
        }

        /* ── Dark/Light Mode: انتقال ناعم للألوان في كل الموقع ──
           عام على كل عنصر عشان الكروت والحدود في أي صفحة تتحول بنعومة
           من غير ما نضيف transition يدوي في كل ملف View لوحده.
           مش شامل transform عشان مايتعارضش مع الـ hover transitions
           الموجودة أصلاً (زي .theme-toggle, .btn-explore...) */
        html { scroll-behavior: smooth; }
        body {
                background-color: var(--dark);
                background-image:
                    repeating-linear-gradient(0deg, rgba(var(--gold-rgb),0.02) 0px, transparent 1px, transparent 3px),
                    repeating-linear-gradient(90deg, rgba(var(--gold-rgb),0.015) 0px, transparent 1px, transparent 4px);
            color: var(--text);
            font-family: 'Crimson Pro', serif;
            overflow-x: hidden;
        }

       
        /* 🆕 Navbar بقى صف واحد بس — اللوجو + اللينكات + شريط الأدوات (بحث/سلة/لغة/ثيم/خروج)
           كلهم جنب بعض بنفس الارتفاع، بدل صفين منفصلين بصريًا زي الأول */
        nav.main-nav {
            position: fixed; top: 0; left: 0; right: 0; z-index: 100;
            display: flex; flex-direction: column;
            background: rgba(var(--dark-rgb),0.9);
            backdrop-filter: blur(10px);
                border-bottom: 1px solid var(--border);
            transition: background .25s ease, border-color .25s ease, box-shadow .3s ease;
        }
        nav.main-nav.pl-scrolled {
            box-shadow: 0 4px 20px rgba(var(--dark-rgb),.3);
            background: rgba(var(--dark-rgb),0.97);
        }

        .nav-row-main {
            display: flex; align-items: center; gap: 1.8rem;
            padding: .7rem 2.2rem;
            transition: padding .3s ease;
        }
        .pl-scrolled .nav-row-main {
            padding: .5rem 2.2rem;
        }

        .nav-logo {
            text-decoration: none;
            display: flex; align-items: center; gap: .75rem;
            flex-shrink: 0;
        }
        .nav-logo-icon { font-size: 1.3rem; color: var(--gold); }
        .nav-logo-text { display: flex; flex-direction: column; line-height: 1.15; }
        .nav-logo-title {
            font-family: 'Cinzel', serif;
            color: var(--gold); font-size: 1.1rem;
            letter-spacing: 3px; text-transform: uppercase;
        }
        .nav-logo-tagline {
            font-family: 'Crimson Pro', serif;
            color: var(--muted); font-size: .68rem;
            letter-spacing: .5px; margin-top: 2px;
        }
        .nav-links {
            display: flex; align-items: center; justify-content: flex-start;
            flex: 1; min-width: 0;
            gap: 1.5rem; list-style: none;
        }
        /* 🆕 أيقونات SVG — بدل الإيموجي في كل عناصر الناف بار */
        .nav-ic {
            width: 15px; height: 15px; flex-shrink: 0;
            fill: none; stroke: currentColor; stroke-width: 1.8;
            stroke-linecap: round; stroke-linejoin: round;
        }
        .nav-ic-sm { width: 13px; height: 13px; }
        .nav-caret {
            width: 9px; height: 9px; margin-inline-start: 2px;
            transition: transform .25s ease;
        }
        .nav-dropdown-toggle[aria-expanded="true"] .nav-caret { transform: rotate(180deg); }
        .nav-links a {
            font-family: 'Cinzel', serif; font-size: .68rem;
            letter-spacing: 1.6px; text-transform: uppercase;
            color: var(--muted); text-decoration: none;
            position: relative; padding-bottom: 4px;
            white-space: nowrap;
            transition: color .3s;
        }
        .nav-links a::after {
            content: '';
            position: absolute; bottom: 0; inset-inline-start: 0;
            width: 0%; height: 1px;
            background: var(--gold);
            transition: width .3s ease;
        }
        .nav-links a:hover::after,
        .nav-links a.active::after {
            width: 100%;
        }
        .nav-links a.active {
            color: var(--gold);
        }

                .nav-links li {
                    display: flex;
                    align-items: center;
                }

        /* 🆕 لينك الداشبورد — كان عايم من غير كلاس ولا حاوية بين اللوجو واللينكات
           (السبب الرئيسي في اختلال الصف). دلوقتي جوه <ul> زي باقي اللينكات
           بالظبط، ومفصول عنهم بخط رفيع عشان يبان إنه "حسابي" مش صفحة محتوى */
        .nav-dashboard-item {
            padding-inline-end: 1.3rem;
            margin-inline-end: .3rem;
            border-inline-end: 1px solid var(--border);
        }
        .nav-dashboard-link {
            display: flex !important; align-items: center; gap: .5rem;
            color: var(--gold-light) !important;
        }
        .nav-dashboard-link::after { background: var(--gold-light) !important; }
        .nav-dashboard-avatar {
            width: 24px; height: 24px; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            background: rgba(var(--gold-rgb),.12);
            border: 1px solid rgba(var(--gold-rgb),.4);
            flex-shrink: 0;
        }
        .nav-dashboard-avatar .nav-ic { width: 13px; height: 13px; }

        .nav-links a:hover { color: var(--gold); }
        .nav-search {
            display: flex; align-items: center; gap: .5rem;
                background: var(--dark3);
                border: 1px solid var(--border);
            border-radius: 4px; padding: .3rem .8rem;
            box-shadow: var(--card-shadow);
        }
        .nav-search input {
            background: none; border: none; outline: none;
            color: var(--text); font-family: 'Crimson Pro', serif;
            font-size: .85rem; width: 90px;
        }
        .nav-search input::placeholder { color: var(--muted); }
        .nav-search button {
            background: none; border: none; display: flex; align-items: center;
            color: var(--muted); cursor: pointer;
            transition: color .3s;
        }
        .nav-search button:hover { color: var(--gold); }

        /* 🆕 السلة — أيقونة في الـ nav */
        .nav-cart-link {
            position: relative;
            display: inline-flex; align-items: center;
            color: var(--muted); text-decoration: none;
            transition: color .3s;
        }
        .nav-cart-link:hover { color: var(--gold); }
        .nav-cart-badge {
            position: absolute; top: -7px; inset-inline-end: -9px;
            background: var(--gold); color: #1a0a00;
            font-size: .6rem; font-weight: 700;
            border-radius: 999px; min-width: 15px; height: 15px;
            display: inline-flex; align-items: center; justify-content: center;
            padding: 0 3px; font-family: 'Cinzel', serif;
        }

        .nav-logout {
            font-family: 'Cinzel', serif; font-size: .6rem;
            letter-spacing: 1.8px; text-transform: uppercase;
            color: var(--muted); text-decoration: none;
                border: 1px solid var(--border);
                border-radius: 4px;
            display: inline-flex; align-items: center; gap: .35rem;
            padding: .3rem .7rem; transition: all .3s;
            white-space: nowrap;
            box-shadow: var(--card-shadow);
        }
        .nav-logout:hover { border-color: #e74c3c; color: #e74c3c; }

        /* 🆕 حاوية شريط الأدوات — بحث/سلة/لغة/ثيم/دخول-خروج، كلهم دلوقتي
           في نفس صف اللينكات، متجمعين آخر الصف */
        .nav-utils {
            display: flex; align-items: center; gap: 1rem;
            flex-shrink: 0;
        }

        /* 🆕 فاصل رفيع بين لينكات الصفحات (Home/Explore/More/Shop/Quiz) وشريط
           الأدوات (بحث/سلة/لغة/ثيم/خروج) — بيوضح إنهم مجموعتين مختلفتين من
           غير ما نكسر الصف لصفين */
        .nav-group-divider {
            width: 1px; align-self: stretch; margin: .2rem .4rem;
            background: var(--border); flex-shrink: 0;
        }
        @@media (max-width: 1100px) {
            .nav-group-divider { display: none; }
        }

        .lang-switch {
            position: relative;
            display: inline-grid;
            grid-template-columns: 1fr 1fr;
            background: rgba(var(--gold-rgb),.06);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 3px;
            box-shadow: var(--card-shadow);
        }
        .lang-switch-indicator {
            position: absolute;
            top: 3px; bottom: 3px;
            width: calc(50% - 3px);
            border-radius: 16px;
            background: linear-gradient(135deg, #c9a227, #a07a1a);
            box-shadow: 0 2px 10px rgba(201,162,39,.35);
            transition: inset-inline-start .35s cubic-bezier(.4,0,.2,1);
            z-index: 0;
        }
        .lang-switch form { display: contents; }
        .lang-switch-btn {
            position: relative;
            z-index: 1;
            background: transparent;
            border: none;
            font-family: 'Cinzel', serif;
            font-size: .62rem;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--muted);
            cursor: pointer;
            padding: .32rem .8rem;
            border-radius: 16px;
            transition: color .3s ease;
        }
        .lang-switch-btn.active { color: #0d0702; font-weight: 600; }
        .lang-switch-btn:not(.active):hover { color: var(--gold); }

       
        .nav-toggle {
            display: none; flex-direction: column; gap: 5px;
            background: none; border: none; cursor: pointer; padding: .5rem;
            margin-inline-start: auto;
        }
        .nav-toggle span {
            display: block; width: 22px; height: 2px;
            background: var(--muted); border-radius: 2px; transition: all .3s;
        }
        /* ── Theme Toggle: Pill Switch (زي شكل EN/AR جنبه بالظبط) ──
           أيقونتين ثابتتين (شمس = فاتح، لوتس = غامق) + دائرة ذهبية بتزحلق
           بين الاتنين، عشان يبقى واضح بصرياً إنه سويتش بين وضعين مش زرار عادي */
        .theme-toggle {
            position: relative;
            background: rgba(var(--gold-rgb),.06);
            border: 1px solid var(--border);
            border-radius: 20px;
            cursor: pointer;
            width: 48px; height: 24px;
            padding: 0;
            display: flex; align-items: center; justify-content: space-between;
            box-shadow: var(--card-shadow);
            transition: border-color .25s ease, box-shadow .25s ease;
        }
        .theme-toggle:hover {
            border-color: var(--gold-light);
            box-shadow: 0 0 10px rgba(var(--gold-rgb),.2);
        }
        .theme-toggle:focus-visible {
            outline: none;
            box-shadow: 0 0 0 3px rgba(var(--gold-rgb),.25);
        }
        .theme-toggle-icon {
            position: relative; z-index: 1;
            display: flex; width: 13px; height: 13px;
            margin: 0 5px;
            opacity: .45;
            transition: opacity .2s ease;
        }
        html[data-theme="light"] .theme-toggle-icon.theme-toggle-sun { opacity: 1; }
        html:not([data-theme="light"]) .theme-toggle-icon.theme-toggle-lotus { opacity: 1; }
        .theme-toggle-thumb {
            position: absolute;
            top: 2px;
            inset-inline-start: calc(100% - 22px); /* افتراضي: وضع غامق → الدائرة عند اللوتس */
            width: 20px; height: 20px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--gold), var(--gold-dark));
            box-shadow: 0 2px 8px rgba(var(--gold-rgb),.4);
            transition: inset-inline-start .25s cubic-bezier(.4,0,.2,1);
            z-index: 0;
        }
        html[data-theme="light"] .theme-toggle-thumb {
            inset-inline-start: 2px; /* وضع فاتح → الدائرة عند الشمس */
        }


        
        .main-content { padding-top: 66px; min-height: 100vh; }

        
        .hero {
            min-height: 100vh;
            display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            text-align: center; position: relative; overflow: hidden;
            padding: 6rem 2rem 4rem;
        }
        .hero-bg {
            position: absolute; inset: 0;
            background:
                radial-gradient(ellipse at 50% 0%, rgba(var(--gold-rgb),.15) 0%, transparent 60%),
                linear-gradient(180deg, var(--dark) 0%, var(--dark2) 50%, var(--dark) 100%);
        }
        .hero-pyramid {
            position: absolute; bottom: 0; left: 50%; transform: translateX(-50%);
            width: 0; height: 0;
            border-left: 400px solid transparent;
            border-right: 400px solid transparent;
            border-bottom: 280px solid rgba(var(--gold-rgb),.04);
            pointer-events: none;
        }
        .hero-pattern {
            position: absolute; left: 0; right: 0;
            font-size: 1.2rem; letter-spacing: 1.5rem;
            color: rgba(var(--gold-rgb),.08);
            white-space: nowrap; overflow: hidden; pointer-events: none;
        }
        .hero-pattern.top { top: 5rem; }
        .hero-pattern.bottom { bottom: 2rem; }
        .hero-content { position: relative; z-index: 1; max-width: 700px; }
        .hero-eyebrow {
            font-family: 'Cinzel', serif; font-size: .7rem;
            letter-spacing: 5px; text-transform: uppercase;
            color: var(--gold); margin-bottom: 1.5rem;
            display: flex; align-items: center; gap: 1rem; justify-content: center;
        }
        .hero-eyebrow::before, .hero-eyebrow::after {
            content: ''; width: 60px; height: 1px; background: var(--gold); opacity: .5;
        }
        .hero-title {
            font-family: 'Cinzel', serif;
            font-size: clamp(2.5rem, 6vw, 5rem);
            font-weight: 700; line-height: 1.1;
            color: var(--text); margin-bottom: 1.5rem;
        }
        .hero-title span { color: var(--gold); }
        .hero-subtitle {
            font-size: 1.2rem; color: var(--muted);
            line-height: 1.7; margin-bottom: 2.5rem; font-style: italic;
        }
        .hero-cta { display: inline-flex; gap: 1rem; flex-wrap: wrap; justify-content: center; }
        .hero-scroll {
            position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%);
            display: flex; flex-direction: column; align-items: center; gap: .5rem;
            color: var(--muted); font-size: .65rem; letter-spacing: 3px;
            text-transform: uppercase; font-family: 'Cinzel', serif;
            animation: bounce 2s infinite;
        }
        .hero-scroll::after { content: '▼'; font-size: .8rem; }
        @@keyframes bounce {
            0%,100%{ transform:translateX(-50%) translateY(0); }
            50%{ transform:translateX(-50%) translateY(6px); }
        }

       
        .stats-bar {
            display: flex; justify-content: center;
                background: var(--dark3);
            border-top: 1px solid var(--border);
                border-bottom: 1px solid var(--border);
            padding: 1.5rem 3rem; gap: 4rem; flex-wrap: wrap;
        }
        .stat { text-align: center; }
        .stat-num {
            font-family: 'Cinzel', serif; font-size: 1.8rem;
            color: var(--gold); font-weight: 700; display: block;
        }
        .stat-label {
            font-size: .7rem; letter-spacing: 2px; text-transform: uppercase;
            color: var(--muted); font-family: 'Cinzel', serif;
        }

        
        .section { padding: 5rem 3rem; max-width: 1200px; margin: 0 auto; }
        .section-header { text-align: center; margin-bottom: 3rem; }
        .section-tag {
            font-family: 'Cinzel', serif; font-size: .65rem;
            letter-spacing: 4px; text-transform: uppercase;
            color: var(--gold); margin-bottom: .75rem; display: block;
        }
        .section-tag::before { content: '𓋹  '; }
        .section-title {
            font-family: 'Cinzel', serif; font-size: 2rem;
            font-weight: 600; color: var(--text); margin-bottom: 1rem;
        }
        .section-line {
            width: 60px; height: 2px;
            background: linear-gradient(90deg, transparent, var(--gold), transparent);
            margin: 0 auto;
        }

        
        .daily-fact-section { padding: 3rem 3rem; }
        .daily-fact-card {
            background: var(--dark3);
            border: 1px solid var(--border);
            border-radius: 14px;
            box-shadow: var(--card-shadow);
            max-width: 780px;
            margin: 0 auto;
            padding: 2.2rem 2.5rem;
            text-align: center;
            position: relative;
            transition: box-shadow .35s ease, border-color .35s ease,
                        opacity .6s ease, transform .6s ease;
        }
        /* Scroll Reveal — الحالة الابتدائية (مخفي شوية ومتنزل)، وبعدين .is-visible بيرجعه لمكانه */
        .daily-fact-card.reveal-on-scroll {
            opacity: 0;
            transform: translateY(24px);
        }
        .daily-fact-card.reveal-on-scroll.is-visible {
            opacity: 1;
            transform: translateY(0);
        }
        /* توهج ذهبي خفيف عند الـ Hover — نفس لمسة .btn-gold (شادو مستقل، مش متجمّع مع --card-shadow-hover
           عشان دي بتبقى none في الدارك مود، ودمج none مع شادو تاني بيبطل الـ box-shadow كله) */
        .daily-fact-card:hover {
            border-color: var(--gold);
            box-shadow: 0 0 22px rgba(var(--gold-rgb), .18);
        }
        .daily-fact-icon {
            display: inline-block; font-size: 1.8rem; color: var(--gold);
            margin-bottom: .5rem;
            animation: dailyFactPulse 3.2s ease-in-out infinite;
        }
        @@keyframes dailyFactPulse {
            0%, 100% { transform: scale(1); opacity: 1; }
            50%      { transform: scale(1.12); opacity: .82; }
        }
        @@media (prefers-reduced-motion: reduce) {
            .daily-fact-icon { animation: none; }
            .daily-fact-card.reveal-on-scroll {
                transition: none; opacity: 1; transform: none;
            }
        }
        .daily-fact-tag { display: block; margin-bottom: 0; }
        .daily-fact-tag::before { content: none; }
        .daily-fact-meta {
            display: flex; align-items: center; justify-content: center;
            gap: 10px; flex-wrap: wrap;
        }
        .daily-fact-category {
            font-family: 'Cinzel', serif; font-size: .58rem;
            letter-spacing: 1.5px; text-transform: uppercase;
            color: var(--gold); border: 1px solid var(--border);
            border-radius: 20px; padding: 3px 12px;
        }
        .daily-fact-text {
            font-size: 1.05rem; line-height: 1.9; color: var(--text);
            margin-top: .75rem;
            transition: opacity .25s ease;
        }
        .daily-fact-text.is-fading { opacity: 0; }
        /* زرار النسخ — أيقونة شفافة صغيرة في الركن، بتبان واضحة عند الـ hover بس، من غير ما تاخد سطر لوحدها */
        .daily-fact-actions {
            position: absolute;
            top: 16px;
            inset-inline-end: 16px;
            display: flex;
            align-items: center;
            gap: 4px;
        }
        .daily-fact-copy-btn {
            background: transparent;
            border: 1px solid transparent;
            color: var(--muted);
            border-radius: 7px;
            width: 28px; height: 28px;
            font-size: .8rem;
            cursor: pointer;
            display: inline-flex; align-items: center; justify-content: center;
            opacity: .55;
            transition: opacity .2s ease, color .2s ease, border-color .2s ease,
                        background .2s ease, transform .15s ease;
        }
        .daily-fact-copy-btn:hover {
            opacity: 1;
            color: var(--gold);
            border-color: var(--border);
            background: var(--surface-tint);
        }
        .daily-fact-copy-btn:active { transform: scale(.88); }
        .daily-fact-copy-btn.is-copied {
            opacity: 1;
            color: var(--gold);
            border-color: var(--gold);
            background: rgba(var(--gold-rgb), .1);
        }
        .daily-fact-copy-icon { display: block; }
        .daily-fact-shuffle-btn.is-loading .daily-fact-shuffle-icon {
            animation: dailyFactSpin .6s linear infinite;
        }
        @@keyframes dailyFactSpin {
            to { transform: rotate(360deg); }
        }

        
        .cards-grid {
            display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1.5rem;
        }
        .card {
                background: var(--dark3);
                border: 1px solid var(--border);
            border-radius: 8px; overflow: hidden;
            box-shadow: var(--card-shadow);
            transition: transform .3s, border-color .3s, box-shadow .3s;
            cursor: pointer; text-decoration: none;
            display: block; color: inherit;
        }
        .card:hover { transform: translateY(-4px); border-color: var(--gold); box-shadow: var(--card-shadow-hover); }
        .card-img {
            width: 100%; height: 200px; overflow: hidden;
                background: var(--dark2);
            display: flex; align-items: center; justify-content: center;
        }
        .card-img img {
            width: 100%; height: 100%; object-fit: cover;
            transition: transform .4s;
        }
        .card:hover .card-img img { transform: scale(1.05); }
        .card-body { padding: 1.25rem; }
        .card-tag {
            font-family: 'Cinzel', serif; font-size: .6rem;
            letter-spacing: 2px; text-transform: uppercase;
            color: var(--gold); margin-bottom: .5rem; display: block;
        }
        .card-title {
            font-family: 'Cinzel', serif; font-size: 1rem;
            color: var(--text); margin-bottom: .5rem;
        }
        .card-desc { color: var(--muted); font-size: .9rem; line-height: 1.6; }
        .card-footer {
            padding: .75rem 1.25rem;
                border-top: 1px solid var(--border);
            display: flex; justify-content: space-between; align-items: center;
        }
        .card-footer span { font-size: .8rem; color: var(--muted); font-style: italic; }
        .card-arrow { color: var(--gold); font-size: 1rem; }

        /* ══════════════════════════════════════════════
           لمسات احترافية إضافية (Scrollbar / Ripple / Skeleton /
           Page Fade / Ankh Spinner / Favorite Pulse / Theme Toggle Hint)
           ══════════════════════════════════════════════ */

        /* 1. Scrollbar دهبي رفيع بدل الرمادي الافتراضي */
        html { scrollbar-width: thin; scrollbar-color: rgba(var(--gold-rgb),.5) transparent; }
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: rgba(var(--gold-rgb),.4); border-radius: 8px; }
        ::-webkit-scrollbar-thumb:hover { background: rgba(var(--gold-rgb),.65); }

        /* 2. Ripple effect عند الضغط على أي زرار */
        .pl-ripple-host { position: relative; overflow: hidden; }
        .pl-ripple-span {
            position: absolute;
            border-radius: 50%;
            background: rgba(var(--gold-rgb), .35);
            transform: scale(0);
            pointer-events: none;
            animation: pl-ripple .55s ease-out;
        }
        @@keyframes pl-ripple { to { transform: scale(2.6); opacity: 0; } }

        /* 3. Skeleton shimmer وقت تحميل الصور */
        .pl-img-loading {
            background: linear-gradient(90deg, var(--dark2) 25%, var(--dark3) 37%, var(--dark2) 63%);
            background-size: 400% 100%;
            animation: pl-shimmer 1.4s ease infinite;
        }
        @@keyframes pl-shimmer {
            0% { background-position: 100% 50%; }
            100% { background-position: 0 50%; }
        }

        /* 4. Page transition — اتشالت بالكامل، كانت بتضيف تأخير حقيقي (220ms قبل أي navigation + 350ms fade-in) */

        /* 5. Ankh Spinner — لودر بشكل عنخ بيلف، بديل عن أي spinner عادي */
        .pl-ankh-spinner {
            display: inline-block;
            font-size: 1.4rem;
            color: var(--gold);
            animation: pl-ankh-spin 1.1s linear infinite;
        }
        @@keyframes pl-ankh-spin { to { transform: rotate(360deg); } }

        /* 6. Favorite Heart Pulse — نبضة بسيطة عند الضغط على أي زرار مفضلة */
        .pl-heart-pulse { animation: pl-heart-pulse .4s ease; }
        @@keyframes pl-heart-pulse {
            0%   { transform: scale(1); }
            40%  { transform: scale(1.35); }
            100% { transform: scale(1); }
        }

        /* 7. Theme Toggle — لفتة انتباه لطيفة أول مرة بس عشان توضح إنه بيتضغط */
        @@keyframes pl-theme-hint {
            0%, 100% { box-shadow: 0 0 0 rgba(var(--gold-rgb),0); }
            50% { box-shadow: 0 0 0 4px rgba(var(--gold-rgb),.18), 0 0 10px rgba(var(--gold-rgb),.3); }
        }
        .theme-toggle.pl-hint { animation: pl-theme-hint 1.3s ease-in-out 3; }


     
        .details-wrap { padding: 3rem; max-width: 1000px; margin: 0 auto; }
        .details-card {
            display: grid; grid-template-columns: 1fr 1.5fr;
            gap: 3rem; align-items: start;
                background: var(--dark3);
                border: 1px solid var(--border);
            border-radius: 8px; overflow: hidden; padding: 2rem;
            box-shadow: var(--card-shadow);
        }
        .details-img { border-radius: 8px; overflow: hidden; }
        .details-img img { width: 100%; height: 350px; object-fit: cover; }
        .details-title {
            font-family: 'Cinzel', serif; font-size: 2rem;
            color: var(--text); margin-bottom: 1rem;
        }
        .details-text { color: var(--muted); font-size: 1rem; line-height: 1.8; margin-bottom: 1.5rem; }
        .details-meta { display: flex; gap: 2rem; flex-wrap: wrap; margin-bottom: 1.5rem; }
        .meta-label {
            font-family: 'Cinzel', serif; font-size: .6rem;
            letter-spacing: 2px; text-transform: uppercase;
            color: var(--gold); display: block; margin-bottom: .25rem;
        }
        .meta-value { color: var(--text); font-size: .95rem; }
        .page-header { text-align: center; padding: 3rem 2rem 1rem; }
        .see-all-wrap { text-align: center; margin-top: 2rem; }

        
        .btn-gold {
            display: inline-block; padding: .9rem 2.5rem;
            background: linear-gradient(135deg, var(--gold), #a07a1a);
            border: none; border-radius: 4px;
                color: #0d0702;
                font-family: 'Cinzel', serif;
            font-size: .75rem; font-weight: 700;
            letter-spacing: 2px; text-transform: uppercase;
            cursor: pointer; transition: opacity .3s, box-shadow .3s; text-decoration: none;
            box-shadow: 0 0 0 rgba(var(--gold-rgb),0);
        }

                .btn-gold:hover {
                    opacity: .9;
                    color: #0d0702;
                    box-shadow: 0 4px 20px rgba(var(--gold-rgb),.35);
                }
        .btn-outline {
            display: inline-block; padding: .9rem 2.5rem;
            background: transparent;
                border: 1px solid var(--border);
                border-radius: 4px;
            color: var(--muted); font-family: 'Cinzel', serif;
            font-size: .75rem; letter-spacing: 2px; text-transform: uppercase;
            cursor: pointer; transition: all .3s; text-decoration: none;
        }
        .btn-outline:hover { border-color: var(--gold); color: var(--gold); box-shadow: 0 4px 16px rgba(var(--gold-rgb),.15); }
        .btn-back {
            display: inline-block; margin-bottom: 1.5rem;
            font-family: 'Cinzel', serif; font-size: .7rem;
            letter-spacing: 2px; text-transform: uppercase;
            color: var(--muted); text-decoration: none; transition: color .3s;
        }
        .btn-back:hover { color: var(--gold); }

        
        footer.main-footer {
                background: var(--dark3);
                border-top: 1px solid var(--border);
            text-align: center; padding: 2rem;
            color: var(--muted); font-size: .85rem; font-style: italic;
            transition: background .25s ease, border-color .25s ease;
        }
        footer.main-footer span { color: var(--gold); }

        /* 🆕 من هنا الناف بار بتاعها بريك بوينت لوحدها (1100px) — أعلى من بريك بوينت
           محتوى الصفحة (768px) تحت، عشان الصف الواحد (لوجو + 5 لينكات + سيرش +
           سلة + لغة + ثيم + خروج) كان بيتزنق على شاشات لابتوب عادية زي 1366px
           لو فضل معتمد على 768px بس */
        @@media (max-width: 1100px) {
            .nav-row-main { padding: .6rem 1.5rem; }
            .nav-links {
                display: none; flex-direction: column; align-items: stretch; gap: 1rem;
                position: absolute; top: 100%; left: 0; right: 0;
                background: rgba(var(--dark-rgb),0.97); padding: 1.5rem;
                border-bottom: 1px solid var(--border);
                max-height: calc(100vh - 60px); overflow-y: auto;
            }
            .nav-links.open { display: flex; }
            /* 🆕 شريط الأدوات (سلة/لغة/ثيم/دخول) فاضل ظاهر زي ما كان دايمًا، بس البحث بيتخبى
               والقايمة الرئيسية بس اللي بتتقفل جوه الـ hamburger */
            .nav-utils { gap: .6rem; }
            .nav-search { display: none; }
            .nav-toggle { display: flex; }
            .nav-mega-menu { position: static; width: 100%; border: none; box-shadow: none;
                background: rgba(var(--gold-rgb),.04); margin-top: .5rem; grid-template-columns: 1fr; }
        }

        @@media (max-width: 768px) {
            .hero-title { font-size: 2.2rem; }
            .hero-pyramid { border-left-width: 200px; border-right-width: 200px; border-bottom-width: 150px; }

            .stats-bar { gap: 1.5rem; padding: 1.5rem; }

            .section { padding: 3rem 1.5rem; }

            .cards-grid { grid-template-columns: 1fr; }

            .details-card { grid-template-columns: 1fr; gap: 1.5rem; }
            .details-img img { height: 220px; }
            .details-wrap { padding: 1.5rem; }

            .btn-gold, .btn-outline { padding: .75rem 1.5rem; }
        }

        @@media (max-width: 480px) {
            .hero-title { font-size: 1.8rem; }
            .stat-num { font-size: 1.4rem; }
            .section-title { font-size: 1.5rem; }
        }


            /* ── Dropdown ── */
            .nav-dropdown {
                position: relative;
            }

            .nav-dropdown-toggle {
                cursor: pointer;
                display: flex;
                align-items: center;
                gap: 4px;
                padding: 0;
                margin: 0;
                line-height: normal;
            }

            .nav-dropdown {
                position: relative;
                display: flex;
                align-items: center;
            }

            .nav-dropdown-menu {
                display: none;
                position: absolute;
                top: calc(100% + 10px);
                left: 50%;
                transform: translateX(-50%);
                background: var(--dark2);
                border: 1px solid rgba(var(--gold-rgb),0.3);
                border-radius: 10px;
                padding: 8px 0;
                min-width: 200px;
                z-index: 999;
                box-shadow: 0 10px 30px rgba(0,0,0,0.25);
                list-style: none;
            }

            .nav-dropdown-group {
                font-family: 'Cinzel', serif;
                font-size: .6rem;
                letter-spacing: 2px;
                text-transform: uppercase;
                color: var(--gold);
                opacity: .7;
                padding: 10px 20px 4px;
            }
                .nav-dropdown-group:first-child {
                    padding-top: 4px;
                }

                .nav-dropdown-menu li a {
                    display: block;
                    padding: 10px 20px;
                    color: var(--muted);
                    text-decoration: none;
                    font-size: .85rem;
                    letter-spacing: .05em;
                    transition: all .2s;
                }

                    .nav-dropdown-menu li a:hover {
                        color: var(--gold);
                        background: rgba(var(--gold-rgb),0.08);
                        padding-inline-start: 26px;
                    }

            /* ── 🆕 Mega Menu — "استكشف" ──
               مخفي افتراضيًا. بيتفتح بالـ hover على الكمبيوتر (pointer دقيق زي الماوس)
               وبالـ click على الموبايل/التاتش (كلاس .show بيتحط بالـ JS) */
            .nav-mega-parent { position: relative; }
            .nav-mega-menu {
                display: none;
                position: absolute;
                top: calc(100% + 12px);
                inset-inline-start: 50%;
                transform: translateX(-50%);
                background: var(--dark2);
                border: 1px solid rgba(var(--gold-rgb),0.3);
                border-radius: 10px;
                padding: 1.5rem;
                min-width: 420px;
                z-index: 999;
                box-shadow: 0 20px 45px rgba(0,0,0,0.35);
                grid-template-columns: repeat(3, auto);
                gap: 2.2rem;
            }
            .nav-mega-menu.show { display: grid; }
            @@media (hover: hover) and (pointer: fine) {
                .nav-mega-parent:hover .nav-mega-menu { display: grid; }
            }
            .nav-mega-col-title {
                font-family: 'Cinzel', serif; font-size: .6rem;
                letter-spacing: 2px; text-transform: uppercase;
                color: var(--gold); opacity: .75;
                margin-bottom: .6rem; white-space: nowrap;
            }
            .nav-mega-col a {
                display: flex; align-items: center; gap: .55rem;
                padding: .5rem .4rem;
                color: var(--muted); text-decoration: none;
                font-size: .85rem; white-space: nowrap;
                border-radius: 6px;
                transition: all .2s;
            }
            .nav-mega-col a:hover {
                color: var(--gold);
                background: rgba(var(--gold-rgb),0.08);
                padding-inline-start: .7rem;
            }
            .nav-mega-col a .nav-ic { color: var(--gold); opacity: .8; }
    </style>
    <style>
        /* 🆕 Toast مشترك — TempData["Message"]/["Error"] */
        .pl-toast {
            position: fixed;
            top: 100px;
            inset-inline-end: 24px;
            z-index: 10000;
            display: flex;
            align-items: center;
            gap: 10px;
            max-width: 380px;
            padding: 14px 18px;
            border-radius: 8px;
            background: var(--dark2);
            border: 1px solid var(--border);
            box-shadow: 0 10px 30px rgba(0,0,0,.35);
            font-family: 'Crimson Pro', serif;
            font-size: .95rem;
            color: var(--text);
            animation: pl-toast-in .35s ease;
        }
        .pl-toast.success { border-color: var(--green); }
        .pl-toast.success .pl-toast-icon { color: var(--green); }
        .pl-toast.error { border-color: var(--red); }
        .pl-toast.error .pl-toast-icon { color: var(--red); }
        .pl-toast-icon { font-size: 1.1rem; flex-shrink: 0; }
        .pl-toast-text { flex: 1; line-height: 1.4; }
        .pl-toast-close {
            background: none; border: none; color: var(--muted);
            cursor: pointer; font-size: .9rem; flex-shrink: 0;
        }
        @@keyframes pl-toast-in {
            from { opacity: 0; transform: translateY(-12px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        @@keyframes pl-toast-out {
            to { opacity: 0; transform: translateY(-12px); }
        }
        @@media (max-width: 560px) {
            .pl-toast { inset-inline-end: 12px; inset-inline-start: 12px; max-width: none; top: 78px; }
        }
    </style>
    @RenderSection("Styles", required: false)
</head>

