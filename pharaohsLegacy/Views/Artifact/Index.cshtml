@using pharaohsLegacy.Extensions

@model List<pharaohsLegacy.Models.Artifact>
@{
    ViewData["Title"] = "Artifacts";
}

@section Styles {
    <style>
        .art-page {
            max-width: 1200px;
            margin: 0 auto;
            padding: 3rem 2rem 5rem;
        }

        .art-hero {
            text-align: center;
            margin-bottom: 3rem;
        }

        .art-hero-tag {
            font-family: 'Cinzel', serif;
            font-size: .65rem;
            letter-spacing: 4px;
            text-transform: uppercase;
            color: #c9a227;
            margin-bottom: 1rem;
            display: block;
        }

        .art-hero-title {
            font-family: 'Cinzel', serif;
            font-size: clamp(2rem, 5vw, 3rem);
            font-weight: 700;
            color: #e8d5b0;
            margin-bottom: 1rem;
        }

        .art-hero-line {
            width: 80px;
            height: 1px;
            background: linear-gradient(90deg, transparent, #c9a227, transparent);
            margin: 0 auto;
        }

        /* Filters */
        .art-filters {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            justify-content: center;
            margin-bottom: 2.5rem;
        }

        .art-filter-btn {
            font-family: 'Cinzel', serif;
            font-size: .62rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            padding: 7px 16px;
            border-radius: 20px;
            border: 1px solid #3d2a15;
            background: transparent;
            color: #8a7055;
            cursor: pointer;
            transition: all .25s;
        }

            .art-filter-btn:hover,
            .art-filter-btn.active {
                border-color: #c9a227;
                color: #c9a227;
                background: rgba(201,162,39,0.08);
            }

        /* Grid */
        .art-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 1.5rem;
        }

        /* Card */
        .art-card {
            background: #2d1a08;
            border: 1px solid #3d2a15;
            border-radius: 12px;
            overflow: hidden;
            text-decoration: none;
            display: block;
            transition: transform .3s, border-color .3s;
            animation: fadeUp .5s ease both;
        }

            .art-card:hover {
                transform: translateY(-4px);
                border-color: #c9a227;
            }

        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(16px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .art-card-img {
            height: 200px;
            overflow: hidden;
            background: #1a0e05;
            position: relative;
        }

            .art-card-img img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                transition: transform .4s;
                filter: brightness(.8);
            }

        .art-card:hover .art-card-img img {
            transform: scale(1.05);
            filter: brightness(1);
        }

        .art-card-category {
            position: absolute;
            top: 10px;
            right: 10px;
            font-family: 'Cinzel', serif;
            font-size: .55rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: #0d0702;
            background: #c9a227;
            padding: 4px 10px;
            border-radius: 12px;
        }

        .art-card-body {
            padding: 1.2rem;
        }

        .art-card-origin {
            font-family: 'Cinzel', serif;
            font-size: .6rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: #c9a227;
            margin-bottom: .4rem;
        }

        .art-card-name {
            font-family: 'Cinzel', serif;
            font-size: 1rem;
            font-weight: 700;
            color: #e8d5b0;
            margin-bottom: .3rem;
        }

        .art-card-period {
            font-size: .85rem;
            color: #8a7055;
            margin-bottom: .5rem;
        }

        .art-card-museum {
            font-size: .8rem;
            color: #8a7055;
            font-style: italic;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .art-card-footer {
            padding: .75rem 1.2rem;
            border-top: 1px solid #3d2a15;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

            .art-card-footer span {
                font-size: .75rem;
                color: #8a7055;
                font-family: 'Cinzel', serif;
                letter-spacing: 1px;
            }

        .art-card-arrow {
            color: #c9a227;
        }

        /* Empty */
        .art-empty {
            text-align: center;
            padding: 4rem 2rem;
            color: #8a7055;
            font-family: 'Cinzel', serif;
            font-size: .85rem;
            letter-spacing: 2px;
            display: none;
            grid-column: 1/-1;
        }

        @@media (max-width: 768px) {
            .art-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
}

<div class="art-page">

    <!-- Hero -->
    <div class="art-hero">
        <span class="art-hero-tag">𓏏 @Html.L("Art_Hero_Tag")</span>
        <h1 class="art-hero-title">@Html.L("Art_Hero_Title")</h1>
        <div class="art-hero-line"></div>
    </div>

    <!-- Filters -->
    <div class="art-filters">
        <button class="art-filter-btn active" onclick="filterArt('all', this)">@Html.L("Booking_Filter_All")</button>
        @foreach (var cat in Model.Select(a => a.Category).Distinct().OrderBy(c => c))
        {
            <button class="art-filter-btn" onclick="filterArt('@cat', this)">@cat</button>
        }
    </div>

    <!-- Grid -->
    <div class="art-grid" id="artGrid">
        @if (!Model.Any())
        {
            <div class="art-empty" style="display:block;">𓏏 @Html.L("Art_Empty_Text")</div>
        }
        @foreach (var a in Model)
        {
            <a href="/Artifact/Details/@a.Id" class="art-card" data-category="@a.Category">
                <div class="art-card-img">
                    <img src="@a.ImageUrl" alt="@a.Name"
                         onerror="this.src='https://via.placeholder.com/400x200/2d1a08/c9a227?text=@a.Name'" />
                    <span class="art-card-category">@a.Category</span>
                </div>
                <div class="art-card-body">
                    <div class="art-card-origin">@a.Origin</div>
                    <div class="art-card-name">@a.Name</div>
                    <div class="art-card-period">@a.Period</div>
                    @if (!string.IsNullOrEmpty(a.Museum))
                    {
                        <div class="art-card-museum">𓏠 @a.Museum</div>
                    }
                </div>
                <div class="art-card-footer">
                    <span>@a.CurrentLocation</span>
                    <span class="art-card-arrow">→</span>
                </div>
            </a>
        }
    </div>

</div>

@section Scripts {
    <script>
        function filterArt(category, btn) {
            document.querySelectorAll('.art-filter-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');

            const cards = document.querySelectorAll('.art-card');
            let count = 0;

            cards.forEach(card => {
                if (category === 'all' || card.dataset.category === category) {
                    card.style.display = '';
                    count++;
                } else {
                    card.style.display = 'none';
                }
            });

            const empty = document.querySelector('.art-empty');
            if (empty) empty.style.display = count === 0 ? 'block' : 'none';
        }
    </script>
}
