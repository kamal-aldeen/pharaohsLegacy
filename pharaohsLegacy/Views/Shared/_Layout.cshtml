        transition: transform 0.3s, box-shadow 0.3s;
        }

        .aichat-btn:hover {
        transform: scale(1.08);
        box-shadow: 0 6px 32px rgba(201,162,39,0.55);
        }

        .aichat-btn.active {
        animation: none;
        transform: rotate(20deg) scale(1.05);
