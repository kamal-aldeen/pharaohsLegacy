@using pharaohsLegacy.Extensions

@{
    ViewData["Title"] = "AI Tour Guide";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&display=swap');

    :root {
        --gold: #d4af37;
        --gold-light: #f0d060;
        --gold-dim: #a08040;
        --dark: #110d04;
        --dark-card: #1e1608;
        --dark-border: #3a2e10;
    }

    .chat-page {
        min-height: 100vh;
        background: radial-gradient(ellipse at top, #2a1f08 0%, #110d04 60%, #0a0804 100%);
        padding: 40px 20px 60px;
        font-family: 'Cinzel', serif;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    /* Header */
    .chat-header {
        text-align: center;
        margin-bottom: 32px;
    }

        .chat-header .subtitle {
            font-size: 0.78rem;
            letter-spacing: 6px;
            color: var(--gold-dim);
            text-transform: uppercase;
            margin-bottom: 8px;
        }

        .chat-header h1 {
            font-size: clamp(1.6rem, 3vw, 2.4rem);
            font-weight: 700;
            color: var(--gold-light);
            text-shadow: 0 0 30px rgba(212,175,55,0.4);
            letter-spacing: 3px;
            margin: 0 0 8px;
        }

        .chat-header .divider {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 16px;
            margin-top: 12px;
        }

            .chat-header .divider span {
                height: 1px;
                width: 60px;
                background: linear-gradient(to right, transparent, var(--gold-dim));
            }

                .chat-header .divider span:last-child {
                    background: linear-gradient(to left, transparent, var(--gold-dim));
                }

    /* Avatar */
    .imhotep-avatar {
        width: 70px;
        height: 70px;
        background: linear-gradient(135deg, #3a2e10, #1e1608);
        border: 2px solid var(--dark-border);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        margin: 0 auto 16px;
        box-shadow: 0 0 20px rgba(212,175,55,0.2);
    }

    /* Chat Container */
    .chat-container {
        width: 100%;
        max-width: 720px;
        background: linear-gradient(135deg, #1e1608, #110d04);
        border: 1px solid var(--dark-border);
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 12px 50px rgba(0,0,0,0.6);
    }

    /* Messages Area */
    .messages-area {
        height: 460px;
        overflow-y: auto;
        padding: 24px;
        display: flex;
        flex-direction: column;
        gap: 16px;
        scrollbar-width: thin;
        scrollbar-color: var(--dark-border) transparent;
    }

        .messages-area::-webkit-scrollbar {
            width: 4px;
        }

        .messages-area::-webkit-scrollbar-track {
            background: transparent;
        }

        .messages-area::-webkit-scrollbar-thumb {
            background: var(--dark-border);
            border-radius: 4px;
        }

    /* Message Bubbles */
    .message {
        display: flex;
        gap: 10px;
        animation: msgIn 0.3s ease both;
    }

    @@keyframes msgIn {
        from {
            opacity: 0;
            transform: translateY(8px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .message.user {
        flex-direction: row-reverse;
    }

    .msg-avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        border: 1px solid var(--dark-border);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        flex-shrink: 0;
        background: linear-gradient(135deg, #2a1f08, #1a1208);
    }

    .msg-bubble {
        max-width: 75%;
        padding: 12px 16px;
        border-radius: 16px;
        font-family: Georgia, serif;
        font-size: 0.88rem;
        line-height: 1.7;
    }

    .message.bot .msg-bubble {
        background: linear-gradient(135deg, #2a1f08, #1e1608);
        border: 1px solid var(--dark-border);
        color: #c8a855;
        border-radius: 4px 16px 16px 16px;
    }

    .message.user .msg-bubble {
        background: linear-gradient(135deg, #d4af37, #a08028);
        color: #1a1208;
        font-weight: 600;
        border-radius: 16px 4px 16px 16px;
    }

    /* Typing indicator */
    .typing .msg-bubble {
        display: flex;
        gap: 5px;
        align-items: center;
        padding: 14px 18px;
    }

    .dot {
        width: 7px;
        height: 7px;
        background: var(--gold-dim);
        border-radius: 50%;
        animation: bounce 1.2s infinite;
    }

        .dot:nth-child(2) {
            animation-delay: 0.2s;
        }

        .dot:nth-child(3) {
            animation-delay: 0.4s;
        }

    @@keyframes bounce {
        0%, 60%, 100% {
            transform: translateY(0);
        }

        30% {
            transform: translateY(-6px);
        }
    }

    /* Input Area */
    .input-area {
        padding: 16px 20px;
        border-top: 1px solid var(--dark-border);
        display: flex;
        gap: 10px;
        background: rgba(0,0,0,0.2);
    }

    .chat-input {
        flex: 1;
        background: rgba(0,0,0,0.35);
        border: 1px solid var(--dark-border);
        border-radius: 10px;
        padding: 12px 16px;
        font-family: Georgia, serif;
        font-size: 0.9rem;
        color: var(--gold-light);
        outline: none;
        transition: border-color 0.3s;
        resize: none;
    }

        .chat-input::placeholder {
            color: #4a3820;
        }

        .chat-input:focus {
            border-color: var(--gold-dim);
        }

    .send-btn {
        background: linear-gradient(135deg, #d4af37, #a08028);
        border: none;
        border-radius: 10px;
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.25s;
        color: #1a1208;
        font-size: 1.2rem;
        flex-shrink: 0;
        align-self: flex-end;
    }

        .send-btn:hover {
            background: linear-gradient(135deg, #f0d060, #c09030);
            transform: scale(1.05);
        }

        .send-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }

    /* Suggestions */
    .suggestions {
        width: 100%;
        max-width: 720px;
        margin-top: 16px;
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        justify-content: center;
    }

    .suggestion-btn {
        background: transparent;
        border: 1px solid var(--dark-border);
        border-radius: 20px;
        padding: 7px 16px;
        font-family: 'Cinzel', serif;
        font-size: 0.72rem;
        color: var(--gold-dim);
        cursor: pointer;
        transition: all 0.2s;
        letter-spacing: 1px;
    }

        .suggestion-btn:hover {
            border-color: var(--gold-dim);
            color: #c9a227;
            background: rgba(212,175,55,0.06);
        }
</style>

<div class="chat-page">

    <!-- Header -->
    <div class="chat-header">
        <div class="subtitle">𓂀 @Html.L("Chat_PoweredByAI") 𓂀</div>
        <div class="imhotep-avatar">𓁹</div>
        <h1>@Html.L("Chat_HeaderTitle")</h1>
        <div class="divider">
            <span></span>𓋹<span></span>
        </div>
    </div>

    <!-- Chat Container -->
    <div class="chat-container">
        <div class="messages-area" id="messagesArea">
            <!-- Welcome message -->
            <div class="message bot">
                <div class="msg-avatar">𓁹</div>
                <div class="msg-bubble">
                    @Html.L("Chat_WelcomeMessage")
                </div>
            </div>
        </div>

        <div class="input-area">
            <textarea class="chat-input"
                      id="chatInput"
                      placeholder="@Html.L("Chat_Input_Placeholder")"
                      rows="1"
                      onkeydown="handleKey(event)"></textarea>
            <button class="send-btn" id="sendBtn" onclick="sendMessage()">➤</button>
        </div>
    </div>

    <!-- Suggestions -->
    <div class="suggestions">
        <button class="suggestion-btn" onclick="ask('@Html.L("Chat_Suggestion_Ramesses_Q")')">@Html.L("Chat_Suggestion_Ramesses")</button>
        <button class="suggestion-btn" onclick="ask('@Html.L("Chat_Suggestion_Pyramid_Q")')">@Html.L("Chat_Suggestion_Pyramid")</button>
        <button class="suggestion-btn" onclick="ask('@Html.L("Chat_Suggestion_Ra_Q")')">@Html.L("Chat_Suggestion_Ra")</button>
        <button class="suggestion-btn" onclick="ask('@Html.L("Chat_Suggestion_Hiero_Q")')">@Html.L("Chat_Suggestion_Hiero")</button>
        <button class="suggestion-btn" onclick="ask('@Html.L("Chat_Suggestion_Cleopatra_Q")')">@Html.L("Chat_Suggestion_Cleopatra")</button>
    </div>

</div>

@section Scripts {
    <script>
        const chatErrorMsg = '@Html.Raw(Html.L("Chat_ErrorMessage"))';
        const messagesArea = document.getElementById('messagesArea');
        const chatInput    = document.getElementById('chatInput');
        const sendBtn      = document.getElementById('sendBtn');

        function handleKey(e) {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                sendMessage();
            }
        }

        function ask(text) {
            chatInput.value = text;
            sendMessage();
        }

        function addMessage(text, role) {
            const div = document.createElement('div');
            div.className = `message ${role}`;
            div.innerHTML = `
                <div class="msg-avatar">${role === 'bot' ? '𓁹' : '𓀀'}</div>
                <div class="msg-bubble">${text}</div>
            `;
            messagesArea.appendChild(div);
            messagesArea.scrollTop = messagesArea.scrollHeight;
            return div;
        }

        function addTyping() {
            const div = document.createElement('div');
            div.className = 'message bot typing';
            div.id = 'typingIndicator';
            div.innerHTML = `
                <div class="msg-avatar">𓁹</div>
                <div class="msg-bubble">
                    <span class="dot"></span>
                    <span class="dot"></span>
                    <span class="dot"></span>
                </div>
            `;
            messagesArea.appendChild(div);
            messagesArea.scrollTop = messagesArea.scrollHeight;
        }

        function removeTyping() {
            const t = document.getElementById('typingIndicator');
            if (t) t.remove();
        }

        async function sendMessage() {
            const text = chatInput.value.trim();
            if (!text) return;

            chatInput.value = '';
            sendBtn.disabled = true;

            addMessage(text, 'user');
            addTyping();

            try {
                const res = await fetch('/Chatbot/Ask', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message: text })
                });

                const data = await res.json();
                removeTyping();
                addMessage(data.reply, 'bot');
            } catch {
                removeTyping();
                addMessage(chatErrorMsg, 'bot');
            }

            sendBtn.disabled = false;
            chatInput.focus();
        }
    </script>
}
