@using pharaohsLegacy.Extensions

@model pharaohsLegacy.Models.Artifact
@{
    ViewData["Title"] = Model.Name;
    var userEmail = Context.Session.GetString("UserEmail");
    var isGuest = userEmail == null || userEmail == "guest";
    var isFav = ViewBag.IsFav as bool? ?? false;
}

@section Styles {
    <style>
        .det-wrap {
            max-width: 1100px;
            margin: 0 auto;
            padding: 2rem 2rem 5rem;
        }

        .det-banner {
            position: relative;
            height: 380px;
            border-radius: 16px;
            overflow: hidden;
            margin-bottom: 2rem;
            border: 1px solid #3d2a15;
        }

            .det-banner img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                filter: brightness(.55);
            }

        .det-banner-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, rgba(13,7,2,.95) 0%, rgba(13,7,2,.3) 60%, transparent 100%);
        }

        .det-banner-content {
            position: absolute;
            bottom: 2rem;
            left: 2rem;
            right: 2rem;
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            gap: 1rem;
        }

        .det-banner-tag {
            font-family: 'Cinzel', serif;
            font-size: .65rem;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: #c9a227;
            margin-bottom: .5rem;
        }

        .det-banner-name {
            font-family: 'Cinzel', serif;
            font-size: clamp(2rem, 5vw, 3.2rem);
            font-weight: 700;
            color: #e8d5b0;
            line-height: 1.1;
            text-shadow: 0 2px 20px rgba(0,0,0,.5);
        }

        .det-content {
            display: grid;
            grid-template-columns: 1fr 320px;
            gap: 2rem;
            align-items: start;
        }

        .det-section-title {
            font-family: 'Cinzel', serif;
            font-size: .65rem;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: #c9a227;
            margin-bottom: .75rem;
            display: flex;
            align-items: center;
            gap: .75rem;
        }

            .det-section-title::after {
                content: '';
                flex: 1;
                height: 1px;
                background: linear-gradient(90deg, #3d2a15, transparent);
            }

        .det-description {
            color: #8a7055;
            font-size: 1.05rem;
            line-height: 1.9;
            margin-bottom: 2rem;
        }

        .det-sidebar {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .det-info-card {
            background: #2d1a08;
            border: 1px solid#3d2a15;
            border-radius: 12px;
            padding: 1.5rem;
        }

        .det-info-card-title {
            font-family: 'Cinzel', serif;
            font-size: .65rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: #c9a227;
            margin-bottom: 1rem;
            padding-bottom: .75rem;
            border-bottom: 1px solid #3d2a15;
        }

        .det-info-row {
            display: flex;
            align-items: center;
            gap: .75rem;
            padding: .6rem 0;
            border-bottom: 1px solid rgba(61,42,21,.5);
        }

            .det-info-row:last-child {
                border-bottom: none;
            }

        .det-info-icon {
            font-size: 1.1rem;
            width: 24px;
            text-align: center;
            flex-shrink: 0;
        }

        .det-info-label {
            font-size: .75rem;
            color: #8a7055;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-family: 'Cinzel', serif;
        }

        .det-info-value {
            font-size: .95rem;
            color: #e8d5b0;
            margin-top: 2px;
        }

        .det-btn {
            width: 100%;
            padding: .9rem;
            border-radius: 8px;
            font-family: 'Cinzel', serif;
            font-size: .7rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            cursor: pointer;
            transition: all .3s;
            border: 1px solid;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: .6rem;
            text-decoration: none;
        }

        .det-btn-fav {
            background: transparent;
            border-color: #3d2a15;
            color: #8a7055;
        }

            .det-btn-fav:hover {
                border-color: #e74c3c;
                color: #e74c3c;
            }

            .det-btn-fav.active {
                background: rgba(231,76,60,.08);
                border-color: #e74c3c;
                color: #e74c3c;
            }

        .det-nav {
            display: flex;
            gap: 1rem;
            margin-top: 2rem;
            flex-wrap: wrap;
        }

        @@media (max-width: 900px) {
            .det-content {
                grid-template-columns: 1fr;
            }

            .det-sidebar {
                order: -1;
            }

            .det-banner {
                height: 280px;
            }

            .det-banner-name {
                font-size: 2rem;
            }
        }

        @@media (max-width: 480px) {
            .det-wrap {
                padding: 1rem 1rem 4rem;
            }

            .det-banner {
                height: 220px;
            }
        }
    </style>
}

<div class="det-wrap">
    <a href="/Artifact/Index" class="btn-back">← @Html.L("Art_Back_Link")</a>

    <!-- Banner -->
    <div class="det-banner">
        <img src="@Model.ImageUrl" alt="@Model.Name"
             onerror="this.src='https://via.placeholder.com/1200x400/2d1a08/c9a227?text=@Model.Name'" />
        <div class="det-banner-overlay"></div>
        <div class="det-banner-content">
            <div>
                <div class="det-banner-tag">𓏏 @Model.Category</div>
                <div class="det-banner-name">@Model.Name</div>
            </div>
        </div>
    </div>

    <!-- Content -->
    <div class="det-content">

        <!-- Left: Description -->
        <div>
            <div class="det-section-title">@Html.L("Common_About") @Model.Name</div>
            <p class="det-description">@Model.Description</p>
            <div class="det-nav">
                <a href="/Artifact/Index" class="btn-outline">← @Html.L("Art_AllArtifacts_Link")</a>
            </div>
        </div>

        <!-- Right: Sidebar -->
        <div class="det-sidebar">
            <div class="det-info-card">
                <div class="det-info-card-title">@Html.L("Common_QuickFacts")</div>
                <div class="det-info-row">
                    <span class="det-info-icon">𓏏</span>
                    <div>
                        <div class="det-info-label">@Html.L("Common_Category")</div>
                        <div class="det-info-value">@Model.Category</div>
                    </div>
                </div>
                <div class="det-info-row">
                    <span class="det-info-icon">📅</span>
                    <div>
                        <div class="det-info-label">@Html.L("Common_Period")</div>
                        <div class="det-info-value">@Model.Period</div>
                    </div>
                </div>
                <div class="det-info-row">
                    <span class="det-info-icon">📍</span>
                    <div>
                        <div class="det-info-label">@Html.L("Common_Origin")</div>
                        <div class="det-info-value">@Model.Origin</div>
                    </div>
                </div>
                <div class="det-info-row">
                    <span class="det-info-icon">🏛️</span>
                    <div>
                        <div class="det-info-label">@Html.L("Common_Museum")</div>
                        <div class="det-info-value">@(string.IsNullOrEmpty(Model.Museum) ? Html.L("Common_Unknown") : Model.Museum)</div>
                    </div>
                </div>
                <div class="det-info-row">
                    <span class="det-info-icon">🌍</span>
                    <div>
                        <div class="det-info-label">@Html.L("Common_Location")</div>
                        <div class="det-info-value">@(string.IsNullOrEmpty(Model.CurrentLocation) ? Html.L("Common_Unknown") : Model.CurrentLocation)</div>
                    </div>
                </div>
            </div>

            @if (!isGuest)
            {
                <a href="@(isFav ? $"/Favorite/Remove/{ViewBag.FavId}?returnUrl=/Artifact/Details/{Model.Id}" : $"/Favorite/Add?type=artifact&itemId={Model.Id}&returnUrl=/Artifact/Details/{Model.Id}")"
                   class="det-btn det-btn-fav @(isFav ? "active" : "")">
                    @(isFav ? "❤️ " + Html.L("Common_RemoveFavorite") : "🤍 " + Html.L("Common_AddFavorite"))
                </a>
            }
            else
            {
                <a href="/User/Login" class="det-btn det-btn-fav">🔒 @Html.L("Common_LoginToSave")</a>
            }
        </div>
    </div>
    @await Html.PartialAsync("_Reviews", (
    Reviews: (List<pharaohsLegacy.Models.Review>)ViewBag.Reviews,
    Type: "artifact",
    ItemId: Model.Id,
    UserReviewed: (bool)ViewBag.HasReviewed
))
</div>