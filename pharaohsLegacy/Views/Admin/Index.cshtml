//  Counter Animation 
document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.counter').forEach(el => {
        const target = parseInt(el.dataset.target) || 0;
        let current = 0;
        const step = Math.max(1, target / 60);
        const timer = setInterval(() => {
            current = Math.min(current + step, target);
            el.textContent = Math.floor(current);
            if (current >= target) clearInterval(timer);
        }, 16);
    });

    // Revenue
    const revEl = document.getElementById('revenueVal');
    if (revEl) {
        const target = @Model.TotalRevenue.ToString(System.Globalization.CultureInfo.InvariantCulture);
        let current = 0;
        const step = Math.max(1, target / 80);
        const timer = setInterval(() => {
            current = Math.min(current + step, target);
            revEl.textContent = Math.floor(current).toLocaleString();
            if (current >= target) clearInterval(timer);
        }, 16);
    }

    // Auto-dismiss toast
    const toast = document.getElementById('toastMsg');
    if (toast) setTimeout(() => toast.remove(), 4000);
});


