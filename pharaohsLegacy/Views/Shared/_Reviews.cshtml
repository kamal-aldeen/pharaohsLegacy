@using pharaohsLegacy.Extensions
@model (List<pharaohsLegacy.Models.Review> Reviews, string Type, int ItemId, bool UserReviewed)

@{
    var reviews = Model.Reviews;
    var type = Model.Type;
    var itemId = Model.ItemId;
    var hasReviewed = Model.UserReviewed;
    var email = Context.Session.GetString("UserEmail");
    var isGuest = string.IsNullOrEmpty(email) || email == "guest";
    var isAdmin = Context.Session.GetString("UserRole") == "Admin";
    var lang = Context.Session.GetString("Lang") ?? "en";

    double avgRating = reviews.Any() ? reviews.Average(r => r.Rating) : 0;
    int totalReviews = reviews.Count;
}

<section class="reviews-section">
    <h3 class="reviews-title">
        <span class="reviews-icon">⭐</span>
        @Html.L("Review_SectionTitle")
        @if (totalReviews > 0)
        {
            <span class="reviews-avg">@Html.Digits(avgRating.ToString("0.0")) / @Html.Digits(5)</span>
            <span class="reviews-count">(@Html.Digits(totalReviews) @Html.L("Review_ReviewsSuffix"))</span>
        }
    </h3>

    <!-- Star Summary Bar -->
    @if (totalReviews > 0)
    {
        <div class="rating-summary">
            <div class="big-rating">@Html.Digits(avgRating.ToString("0.0"))</div>
            <div class="big-stars">
                @for (int i = 1; i <= 5; i++)
                {
                    <span class="@(i <= Math.Round(avgRating) ? "star filled" : "star")">★</span>
                }
            </div>
            <div class="rating-bars">
                @for (int star = 5; star >= 1; star--)
                {
                    var count = reviews.Count(r => r.Rating == star);
                    var pct = totalReviews > 0 ? (count * 100 / totalReviews) : 0;
                    <div class="bar-row">
                        <span class="bar-label">@Html.Digits(star) ★</span>
                        <div class="bar-track">
                            <div class="bar-fill" style="width:@pct%"></div>
                        </div>
                        <span class="bar-count">@Html.Digits(count)</span>
                    </div>
                }
            </div>
        </div>
    }

    <!-- Write Review Form -->
    @if (isAdmin)
    {
        <div class="already-reviewed">⚠️ @Html.L("Review_AdminsCannotWrite")</div>
    }
    else if (!isGuest && !hasReviewed)
    {
        <div class="write-review">
            <h4>@Html.L("Review_WriteReview_Title")</h4>
            <div class="star-picker" id="starPicker">
                @for (int i = 1; i <= 5; i++)
                {
                    <span class="pick-star" data-value="@i">★</span>
                }
            </div>
            <p class="star-hint">@Html.L("Review_ClickStarHint")</p>
            <input type="hidden" id="selectedRating" value="0" />
            <textarea id="reviewComment" placeholder="@Html.L("Review_CommentPlaceholder")" maxlength="500"></textarea>
            <div class="char-count"><span id="charCount">@Html.Digits(0)</span>/@Html.Digits(500)</div>
            <button class="btn-submit-review" onclick="submitReview('@type', @itemId)">@Html.L("Review_SubmitBtn")</button>
            <p id="reviewMsg" class="review-msg"></p>
        </div>
    }
    else if (hasReviewed)
    {
        <div class="already-reviewed">✅ @Html.L("Review_AlreadyReviewed")</div>
    }
    else if (isGuest)
    {
        <div class="login-to-review">
            <a href="/User/Login">@Html.L("Common_Login")</a> @Html.L("Review_ToLeaveReview")
        </div>
    }

    <!-- Filter by Rating -->
    @if (reviews.Any())
    {
        <div class="reviews-filter">
            <button class="rev-filter-btn active" onclick="filterByRating(0, this)">@Html.L("Booking_Filter_All")</button>
            <button class="rev-filter-btn" onclick="filterByRating(5, this)">★★★★★</button>
            <button class="rev-filter-btn" onclick="filterByRating(4, this)">★★★★☆</button>
            <button class="rev-filter-btn" onclick="filterByRating(3, this)">★★★☆☆</button>
            <button class="rev-filter-btn" onclick="filterByRating(2, this)">★★☆☆☆</button>
            <button class="rev-filter-btn" onclick="filterByRating(1, this)">★☆☆☆☆</button>
        </div>
    }

    <!-- Reviews List -->
    <div class="reviews-list" id="reviewsList">
        @if (!reviews.Any())
        {
            <p class="no-reviews">@Html.L("Review_NoReviewsYet")</p>
        }
        else
        {
            @foreach (var r in reviews.OrderByDescending(x => x.CreatedAt))
            {
                <div class="review-card" id="review-@r.Id" data-rating="@r.Rating">
                    <div class="review-header">
                        <div class="reviewer-avatar">@r.UserName[0]</div>
                        <div class="reviewer-info">
                            <span class="reviewer-name">
                                @r.UserName
                                @if (r.IsEdited)
                                {
                                    <span class="edited-badge">(@Html.L("Review_EditedBadge"))</span>
                                }
                            </span>
                            <span class="reviewer-date">@Html.DateLoc(r.CreatedAt, "MMM dd, yyyy")</span>
                        </div>
                        <div class="review-stars" id="stars-display-@r.Id">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <span class="@(i <= r.Rating ? "star filled" : "star")">★</span>
                            }
                        </div>

                        <!-- Edit button: only for review owner -->
                        @if (!isGuest && !isAdmin && r.UserEmail == email)
                        {
                            <button class="btn-edit-review" onclick="toggleEditForm(@r.Id)" id="edit-btn-@r.Id">✏️ @Html.L("Common_Edit")</button>
                        }

                        <!-- Report button: non-owner, non-admin, non-guest -->
                        @if (!isGuest && !isAdmin && r.UserEmail != email)
                        {
                            <button class="btn-report-review" onclick="openReportModal(@r.Id)" title="@Html.L("Review_ReportTitle")">🚩</button>
                        }
                    </div>

                    <!-- Comment text -->
                    <p class="review-comment" id="comment-display-@r.Id">@r.Comment</p>

                    <!-- Inline Edit Form (hidden) -->
                    @if (!isGuest && !isAdmin && r.UserEmail == email)
                    {
                        <div class="edit-form" id="edit-form-@r.Id" style="display:none;">
                            <div class="star-picker edit-star-picker" id="editStarPicker-@r.Id">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <span class="pick-star @(i <= r.Rating ? "active" : "")"
                                          data-value="@i"
                                          data-review="@r.Id">★</span>
                                }
                            </div>
                            <input type="hidden" id="editRating-@r.Id" value="@r.Rating" />
                            <textarea id="editComment-@r.Id" maxlength="500">@r.Comment</textarea>
                            <div class="char-count">
                                <span id="editCharCount-@r.Id">@Html.Digits(r.Comment.Length)</span>/@Html.Digits(500)
                            </div>
                            <div class="edit-actions">
                                <button class="btn-save-edit" onclick="saveEdit(@r.Id)">💾 @Html.L("Common_Save")</button>
                                <button class="btn-cancel-edit" onclick="toggleEditForm(@r.Id)">@Html.L("Common_Cancel")</button>
                            </div>
                            <p id="editMsg-@r.Id" class="review-msg"></p>
                        </div>
                    }

                    <!-- Helpful Button -->
                    <div class="review-footer">
                        @if (!isGuest && !isAdmin)
                        {
                            <button class="btn-helpful" id="helpful-btn-@r.Id" onclick="toggleHelpful(@r.Id)">
                                👍 @Html.L("Review_HelpfulLabel") (<span id="helpful-count-@r.Id">@Html.Digits(0)</span>)
                            </button>
                        }
                        else
                        {
                            <span class="helpful-display">👍 <span id="helpful-count-@r.Id">@Html.Digits(0)</span></span>
                        }
                    </div>
                </div>
            }
        }
    </div>
</section>

<!-- ══════════════ Report Modal ══════════════ -->
<div id="reportModalOverlay" class="report-overlay" onclick="closeReportModal()"></div>
<div id="reportModal" class="report-modal">
    <h4>🚩 @Html.L("Review_ReportModal_Title")</h4>
    <p class="report-subtitle">@Html.L("Review_ReportModal_Sub")</p>
    <input type="hidden" id="reportReviewId" value="0" />
    <div class="report-reasons">
        <button class="reason-btn" onclick="selectReason(this, '@Html.L("Review_Reason_Spam").Replace("'", "\\'")')">@Html.L("Review_Reason_Spam")</button>
        <button class="reason-btn" onclick="selectReason(this, '@Html.L("Review_Reason_Offensive").Replace("'", "\\'")')">@Html.L("Review_Reason_Offensive")</button>
        <button class="reason-btn" onclick="selectReason(this, '@Html.L("Review_Reason_Irrelevant").Replace("'", "\\'")')">@Html.L("Review_Reason_Irrelevant")</button>
        <button class="reason-btn" onclick="selectReason(this, '@Html.L("Review_Reason_Misinfo").Replace("'", "\\'")')">@Html.L("Review_Reason_Misinfo")</button>
    </div>
    <textarea id="reportReason" placeholder="@Html.L("Review_ReportPlaceholder")" maxlength="300"></textarea>
    <div class="report-actions">
        <button class="btn-submit-report" onclick="submitReport()">@Html.L("Review_SubmitReportBtn")</button>
        <button class="btn-cancel-report" onclick="closeReportModal()">@Html.L("Common_Cancel")</button>
    </div>
    <p id="reportMsg" class="review-msg"></p>
</div>

