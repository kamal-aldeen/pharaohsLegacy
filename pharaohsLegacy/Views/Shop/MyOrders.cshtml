@model List<pharaohsLegacy.Models.ShopOrder>
@using pharaohsLegacy.Extensions
@{
    ViewData["Title"] = "My Orders";
    var lang = Context.Session.GetString("Lang") ?? "en";
}

<div class="shop-wrap">
    <nav class="breadcrumbs">
        <a href="/Shop/Index">@Html.L("Shop_Title")</a>
        <span class="crumb-sep">/</span>
        <span class="crumb-current">@Html.L("Shop_MyOrders")</span>
    </nav>

    <div class="shop-hero">
        <h1 class="shop-page-title">@Html.L("Shop_MyOrders")</h1>
        <div class="shop-hero-divider"><span>𓋹</span></div>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="shop-alert shop-alert-success">@TempData["Message"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="shop-alert shop-alert-error">@TempData["Error"]</div>
    }

    @if (!Model.Any())
    {
        <div class="shop-empty-state">
            <div class="shop-empty-glyph">𓆓</div>
            <p>@Html.L("Shop_NoOrders")</p>
            <a href="/Shop/Index" class="btn-gold">@Html.L("Shop_Cart_ContinueShopping")</a>
        </div>
    }
    else
    {
        <div class="orders-list">
            @foreach (var o in Model)
            {
                // 🆕 تراك الشحن ذو معنى بس لما الأوردر Confirmed
                var steps = new[] { "Processing", "Shipped", "Delivered" };
                var currentStepIndex = Array.IndexOf(steps, o.ShippingStatus);
                // 🆕 نفس شرط الإلغاء بالظبط اللي في الكنترولر — لو اتغيّر هناك، غيّره هنا كمان
                var canCancel = o.Status == "Confirmed" && o.ShippingStatus == "Processing";

                <div class="order-card">
                    <div class="order-card-header">
                        <span class="order-id">@Html.L("Shop_Order_Number") #@Html.Digits(o.Id)</span>
                        <span class="order-date">@o.CreatedAt.ToString("dd MMM yyyy")</span>
                        <span class="order-status status-@o.Status.ToLower()">@o.Status</span>
                    </div>

                    @if (o.Status == "Confirmed")
                    {
                        // 🆕 موعد الوصول المتوقع — بيتحسب من جديد في كل مرة الصفحة بتتفتح، فلو الأوردر
                        // "هيوصل بعد 3 أيام" النهارده، هيبقى "هيوصل بعد يومين" بكرا تلقائي من غير أي كرون جوب إضافي
                        var deliveryDays = pharaohsLegacy.Models.Governorates.GetDeliveryDays(o.Governorate);
                        DateTime? etaDate = o.ShippingStatus == "Shipped" && o.ShippedAt != null
                            ? o.ShippedAt.Value.Date.AddDays(deliveryDays)
                            : (DateTime?)null;

                        <div class="order-track">
                            @for (int i = 0; i < steps.Length; i++)
                            {
                                <div class="track-step @(i <= currentStepIndex ? "done" : "")">
                                    <span class="track-dot"></span>
                                    <span class="track-label">@Html.L("Shop_Track_" + steps[i])</span>
                                </div>
                                if (i < steps.Length - 1)
                                {
                                    <div class="track-line @(i < currentStepIndex ? "done" : "")"></div>
                                }
                            }
                        </div>

                        <div class="order-eta">
                            <svg class="icon" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="7" width="14" height="10"/><path d="M15 10h4l3 3v4h-7"/><circle cx="6" cy="19" r="1.8"/><circle cx="17.5" cy="19" r="1.8"/></svg>
                            @if (o.ShippingStatus == "Processing")
                            {
                                <span>@Html.L("Shop_Track_WillShipSoon")</span>
                            }
                            else if (o.ShippingStatus == "Shipped" && etaDate.HasValue)
                            {
                                var daysRemaining = (etaDate.Value - DateTime.Now.Date).Days;
                                if (daysRemaining <= 0)
                                {
                                    <span>@Html.L("Shop_Track_ArrivesToday")</span>
                                }
                                else if (daysRemaining == 1)
                                {
                                    <span>@Html.L("Shop_Track_ArrivesTomorrow")</span>
                                }
                                else
                                {
                                    <span>@Html.L("Shop_Track_ArrivesIn") @Html.Digits(daysRemaining) @Html.L("Shop_Track_Days") (@etaDate.Value.ToString("dd MMM"))</span>
                                }
                            }
                            else if (o.ShippingStatus == "Delivered" && o.DeliveredAt != null)
                            {
                                <span>@Html.L("Shop_Track_DeliveredOn") @o.DeliveredAt.Value.ToString("dd MMM yyyy")</span>
                            }
                        </div>
                    }
                    @if (o.Status == "Cancelled")
                    {
                        <p class="order-note">@Html.L("Shop_Cancel_PendingRefundNote")</p>
                    }

                    <div class="order-items">
                        @foreach (var item in o.Items)
                        {
                            <div class="order-row">
                                <img src="@item.ProductImage" alt="@item.ProductName" />
                                <div class="order-info">
                                    <h4>@item.ProductName</h4>
                                    <span>@Html.L("Shop_Quantity_Label"): @Html.Digits((object)item.Quantity)</span>
                                </div>
                                <span class="order-item-price">@Html.Digits((object)(item.UnitPrice * item.Quantity)) @Html.L("Common_EGP")</span>
                            </div>
                        }
                    </div>

                    <div class="order-card-footer">
                        <div class="order-delivery">
                            <span><svg class="icon" viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s7-6.7 7-11.8A7 7 0 1 0 5 9.2C5 14.3 12 21 12 21z"/><circle cx="12" cy="9.2" r="2.2"/></svg> @o.Address, @o.Governorate</span>
                            <span><svg class="icon" viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6.6 3h3l1.4 4.4-2 1.7a12.3 12.3 0 0 0 5.9 5.9l1.7-2L21 14.4v3a2 2 0 0 1-2.2 2A17.3 17.3 0 0 1 4.6 5.2 2 2 0 0 1 6.6 3z"/></svg> @o.PhoneNumber</span>
                        </div>
                        <div class="order-totals">
                            <span>@Html.L("Shop_Checkout_Shipping"): @Html.Digits((object)o.ShippingFee) @Html.L("Common_EGP")</span>
                            <span class="order-grand-total">@Html.L("Booking_Total_Label"): @Html.Digits((object)o.TotalPrice) @Html.L("Common_EGP")</span>
                        </div>
                    </div>

                    @if (canCancel)
                    {
                        <div class="order-cancel-form">
                            <button type="button" class="order-cancel-btn"
                                    onclick="openCancelOrderModal(@o.Id, '#@Html.Digits(o.Id)', @o.TotalPrice.ToString(System.Globalization.CultureInfo.InvariantCulture))">
                                <svg class="icon" viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M5 5l14 14M19 5L5 19"/></svg> @Html.L("Shop_Cancel_Order")
                            </button>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@* 🆕 مودال إلغاء الطلب — بديل عن الـ confirm() الافتراضي بتاع المتصفح، بنفس فكرة مودال إلغاء الحجز في الداشبورد *@
<div id="cancelOrderOverlay" class="cancel-order-overlay">
  <div class="cancel-order-modal">
    <div class="cancel-order-head">
      <div class="cancel-order-title"><svg class="icon" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M5 5l14 14M19 5L5 19"/></svg> @Html.L("Shop_Cancel_Order")</div>
      <div class="cancel-order-sub">@Html.L("Shop_Cancel_Confirm")</div>
      <button type="button" class="cancel-order-close" onclick="closeCancelOrderModal()"><svg class="icon" viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M5 5l14 14M19 5L5 19"/></svg></button>
    </div>

    <div class="cancel-order-body">
      <div class="cancel-order-summary">
        <div class="cancel-order-row">
          <span>@Html.L("Shop_Order_Number")</span>
          <span id="cancelOrderNumber" class="cancel-order-value"></span>
        </div>
        <div class="cancel-order-divider"></div>
        <div class="cancel-order-row">
          <span>@Html.L("Booking_Total_Label")</span>
          <span id="cancelOrderAmount" class="cancel-order-value cancel-order-amount"></span>
        </div>
      </div>
      <div class="cancel-order-warning">
        <span><svg class="icon" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3.5l9.5 16.5H2.5L12 3.5z"/><path d="M12 9.5v5"/><circle cx="12" cy="17.3" r="0.9" fill="currentColor" stroke="none"/></svg></span>
        <span>@Html.L("Shop_Cancel_PendingRefundNote")</span>
      </div>
    </div>

    <div class="cancel-order-foot">
      <button type="button" class="cancel-order-keep" onclick="closeCancelOrderModal()">@Html.L("Shop_Cancel_Keep")</button>
      <form id="cancelOrderForm" asp-controller="Shop" asp-action="Cancel" method="post" style="margin:0;">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" id="cancelOrderId" />
        <button type="submit" class="cancel-order-confirm"><svg class="icon" viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M5 5l14 14M19 5L5 19"/></svg> @Html.L("Shop_Cancel_Order")</button>
      </form>
    </div>
  </div>
</div>

<style>
    .shop-wrap { max-width: 1280px; margin: 0 auto; padding: 2.5rem 2rem 4rem; }
    .shop-hero { margin-bottom: 2.25rem; }
    .shop-page-title { font-family: 'Cinzel', serif; font-size: clamp(1.9rem, 4vw, 2.4rem); font-weight: 600; color: var(--gold); text-align: center; letter-spacing: 3px; margin: 0; }
    .shop-hero-divider { display: flex; align-items: center; justify-content: center; gap: .9rem; margin-top: 1rem; color: var(--gold); }
    .shop-hero-divider::before, .shop-hero-divider::after { content: ''; flex: 1; max-width: 90px; height: 1px; background: linear-gradient(90deg, transparent, rgba(var(--gold-rgb),.55)); }
    .shop-hero-divider::after { background: linear-gradient(90deg, rgba(var(--gold-rgb),.55), transparent); }
    .shop-hero-divider span { font-size: 1.1rem; opacity: .85; }
    .shop-empty-state { text-align: center; padding: 5rem 1rem; color: var(--muted); }
    .shop-empty-glyph { font-size: 2.6rem; margin-bottom: 1rem; opacity: .7; }
    .shop-empty-state p { margin-bottom: 1.5rem; font-size: 1.05rem; }

    .breadcrumbs { font-size: .82rem; color: var(--muted); margin-bottom: 1.5rem; display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
    .breadcrumbs a { color: var(--muted); text-decoration: none; }
    .breadcrumbs a:hover { color: var(--gold); }
    .breadcrumbs .crumb-sep { color: var(--border); }
    .breadcrumbs .crumb-current { color: var(--gold); font-weight: 600; }

    .orders-list { display: flex; flex-direction: column; gap: 1.5rem; max-width: 860px; margin: 0 auto; }
    .order-card { background: linear-gradient(160deg, var(--dark3), var(--dark)); border: 1px solid var(--border); border-radius: 14px; padding: 1.6rem; box-shadow: 0 12px 32px -16px rgba(0,0,0,.5); }
    .order-card-header { display: flex; align-items: center; gap: 1.2rem; margin-bottom: 1.2rem; padding-bottom: 1rem; border-bottom: 1px solid var(--border); flex-wrap: wrap; }
    .order-id { font-family: 'Cinzel', serif; color: var(--text); font-size: .95rem; font-weight: 600; }
    .order-date { color: var(--muted); font-size: .85rem; margin-inline-end: auto; }
    .order-items { display: flex; flex-direction: column; gap: .9rem; }
    .order-row { display: flex; align-items: center; gap: 1.1rem; }
    .order-row img { width: 60px; height: 60px; object-fit: cover; border-radius: 8px; border: 1px solid var(--border); }
    .order-info { flex: 1; display: flex; flex-direction: column; gap: .25rem; }
    .order-info h4 { margin: 0; font-family: 'Cinzel', serif; color: var(--text); font-size: .95rem; font-weight: 600; }
    .order-info span { font-size: .82rem; color: var(--muted); }
    .order-item-price { font-size: .9rem; color: var(--gold); font-family: 'Cinzel', serif; font-weight: 700; white-space: nowrap; }
    .order-status { font-size: .72rem; padding: .4rem .9rem; border-radius: 20px; font-family: 'Cinzel', serif; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; }
    .status-confirmed { background: rgba(63,174,90,.15); color: #3fae5a; }
    .status-cancelled, .status-refunded { background: rgba(192,57,43,.15); color: #e0685a; }
    .order-card-footer { display: flex; justify-content: space-between; align-items: flex-end; margin-top: 1.2rem; padding-top: 1rem; border-top: 1px solid var(--border); flex-wrap: wrap; gap: .8rem; }
    .order-delivery { display: flex; flex-direction: column; gap: .3rem; font-size: .82rem; color: var(--muted); }
    .order-delivery span { display: flex; align-items: center; gap: 6px; }
    .icon { display: inline-block; vertical-align: -2px; flex-shrink: 0; }
    .order-totals { display: flex; flex-direction: column; gap: .3rem; align-items: flex-end; font-size: .82rem; color: var(--muted); }
    .order-grand-total { font-family: 'Cinzel', serif; color: var(--gold); font-size: 1.05rem; font-weight: 800; }

    /* 🎨 Shipping Tracker */
    .order-track { display: flex; align-items: center; margin-bottom: 1.2rem; padding-bottom: 1rem; border-bottom: 1px solid var(--border); }
    .track-step { display: flex; flex-direction: column; align-items: center; gap: .4rem; flex: 0 0 auto; }
    .track-dot { width: 14px; height: 14px; border-radius: 50%; background: var(--border); border: 2px solid var(--border); transition: all .3s; }
    .track-step.done .track-dot { background: var(--gold); border-color: var(--gold); box-shadow: 0 0 0 4px rgba(var(--gold-rgb),.18); }
    .track-label { font-size: .72rem; color: var(--muted); font-family: 'Cinzel', serif; white-space: nowrap; }
    .track-step.done .track-label { color: var(--gold); font-weight: 600; }
    .track-line { flex: 1 1 auto; height: 2px; background: var(--border); margin: 0 .5rem; margin-bottom: 1.4rem; }
    .track-line.done { background: var(--gold); }

    /* 🎨 Estimated arrival note */
    .order-eta { display: flex; align-items: center; gap: 8px; font-size: .82rem; color: var(--gold); margin-bottom: 1.2rem; padding-bottom: 1rem; border-bottom: 1px solid var(--border); font-weight: 600; }

    /* 🎨 Cancel button + notes */
    .order-note { font-size: .82rem; color: var(--muted); margin: 0 0 1.2rem; font-style: italic; }
    .order-cancel-form { margin-top: 1.2rem; text-align: end; }
    .order-cancel-btn { background: transparent; border: 1.5px solid #c0392b; color: #e0685a; padding: .6rem 1.4rem; border-radius: 8px; font-family: 'Cinzel', serif; font-weight: 600; font-size: .82rem; cursor: pointer; transition: .25s; display: inline-flex; align-items: center; gap: 6px; }
    .order-cancel-btn:hover { background: #c0392b; color: #fff; box-shadow: 0 6px 16px rgba(192,57,43,.3); }

    .shop-alert { max-width: 860px; margin: 0 auto 1.5rem; padding: 1rem 1.2rem; border-radius: 10px; font-size: .9rem; }
    .shop-alert-success { background: rgba(63,174,90,.15); color: #3fae5a; }
    .shop-alert-error { background: rgba(192,57,43,.15); color: #e0685a; }

    @@media (max-width: 560px) {
        .shop-wrap { padding: 1.75rem 1.1rem 3rem; }
        .order-card { padding: 1.2rem; }
        .order-card-footer { flex-direction: column; align-items: flex-start; }
        .order-totals { align-items: flex-start; }
        .track-label { font-size: .62rem; }
    }

    /* 🆕 مودال إلغاء الطلب */
    .cancel-order-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.72); z-index: 9999; align-items: center; justify-content: center; backdrop-filter: blur(4px); padding: 1rem; }
    .cancel-order-overlay.active { display: flex; }
    .cancel-order-modal { background: linear-gradient(160deg, var(--dark3), var(--dark)); border: 1px solid rgba(var(--gold-rgb),.25); border-radius: 16px; width: 100%; max-width: 440px; overflow: hidden; animation: cancelOrderFadeIn .22s ease; }
    @@keyframes cancelOrderFadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    .cancel-order-head { position: relative; padding: 1.5rem 1.75rem 1.2rem; border-bottom: 1px solid var(--border); }
    .cancel-order-title { font-family: 'Cinzel', serif; font-size: 1.05rem; color: #e0685a; letter-spacing: 1px; font-weight: 700; display: flex; align-items: center; gap: 8px; }
    .cancel-order-sub { font-size: .82rem; color: var(--muted); margin-top: .4rem; }
    .cancel-order-close { position: absolute; top: 1.1rem; inset-inline-end: 1.1rem; width: 30px; height: 30px; border-radius: 50%; background: rgba(255,255,255,.05); border: none; color: var(--muted); font-size: .85rem; cursor: pointer; transition: .2s; display: flex; align-items: center; justify-content: center; }
    .cancel-order-close:hover { background: rgba(192,57,43,.18); color: #e0685a; }
    .cancel-order-body { padding: 1.5rem 1.75rem; }
    .cancel-order-summary { background: rgba(var(--gold-rgb),.06); border: 1px solid rgba(var(--gold-rgb),.18); border-radius: 10px; padding: 1rem 1.1rem; display: flex; flex-direction: column; gap: .7rem; margin-bottom: 1.2rem; }
    .cancel-order-row { display: flex; justify-content: space-between; align-items: center; font-size: .85rem; color: var(--muted); }
    .cancel-order-value { color: var(--text); font-weight: 600; font-family: 'Cinzel', serif; }
    .cancel-order-amount { color: var(--gold); font-size: 1.05rem; font-weight: 800; }
    .cancel-order-divider { height: 1px; background: rgba(var(--gold-rgb),.12); }
    .cancel-order-warning { background: rgba(192,57,43,.08); border: 1px solid rgba(192,57,43,.22); border-radius: 8px; padding: .8rem .95rem; display: flex; gap: .7rem; align-items: flex-start; font-size: .8rem; color: #e0685a; line-height: 1.6; }
    .cancel-order-warning .icon { margin-top: 2px; }
    .cancel-order-foot { display: flex; gap: .7rem; justify-content: flex-end; padding: 1.1rem 1.75rem 1.5rem; border-top: 1px solid var(--border); }
    .cancel-order-keep { padding: .65rem 1.3rem; border-radius: 8px; border: 1px solid var(--border); background: rgba(255,255,255,.04); color: var(--muted); cursor: pointer; font-size: .82rem; font-family: 'Cinzel', serif; transition: .2s; }
    .cancel-order-keep:hover { background: rgba(255,255,255,.08); color: var(--text); }
    .cancel-order-confirm { padding: .65rem 1.4rem; border-radius: 8px; border: none; background: linear-gradient(135deg, #a8281f, #e0453a); color: #fff; font-weight: 700; font-size: .82rem; font-family: 'Cinzel', serif; letter-spacing: .5px; cursor: pointer; transition: opacity .2s; display: inline-flex; align-items: center; gap: 6px; }
    .cancel-order-confirm:hover { opacity: .88; }
</style>

<script>
    // 🆕 مودال إلغاء الطلب — بديل الـ confirm() الافتراضي
    var cancelOrderCurrencyLabel = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Html.L("Common_EGP")));
    var cancelOrderLang = '@lang';
    var cancelOrderArabicDigitsMap = ['٠', '١', '٢', '٣', '٤', '٥', '٦', '٧', '٨', '٩'];
    function cancelOrderToLocalDigits(input) {
        var str = String(input);
        if (cancelOrderLang !== 'ar') return str;
        return str.replace(/[0-9]/g, function (d) { return cancelOrderArabicDigitsMap[+d]; });
    }
    function openCancelOrderModal(id, orderNumber, amount) {
        document.getElementById('cancelOrderId').value = id;
        document.getElementById('cancelOrderNumber').textContent = orderNumber;
        document.getElementById('cancelOrderAmount').textContent = cancelOrderToLocalDigits(amount) + ' ' + cancelOrderCurrencyLabel;
        document.getElementById('cancelOrderOverlay').classList.add('active');
        document.body.style.overflow = 'hidden';
    }
    function closeCancelOrderModal() {
        document.getElementById('cancelOrderOverlay').classList.remove('active');
        document.body.style.overflow = '';
    }
    document.getElementById('cancelOrderOverlay').addEventListener('click', function (e) {
        if (e.target === this) closeCancelOrderModal();
    });
</script>
