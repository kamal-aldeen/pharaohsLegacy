@using pharaohsLegacy.Extensions
@{
    ViewData["Title"] = "Home";
    var pharaohs = ViewBag.Pharaohs as List<pharaohsLegacy.Models.Pharaoh>;
    var temples = ViewBag.Temples as List<pharaohsLegacy.Models.Temple>;
    var lang = Context.Session.GetString("Lang") ?? "en";
    var arrowNext = lang == "ar" ? "←" : "→";
}

@if (TempData["Error"] != null)
{
    <div style="
        position: fixed;
        top: 20px;
        right: 20px;
        z-index: 9999;
        background: var(--dark3);
        border: 1px solid var(--gold);
        border-radius: 10px;
        padding: 16px 24px;
        color: var(--gold);
        font-size: 14px;
        font-family: 'Cinzel', serif;
        box-shadow: 0 8px 32px rgba(0,0,0,0.5);
        animation: fadeOut 0.5s ease 3s forwards;">
        ⚠️ @TempData["Error"]
    </div>

    <style>
        @@keyframes fadeOut {
            from {
                opacity: 1;
            }

            to {
                opacity: 0;
                pointer-events: none;
            }
        }
    </style>
}


<section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-pyramid"></div>
    <div class="hero-pattern top">𓂀 𓃭 𓆣 𓇯 𓈖 𓉐 𓊃 𓋴 𓌀 𓍿 𓎛 𓏭</div>

    <div class="hero-content">
        <div class="hero-eyebrow">@Html.L("Home_Eyebrow")</div>
        <h1 class="hero-title">
            @Html.L("Home_TitleLine1")<br /><span>@Html.L("Home_TitleLine2")</span>
        </h1>
        <p class="hero-subtitle">
            @Html.L("Home_Subtitle")
        </p>
        <div class="hero-cta">
            <a href="#explore" class="btn-gold">@Html.L("Home_BtnExplore")</a>
            <a href="/Pharaoh/Index" class="btn-outline">@Html.L("Home_BtnMeetPharaohs")</a>
        </div>
    </div>

    <div class="hero-pattern bottom">𓂀 𓃭 𓆣 𓇯 𓈖 𓉐 𓊃 𓋴 𓌀 𓍿 𓎛 𓏭</div>
    <div class="hero-scroll">@Html.L("Home_Scroll")</div>
</section>

<div class="stats-bar">
    <div class="stat"><span class="stat-num">@Html.Digits("170+")</span><span class="stat-label">@Html.L("Stat_Pharaohs")</span></div>
    <div class="stat"><span class="stat-num">@Html.Digits("3,000")</span><span class="stat-label">@Html.L("Stat_YearsHistory")</span></div>
    <div class="stat"><span class="stat-num">@Html.Digits("50+")</span><span class="stat-label">@Html.L("Stat_TemplesSites")</span></div>
    <div class="stat"><span class="stat-num">@Html.Digits("30")</span><span class="stat-label">@Html.L("Stat_Dynasties")</span></div>
</div>


<div id="explore">
    <div class="section">
        <div class="section-header">
            <span class="section-tag">@Html.L("Home_Tag_Rulers")</span>
            <h2 class="section-title">@Html.L("Home_SectionTitle_Pharaohs")</h2>
            <div class="section-line"></div>
        </div>
        <div class="cards-grid">
            @if (pharaohs != null)
            {
                @foreach (var pharaoh in pharaohs)
                {
                    var phName = (lang == "ar" && !string.IsNullOrEmpty(pharaoh.NameAr)) ? pharaoh.NameAr : pharaoh.Name;
                    var phDynasty = Html.Digits((lang == "ar" && !string.IsNullOrEmpty(pharaoh.DynastyAr)) ? pharaoh.DynastyAr : pharaoh.Dynasty);
                    var phPeriod = Html.Digits((lang == "ar" && !string.IsNullOrEmpty(pharaoh.PeriodAr)) ? pharaoh.PeriodAr : pharaoh.Period);
                    var phDescription = (lang == "ar" && !string.IsNullOrEmpty(pharaoh.DescriptionAr)) ? pharaoh.DescriptionAr : pharaoh.Description;
                    <a href="/Pharaoh/Details/@pharaoh.Id" class="card">
                        <div class="card-img">
                            <img src="@pharaoh.ImageUrl" alt="@phName" />
                        </div>
                        <div class="card-body">
                            <span class="card-tag">@phDynasty</span>
                            <h3 class="card-title">@phName</h3>
                            <p class="card-desc">@phDescription</p>
                        </div>
                        <div class="card-footer">
                            <span>@phPeriod</span>
                            <span class="card-arrow">@arrowNext</span>
                        </div>
                    </a>
                }
            }
        </div>
        <div class="see-all-wrap">
            <a href="/Pharaoh/Index" class="btn-outline">@Html.L("Home_SeeAllPharaohs") @arrowNext</a>
        </div>
    </div>
</div>


<div style="background: rgba(var(--gold-rgb),.03); border-top:1px solid var(--border); border-bottom:1px solid var(--border);">
    <div class="section">
        <div class="section-header">
            <span class="section-tag">@Html.L("Home_Tag_SacredSites")</span>
            <h2 class="section-title">@Html.L("Home_SectionTitle_Temples")</h2>
            <div class="section-line"></div>
        </div>
        <div class="cards-grid">
            @if (temples != null)
            {
                @foreach (var temple in temples)
                {
                    var tpName = (lang == "ar" && !string.IsNullOrEmpty(temple.NameAr)) ? temple.NameAr : temple.Name;
                    var tpLocation = (lang == "ar" && !string.IsNullOrEmpty(temple.LocationAr)) ? temple.LocationAr : temple.Location;
                    var tpPeriod = Html.Digits((lang == "ar" && !string.IsNullOrEmpty(temple.PeriodAr)) ? temple.PeriodAr : temple.Period);
                    var tpDescription = (lang == "ar" && !string.IsNullOrEmpty(temple.DescriptionAr)) ? temple.DescriptionAr : temple.Description;
                    <a href="/Temple/Details/@temple.Id" class="card">
                        <div class="card-img">
                            <img src="@temple.ImageUrl" alt="@tpName" />
                        </div>
                        <div class="card-body">
                            <span class="card-tag">@tpLocation</span>
                            <h3 class="card-title">@tpName</h3>
                            <p class="card-desc">@tpDescription</p>
                        </div>
                        <div class="card-footer">
                            <span>@tpPeriod</span>
                            <span class="card-arrow">@arrowNext</span>
                        </div>
                    </a>
                }
            }
        </div>
        <div class="see-all-wrap">
            <a href="/Temple/Index" class="btn-outline">@Html.L("Home_SeeAllTemples") @arrowNext</a>
        </div>
    </div>
</div>


<div style="background: rgba(var(--gold-rgb),.03); border-top:1px solid var(--border); border-bottom:1px solid var(--border);">
    <div class="section">
        <div class="section-header">
            <span class="section-tag">@Html.L("Home_Tag_Collections")</span>
            <h2 class="section-title">@Html.L("Home_SectionTitle_Museums")</h2>
            <div class="section-line"></div>
        </div>
        @{
            var museums = ViewBag.Museums as List<pharaohsLegacy.Models.Museum>;
        }
        <div class="cards-grid">
            @if (museums != null)
            {
                @foreach (var m in museums)
                {
                    var muName = (lang == "ar" && !string.IsNullOrEmpty(m.NameAr)) ? m.NameAr : m.Name;
                    var muLocation = (lang == "ar" && !string.IsNullOrEmpty(m.LocationAr)) ? m.LocationAr : m.Location;
                    var muDescription = (lang == "ar" && !string.IsNullOrEmpty(m.DescriptionAr)) ? m.DescriptionAr : m.Description;
                    <a href="/Museum/Details/@m.Id" class="card">
                        <div class="card-img">
                            <img src="@m.ImageUrl" alt="@muName" />
                        </div>
                        <div class="card-body">
                            <span class="card-tag">@muLocation</span>
                            <h3 class="card-title">@muName</h3>
                            <p class="card-desc">@muDescription</p>
                        </div>
                        <div class="card-footer">
                            <span>@Html.L("Home_Est") @Html.Digits(m.Founded)</span>
                            <span class="card-arrow">@arrowNext</span>
                        </div>
                    </a>
                }
            }
        </div>
        <div class="see-all-wrap">
            <a href="/Museum/Index" class="btn-outline">@Html.L("Home_SeeAllMuseums") @arrowNext</a>
        </div>
    </div>
</div>
@{
    var gods = ViewBag.Gods as List<pharaohsLegacy.Models.God>;
}


<div class="section">
    <div class="section-header">
        <span class="section-tag">@Html.L("Home_Tag_Mythology")</span>
        <h2 class="section-title">@Html.L("Home_SectionTitle_Gods")</h2>
        <div class="section-line"></div>
    </div>
    <div class="cards-grid">
        @if (gods != null)
        {
            @foreach (var god in gods)
            {
                var gdName = (lang == "ar" && !string.IsNullOrEmpty(god.NameAr)) ? god.NameAr : god.Name;
                var gdRole = (lang == "ar" && !string.IsNullOrEmpty(god.RoleAr)) ? god.RoleAr : god.Role;
                var gdDescription = (lang == "ar" && !string.IsNullOrEmpty(god.DescriptionAr)) ? god.DescriptionAr : god.Description;
                var gdSymbol = (lang == "ar" && !string.IsNullOrEmpty(god.SymbolAr)) ? god.SymbolAr : god.Symbol;
                <a href="/God/Details/@god.Id" class="card">
                    <div class="card-img">
                        <img src="@god.ImageUrl" alt="@gdName" />
                    </div>
                    <div class="card-body">
                        <span class="card-tag">@gdRole</span>
                        <h3 class="card-title">@gdName</h3>
                        <p class="card-desc">@gdDescription</p>
                    </div>
                    <div class="card-footer">
                        <span>@gdSymbol</span>
                        <span class="card-arrow">@arrowNext</span>
                    </div>
                </a>
            }
        }
    </div>
    <div class="see-all-wrap">
        <a href="/God/Index" class="btn-outline">@Html.L("Home_SeeAllGods") @arrowNext</a>
    </div>
</div>