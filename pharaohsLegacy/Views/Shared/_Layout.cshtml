<script>
    
    function toggleNav() {
        var links = document.getElementById('navLinks');
        var btn = document.getElementById('navToggle');
        var isOpen = links.classList.toggle('open');
        if (btn) btn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    }

    // ── Theme Toggle (Light / Dark) — Circle Reveal Animation ──
    // دايرة بتتوسع من مكان الزرار وقت الضغط؛ لو المتصفح مش بيدعم
    // View Transitions API، بترجع تلقائي للتبديل الفوري العادي.
    function updateThemeToggleTitle() {
        var btn = document.getElementById('themeToggle');
        if (!btn) return;
        var isLight = document.documentElement.getAttribute('data-theme') === 'light';
        btn.title = isLight ? 'Switch to Dark mode' : 'Switch to Light mode';
    }

    function applyThemeChange() {
        var html = document.documentElement;
        var isLight = html.getAttribute('data-theme') === 'light';
        if (isLight) {
            html.removeAttribute('data-theme');
            localStorage.setItem('plTheme', 'dark');
        } else {
            html.setAttribute('data-theme', 'light');
            localStorage.setItem('plTheme', 'light');
        }
        updateThemeToggleTitle();
    }

    function toggleTheme(e) {
        // فallback: المتصفح مش بيدعم الأنيميشن → تبديل فوري زي ما هو
        if (!document.startViewTransition || !e) {
            applyThemeChange();
            return;
        }

        var x = e.clientX;
        var y = e.clientY;
        var endRadius = Math.hypot(
            Math.max(x, window.innerWidth - x),
            Math.max(y, window.innerHeight - y)
        );

        var transition = document.startViewTransition(applyThemeChange);
        transition.ready.then(function () {
            document.documentElement.animate(
                {
                    clipPath: [
                        'circle(0px at ' + x + 'px ' + y + 'px)',
                        'circle(' + endRadius + 'px at ' + x + 'px ' + y + 'px)'
                    ]
                },
                {
                    duration: 500,
                    easing: 'ease-in-out',
                    pseudoElement: '::view-transition-new(root)'
                }
            );
        });
    }

    updateThemeToggleTitle();

    // ── 3. Skeleton shimmer وقت تحميل الصور ──
    document.querySelectorAll('img').forEach(function (img) {
        if (!img.complete) {
            img.classList.add('pl-img-loading');
        }
        img.addEventListener('load', function () {
            this.classList.remove('pl-img-loading');
        });
        img.addEventListener('error', function () {
            this.classList.remove('pl-img-loading');
            // SVG محلي كـ data URI بدل خدمة خارجية (via.placeholder.com بيقع أحياناً)
            this.src = 'data:image/svg+xml;utf8,' + encodeURIComponent(
                '<svg xmlns="http://www.w3.org/2000/svg" width="400" height="300" viewBox="0 0 400 300">' +
                '<rect width="400" height="300" fill="#2d1a08"/>' +
                '<text x="50%" y="50%" fill="#c9a227" font-family="serif" font-size="18" text-anchor="middle" dominant-baseline="middle">𓁹 No Image</text>' +
                '</svg>'
            );
        });
    });

    // ── 2. Ripple effect عند الضغط على أي زرار في الموقع ──
    document.addEventListener('click', function (e) {
        var target = e.target.closest('button, .btn-gold, .nav-logout, a.card, .theme-toggle');
        if (!target) return;
        target.classList.add('pl-ripple-host');
        var rect = target.getBoundingClientRect();
        var size = Math.max(rect.width, rect.height);
        var span = document.createElement('span');
        span.className = 'pl-ripple-span';
        span.style.width = span.style.height = size + 'px';
        span.style.left = (e.clientX - rect.left - size / 2) + 'px';
        span.style.top = (e.clientY - rect.top - size / 2) + 'px';
        target.appendChild(span);
        span.addEventListener('animationend', function () { span.remove(); });
    });

    // ── 3. Navbar يتقلّص شوية عند الـ Scroll ──
    (function () {
        var nav = document.querySelector('nav.main-nav');
        if (!nav) return;
        window.addEventListener('scroll', function () {
            nav.classList.toggle('pl-scrolled', window.scrollY > 40);
        }, { passive: true });
    })();

    // ── 6. Favorite Heart Pulse — نبضة بسيطة عند الضغط على أي زرار مفضلة ──
    document.addEventListener('click', function (e) {
        var heart = e.target.closest('[class*="fav"]');
        if (!heart) return;
        heart.classList.remove('pl-heart-pulse');
        void heart.offsetWidth; // reflow عشان الأنيميشن تتكرر لو اتضغط تاني بسرعة
        heart.classList.add('pl-heart-pulse');
    });

    // ── 7. Theme Toggle — لفتة انتباه لطيفة أول زيارة بس ──
    (function () {
        var btn = document.getElementById('themeToggle');
        if (!btn || sessionStorage.getItem('plThemeHintShown')) return;
        setTimeout(function () {
            btn.classList.add('pl-hint');
            sessionStorage.setItem('plThemeHintShown', '1');
            btn.addEventListener('animationend', function () { btn.classList.remove('pl-hint'); }, { once: true });
        }, 1200);
    })();
</script>

@await RenderSectionAsync("Scripts", required: false)
<script src="~/js/pharaoh.js"></script>
    <!-- ═══════════ AI Tour Guide Widget ═══════════ -->
    <style>
        .aichat-btn {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: linear-gradient(135deg, #c9a227, #7a5e10);
        border: 2px solid rgba(201,162,39,0.4);
        cursor: pointer;
        font-size: 1.6rem;
        color: #0d0702;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 24px rgba(201,162,39,0.35), 0 0 0 0 rgba(201,162,39,0.4);
        animation: ai-pulse 2.5s infinite;
        transition: transform 0.3s, box-shadow 0.3s;
        }

        .aichat-btn:hover {
        transform: scale(1.08);
        box-shadow: 0 6px 32px rgba(201,162,39,0.55);
        }

        .aichat-btn.active {
        animation: none;
        transform: rotate(20deg) scale(1.05);
        }

        @@keyframes ai-pulse {
        0%, 100% {
        box-shadow: 0 4px 24px rgba(201,162,39,0.35), 0 0 0 0 rgba(201,162,39,0.3);
        }

        50% {
        box-shadow: 0 4px 24px rgba(201,162,39,0.35), 0 0 0 10px rgba(201,162,39,0);
        }
        }

        .aichat-popup {
        position: fixed;
        bottom: 102px;
        right: 28px;
        z-index: 9998;
        width: 380px;
        background: var(--dark2);
        border: 1px solid rgba(var(--gold-rgb),0.25);
        border-radius: 20px;
        box-shadow: 0 24px 60px rgba(0,0,0,0.35), 0 0 0 1px rgba(var(--gold-rgb),0.08);
        display: none;
        flex-direction: column;
        overflow: hidden;
        transform-origin: bottom right;
        transition: background .25s ease, border-color .25s ease;
        }

        .aichat-popup.open {
        display: flex;
        animation: aiPopIn 0.3s cubic-bezier(0.34,1.56,0.64,1);
        }

        @@keyframes aiPopIn {
        from {
        opacity: 0;
        transform: scale(0.85) translateY(12px);
        }

        to {
        opacity: 1;
        transform: scale(1) translateY(0);
        }
        }

        /* Header */
        .aichat-header {
        padding: 16px 18px;
        background: var(--dark3);
        border-bottom: 1px solid rgba(var(--gold-rgb),0.15);
        display: flex;
        align-items: center;
        gap: 12px;
        position: relative;
        }

        .aichat-header::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 18px;
        right: 18px;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(201,162,39,0.3), transparent);
        }

        .aichat-avatar-wrap {
        position: relative;
        }

        .aichat-avatar {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        background: linear-gradient(135deg, #c9a227, #5a3d08);
        border: 2px solid rgba(201,162,39,0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        color: #0d0702;
        flex-shrink: 0;
        box-shadow: 0 0 14px rgba(201,162,39,0.3);
        }

        .aichat-online-dot {
        position: absolute;
        bottom: 1px;
        right: 1px;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: #4caf76;
        border: 2px solid var(--dark2);
        }

        .aichat-info {
        flex: 1;
        }

        .aichat-name {
        font-family: 'Cinzel', serif;
        font-size: 0.85rem;
        color: var(--gold);
        letter-spacing: 1px;
        display: block;
        line-height: 1.2;
        }

        .aichat-sub {
        font-size: 0.68rem;
        color: #6a8a5a;
        font-family: 'Crimson Pro', serif;
        font-style: italic;
        display: flex;
        align-items: center;
        gap: 5px;
        margin-top: 2px;
        }

        .aichat-sub::before {
        content: '';
        width: 5px;
        height: 5px;
        background: #4caf76;
        border-radius: 50'; display: inline-block;
        }

        .aichat-close {
        background: var(--surface-tint);
        border: 1px solid rgba(var(--gold-rgb),0.15);
        border-radius: 8px;
        color: var(--muted);
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.2s;
        width: 30px;
        height: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        }

        .aichat-close:hover {
        background: rgba(var(--gold-rgb),0.1);
        color: var(--gold);
        border-color: rgba(var(--gold-rgb),0.35);
        }

        /* Messages */
        .aichat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 16px 14px;
        display: flex;
        flex-direction: column;
        gap: 14px;
        max-height: 420px;
        min-height: 280px;
        scrollbar-width: thin;
        scrollbar-color: rgba(201,162,39,0.2) transparent;
        }

        .aichat-messages::-webkit-scrollbar {
        width: 3px;
        }

        .aichat-messages::-webkit-scrollbar-thumb {
        background: rgba(201,162,39,0.2);
        border-radius: 4px;
        }

        .aichat-msg {
        display: flex;
        gap: 9px;
        align-items: flex-end;
        }

        .aichat-msg.user {
        flex-direction: row-reverse;
        }

        .aichat-msg-av {
        width: 30px;
        height: 30px;
        border-radius: 50%;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.85rem;
        border: 1px solid rgba(201,162,39,0.2);
        }

        .aichat-msg.bot .aichat-msg-av {
        background: var(--dark3);
        color: var(--gold);
        }

        .aichat-msg.user .aichat-msg-av {
        background: linear-gradient(135deg, #c9a227, #7a5e10);
        color: #0d0702;
        }

        .aichat-bubble {
        max-width: 80%;
        padding: 10px 14px;
        border-radius: 16px;
        font-family: 'Crimson Pro', serif;
        font-size: 0.92rem;
        line-height: 1.65;
        animation: bubbleIn 0.25s ease;
        }

        @@keyframes bubbleIn {
        from {
        opacity: 0;
        transform: scale(0.95) translateY(4px);
        }

        to {
        opacity: 1;
        transform: scale(1) translateY(0);
        }
        }

        .aichat-msg.bot .aichat-bubble {
        background: var(--dark3);
        border: 1px solid rgba(var(--gold-rgb),0.18);
        color: var(--text);
        border-radius: 4px 16px 16px 16px;
        }

        .aichat-msg.user .aichat-bubble {
        background: linear-gradient(135deg, #c9a227, #8a6b14);
        color: #0d0702;
        font-weight: 600;
        border-radius: 16px 4px 16px 16px;
        box-shadow: 0 2px 12px rgba(201,162,39,0.2);
        }

        /* Typing dots */
        .aichat-typing .aichat-bubble {
        display: flex;
        gap: 5px;
        align-items: center;
        padding: 13px 16px;
        }

        .aichat-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: rgba(201,162,39,0.5);
        animation: aiDot 1.3s infinite;
        }

        .aichat-dot:nth-child(2) {
        animation-delay: 0.2s;
        }

        .aichat-dot:nth-child(3) {
        animation-delay: 0.4s;
        }

        @@keyframes aiDot {
        0%, 60%, 100% {
        transform: translateY(0);
        opacity: 0.5;
        }

        30% {
        transform: translateY(-6px);
        opacity: 1;
        }
        }

        /* Suggestions */
        .aichat-suggestions {
        padding: 0 14px 10px;
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        }

        .aichat-sug {
        background: rgba(var(--gold-rgb),0.07);
        border: 1px solid rgba(var(--gold-rgb),0.2);
        border-radius: 20px;
        padding: 5px 12px;
        font-family: 'Cinzel', serif;
        font-size: 0.62rem;
        color: var(--muted);
        cursor: pointer;
        transition: all 0.2s;
        letter-spacing: 0.5px;
        }

        .aichat-sug:hover {
        background: rgba(var(--gold-rgb),0.14);
        color: var(--gold);
        border-color: rgba(var(--gold-rgb),0.4);
        }

        /* Input */
        .aichat-input-wrap {
        padding: 12px 14px;
        border-top: 1px solid rgba(var(--gold-rgb),0.12);
        background: var(--well-bg);
        display: flex;
        gap: 8px;
        align-items: flex-end;
        }

        .aichat-input {
        flex: 1;
        background: var(--surface-tint);
        border: 1px solid rgba(var(--gold-rgb),0.2);
        border-radius: 10px;
        padding: 10px 13px;
        font-family: 'Crimson Pro', serif;
        font-size: 0.9rem;
        color: var(--text);
        outline: none;
        resize: none;
        transition: border-color 0.25s, background 0.25s;
        line-height: 1.5;
        max-height: 80px;
        }

        .aichat-input::placeholder {
        color: var(--muted);
        }

        .aichat-input:focus {
        border-color: rgba(var(--gold-rgb),0.45);
        background: var(--surface-tint-strong);
        }

        .aichat-send {
        background: linear-gradient(135deg, #c9a227, #7a5e10);
        border: none;
        border-radius: 10px;
        width: 40px;
        height: 40px;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: #0d0702;
        font-size: 1rem;
        transition: all 0.2s;
        box-shadow: 0 2px 10px rgba(201,162,39,0.2);
        }

        .aichat-send:hover {
        opacity: 0.88;
        transform: scale(1.06);
        }

        .aichat-send:disabled {
        opacity: 0.35;
        cursor: not-allowed;
        transform: none;
        }

        .aichat-footer {
        text-align: center;
        padding: 6px;
        font-size: 0.6rem;
        color: var(--border);
        font-family: 'Cinzel', serif;
        letter-spacing: 1px;
        border-top: 1px solid rgba(201,162,39,0.06);
        }

        @@media (max-width: 480px) {
        .aichat-popup {
        width: calc(100vw - 32px);
        right: 16px;
        }

        .aichat-btn {
        right: 16px;
        bottom: 20px;
        }
        }
    </style>

    <!-- Floating Button -->
    <div style="position:fixed; bottom:28px; right:28px; z-index:9999; display:flex; flex-direction:column; align-items:center; gap:6px;">
        <span style="font-family:'Cinzel',serif; font-size:0.55rem; color:#c9a227; letter-spacing:2px; text-shadow:0 0 10px rgba(201,162,39,0.5);">@Html.L("Widget_AIGuideLabel")</span>
        <button class="aichat-btn" id="aichatBtn" onclick="aiToggle()" title="@Html.L("Widget_AITourGuideTitle")">𓁹</button>
    </div>

    <!-- Popup -->
    <div class="aichat-popup" id="aichatPopup">
        <div class="aichat-header">
            <div class="aichat-avatar-wrap">
                <div class="aichat-avatar">𓁹</div>
                <div class="aichat-online-dot"></div>
            </div>
            <div class="aichat-info">
                <span class="aichat-name">@Html.L("Widget_AITourGuideTitle")</span>
                <span class="aichat-sub">@Html.L("Widget_OnlineStatus")</span>
            </div>
            <button class="aichat-close" onclick="aiExpand()" title="@Html.L("Common_Expand")" style="margin-inline-end:4px;">⛶</button>
            <button class="aichat-close" onclick="aiToggle()">✕</button>
        </div>

        <div class="aichat-messages" id="aichatMsgs">
            <div class="aichat-msg bot">
                <div class="aichat-msg-av">𓁹</div>
                <div class="aichat-bubble">
                    @Html.L("Widget_WelcomeMessage")
                </div>
            </div>
        </div>

        <div class="aichat-suggestions" id="aichatSugs">
            <button class="aichat-sug" onclick="aiAsk('@Html.L("Chat_Suggestion_Ramesses_Q")')">@Html.L("Widget_Suggestion_Ramesses")</button>
            <button class="aichat-sug" onclick="aiAsk('@Html.L("Chat_Suggestion_Pyramid_Q")')">@Html.L("Chat_Suggestion_Pyramid")</button>
            <button class="aichat-sug" onclick="aiAsk('@Html.L("Chat_Suggestion_Ra_Q")')">@Html.L("Chat_Suggestion_Ra")</button>
            <button class="aichat-sug" onclick="aiAsk('@Html.L("Chat_Suggestion_Cleopatra_Q")')">@Html.L("Chat_Suggestion_Cleopatra")</button>
        </div>

        <div class="aichat-input-wrap">
            <textarea class="aichat-input" id="aichatInput" rows="1"
                      placeholder="@Html.L("Chat_Input_Placeholder")"
                      onkeydown="aiKey(event)"
                      oninput="aiResize(this)"></textarea>
            <button class="aichat-send" id="aichatSend" onclick="aiSend()">➤</button>
        </div>
        <div class="aichat-footer">𓂀 @Html.L("Widget_Footer")</div>
    </div>

    <script>
        const aiErrorMsg = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Html.L("Chat_ErrorMessage")));
        // Dropdown — close on outside click
document.addEventListener('click', function(e) {
    const dropdown = document.querySelector('.nav-dropdown');
    if (dropdown && !dropdown.contains(e.target)) {
        dropdown.querySelector('.nav-dropdown-menu').style.display = 'none';
    }
});

document.querySelector('.nav-dropdown-toggle')?.addEventListener('click', function(e) {
    e.stopPropagation();
    const menu = document.querySelector('.nav-dropdown-menu');
    menu.style.display = menu.style.display === 'block' ? 'none' : 'block';
});
        
        function aiToggle() {
        const popup = document.getElementById('aichatPopup');
        const btn = document.getElementById('aichatBtn');
        popup.classList.toggle('open');
        btn.classList.toggle('active');
        if (popup.classList.contains('open'))
        document.getElementById('aichatInput').focus();
        }

        function aiKey(e) {
        if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); aiSend(); }
        }

        function aiResize(el) {
        el.style.height = 'auto';
        el.style.height = Math.min(el.scrollHeight, 80) + 'px';
        }

        function aiAsk(text) {
        document.getElementById('aichatSugs').style.display = 'none';
        document.getElementById('aichatInput').value = text;
        aiSend();
        }

        function aiAddMsg(text, role) {
        const area = document.getElementById('aichatMsgs');
        const div = document.createElement('div');
        div.className = `aichat-msg ${role}`;
        div.innerHTML = `
        <div class="aichat-msg-av">${role === 'bot' ? '𓁹' : '𓀀'}</div>
        <div class="aichat-bubble">${text}</div>`;
        area.appendChild(div);
        area.scrollTop = area.scrollHeight;
        }

        function aiTyping() {
        const area = document.getElementById('aichatMsgs');
        const div = document.createElement('div');
        div.className = 'aichat-msg bot aichat-typing';
        div.id = 'aichatTyping';
        div.innerHTML = `<div class="aichat-msg-av">𓁹</div>
        <div class="aichat-bubble">
        <span class="pl-ankh-spinner">𓋹</span>
        </div>`;
        area.appendChild(div);
        area.scrollTop = area.scrollHeight;
        }

       function aiExpand() {
    const popup = document.getElementById('aichatPopup');
    const isExpanded = popup.style.width === '520px';
    popup.style.width = isExpanded ? '380px' : '520px';
    popup.style.bottom = isExpanded ? '102px' : '20px';
}
        
        
        
        async function aiSend() {
        const input = document.getElementById('aichatInput');
        const text = input.value.trim();
        if (!text) return;
        input.value = '';
        input.style.height = 'auto';
        document.getElementById('aichatSend').disabled = true;
        document.getElementById('aichatSugs').style.display = 'none';
        aiAddMsg(text, 'user');
        aiTyping();
        try {
        const res = await fetch('/Chatbot/Ask', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: text })
        });
        const data = await res.json();
        document.getElementById('aichatTyping')?.remove();
        aiAddMsg(data.reply, 'bot');
        } catch {
        document.getElementById('aichatTyping')?.remove();
        aiAddMsg(aiErrorMsg, 'bot');
        }
        document.getElementById('aichatSend').disabled = false;
        input.focus();
        }
    </script>
    <!-- ═══════════════════════════════════════════ -->

</body>
</html>
