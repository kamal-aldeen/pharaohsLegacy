@using pharaohsLegacy.ViewModels
@model pharaohsLegacy.ViewModels.AdminOverviewViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = null; 
    var activeTab = Context.Request.Query["tab"].ToString();
    if (string.IsNullOrEmpty(activeTab)) activeTab = "overview";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Admin — Pharaohs Legacy</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
<style>

:root {
    --gold:        #c9a84c;
    --gold-light:  #f0c96e;
    --gold-dim:    #8b6914;
    --dark:        #0b0905;
    --dark-2:      #111009;
    --dark-3:      #181410;
    --dark-4:      #201c14;
    --dark-card:   #151209;
    --sidebar-w:   260px;
    --border:      rgba(201,168,76,0.15);
    --border-h:    rgba(201,168,76,0.4);
    --text:        #e8dcc8;
    --text-dim:    #9e8e70;
    --text-muted:  #5a5040;
    --red:         #e05252;
    --green:       #4caf80;
    --blue:        #5b8dd9;
    --orange:      #e09050;
    --shadow:      0 8px 32px rgba(0,0,0,0.5);
    --shadow-gold: 0 0 40px rgba(201,168,76,0.1);
    --radius:      14px;
    --radius-sm:   8px;
}
*, *::before, *::after { box-sizing: border-box; margin:0; padding:0; }
html, body { height: 100%; }
body {
    font-family: 'Inter', sans-serif;
    background: #0d0702;
    color: #e8d5b0;
    display: flex;
    overflow: hidden;
}


.adm-sidebar {
    width: var(--sidebar-w);
    height: 100vh;
    background: var(--dark-2);
    border-right: 1px solid #3d2a15 ;
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
    position: fixed;
    left: 0; top: 0;
    z-index: 100;
    overflow-y: auto;
}
.adm-logo {
    padding: 28px 24px 20px;
        border-bottom: 1px solid #3d2a15;
}
.adm-logo-symbol {
    font-size: 28px;
    margin-bottom: 8px;
    display: block;
}
.adm-logo-title {
    font-family: 'Cinzel', serif;
    font-size: 15px;
    color: var(--gold-light);
    letter-spacing: 1.5px;
    line-height: 1.3;
}
.adm-logo-sub {
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-top: 3px;
}

.adm-nav { padding: 16px 12px; flex: 1; }
.adm-nav-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--text-muted);
    padding: 8px 12px 6px;
    display: block;
}
.adm-nav-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 11px 14px;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: all 0.2s;
    font-size: 14px;
    color: var(--text-dim);
        border: 1px solid transparent;
    margin-bottom: 2px;
    font-weight: 500;
    text-decoration: none;
    background: none;
    width: 100%;
    text-align: left;
}
.adm-nav-item:hover {
    background: rgba(201,168,76,0.06);
    color: #e8d5b0;
    border-color: #3d2a15 ;
}
.adm-nav-item.active {
    background: rgba(201,168,76,0.1);
    color: var(--gold-light);
    border-color:  #3d2a15;
}
.adm-nav-item .nav-icon { font-size: 17px; width: 22px; text-align: center; }
.adm-nav-item .nav-count {
    margin-left: auto;
    background: var(--dark-4);
    border: 1px solid #3d2a15 ;
    border-radius: 20px;
    padding: 2px 8px;
    font-size: 11px;
    color: var(--text-dim);
}
.adm-nav-item.active .nav-count {
    background: rgba(201,168,76,0.15);
    color: #c9a227;
}

.adm-sidebar-footer {
    padding: 16px 12px;
    border-top: 1px solid  #3d2a15;
}
.adm-back-btn {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    border-radius: var(--radius-sm);
    color: var(--text-dim);
    text-decoration: none;
    font-size: 13px;
    transition: all 0.2s;
    border: 1px solid #3d2a15 ;
}
        .adm-back-btn:hover {
        color: #e8d5b0;
        border-color: #3d2a15;
        }


.adm-main {
    margin-left: var(--sidebar-w);
    flex: 1;
    height: 100vh;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
}

.adm-topbar {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(11,9,5,0.85);
    backdrop-filter: blur(12px);
        border-bottom: 1px solid #3d2a15;
    padding: 0 32px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-shrink: 0;
}
.adm-topbar-title {
    font-family: 'Cinzel', serif;
    font-size: 17px;
    color: var(--gold-light);
    letter-spacing: 1px;
}
.adm-topbar-right {
    display: flex;
    align-items: center;
    gap: 16px;
}
.adm-admin-pill {
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(201,168,76,0.08);
    border: 1px solid  #3d2a15;
    border-radius: 25px;
    padding: 6px 14px;
    font-size: 13px;
    color: #c9a227;
}
.adm-admin-dot {
    width: 8px; height: 8px;
    background: var(--green);
    border-radius: 50%;
}

.adm-body { padding: 32px; flex: 1; }


.adm-panel { display: none; }
.adm-panel.active { display: block; }

.adm-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    margin-bottom: 32px;
}
.adm-stat {
    background: var(--dark-card);
        border: 1px solid #3d2a15;
    border-radius: var(--radius);
    padding: 22px 24px;
    display: flex;
    align-items: center;
    gap: 18px;
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
}
.adm-stat::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    opacity: 0;
    transition: opacity 0.3s;
}
.adm-stat.c-gold::after  { background: linear-gradient(90deg, transparent, #c9a227, transparent); }
.adm-stat.c-green::after { background: linear-gradient(90deg, transparent, var(--green), transparent); }
.adm-stat.c-blue::after  { background: linear-gradient(90deg, transparent, var(--blue), transparent); }
.adm-stat.c-orange::after{ background: linear-gradient(90deg, transparent, var(--orange), transparent); }
.adm-stat.c-red::after   { background: linear-gradient(90deg, transparent, var(--red), transparent); }
.adm-stat.c-purple::after{ background: linear-gradient(90deg, transparent, #9b6dd9, transparent); }
.adm-stat:hover { border-color: var(--border-h); transform: translateY(-3px); box-shadow: var(--shadow-gold); }
.adm-stat:hover::after { opacity: 1; }
.adm-stat-icon {
    width: 50px; height: 50px;
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 22px;
    flex-shrink: 0;
    border: 1px solid #3d2a15 ;
}
.adm-stat.c-gold   .adm-stat-icon { background: rgba(201,168,76,0.1); }
.adm-stat.c-green  .adm-stat-icon { background: rgba(76,175,128,0.1); }
.adm-stat.c-blue   .adm-stat-icon { background: rgba(91,141,217,0.1); }
.adm-stat.c-orange .adm-stat-icon { background: rgba(224,144,80,0.1); }
.adm-stat.c-red    .adm-stat-icon { background: rgba(224,82,82,0.1); }
.adm-stat.c-teal .adm-stat-icon { background: rgba(0,191,165,0.1); }
.adm-stat.c-purple .adm-stat-icon { background: rgba(155,109,217,0.1); }
.adm-stat-val {
    font-size: 30px;
    font-weight: 700;
    font-family: 'Cinzel', serif;
    color: var(--gold-light);
    line-height: 1;
    margin-bottom: 4px;
}
.adm-stat-label {
    font-size: 12px;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 1px;
}


.adm-sec-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
}
.adm-sec-title {
    font-family: 'Cinzel', serif;
    font-size: 17px;
    color: var(--gold-light);
    letter-spacing: 1px;
    display: flex;
    align-items: center;
    gap: 10px;
}
.adm-sec-title::before {
    content: '';
    width: 4px; height: 20px;
    background: linear-gradient(to bottom, #c9a227, var(--gold-dim));
    border-radius: 4px;
    display: block;
}


.adm-search-wrap {
    position: relative;
    width: 280px;
}
.adm-search {
    width: 100%;
    background: var(--dark-3);
    border: 1px solid  #3d2a15;
    border-radius: 25px;
    padding: 9px 16px 9px 38px;
    color: #e8d5b0;
    font-size: 13px;
    outline: none;
    transition: border-color 0.2s;
}
.adm-search:focus { border-color: #c9a227; }
.adm-search::placeholder { color: var(--text-muted); }
.adm-search-icon {
    position: absolute;
    left: 13px; top: 50%;
    transform: translateY(-50%);
    color: var(--text-muted);
    font-size: 14px;
    pointer-events: none;
}


.adm-table-wrap {
    background: var(--dark-card);
    border: 1px solid #3d2a15 ;
    border-radius: var(--radius);
    overflow: hidden;
}
.adm-table {
    width: 100%;
    border-collapse: collapse;
}
.adm-table thead tr {
    background: rgba(201,168,76,0.05);
    border-bottom: 1px solid #3d2a15 ;
}
.adm-table th {
    padding: 14px 18px;
    text-align: left;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--text-muted);
    font-weight: 600;
    white-space: nowrap;
}
.adm-table td {
    padding: 14px 18px;
    font-size: 13.5px;
    color: #e8d5b0;
    border-bottom: 1px solid rgba(201,168,76,0.07);
    vertical-align: middle;
}
.adm-table tbody tr:last-child td { border-bottom: none; }
.adm-table tbody tr {
    transition: background 0.15s;
}
.adm-table tbody tr:hover { background: rgba(201,168,76,0.03); }

.adm-thumb {
    width: 44px; height: 44px;
    border-radius: 8px;
    object-fit: cover;
    background: var(--dark-3);
    border: 1px solid #3d2a15 ;
}
.adm-name-cell { font-weight: 500; color: var(--gold-light); }
.adm-sub-cell  { font-size: 12px; color: var(--text-dim); margin-top: 2px; }


.adm-actions { display: flex; gap: 6px; align-items: center; }
.adm-btn {
    padding: 6px 14px;
    border-radius: var(--radius-sm);
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
        border: 1px solid #3d2a15 transparent;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: 'Inter', sans-serif;
    letter-spacing: 0.3px;
}
.adm-btn-edit {
    background: rgba(91,141,217,0.1);
    border-color: rgba(91,141,217,0.3);
    color: var(--blue);
}
.adm-btn-edit:hover { background: rgba(91,141,217,0.2); }
.adm-btn-del {
    background: rgba(224,82,82,0.1);
    border-color: rgba(224,82,82,0.3);
    color: var(--red);
}
.adm-btn-del:hover { background: rgba(224,82,82,0.2); }
.adm-btn-add {
    background: linear-gradient(135deg, var(--gold-dim), #c9a227);
        color: #0d0702;
    font-weight: 700;
    padding: 9px 20px;
    font-size: 13px;
    font-family: 'Cinzel', serif;
    letter-spacing: 0.5px;
}
.adm-btn-add:hover { filter: brightness(1.15); transform: translateY(-1px); }


.adm-badge {
    display: inline-flex; align-items: center; gap: 4px;
    padding: 3px 10px; border-radius: 20px;
    font-size: 11px; font-weight: 600; letter-spacing: 0.5px;
}
.adm-badge.Confirmed { background: rgba(76,175,128,0.12); color: var(--green); border: 1px solid rgba(76,175,128,0.25); }
.adm-badge.Cancelled { background: rgba(224,82,82,0.1);  color: var(--red);   border: 1px solid rgba(224,82,82,0.2); }
.adm-badge.Refunded  { background: rgba(91,141,217,0.1); color: var(--blue);  border: 1px solid rgba(91,141,217,0.2); }


.adm-overlay {
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.75);
    backdrop-filter: blur(4px);
    z-index: 200;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 20px;
}
.adm-overlay.open { display: flex; }
.adm-modal {
    background: var(--dark-2);
    border: 1px solid #3d2a15;
    border-radius: 20px;
    width: 100%;
    max-width: 560px;
    max-height: 90vh;
    overflow-y: auto;
    box-shadow: var(--shadow);
    animation: modalIn 0.25s ease;
}
@@keyframes modalIn {
    from { opacity: 0; transform: scale(0.95) translateY(10px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
}
.adm-modal-head {
    padding: 24px 28px 20px;
    border-bottom: 1px solid  #3d2a15;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky; top: 0;
    background: var(--dark-2);
    border-radius: 20px 20px 0 0;
}
.adm-modal-title {
    font-family: 'Cinzel', serif;
    font-size: 17px;
    color: var(--gold-light);
    letter-spacing: 1px;
}
.adm-modal-close {
    width: 32px; height: 32px;
    background: var(--dark-3);
    border: 1px solid #3d2a15;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    color: var(--text-dim);
    font-size: 16px;
    transition: all 0.2s;
}
.adm-modal-close:hover { color: var(--red); border-color: var(--red); }
.adm-modal-body { padding: 24px 28px; }
.adm-modal-foot {
    padding: 16px 28px 24px;
    display: flex;
    gap: 10px;
    justify-content: flex-end;
}

/* Form */
.adm-form-row { margin-bottom: 18px; }
.adm-form-row-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin-bottom: 18px;
}
.adm-label {
    display: block;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-dim);
    margin-bottom: 7px;
    font-weight: 600;
}
.adm-input, .adm-textarea, .adm-select {
    width: 100%;
    background: var(--dark-3);
    border: 1px solid  #3d2a15;
    border-radius: var(--radius-sm);
    padding: 10px 14px;
    color: #e8d5b0;
    font-size: 14px;
    outline: none;
    transition: border-color 0.2s;
    font-family: 'Inter', sans-serif;
}
.adm-input:focus, .adm-textarea:focus, .adm-select:focus {
    border-color: #c9a227;
    background: rgba(201,168,76,0.03);
}
.adm-textarea { resize: vertical; min-height: 90px; }
.adm-select option { background: var(--dark-3); }

/* Arabic translation section */
.adm-lang-divider {
    display: flex;
    align-items: baseline;
    gap: 8px;
    flex-wrap: wrap;
    margin: 22px 0 16px;
    padding-top: 16px;
    border-top: 1px dashed #3d2a15;
    font-family: 'Cinzel', serif;
    font-size: 12.5px;
    color: var(--gold-light);
    letter-spacing: .5px;
}
.adm-lang-divider small {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 10.5px;
    color: var(--text-dim);
    letter-spacing: 0;
}
.adm-input-ar, .adm-textarea-ar {
    direction: rtl;
    text-align: right;
    font-family: 'Segoe UI', Tahoma, Arial, sans-serif;
}


.adm-img-preview {
    width: 100%; height: 120px;
    border-radius: var(--radius-sm);
    object-fit: cover;
    background: var(--dark-3);
        border: 1px solid #3d2a15;
    display: block;
    margin-top: 8px;
}


.adm-toast {
    position: fixed;
    bottom: 30px; right: 30px;
    background: var(--dark-3);
    border: 1px solid var(--green);
    border-radius: var(--radius-sm);
    padding: 14px 20px;
    color: var(--green);
    font-size: 14px;
    font-weight: 500;
    z-index: 999;
    display: flex;
    align-items: center;
    gap: 10px;
    box-shadow: var(--shadow);
    animation: toastIn 0.3s ease, toastOut 0.3s ease 3s forwards;
}
@@keyframes toastIn  { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:translateY(0); } }
@@keyframes toastOut { from { opacity:1; } to { opacity:0; pointer-events:none; } }


.adm-empty {
    text-align: center;
    padding: 48px;
    color: var(--text-muted);
}
.adm-empty-icon { font-size: 40px; margin-bottom: 12px; }
.adm-empty-text { font-size: 14px; font-family: 'Cinzel', serif; }


::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: var(--dark-2); }
::-webkit-scrollbar-thumb { background: var(--gold-dim); border-radius: 3px; }

        .adm-badge.Visited {
        background: rgba(76,175,128,0.15);
        color: #4caf80;
        border: 1px solid rgba(76,175,128,0.3);
        }
        }

        .db-filter-btn {
        background: var(--dark-card, #1a1509);
        border: 1px solid rgba(201,168,76,0.18);
        color: #9e8e70;
        padding: 8px 18px;
        border-radius: 25px;
        font-size: 13px;
        cursor: pointer;
        transition: all 0.2s;
        }

        .db-filter-btn:hover, .db-filter-btn.active {
        background: rgba(201,168,76,0.12);
        border-color: #c9a84c;
        color: #f0c96e;
        }

        .adm-badge.Visited {
        background: rgba(76,175,128,0.15);
        color: #4caf80;
        border: 1px solid rgba(76,175,128,0.3);
        }

        .resolved-row {
        opacity: 0.6;
        }

        .badge-resolved {
        background: rgba(39,174,96,0.15);
        color: #27ae60;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: .8rem;
        }

        .badge-pending {
        background: rgba(231,76,60,0.15);
        color: #e74c3c;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: .8rem;
        }

        .adm-btn-resolve {
        background: transparent;
        border: 1px solid #27ae60;
        color: #27ae60;
        padding: 4px 10px;
        border-radius: 5px;
        cursor: pointer;
        font-size: .82rem;
        transition: all .2s;
        margin-right: 5px;
        }

        .adm-btn-resolve:hover {
        background: #27ae60;
        color: #fff;
        }

</style>
</head>
<body>

<!-- SIDEBAR-->
    <aside class="adm-sidebar">
        <div class="adm-logo">
            <span class="adm-logo-symbol">𓂀</span>
            <div class="adm-logo-title">Pharaohs Legacy</div>
            <div class="adm-logo-sub">Admin Panel</div>
        </div>

        <nav class="adm-nav">
            <span class="adm-nav-label">Main</span>
            <button class="adm-nav-item @(activeTab == "overview" ? "active" : "")"
                    onclick="switchPanel('overview',this)">
                <span class="nav-icon">𓋹</span> Overview
            </button>

            <span class="adm-nav-label" style="margin-top:12px;">Content</span>
            <button class="adm-nav-item @(activeTab == "pharaohs" ? "active" : "")"
                    onclick="switchPanel('pharaohs',this)">
                <span class="nav-icon">👑</span> Pharaohs
                <span class="nav-count">@Model.TotalPharaohs</span>
            </button>
            <button class="adm-nav-item @(activeTab == "temples" ? "active" : "")"
                    onclick="switchPanel('temples',this)">
                <span class="nav-icon">🛕</span> Temples
                <span class="nav-count">@Model.TotalTemples</span>
            </button>
            <button class="adm-nav-item @(activeTab == "museums" ? "active" : "")"
                    onclick="switchPanel('museums',this)">
                <span class="nav-icon">🏛️</span> Museums
                <span class="nav-count">@Model.TotalMuseums</span>
            </button>
            <button class="adm-nav-item @(activeTab == "gods" ? "active" : "")"
                    onclick="switchPanel('gods',this)">
                <span class="nav-icon">⚡</span> Gods
                <span class="nav-count">@Model.TotalGods</span>
            </button>
            <button class="adm-nav-item @(activeTab == "artifacts" ? "active" : "")"
                    onclick="switchPanel('artifacts',this)">
                <span class="nav-icon">𓏠</span> Artifacts
                <span class="nav-count">@Model.TotalArtifacts</span>
            </button>
            <button class="adm-nav-item @(activeTab == "dynasties" ? "active" : "")"
                    onclick="switchPanel('dynasties',this)">
                <span class="nav-icon">𓂀</span> Dynasties
                <span class="nav-count">@Model.TotalDynasties</span>
            </button>

            <button class="adm-nav-item @(activeTab == "events" ? "active" : "")"
                    onclick="switchPanel('events',this)">
                <span class="nav-icon">𓋹</span> Events
                <span class="nav-count">@Model.TotalHistoricalEvents</span>
            </button>
