    @* {{-- ===== BOOKINGS ===== --}} *@
    <div id="tab-bookings" class="db-panel">
        <div style="margin-top:32px;">
            <div class="db-filter-bar" id="bookingFilters">
                <button class="db-filter-btn active" onclick="filterBookings('All', this)">@Html.L("Dash_Filter_All")</button>
                <button class="db-filter-btn" onclick="filterBookings('Confirmed', this)">✅ @Html.L("Status_Confirmed")</button>
                <button class="db-filter-btn" onclick="filterBookings('Cancelled', this)">✖ @Html.L("Status_Cancelled")</button>
                <button class="db-filter-btn" onclick="filterBookings('Refunded', this)">💙 @Html.L("Status_Refunded")</button>
                <button class="db-filter-btn" onclick="filterBookings('Visited', this)">✅ @Html.L("Status_Visited")</button>
            </div>
            @if (!Model.Bookings.Any())
            {
                <div class="db-empty">
                    <div class="db-empty-icon">📅</div>
                    <div class="db-empty-text">@Html.L("Dash_NoBookingsMade")</div>
                    <br />
                    <a href="/Temple/Index" class="btn-gold" style="margin-top:16px; margin-inline-end:8px;">🛕 @Html.L("Dash_ExploreTemples")</a>
                    <a href="/Museum/Index" class="btn-gold" style="margin-top:16px; margin-inline-end:8px;">🏛️ @Html.L("Dash_ExploreMuseums")</a>
                </div>
            }
            else
            {
                <div class="db-booking-cards" id="bookingCards">
                    @foreach (var b in Model.Bookings)
                    {
                        <div class="db-bcard fade-up" data-status="@b.Status">
                            <img class="db-bcard-img" src="@(b.ImageUrl ?? "/images/placeholder.jpg")" alt="@b.PlaceName" onerror="this.src='/images/placeholder.jpg'" />
                            <div class="db-bcard-body">
                                <div class="db-bcard-top">
                                    <div>
                                        <div class="db-bcard-name">@b.PlaceName</div>
                                        <div class="db-bcard-type">@(b.PlaceType == "temple" ? "🛕 " + Html.L("Dash_TempleSite") : "🏛️ " + Html.L("Dash_Museum"))</div>
                                    </div>
                                    <span class="status-badge @b.Status">@Html.L("Status_" + b.Status)</span>
                                </div>
                                <div class="db-bcard-meta">
                                    <div class="db-bcard-field">
                                        <div class="db-bcard-field-label">@Html.L("Dash_VisitDate")</div>
                                        <div class="db-bcard-field-val">@Html.DateLoc(b.VisitDate, "MMM dd, yyyy")</div>
                                    </div>
                                    <div class="db-bcard-field">
                                        <div class="db-bcard-field-label">@Html.L("Dash_Tickets")</div>
                                        <div class="db-bcard-field-val">@Html.Digits(b.NumberOfTickets) 🎫</div>
                                    </div>
                                    <div class="db-bcard-field">
                                        <div class="db-bcard-field-label">@Html.L("Dash_BookedOn")</div>
                                        <div class="db-bcard-field-val">@Html.DateLoc(b.CreatedAt, "MMM dd, yyyy")</div>
                                    </div>
                                    <div class="db-bcard-field">
                                        <div class="db-bcard-field-label">@Html.L("Dash_TotalPrice")</div>
                                        <div class="db-bcard-field-val db-bcard-price-val">@Html.Digits(b.TotalPrice.ToString("N0")) @Html.L("Dash_EGP")</div>
                                    </div>
                                </div>
                            </div>
                            @if (b.Status == "Confirmed")
                            {
                                <div class="db-bcard-footer">
                                    @{
                                        // 🆕 لازم يتطابق تمامًا مع الشرط في BookingStatusService.ToCancelledAsync
                                        // (48 ساعة من الحجز + معاد الزيارة نفسه لسه ما جاش) — عشان الزرار
                                        // يختفي من الأول بدل ما اليوزر يدوس عليه ويترفض من السيرفر
                                        var canCancel = (DateTime.Now - b.CreatedAt).TotalHours < 48
                                                         && b.VisitDate.Date >= DateTime.Today;
                                    }
                                    @if (canCancel)
                                    {
                                        <form class="cancel-form" action="/Booking/Cancel" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@b.Id" />
                                            <button type="button" class="btn-outline"
                                                    onclick="openCancelModal(@b.Id, '@Html.Raw(b.PlaceName?.Replace("'", "\\'") ?? "")', '@Html.DateLoc(b.VisitDate, "MMM dd, yyyy")', @b.TotalPrice.ToString(System.Globalization.CultureInfo.InvariantCulture))">
                                                ✖ @Html.L("Dash_Cancel")
                                            </button>
                                        </form>
                                        <small style="color:var(--text-dim); font-size:11px;">⏳ @Html.Digits(Math.Round(48 - (DateTime.Now - b.CreatedAt).TotalHours, 1))@Html.L("Dash_HoursLeftToCancel")</small>
                                    }
                                    else
                                    {
                                        <span style="color:var(--text-dim); font-size:12px;">🔒 @Html.L("Dash_CancelWindowClosed")</span>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </div>

