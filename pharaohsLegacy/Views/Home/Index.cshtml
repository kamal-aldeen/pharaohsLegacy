@using pharaohsLegacy.Extensions
@{
    ViewData["Title"] = "Home";
    var pharaohs = ViewBag.Pharaohs as List<pharaohsLegacy.Models.Pharaoh>;
    var temples = ViewBag.Temples as List<pharaohsLegacy.Models.Temple>;
    var todaysFact = ViewBag.TodaysFact as pharaohsLegacy.Models.DailyFact;
    var lang = Context.Session.GetString("Lang") ?? "en";
    var arrowNext = lang == "ar" ? "←" : "→";
}

@if (TempData["Error"] != null)
{
    <div style="
        position: fixed;
        top: 20px;
        right: 20px;
        z-index: 9999;
        background: var(--dark3);
        border: 1px solid var(--gold);
        border-radius: 10px;
        padding: 16px 24px;
        color: var(--gold);
        font-size: 14px;
        font-family: 'Cinzel', serif;
        box-shadow: 0 8px 32px rgba(0,0,0,0.5);
        animation: fadeOut 0.5s ease 3s forwards;">
        ⚠️ @TempData["Error"]
    </div>

    <style>
        @@keyframes fadeOut {
            from {
                opacity: 1;
            }

            to {
                opacity: 0;
                pointer-events: none;
            }
        }
    </style>
}


<section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-pyramid"></div>
    <div class="hero-pattern top">𓂀 𓃭 𓆣 𓇯 𓈖 𓉐 𓊃 𓋴 𓌀 𓍿 𓎛 𓏭</div>

    <div class="hero-content">
        <div class="hero-eyebrow">@Html.L("Home_Eyebrow")</div>
        <h1 class="hero-title">
            @Html.L("Home_TitleLine1")<br /><span>@Html.L("Home_TitleLine2")</span>
        </h1>
        <p class="hero-subtitle">
            @Html.L("Home_Subtitle")
        </p>
        <div class="hero-cta">
            <a href="#explore" class="btn-gold">@Html.L("Home_BtnExplore")</a>
            <a href="/Pharaoh/Index" class="btn-outline">@Html.L("Home_BtnMeetPharaohs")</a>
        </div>
    </div>

    <div class="hero-pattern bottom">𓂀 𓃭 𓆣 𓇯 𓈖 𓉐 𓊃 𓋴 𓌀 𓍿 𓎛 𓏭</div>
    <div class="hero-scroll">@Html.L("Home_Scroll")</div>
</section>

<div class="stats-bar">
    <div class="stat"><span class="stat-num">@Html.Digits("170+")</span><span class="stat-label">@Html.L("Stat_Pharaohs")</span></div>
    <div class="stat"><span class="stat-num">@Html.Digits("3,000")</span><span class="stat-label">@Html.L("Stat_YearsHistory")</span></div>
    <div class="stat"><span class="stat-num">@Html.Digits("50+")</span><span class="stat-label">@Html.L("Stat_TemplesSites")</span></div>
    <div class="stat"><span class="stat-num">@Html.Digits("30")</span><span class="stat-label">@Html.L("Stat_Dynasties")</span></div>
</div>

@if (todaysFact != null)
{
    var factText = (lang == "ar" && !string.IsNullOrEmpty(todaysFact.FactTextAr)) ? todaysFact.FactTextAr : todaysFact.FactText;
    <div class="section daily-fact-section">
        <div class="daily-fact-card reveal-on-scroll" id="dailyFactCard" data-fact-id="@todaysFact.Id">
            <div class="daily-fact-actions">
                <button type="button" class="daily-fact-copy-btn daily-fact-shuffle-btn" onclick="shuffleDailyFact(this)"
                        title="@(lang == "ar" ? "حقيقة تانية" : "Another fact")"
                        aria-label="@(lang == "ar" ? "حقيقة تانية" : "Another fact")">
                    <svg class="daily-fact-shuffle-icon" viewBox="0 0 24 24" width="15" height="15"
                         fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="23 4 23 10 17 10"></polyline>
                        <polyline points="1 20 1 14 7 14"></polyline>
                        <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path>
                    </svg>
                </button>
                <button type="button" class="daily-fact-copy-btn" onclick="copyDailyFact(this)"
                        title="@(lang == "ar" ? "انسخ الحقيقة" : "Copy fact")"
                        aria-label="@(lang == "ar" ? "انسخ الحقيقة" : "Copy fact")">
                    <svg class="daily-fact-copy-icon icon-copy" viewBox="0 0 24 24" width="15" height="15"
                         fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="8" y="8" width="12" height="12" rx="2"></rect>
                        <path d="M4 16V5a1 1 0 0 1 1-1h11"></path>
                    </svg>
                    <svg class="daily-fact-copy-icon icon-check" viewBox="0 0 24 24" width="15" height="15"
                         fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"
                         style="display:none">
                        <polyline points="4 12 9 17 20 6"></polyline>
                    </svg>
                </button>
            </div>
            <span class="daily-fact-icon">𓋹</span>
            <div class="daily-fact-meta">
                <span class="section-tag daily-fact-tag" id="dailyFactTag">@Html.L("DailyFact_Title")</span>
                @if (!string.IsNullOrEmpty(todaysFact.Category))
                {
                    <span class="daily-fact-category" id="dailyFactCategory">@Html.D(todaysFact.CategoryAr, todaysFact.Category)</span>
                }
            </div>
            <p class="daily-fact-text" id="dailyFactText" aria-live="polite">@factText</p>
        </div>
    </div>

    <script>
        function copyDailyFact(btn) {
            var text = document.getElementById('dailyFactText').innerText;
            var copyIcon = btn.querySelector('.icon-copy');
            var checkIcon = btn.querySelector('.icon-check');

            function showCopied() {
                if (btn._resetTimer) clearTimeout(btn._resetTimer);
                copyIcon.style.display = 'none';
                checkIcon.style.display = 'block';
                btn.classList.add('is-copied');
                btn._resetTimer = setTimeout(function () {
                    copyIcon.style.display = 'block';
                    checkIcon.style.display = 'none';
                    btn.classList.remove('is-copied');
                }, 1600);
            }

            if (navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(text).then(showCopied).catch(function () {
                    fallbackCopy(text);
                    showCopied();
                });
            } else {
                fallbackCopy(text);
                showCopied();
            }
        }

        function fallbackCopy(text) {
            var ta = document.createElement('textarea');
            ta.value = text;
            ta.style.position = 'fixed';
            ta.style.opacity = '0';
            document.body.appendChild(ta);
            ta.select();
            try { document.execCommand('copy'); } catch (e) { }
            document.body.removeChild(ta);
        }

        // مفيش IntersectionObserver عام في الموقع بيتعامل مع reveal-on-scroll،
        // فبنعمل واحد هنا مخصوص للكارت ده عشان يظهر لما اليوزر يوصله بالسكرول
        (function () {
            var el = document.querySelector('.daily-fact-card.reveal-on-scroll');
            if (!el) return;

            if (!('IntersectionObserver' in window)) {
                el.classList.add('is-visible');
                return;
            }

            var observer = new IntersectionObserver(function (entries) {
                entries.forEach(function (entry) {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('is-visible');
                        observer.unobserve(entry.target);
                    }
                });
            }, { threshold: 0.15 });

            observer.observe(el);
        })();

        function shuffleDailyFact(btn) {
            if (btn.classList.contains('is-loading')) return;

            var card = document.getElementById('dailyFactCard');
            var textEl = document.getElementById('dailyFactText');
            var tagEl = document.getElementById('dailyFactTag');
            var categoryEl = document.getElementById('dailyFactCategory');
            var currentId = card.getAttribute('data-fact-id');

            btn.classList.add('is-loading');
            textEl.classList.add('is-fading');

            fetch('/Home/GetRandomFact?excludeId=' + encodeURIComponent(currentId))
                .then(function (res) { return res.json(); })
                .then(function (data) {
                    if (!data || !data.success) return;

                    setTimeout(function () {
                        textEl.textContent = data.text;
                        card.setAttribute('data-fact-id', data.id);

                        if (data.category) {
                            if (categoryEl) {
                                categoryEl.textContent = data.category;
                            } else {
                                categoryEl = document.createElement('span');
                                categoryEl.className = 'daily-fact-category';
                                categoryEl.id = 'dailyFactCategory';
                                categoryEl.textContent = data.category;
                                tagEl.parentElement.appendChild(categoryEl);
                            }
                        } else if (categoryEl) {
                            categoryEl.remove();
                        }

                        textEl.classList.remove('is-fading');
                    }, 200);
                })
                .catch(function () {
                    textEl.classList.remove('is-fading');
                })
                .finally(function () {
                    btn.classList.remove('is-loading');
                });
        }
    </script>
}

<div id="explore">
    <div class="section">
        <div class="section-header">
            <span class="section-tag">@Html.L("Home_Tag_Rulers")</span>
            <h2 class="section-title">@Html.L("Home_SectionTitle_Pharaohs")</h2>
            <div class="section-line"></div>
        </div>
        <div class="cards-grid">
            @if (pharaohs != null)
            {
                @foreach (var pharaoh in pharaohs)
                {
                    var phName = (lang == "ar" && !string.IsNullOrEmpty(pharaoh.NameAr)) ? pharaoh.NameAr : pharaoh.Name;
                    var phDynasty = Html.Digits((lang == "ar" && !string.IsNullOrEmpty(pharaoh.DynastyAr)) ? pharaoh.DynastyAr : pharaoh.Dynasty);
                    var phPeriod = Html.Digits((lang == "ar" && !string.IsNullOrEmpty(pharaoh.PeriodAr)) ? pharaoh.PeriodAr : pharaoh.Period);
                    var phDescription = (lang == "ar" && !string.IsNullOrEmpty(pharaoh.DescriptionAr)) ? pharaoh.DescriptionAr : pharaoh.Description;
                    <a href="/Pharaoh/Details/@pharaoh.Id" class="card">
                        <div class="card-img">
                            <img src="@pharaoh.ImageUrl" alt="@phName" />
                        </div>
                        <div class="card-body">
                            <span class="card-tag">@phDynasty</span>
                            <h3 class="card-title">@phName</h3>
                            <p class="card-desc">@phDescription</p>
                        </div>
                        <div class="card-footer">
                            <span>@phPeriod</span>
                            <span class="card-arrow">@arrowNext</span>
                        </div>
                    </a>
                }
            }
        </div>
        <div class="see-all-wrap">
            <a href="/Pharaoh/Index" class="btn-outline">@Html.L("Home_SeeAllPharaohs") @arrowNext</a>
        </div>
    </div>
</div>


