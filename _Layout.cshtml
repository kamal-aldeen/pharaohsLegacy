@using pharaohsLegacy.Extensions
@{
    var currentLang = Context.Session.GetString("Lang") ?? "en";
    var currentDir = currentLang == "ar" ? "rtl" : "ltr";
}
<!DOCTYPE html>
<html lang="@currentLang" dir="@currentDir">
<head>
    

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Pharaohs Legacy</title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Crimson+Pro:ital,wght@0,300;0,400;0,600;1,300;1,400&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/pharaoh.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Egyptian+Hieroglyphs&display=swap" rel="stylesheet">
    <style>
        :root {
            --gold: #c9a227;
            --dark: #0d0702;
            --dark2: #1a0e05;
            --dark3: #2d1a08;
            --border: #3d2a15;
            --text: #e8d5b0;
            --muted: #8a7055;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        html { scroll-behavior: smooth; }
        body {
                background: #0d0702;
            color: #e8d5b0;
            font-family: 'Crimson Pro', serif;
            overflow-x: hidden;
        }

       
        nav.main-nav {
            position: fixed; top: 0; left: 0; right: 0; z-index: 100;
            display: flex; align-items: center; justify-content: space-between;
            padding: 1rem 3rem;
            background: rgba(13,7,2,0.9);
            backdrop-filter: blur(10px);
                border-bottom: 1px solid #3d2a15;
        }
        .nav-logo {
            text-decoration: none;
            display: flex; align-items: center; gap: .75rem;
        }
        .nav-logo-icon { font-size: 1.3rem; color: #c9a227; }
        .nav-logo-text { display: flex; flex-direction: column; line-height: 1.15; }
        .nav-logo-title {
            font-family: 'Cinzel', serif;
            color: #c9a227; font-size: 1.1rem;
            letter-spacing: 3px; text-transform: uppercase;
        }
        .nav-logo-tagline {
            font-family: 'Crimson Pro', serif;
            color: #8a7055; font-size: .68rem;
            letter-spacing: .5px; margin-top: 2px;
        }
        .nav-links { display: flex; gap: 2rem; list-style: none; }
        .nav-links a {
            font-family: 'Cinzel', serif; font-size: .7rem;
            letter-spacing: 2px; text-transform: uppercase;
            color: #8a7055; text-decoration: none;
            transition: color .3s;
        }

                .nav-links li {
                    display: flex;
                    align-items: center;
                }

        .nav-links a:hover { color: #c9a227; }
        .nav-right { display: flex; align-items: center; gap: 1rem; }
        .nav-search {
            display: flex; align-items: center; gap: .5rem;
                background: #2d1a08;
                border: 1px solid #3d2a15;
            border-radius: 4px; padding: .5rem 1rem;
        }
        .nav-search input {
            background: none; border: none; outline: none;
            color: #e8d5b0; font-family: 'Crimson Pro', serif;
            font-size: .95rem; width: 160px;
        }
        .nav-search input::placeholder { color: #8a7055; }
        .nav-search button {
            background: none; border: none;
            color: #8a7055; cursor: pointer; font-size: 1rem;
            transition: color .3s;
        }
        .nav-search button:hover { color: #c9a227; }
        .nav-logout {
            font-family: 'Cinzel', serif; font-size: .65rem;
            letter-spacing: 2px; text-transform: uppercase;
            color: #8a7055; text-decoration: none;
                border: 1px solid #3d2a15;
                border-radius: 4px;
            padding: .4rem .9rem; transition: all .3s;
        }
        .nav-logout:hover { border-color: #e74c3c; color: #e74c3c; }

        .lang-switch {
            position: relative;
            display: inline-grid;
            grid-template-columns: 1fr 1fr;
            background: rgba(201,162,39,.06);
            border: 1px solid #3d2a15;
            border-radius: 20px;
            padding: 3px;
        }
        .lang-switch-indicator {
            position: absolute;
            top: 3px; bottom: 3px;
            width: calc(50% - 3px);
            border-radius: 16px;
            background: linear-gradient(135deg, #c9a227, #a07a1a);
            box-shadow: 0 2px 10px rgba(201,162,39,.35);
            transition: inset-inline-start .35s cubic-bezier(.4,0,.2,1);
            z-index: 0;
        }
        .lang-switch form { display: contents; }
        .lang-switch-btn {
            position: relative;
            z-index: 1;
            background: transparent;
            border: none;
            font-family: 'Cinzel', serif;
            font-size: .62rem;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: #8a7055;
            cursor: pointer;
            padding: .42rem .95rem;
            border-radius: 16px;
            transition: color .3s ease;
        }
        .lang-switch-btn.active { color: #0d0702; font-weight: 600; }
        .lang-switch-btn:not(.active):hover { color: #c9a227; }

       
        .nav-toggle {
            display: none; flex-direction: column; gap: 5px;
            background: none; border: none; cursor: pointer; padding: .5rem;
        }
        .nav-toggle span {
            display: block; width: 22px; height: 2px;
            background: #8a7055; border-radius: 2px; transition: all .3s;
        }

        
        .main-content { padding-top: 70px; min-height: 100vh; }

        
        .hero {
            min-height: 100vh;
            display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            text-align: center; position: relative; overflow: hidden;
            padding: 6rem 2rem 4rem;
        }
        .hero-bg {
            position: absolute; inset: 0;
            background:
                radial-gradient(ellipse at 50% 0%, rgba(201,162,39,.15) 0%, transparent 60%),
                linear-gradient(180deg, #0d0702 0%, #1a0e05 50%, #0d0702 100%);
        }
        .hero-pyramid {
            position: absolute; bottom: 0; left: 50%; transform: translateX(-50%);
            width: 0; height: 0;
            border-left: 400px solid transparent;
            border-right: 400px solid transparent;
            border-bottom: 280px solid rgba(201,162,39,.04);
            pointer-events: none;
        }
        .hero-pattern {
            position: absolute; left: 0; right: 0;
            font-size: 1.2rem; letter-spacing: 1.5rem;
            color: rgba(201,162,39,.08);
            white-space: nowrap; overflow: hidden; pointer-events: none;
        }
        .hero-pattern.top { top: 5rem; }
        .hero-pattern.bottom { bottom: 2rem; }
        .hero-content { position: relative; z-index: 1; max-width: 700px; }
        .hero-eyebrow {
            font-family: 'Cinzel', serif; font-size: .7rem;
            letter-spacing: 5px; text-transform: uppercase;
            color: #c9a227; margin-bottom: 1.5rem;
            display: flex; align-items: center; gap: 1rem; justify-content: center;
        }
        .hero-eyebrow::before, .hero-eyebrow::after {
            content: ''; width: 60px; height: 1px; background: #c9a227; opacity: .5;
        }
        .hero-title {
            font-family: 'Cinzel', serif;
            font-size: clamp(2.5rem, 6vw, 5rem);
            font-weight: 700; line-height: 1.1;
            color: #e8d5b0; margin-bottom: 1.5rem;
        }
        .hero-title span { color: #c9a227; }
        .hero-subtitle {
            font-size: 1.2rem; color: #8a7055;
            line-height: 1.7; margin-bottom: 2.5rem; font-style: italic;
        }
        .hero-cta { display: inline-flex; gap: 1rem; flex-wrap: wrap; justify-content: center; }
        .hero-scroll {
            position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%);
            display: flex; flex-direction: column; align-items: center; gap: .5rem;
            color: #8a7055; font-size: .65rem; letter-spacing: 3px;
            text-transform: uppercase; font-family: 'Cinzel', serif;
            animation: bounce 2s infinite;
        }
        .hero-scroll::after { content: '▼'; font-size: .8rem; }
        @@keyframes bounce {
            0%,100%{ transform:translateX(-50%) translateY(0); }
            50%{ transform:translateX(-50%) translateY(6px); }
        }

       
        .stats-bar {
            display: flex; justify-content: center;
                background: #2d1a08;
            border-top: 1px solid #3d2a15;
                border-bottom: 1px solid #3d2a15;
            padding: 1.5rem 3rem; gap: 4rem; flex-wrap: wrap;
        }
        .stat { text-align: center; }
        .stat-num {
            font-family: 'Cinzel', serif; font-size: 1.8rem;
            color: #c9a227; font-weight: 700; display: block;
        }
        .stat-label {
            font-size: .7rem; letter-spacing: 2px; text-transform: uppercase;
            color: #8a7055; font-family: 'Cinzel', serif;
        }

        
        .section { padding: 5rem 3rem; max-width: 1200px; margin: 0 auto; }
        .section-header { text-align: center; margin-bottom: 3rem; }
        .section-tag {
            font-family: 'Cinzel', serif; font-size: .65rem;
            letter-spacing: 4px; text-transform: uppercase;
            color: #c9a227; margin-bottom: .75rem; display: block;
        }
        .section-title {
            font-family: 'Cinzel', serif; font-size: 2rem;
            font-weight: 600; color: #e8d5b0; margin-bottom: 1rem;
        }
        .section-line {
            width: 60px; height: 2px;
            background: linear-gradient(90deg, transparent, #c9a227, transparent);
            margin: 0 auto;
        }

        
        .cards-grid {
            display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1.5rem;
        }
        .card {
                background: #2d1a08;
                border: 1px solid #3d2a15;
            border-radius: 8px; overflow: hidden;
            transition: transform .3s, border-color .3s;
            cursor: pointer; text-decoration: none;
            display: block; color: inherit;
        }
        .card:hover { transform: translateY(-4px); border-color: #c9a227; }
        .card-img {
            width: 100%; height: 200px; overflow: hidden;
                background: #1a0e05;
            display: flex; align-items: center; justify-content: center;
        }
        .card-img img {
            width: 100%; height: 100%; object-fit: cover;
            transition: transform .4s;
        }
        .card:hover .card-img img { transform: scale(1.05); }
        .card-body { padding: 1.25rem; }
        .card-tag {
            font-family: 'Cinzel', serif; font-size: .6rem;
            letter-spacing: 2px; text-transform: uppercase;
            color: #c9a227; margin-bottom: .5rem; display: block;
        }
        .card-title {
            font-family: 'Cinzel', serif; font-size: 1rem;
            color: #e8d5b0; margin-bottom: .5rem;
        }
        .card-desc { color: #8a7055; font-size: .9rem; line-height: 1.6; }
        .card-footer {
            padding: .75rem 1.25rem;
                border-top: 1px solid #3d2a15;
            display: flex; justify-content: space-between; align-items: center;
        }
        .card-footer span { font-size: .8rem; color: #8a7055; font-style: italic; }
        .card-arrow { color: #c9a227; font-size: 1rem; }

     
        .details-wrap { padding: 3rem; max-width: 1000px; margin: 0 auto; }
        .details-card {
            display: grid; grid-template-columns: 1fr 1.5fr;
            gap: 3rem; align-items: start;
                background: #2d1a08;
                border: 1px solid #3d2a15;
            border-radius: 8px; overflow: hidden; padding: 2rem;
        }
        .details-img { border-radius: 8px; overflow: hidden; }
        .details-img img { width: 100%; height: 350px; object-fit: cover; }
        .details-title {
            font-family: 'Cinzel', serif; font-size: 2rem;
            color: #e8d5b0; margin-bottom: 1rem;
        }
        .details-text { color: #8a7055; font-size: 1rem; line-height: 1.8; margin-bottom: 1.5rem; }
        .details-meta { display: flex; gap: 2rem; flex-wrap: wrap; margin-bottom: 1.5rem; }
        .meta-label {
            font-family: 'Cinzel', serif; font-size: .6rem;
            letter-spacing: 2px; text-transform: uppercase;
            color: #c9a227; display: block; margin-bottom: .25rem;
        }
        .meta-value { color: #e8d5b0; font-size: .95rem; }
        .page-header { text-align: center; padding: 3rem 2rem 1rem; }
        .see-all-wrap { text-align: center; margin-top: 2rem; }

        
        .btn-gold {
            display: inline-block; padding: .9rem 2.5rem;
            background: linear-gradient(135deg, #c9a227, #a07a1a);
            border: none; border-radius: 4px;
                color: #0d0702;
                font-family: 'Cinzel', serif;
            font-size: .75rem; font-weight: 700;
            letter-spacing: 2px; text-transform: uppercase;
            cursor: pointer; transition: opacity .3s; text-decoration: none;
        }

                .btn-gold:hover {
                    opacity: .85;
                    color: #0d0702;
                }
        .btn-outline {
            display: inline-block; padding: .9rem 2.5rem;
            background: transparent;
                border: 1px solid #3d2a15;
                border-radius: 4px;
            color: #8a7055; font-family: 'Cinzel', serif;
            font-size: .75rem; letter-spacing: 2px; text-transform: uppercase;
            cursor: pointer; transition: all .3s; text-decoration: none;
        }
        .btn-outline:hover { border-color: #c9a227; color: #c9a227; }
        .btn-back {
            display: inline-block; margin-bottom: 1.5rem;
            font-family: 'Cinzel', serif; font-size: .7rem;
            letter-spacing: 2px; text-transform: uppercase;
            color: #8a7055; text-decoration: none; transition: color .3s;
        }
        .btn-back:hover { color: #c9a227; }

        
        footer.main-footer {
                background: #2d1a08;
                border-top: 1px solid #3d2a15;
            text-align: center; padding: 2rem;
            color: #8a7055; font-size: .85rem; font-style: italic;
        }
        footer.main-footer span { color: #c9a227; }

        @@media (max-width: 768px) {
            nav.main-nav { padding: 1rem 1.5rem; }
            .nav-links { display: none; flex-direction: column; gap: 1rem;
                position: absolute; top: 100%; left: 0; right: 0;
                background: rgba(13,7,2,0.97); padding: 1.5rem;
                    border-bottom: 1px solid #3d2a15;
                }
            .nav-links.open { display: flex; }
            .nav-search { display: none; }
            .nav-toggle { display: flex; }

            .hero-title { font-size: 2.2rem; }
            .hero-pyramid { border-left-width: 200px; border-right-width: 200px; border-bottom-width: 150px; }

            .stats-bar { gap: 1.5rem; padding: 1.5rem; }

            .section { padding: 3rem 1.5rem; }

            .cards-grid { grid-template-columns: 1fr; }

            .details-card { grid-template-columns: 1fr; gap: 1.5rem; }
            .details-img img { height: 220px; }
            .details-wrap { padding: 1.5rem; }

            .btn-gold, .btn-outline { padding: .75rem 1.5rem; }
        }

        @@media (max-width: 480px) {
            .hero-title { font-size: 1.8rem; }
            .stat-num { font-size: 1.4rem; }
            .section-title { font-size: 1.5rem; }
        }


            /* ── Dropdown ── */
            .nav-dropdown {
                position: relative;
            }

            .nav-dropdown-toggle {
                cursor: pointer;
                display: flex;
                align-items: center;
                gap: 4px;
                padding: 0;
                margin: 0;
                line-height: normal;
            }

            .nav-dropdown {
                position: relative;
                display: flex;
                align-items: center;
            }

            .nav-dropdown-menu {
                display: none;
                position: absolute;
                top: calc(100% + 10px);
                left: 50%;
                transform: translateX(-50%);
                background: #0d0700;
                border: 1px solid rgba(212,175,55,0.3);
                border-radius: 10px;
                padding: 8px 0;
                min-width: 180px;
                z-index: 999;
                box-shadow: 0 10px 30px rgba(0,0,0,0.8);
                list-style: none;
            }

                .nav-dropdown-menu li a {
                    display: block;
                    padding: 10px 20px;
                    color: #aaa;
                    text-decoration: none;
                    font-size: .85rem;
                    letter-spacing: .05em;
                    transition: all .2s;
                }

                    .nav-dropdown-menu li a:hover {
                        color: #d4af37;
                        background: rgba(212,175,55,0.08);
                        padding-inline-start: 26px;
                    }

            .nav-dropdown:hover .nav-dropdown-menu {
                display: block;
            }
    </style>
    @RenderSection("Styles", required: false)
</head>

<body>




    <button id="back-to-top">▲</button>

    <nav class="main-nav">
        <a class="nav-logo" asp-controller="Home" asp-action="Index">
            <span class="nav-logo-icon">𓂀</span>
            <span class="nav-logo-text">
                <span class="nav-logo-title">Pharaohs Legacy</span>
                @if (currentLang == "ar")
                {
                    <span class="nav-logo-tagline">إرث الفراعنة</span>
                }
            </span>
        </a>

        @if (Context.Session.GetString("UserEmail") == "kamalabdlbast89@gmail.com")
        {
            <a href="/Admin/Index">𓁹 @Html.L("Nav_Dashboard")</a>
        }
        else if (Context.Session.GetString("UserEmail") != null
                 && Context.Session.GetString("UserEmail") != "guest")
        {
            <a href="/User/Dashboard">𓁹 @Html.L("Nav_Dashboard")</a>
        }

        <ul class="nav-links" id="navLinks">
            <li><a asp-controller="Home" asp-action="Index">@Html.L("Nav_Home")</a></li>

            <!-- Explore Dropdown -->
            <li class="nav-dropdown">
                <a class="nav-dropdown-toggle">@Html.L("Nav_Explore") ▾</a>
                <ul class="nav-dropdown-menu">
                    <li><a asp-controller="Pharaoh" asp-action="Index">👑 @Html.L("Nav_Pharaohs")</a></li>
                    <li><a asp-controller="God" asp-action="Index">⚡ @Html.L("Nav_Gods")</a></li>
                    <li><a asp-controller="Temple" asp-action="Index">🏛️ @Html.L("Nav_Temples")</a></li>
                    <li><a asp-controller="Museum" asp-action="Index">🏺 @Html.L("Nav_Museums")</a></li>
                    <li><a asp-controller="Artifact" asp-action="Index">🔮 @Html.L("Nav_Artifacts")</a></li>
                    <li><a asp-controller="Dynasty" asp-action="Index">𓂀 @Html.L("Nav_Dynasties")</a></li>
                    <li><a asp-controller="HistoricalEvent" asp-action="Index">𓋹 @Html.L("Nav_Events")</a></li>
                </ul>
            </li>

            <li><a asp-controller="Home" asp-action="Timeline">@Html.L("Nav_Timeline")</a></li>
            <li><a asp-controller="Home" asp-action="Map">@Html.L("Nav_Map")</a></li>
            <li><a asp-controller="Hieroglyphics" asp-action="Translator">@Html.L("Nav_Translator")</a></li>

            @if (Context.Session.GetString("UserEmail") != null &&
                 Context.Session.GetString("UserEmail") != "guest")
            {
            }
        </ul>

        <div class="nav-right">
            <form method="get" action="/Home/Search" class="nav-search">
                <input type="text" name="q" placeholder="@Html.L("Nav_SearchPlaceholder")" />
                <button type="submit">🔍</button>
            </form>

            <div class="lang-switch">
                <span class="lang-switch-indicator" style="inset-inline-start: @(currentLang == "en" ? "3px" : "calc(50% + 0px)");"></span>
                <form asp-controller="Language" asp-action="SetLanguage" method="get">
                    <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                    <button type="submit" name="lang" value="en" class="lang-switch-btn @(currentLang == "en" ? "active" : "")">EN</button>
                </form>
                <form asp-controller="Language" asp-action="SetLanguage" method="get">
                    <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                    <button type="submit" name="lang" value="ar" class="lang-switch-btn @(currentLang == "ar" ? "active" : "")">AR</button>
                </form>
            </div>

            @if (Context.Session.GetString("UserEmail") != null &&
                 Context.Session.GetString("UserEmail") != "guest")
            {
                <a href="/User/Logout" class="nav-logout">⬡ @Html.L("Nav_Logout")</a>
            }
            else if (Context.Session.GetString("UserEmail") == "guest")
            {
                <a href="/User/Login" class="nav-logout">⬡ @Html.L("Btn_Login")</a>
            }

            <button class="nav-toggle" id="navToggle" onclick="toggleNav()">
                <span></span><span></span><span></span>
            </button>
        </div>
    </nav>


    <div class="main-content">
        @RenderBody()
    </div>


    <footer class="main-footer">
        <p>© 2025 <span>Pharaohs Legacy</span> — @Html.L("Footer_Text")</p>
    </footer>

<script>
    
    function toggleNav() {
        document.getElementById('navLinks').classList.toggle('open');
    }

   
    document.querySelectorAll('img').forEach(function(img) {
        img.addEventListener('error', function() {
            this.src = 'https://via.placeholder.com/400x300/2d1a08/c9a227?text=No+Image';
        });
    });
</script>

@await RenderSectionAsync("Scripts", required: false)
<script src="~/js/pharaoh.js"></script>
    <!-- ═══════════ AI Tour Guide Widget ═══════════ -->
    <style>
        .aichat-btn {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: linear-gradient(135deg, #c9a227, #7a5e10);
        border: 2px solid rgba(201,162,39,0.4);
        cursor: pointer;
        font-size: 1.6rem;
        color: #0d0702;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 24px rgba(201,162,39,0.35), 0 0 0 0 rgba(201,162,39,0.4);
        animation: ai-pulse 2.5s infinite;
        transition: transform 0.3s, box-shadow 0.3s;
        }

        .aichat-btn:hover {
        transform: scale(1.08);
        box-shadow: 0 6px 32px rgba(201,162,39,0.55);
        }

        .aichat-btn.active {
        animation: none;
        transform: rotate(20deg) scale(1.05);
        }

        @@keyframes ai-pulse {
        0%, 100% {
        box-shadow: 0 4px 24px rgba(201,162,39,0.35), 0 0 0 0 rgba(201,162,39,0.3);
        }

        50% {
        box-shadow: 0 4px 24px rgba(201,162,39,0.35), 0 0 0 10px rgba(201,162,39,0);
        }
        }

        .aichat-popup {
        position: fixed;
        bottom: 102px;
        right: 28px;
        z-index: 9998;
        width: 380px;
        background: #0f0a03;
        border: 1px solid rgba(201,162,39,0.25);
        border-radius: 20px;
        box-shadow: 0 24px 60px rgba(0,0,0,0.8), 0 0 0 1px rgba(201,162,39,0.08);
        display: none;
        flex-direction: column;
        overflow: hidden;
        transform-origin: bottom right;
        }

        .aichat-popup.open {
        display: flex;
        animation: aiPopIn 0.3s cubic-bezier(0.34,1.56,0.64,1);
        }

        @@keyframes aiPopIn {
        from {
        opacity: 0;
        transform: scale(0.85) translateY(12px);
        }

        to {
        opacity: 1;
        transform: scale(1) translateY(0);
        }
        }

        /* Header */
        .aichat-header {
        padding: 16px 18px;
        background: linear-gradient(135deg, #1e1203 0%, #0f0a03 100%);
        border-bottom: 1px solid rgba(201,162,39,0.15);
        display: flex;
        align-items: center;
        gap: 12px;
        position: relative;
        }

        .aichat-header::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 18px;
        right: 18px;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(201,162,39,0.3), transparent);
        }

        .aichat-avatar-wrap {
        position: relative;
        }

        .aichat-avatar {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        background: linear-gradient(135deg, #c9a227, #5a3d08);
        border: 2px solid rgba(201,162,39,0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        color: #0d0702;
        flex-shrink: 0;
        box-shadow: 0 0 14px rgba(201,162,39,0.3);
        }

        .aichat-online-dot {
        position: absolute;
        bottom: 1px;
        right: 1px;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: #4caf76;
        border: 2px solid #0f0a03;
        }

        .aichat-info {
        flex: 1;
        }

        .aichat-name {
        font-family: 'Cinzel', serif;
        font-size: 0.85rem;
        color: #c9a227;
        letter-spacing: 1px;
        display: block;
        line-height: 1.2;
        }

        .aichat-sub {
        font-size: 0.68rem;
        color: #6a8a5a;
        font-family: 'Crimson Pro', serif;
        font-style: italic;
        display: flex;
        align-items: center;
        gap: 5px;
        margin-top: 2px;
        }

        .aichat-sub::before {
        content: '';
        width: 5px;
        height: 5px;
        background: #4caf76;
        border-radius: 50'; display: inline-block;
        }

        .aichat-close {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(201,162,39,0.15);
        border-radius: 8px;
        color: #8a7055;
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.2s;
        width: 30px;
        height: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        }

        .aichat-close:hover {
        background: rgba(201,162,39,0.1);
        color: #c9a227;
        border-color: rgba(201,162,39,0.35);
        }

        /* Messages */
        .aichat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 16px 14px;
        display: flex;
        flex-direction: column;
        gap: 14px;
        max-height: 420px;
        min-height: 280px;
        scrollbar-width: thin;
        scrollbar-color: rgba(201,162,39,0.2) transparent;
        }

        .aichat-messages::-webkit-scrollbar {
        width: 3px;
        }

        .aichat-messages::-webkit-scrollbar-thumb {
        background: rgba(201,162,39,0.2);
        border-radius: 4px;
        }

        .aichat-msg {
        display: flex;
        gap: 9px;
        align-items: flex-end;
        }

        .aichat-msg.user {
        flex-direction: row-reverse;
        }

        .aichat-msg-av {
        width: 30px;
        height: 30px;
        border-radius: 50%;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.85rem;
        border: 1px solid rgba(201,162,39,0.2);
        }

        .aichat-msg.bot .aichat-msg-av {
        background: linear-gradient(135deg, #1e1203, #0f0a03);
        color: #c9a227;
        }

        .aichat-msg.user .aichat-msg-av {
        background: linear-gradient(135deg, #c9a227, #7a5e10);
        color: #0d0702;
        }

        .aichat-bubble {
        max-width: 80%;
        padding: 10px 14px;
        border-radius: 16px;
        font-family: 'Crimson Pro', serif;
        font-size: 0.92rem;
        line-height: 1.65;
        animation: bubbleIn 0.25s ease;
        }

        @@keyframes bubbleIn {
        from {
        opacity: 0;
        transform: scale(0.95) translateY(4px);
        }

        to {
        opacity: 1;
        transform: scale(1) translateY(0);
        }
        }

        .aichat-msg.bot .aichat-bubble {
        background: linear-gradient(135deg, #1e1203, #150e02);
        border: 1px solid rgba(201,162,39,0.18);
        color: #d4b87a;
        border-radius: 4px 16px 16px 16px;
        }

        .aichat-msg.user .aichat-bubble {
        background: linear-gradient(135deg, #c9a227, #8a6b14);
        color: #0d0702;
        font-weight: 600;
        border-radius: 16px 4px 16px 16px;
        box-shadow: 0 2px 12px rgba(201,162,39,0.2);
        }

        /* Typing dots */
        .aichat-typing .aichat-bubble {
        display: flex;
        gap: 5px;
        align-items: center;
        padding: 13px 16px;
        }

        .aichat-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: rgba(201,162,39,0.5);
        animation: aiDot 1.3s infinite;
        }

        .aichat-dot:nth-child(2) {
        animation-delay: 0.2s;
        }

        .aichat-dot:nth-child(3) {
        animation-delay: 0.4s;
        }

        @@keyframes aiDot {
        0%, 60%, 100% {
        transform: translateY(0);
        opacity: 0.5;
        }

        30% {
        transform: translateY(-6px);
        opacity: 1;
        }
        }

        /* Suggestions */
        .aichat-suggestions {
        padding: 0 14px 10px;
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        }

        .aichat-sug {
        background: rgba(201,162,39,0.07);
        border: 1px solid rgba(201,162,39,0.2);
        border-radius: 20px;
        padding: 5px 12px;
        font-family: 'Cinzel', serif;
        font-size: 0.62rem;
        color: #8a7055;
        cursor: pointer;
        transition: all 0.2s;
        letter-spacing: 0.5px;
        }

        .aichat-sug:hover {
        background: rgba(201,162,39,0.14);
        color: #c9a227;
        border-color: rgba(201,162,39,0.4);
        }

        /* Input */
        .aichat-input-wrap {
        padding: 12px 14px;
        border-top: 1px solid rgba(201,162,39,0.12);
        background: rgba(0,0,0,0.3);
        display: flex;
        gap: 8px;
        align-items: flex-end;
        }

        .aichat-input {
        flex: 1;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(201,162,39,0.2);
        border-radius: 10px;
        padding: 10px 13px;
        font-family: 'Crimson Pro', serif;
        font-size: 0.9rem;
        color: #e8d5b0;
        outline: none;
        resize: none;
        transition: border-color 0.25s, background 0.25s;
        line-height: 1.5;
        max-height: 80px;
        }

        .aichat-input::placeholder {
        color: #3d2a15;
        }

        .aichat-input:focus {
        border-color: rgba(201,162,39,0.45);
        background: rgba(255,255,255,0.06);
        }

        .aichat-send {
        background: linear-gradient(135deg, #c9a227, #7a5e10);
        border: none;
        border-radius: 10px;
        width: 40px;
        height: 40px;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: #0d0702;
        font-size: 1rem;
        transition: all 0.2s;
        box-shadow: 0 2px 10px rgba(201,162,39,0.2);
        }

        .aichat-send:hover {
        opacity: 0.88;
        transform: scale(1.06);
        }

        .aichat-send:disabled {
        opacity: 0.35;
        cursor: not-allowed;
        transform: none;
        }

        .aichat-footer {
        text-align: center;
        padding: 6px;
        font-size: 0.6rem;
        color: #3d2a15;
        font-family: 'Cinzel', serif;
        letter-spacing: 1px;
        border-top: 1px solid rgba(201,162,39,0.06);
        }

        @@media (max-width: 480px) {
        .aichat-popup {
        width: calc(100vw - 32px);
        right: 16px;
        }

        .aichat-btn {
        right: 16px;
        bottom: 20px;
        }
        }
    </style>

    <!-- Floating Button -->
    <div style="position:fixed; bottom:28px; right:28px; z-index:9999; display:flex; flex-direction:column; align-items:center; gap:6px;">
        <span style="font-family:'Cinzel',serif; font-size:0.55rem; color:#c9a227; letter-spacing:2px; text-shadow:0 0 10px rgba(201,162,39,0.5);">@Html.L("Widget_AIGuideLabel")</span>
        <button class="aichat-btn" id="aichatBtn" onclick="aiToggle()" title="@Html.L("Widget_AITourGuideTitle")">𓁹</button>
    </div>

    <!-- Popup -->
    <div class="aichat-popup" id="aichatPopup">
        <div class="aichat-header">
            <div class="aichat-avatar-wrap">
                <div class="aichat-avatar">𓁹</div>
                <div class="aichat-online-dot"></div>
            </div>
            <div class="aichat-info">
                <span class="aichat-name">@Html.L("Widget_AITourGuideTitle")</span>
                <span class="aichat-sub">@Html.L("Widget_OnlineStatus")</span>
            </div>
            <button class="aichat-close" onclick="aiExpand()" title="@Html.L("Common_Expand")" style="margin-inline-end:4px;">⛶</button>
            <button class="aichat-close" onclick="aiToggle()">✕</button>
        </div>

        <div class="aichat-messages" id="aichatMsgs">
            <div class="aichat-msg bot">
                <div class="aichat-msg-av">𓁹</div>
                <div class="aichat-bubble">
                    @Html.L("Widget_WelcomeMessage")
                </div>
            </div>
        </div>

        <div class="aichat-suggestions" id="aichatSugs">
            <button class="aichat-sug" onclick="aiAsk('@Html.L("Chat_Suggestion_Ramesses_Q")')">@Html.L("Widget_Suggestion_Ramesses")</button>
            <button class="aichat-sug" onclick="aiAsk('@Html.L("Chat_Suggestion_Pyramid_Q")')">@Html.L("Chat_Suggestion_Pyramid")</button>
            <button class="aichat-sug" onclick="aiAsk('@Html.L("Chat_Suggestion_Ra_Q")')">@Html.L("Chat_Suggestion_Ra")</button>
            <button class="aichat-sug" onclick="aiAsk('@Html.L("Chat_Suggestion_Cleopatra_Q")')">@Html.L("Chat_Suggestion_Cleopatra")</button>
        </div>

        <div class="aichat-input-wrap">
            <textarea class="aichat-input" id="aichatInput" rows="1"
                      placeholder="@Html.L("Chat_Input_Placeholder")"
                      onkeydown="aiKey(event)"
                      oninput="aiResize(this)"></textarea>
            <button class="aichat-send" id="aichatSend" onclick="aiSend()">➤</button>
        </div>
        <div class="aichat-footer">𓂀 @Html.L("Widget_Footer")</div>
    </div>

    <script>
        const aiErrorMsg = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Html.L("Chat_ErrorMessage")));
        // Dropdown — close on outside click
document.addEventListener('click', function(e) {
    const dropdown = document.querySelector('.nav-dropdown');
    if (dropdown && !dropdown.contains(e.target)) {
        dropdown.querySelector('.nav-dropdown-menu').style.display = 'none';
    }
});

document.querySelector('.nav-dropdown-toggle')?.addEventListener('click', function(e) {
    e.stopPropagation();
    const menu = document.querySelector('.nav-dropdown-menu');
    menu.style.display = menu.style.display === 'block' ? 'none' : 'block';
});
        
        function aiToggle() {
        const popup = document.getElementById('aichatPopup');
        const btn = document.getElementById('aichatBtn');
        popup.classList.toggle('open');
        btn.classList.toggle('active');
        if (popup.classList.contains('open'))
        document.getElementById('aichatInput').focus();
        }

        function aiKey(e) {
        if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); aiSend(); }
        }

        function aiResize(el) {
        el.style.height = 'auto';
        el.style.height = Math.min(el.scrollHeight, 80) + 'px';
        }

        function aiAsk(text) {
        document.getElementById('aichatSugs').style.display = 'none';
        document.getElementById('aichatInput').value = text;
        aiSend();
        }

        function aiAddMsg(text, role) {
        const area = document.getElementById('aichatMsgs');
        const div = document.createElement('div');
        div.className = `aichat-msg ${role}`;
        div.innerHTML = `
        <div class="aichat-msg-av">${role === 'bot' ? '𓁹' : '𓀀'}</div>
        <div class="aichat-bubble">${text}</div>`;
        area.appendChild(div);
        area.scrollTop = area.scrollHeight;
        }

        function aiTyping() {
        const area = document.getElementById('aichatMsgs');
        const div = document.createElement('div');
        div.className = 'aichat-msg bot aichat-typing';
        div.id = 'aichatTyping';
        div.innerHTML = `<div class="aichat-msg-av">𓁹</div>
        <div class="aichat-bubble">
        <span class="aichat-dot"></span>
        <span class="aichat-dot"></span>
        <span class="aichat-dot"></span>
        </div>`;
        area.appendChild(div);
        area.scrollTop = area.scrollHeight;
        }

       function aiExpand() {
    const popup = document.getElementById('aichatPopup');
    const isExpanded = popup.style.width === '520px';
    popup.style.width = isExpanded ? '380px' : '520px';
    popup.style.bottom = isExpanded ? '102px' : '20px';
}
        
        
        
        async function aiSend() {
        const input = document.getElementById('aichatInput');
        const text = input.value.trim();
        if (!text) return;
        input.value = '';
        input.style.height = 'auto';
        document.getElementById('aichatSend').disabled = true;
        document.getElementById('aichatSugs').style.display = 'none';
        aiAddMsg(text, 'user');
        aiTyping();
        try {
        const res = await fetch('/Chatbot/Ask', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: text })
        });
        const data = await res.json();
        document.getElementById('aichatTyping')?.remove();
        aiAddMsg(data.reply, 'bot');
        } catch {
        document.getElementById('aichatTyping')?.remove();
        aiAddMsg(aiErrorMsg, 'bot');
        }
        document.getElementById('aichatSend').disabled = false;
        input.focus();
        }
    </script>
    <!-- ═══════════════════════════════════════════ -->

</body>
</html>
