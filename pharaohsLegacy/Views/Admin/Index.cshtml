        document.getElementById('editDynAchievements').value = btn.dataset.achievements;
        document.getElementById('editDynNameAr').value         = btn.dataset.namear || '';
        document.getElementById('editDynEraAr').value         = btn.dataset.eraar || '';
        document.getElementById('editDynCapitalAr').value     = btn.dataset.capitalar || '';
        document.getElementById('editDynDescAr').value        = btn.dataset.descar || '';
        document.getElementById('editDynAchievementsAr').value = btn.dataset.achievementsar || '';

        const preview = document.getElementById('editDynImgPreview');
        if (btn.dataset.img) {
        preview.src = btn.dataset.img;
        preview.style.display = 'block';
        } else {
        preview.style.display = 'none';
        }

        openModal('modalEditDynasty');
        }


</script>
</body>
