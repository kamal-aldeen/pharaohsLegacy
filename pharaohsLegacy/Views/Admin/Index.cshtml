                            <tr>
                                <th>User</th>
                                <th>Type</th>
                                <th>Item ID</th>
                                <th>Rating</th>
                                <th>Comment</th>
                                <th>Date</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in Model.Reviews)
                            {
                                <tr id="adm-review-@r.Id"
                                    data-rating="@r.Rating"
                                    data-type="@r.Type"
                                    data-date="@r.CreatedAt.ToString("yyyy-MM-dd")">
                                    <td>@r.UserName<br /><small style="color:#8a7055">@r.UserEmail</small></td>
                                    <td><span class="adm-badge Confirmed">@r.Type</span></td>
                                    <td>
                                        @{
                                            var detailsUrl = r.Type switch
                                            {
                                                "temple" => $"/Temple/Details/{r.ItemId}",
                                                "museum" => $"/Museum/Details/{r.ItemId}",
                                                "pharaoh" => $"/Pharaoh/Details/{r.ItemId}",
                                                "god" => $"/God/Details/{r.ItemId}",
                                                "artifact" => $"/Artifact/Details/{r.ItemId}",
                                                _ => "#"
                                            };
                                        }
                                        <a href="@detailsUrl" target="_blank" style="color:#d4af37; text-decoration:none;">
                                            @r.ItemId ↗
                                        </a>
                                    </td>
                                    <td style="color:#c9a227">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            <span>@(i <= r.Rating ? "★" : "☆")</span>
                                        }
                                    </td>
                                    <td style="max-width:250px">@r.Comment</td>
                                    <td>@r.CreatedAt.ToString("MMM dd, yyyy")</td>
                                    <td>
                                        <form method="post" action="/Review/DeleteAdmin" style="display:inline;" onsubmit="return false;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@r.Id" />
                                            <button type="button" class="adm-btn adm-btn-del"
                                                    onclick="showDeleteConfirm(this.closest('form'), '@r.UserName - @r.Type')">
                                                🗑️
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
