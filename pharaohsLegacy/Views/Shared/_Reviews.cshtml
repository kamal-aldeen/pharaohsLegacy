<!-- ══════════════ Scripts ══════════════ -->
<script>
    var currentLang = '@lang';
    var arabicDigitsMap = ['٠', '١', '٢', '٣', '٤', '٥', '٦', '٧', '٨', '٩'];
    function toLocalDigits(input) {
        var str = String(input);
        if (currentLang !== 'ar') return str;
        return str.replace(/[0-9]/g, function (d) { return arabicDigitsMap[+d]; });
    }

    var reviewI18n = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new
    {
        starWord = Html.L("Review_StarWord"),
        selectRatingWarn = "⚠️ " + Html.L("Review_Warn_SelectRating"),
        writeCommentWarn = "⚠️ " + Html.L("Review_Warn_WriteComment"),
        submittedOk = "✅ " + Html.L("Review_Msg_Submitted"),
        updatedOk = "✅ " + Html.L("Review_Msg_Updated"),
        editBtn = "✏️ " + Html.L("Common_Edit"),
        cancelBtn = "✖ " + Html.L("Common_Cancel"),
        selectReasonWarn = "⚠️ " + Html.L("Review_Warn_SelectReason"),
        reportSubmittedOk = "✅ " + Html.L("Review_Msg_ReportSubmitted")
    }));

    (function () {
        /* ── Star Picker (Write Review) ── */
        const stars = document.querySelectorAll('#starPicker .pick-star');
        stars.forEach(s => {
            s.addEventListener('mouseover', () => highlightStars(stars, +s.dataset.value));
            s.addEventListener('mouseout',  () => highlightStars(stars, +document.getElementById('selectedRating').value));
            s.addEventListener('click', () => {
                document.getElementById('selectedRating').value = s.dataset.value;
                highlightStars(stars, +s.dataset.value);
                document.querySelector('.star-hint').textContent =
                    toLocalDigits(s.dataset.value) + ' ' + reviewI18n.starWord;
            });
        });

        /* ── Char counter (Write Review) ── */
        const ta = document.getElementById('reviewComment');
        if (ta) {
            ta.addEventListener('input', () => {
                document.getElementById('charCount').textContent = toLocalDigits(ta.value.length);
            });
        }

        /* ── Edit Star Pickers ── */
        document.querySelectorAll('.edit-star-picker').forEach(picker => {
            const pickStars = picker.querySelectorAll('.pick-star');
            const reviewId  = pickStars[0]?.dataset.review;
            pickStars.forEach(s => {
                s.addEventListener('mouseover', () => highlightStars(pickStars, +s.dataset.value));
                s.addEventListener('mouseout',  () => highlightStars(pickStars, +document.getElementById('editRating-' + reviewId).value));
                s.addEventListener('click', () => {
                    document.getElementById('editRating-' + reviewId).value = s.dataset.value;
                    highlightStars(pickStars, +s.dataset.value);
                });
            });
        });

        /* ── Edit Char Counters ── */
        document.querySelectorAll('[id^="editComment-"]').forEach(el => {
            const reviewId = el.id.split('-')[1];
            el.addEventListener('input', () => {
                document.getElementById('editCharCount-' + reviewId).textContent = toLocalDigits(el.value.length);
            });
        });

        /* ── Load Helpful Data on Page Load ── */
        const type   = '@type';
        const itemId = @itemId;
        fetch(`/Review/GetHelpfulData?type=${type}&itemId=${itemId}`)
            .then(r => r.json())
            .then(data => {
                // update counts
                Object.entries(data.counts).forEach(([id, count]) => {
                    const el = document.getElementById('helpful-count-' + id);
                    if (el) el.textContent = toLocalDigits(count);
                });
                // mark user's votes
                data.userVotes.forEach(id => {
                    const btn = document.getElementById('helpful-btn-' + id);
                    if (btn) btn.classList.add('voted');
                });
            })
            .catch(() => {});

    })();

    /* ── Helpers ── */
    function highlightStars(stars, val) {
        stars.forEach(s => s.classList.toggle('active', +s.dataset.value <= val));
    }

    function showMsg(el, text, type) {
        el.textContent = text;
        el.style.color = type === 'ok' ? '#27ae60' : type === 'warn' ? '#f39c12' : '#e74c3c';
    }

    /* ── Submit Review ── */
    function submitReview(type, itemId) {
        const rating  = document.getElementById('selectedRating').value;
        const comment = document.getElementById('reviewComment').value.trim();
        const msg     = document.getElementById('reviewMsg');

        if (rating < 1) { showMsg(msg, reviewI18n.selectRatingWarn, 'warn'); return; }
        if (!comment)   { showMsg(msg, reviewI18n.writeCommentWarn, 'warn');       return; }

        fetch('/Review/Add', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: `type=${type}&itemId=${itemId}&rating=${rating}&comment=${encodeURIComponent(comment)}`
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                showMsg(msg, reviewI18n.submittedOk, 'ok');
                setTimeout(() => location.reload(), 1500);
            } else {
                showMsg(msg, '❌ ' + data.message, 'err');
            }
        });
    }

    /* ── Toggle Inline Edit Form ── */
    function toggleEditForm(reviewId) {
        const form = document.getElementById('edit-form-' + reviewId);
        const btn  = document.getElementById('edit-btn-' + reviewId);
        const isOpen = form.style.display !== 'none';
        form.style.display = isOpen ? 'none' : 'block';
        btn.textContent    = isOpen ? reviewI18n.editBtn : reviewI18n.cancelBtn;
    }

        /* ── Save Edit ── */
    function saveEdit(reviewId) {
        const rating  = document.getElementById('editRating-'  + reviewId).value;
        const comment = document.getElementById('editComment-' + reviewId).value.trim();
        const msg     = document.getElementById('editMsg-'     + reviewId);

        if (rating < 1) { showMsg(msg, reviewI18n.selectRatingWarn, 'warn'); return; }
        if (!comment)   { showMsg(msg, reviewI18n.writeCommentWarn, 'warn');       return; }

        fetch('/Review/Edit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: `id=${reviewId}&rating=${rating}&comment=${encodeURIComponent(comment)}`
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                showMsg(msg, reviewI18n.updatedOk, 'ok');
                setTimeout(() => location.reload(), 1500);
            } else {
                showMsg(msg, '❌ ' + data.message, 'err');
            }
        });
    }

    /* ── Helpful Toggle ── */
    function toggleHelpful(reviewId) {
        fetch('/Review/ToggleHelpful', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: `reviewId=${reviewId}`
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                const btn   = document.getElementById('helpful-btn-'   + reviewId);
                const count = document.getElementById('helpful-count-' + reviewId);
                if (btn)   btn.classList.toggle('voted', data.isHelpful);
                if (count) count.textContent = toLocalDigits(data.count);
            }
        });
    }

    /* ── Filter by Rating ── */
    function filterByRating(rating, btn) {
        document.querySelectorAll('.rev-filter-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        document.querySelectorAll('.review-card').forEach(card => {
            card.style.display = (rating === 0 || +card.dataset.rating === rating) ? '' : 'none';
        });
    }

    /* ── Report Modal ── */
    function openReportModal(reviewId) {
        document.getElementById('reportReviewId').value = reviewId;
        document.getElementById('reportReason').value   = '';
        document.getElementById('reportMsg').textContent = '';
        document.querySelectorAll('.reason-btn').forEach(b => b.classList.remove('active'));
        document.getElementById('reportModalOverlay').style.display = 'block';
        document.getElementById('reportModal').style.display        = 'block';
    }

    function closeReportModal() {
        document.getElementById('reportModalOverlay').style.display = 'none';
        document.getElementById('reportModal').style.display        = 'none';
    }

    function selectReason(btn, reason) {
        document.querySelectorAll('.reason-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById('reportReason').placeholder = reason;
        btn.dataset.reason = reason;
    }

    function submitReport() {
        const reviewId = document.getElementById('reportReviewId').value;
        const msg      = document.getElementById('reportMsg');

        // Priority: typed text → selected reason button
        let reason = document.getElementById('reportReason').value.trim();
        if (!reason) {
            const activeBtn = document.querySelector('.reason-btn.active');
            reason = activeBtn ? activeBtn.dataset.reason : '';
        }

        if (!reason) {
            showMsg(msg, reviewI18n.selectReasonWarn, 'warn');
            return;
        }

        fetch('/Review/Report', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: `reviewId=${reviewId}&reason=${encodeURIComponent(reason)}`
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                showMsg(msg, reviewI18n.reportSubmittedOk, 'ok');
                setTimeout(closeReportModal, 1800);
            } else {
                showMsg(msg, '❌ ' + data.message, 'err');
            }
        });
    }
</script>
