                        <span class="adm-search-icon">🔍</span>
                        <input class="adm-search" placeholder="Search bookings..."
                               oninput="searchTable('bookingsTable', this.value)" />
                    </div>
                </div>

                <div class="adm-filter-bar" style="display:flex; gap:8px; margin-bottom:16px; flex-wrap:wrap; margin-top:16px;">
                    <button onclick="filterAdminBookings('All', this)" style="background:rgba(201,168,76,0.12); border:1px solid #c9a84c; color:#f0c96e; padding:8px 18px; border-radius:25px; font-size:13px; cursor:pointer;">All</button>
                    <button onclick="filterAdminBookings('Confirmed', this)" style="background:transparent; border:1px solid rgba(201,168,76,0.18); color:#9e8e70; padding:8px 18px; border-radius:25px; font-size:13px; cursor:pointer;">✅ Confirmed</button>
                    <button onclick="filterAdminBookings('Visited', this)" style="background:transparent; border:1px solid rgba(201,168,76,0.18); color:#9e8e70; padding:8px 18px; border-radius:25px; font-size:13px; cursor:pointer;">🏛️ Visited</button>
                    <button onclick="filterAdminBookings('Cancelled', this)" style="background:transparent; border:1px solid rgba(201,168,76,0.18); color:#9e8e70; padding:8px 18px; border-radius:25px; font-size:13px; cursor:pointer;">✖ Cancelled</button>
                    <button onclick="filterAdminBookings('Refunded', this)" style="background:transparent; border:1px solid rgba(201,168,76,0.18); color:#9e8e70; padding:8px 18px; border-radius:25px; font-size:13px; cursor:pointer;">💙 Refunded</button>
                </div>
            <div class="adm-table-wrap">
                <table class="adm-table" id="bookingsTable">
                    <thead><tr>
                        <th>User</th><th>Place</th><th>Type</th>
                        <th>Visit Date</th><th>Tickets</th><th>Amount</th><th>Status</th><th>Actions</th>
                    </tr></thead>
                    <tbody>
                    @foreach (var b in Model.Bookings)
                    {
                        <tr>
                            <td>@b.UserEmail</td>
                            <td><div class="adm-name-cell">@b.PlaceName</div></td>
                            <td><div class="adm-sub-cell">@(b.PlaceType?.ToLower() == "temple" ? "🛕 Temple" : "🏛️ Museum")</div></td>
                            <td>@b.VisitDate.ToString("MMM dd, yyyy")</td>
                            <td>@b.NumberOfTickets 🎫</td>
                            <td style="color:#c9a227; font-weight:600;">@b.TotalPrice.ToString("N0") EGP</td>
                            <td><span class="adm-badge @b.Status">@b.Status</span></td>
                            <td>
                                <button class="adm-btn adm-btn-edit"
                                        onclick="openBookingStatus(@b.Id,'@Html.Raw(b.PlaceName?.Replace("'","\\'")??"")','@b.Status')">
                                    ✏ Status
                                </button>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</main>

