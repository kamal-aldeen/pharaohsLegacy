        function initAddMuseumMap() {
        setTimeout(function() {
        if (addMuseumMap) { addMuseumMap.remove(); addMuseumMap = null; }
        addMuseumMap = L.map('addMuseumMap').setView([26.5, 30.0], 5);
        L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
        attribution: ''
        }).addTo(addMuseumMap);
        addMuseumMap.attributionControl.remove();

        addMuseumMap.on('click', function(e) {
        var lat = e.latlng.lat.toFixed(6);
        var lng = e.latlng.lng.toFixed(6);
        document.getElementById('addMusLat').value = lat;
        document.getElementById('addMusLng').value = lng;
        if (addMuseumMarker) addMuseumMap.removeLayer(addMuseumMarker);
        addMuseumMarker = L.marker([lat, lng]).addTo(addMuseumMap);
        });
        }, 300);
        }

        function openEditMuseumMap(lat, lng) {
        setTimeout(function() {
        if (editMuseumMap) { editMuseumMap.remove(); editMuseumMap = null; }
        var center = (lat && lng) ? [lat, lng] : [26.5, 30.0];
        editMuseumMap = L.map('editMuseumMap').setView(center, lat ? 8 : 5);
        L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
        attribution: ''
        }).addTo(editMuseumMap);
        editMuseumMap.attributionControl.remove();

        if (lat && lng) {
