@using pharaohsLegacy.Extensions

@model List<pharaohsLegacy.Models.Pharaoh>
@{
    ViewData["Title"] = "Pharaohs";
    var lang = Context.Session.GetString("Lang") ?? "en";
    var arrowNext = lang == "ar" ? "←" : "→";
}

@section Styles {
<style>
.pg-hero {
    text-align: center;
    padding: 4rem 2rem 3rem;
    position: relative;
    overflow: hidden;
}
.pg-hero::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 70% 60% at 50% 0%, rgba(201,162,39,.1) 0%, transparent 70%);
    pointer-events: none;
}
.pg-hero-symbol {
    font-size: 3rem; display: block;
    margin-bottom: 1rem;
    animation: floatSym 3s ease-in-out infinite;
}
@@keyframes floatSym {
    0%,100% { transform: translateY(0); }
    50%      { transform: translateY(-8px); }
}
.pg-hero h1 {
    font-family: 'Cinzel', serif;
    font-size: clamp(2rem, 5vw, 3.5rem);
    color: #e8d5b0; margin-bottom: .75rem;
    font-weight: 700; letter-spacing: 2px;
}
.pg-hero h1 span { color: #c9a227; }
.pg-hero p { color: #8a7055; font-size: 1.1rem; font-style: italic; max-width: 500px; margin: 0 auto 2rem; }
.pg-divider { width: 120px; height: 1px; background: linear-gradient(90deg, transparent, #c9a227, transparent); margin: 0 auto; }

.pg-search-wrap { max-width: 480px; margin: 2rem auto 0; position: relative; }
.pg-search {
    width: 100%;
    background: rgba(201,162,39,.05);
            border: 1px solid #3d2a15;
    border-radius: 50px;
    padding-block: .85rem;
    padding-inline: 3rem 1.5rem;
    color: #e8d5b0;
    font-family: 'Crimson Pro', serif;
    font-size: 1rem; outline: none;
    transition: border-color .3s;
}
.pg-search:focus { border-color: #c9a227; }
.pg-search::placeholder { color: #8a7055; }
.pg-search-icon { position: absolute; inset-inline-start: 1.1rem; top: 50%; transform: translateY(-50%); color: #8a7055; pointer-events: none; }

.pg-count { text-align: center; font-family: 'Cinzel', serif; font-size: .65rem; letter-spacing: 3px; text-transform: uppercase; color: #8a7055; margin: 2rem 0 .5rem; }

.pg-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.5rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem 4rem;
}

.pg-card {
            background: #2d1a08;
            border: 1px solid #3d2a15;
    border-radius: 12px; overflow: hidden;
    text-decoration: none; color: inherit;
    display: block;
    position: relative;
    opacity: 0; transform: translateY(20px);
    transition: border-color .3s, box-shadow .3s, transform .3s;
}
.pg-card.visible { opacity: 1; transform: translateY(0); }
.pg-card:hover { transform: translateY(-6px); border-color: #c9a227; box-shadow: 0 12px 40px rgba(201,162,39,.15); }

        .pg-card-img {
            position: relative;
            height: 220px;
            overflow: hidden;
            background: #1a0e05;
        }
.pg-card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform .5s; }
.pg-card:hover .pg-card-img img { transform: scale(1.08); }
.pg-card-img-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(13,7,2,.85) 0%, transparent 50%); }

.pg-card-badge {
    position: absolute; top: 12px; left: 12px;
    background: rgba(13,7,2,.75); backdrop-filter: blur(4px);
    border: 1px solid rgba(201,162,39,.3); border-radius: 20px;
    padding: 4px 12px;
    font-family: 'Cinzel', serif; font-size: .6rem;
    letter-spacing: 1px; color: #c9a227;
}

.pg-card-body { padding: 1.25rem; }
.pg-card-tag { font-family: 'Cinzel', serif; font-size: .6rem; letter-spacing: 2px; text-transform: uppercase; color: #c9a227; margin-bottom: .4rem; display: block; }
.pg-card-name { font-family: 'Cinzel', serif; font-size: 1.1rem; color: #e8d5b0; margin-bottom: .4rem; font-weight: 600; }
.pg-card-desc { color: #8a7055; font-size: .9rem; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

        .pg-card-footer {
            padding: .75rem 1.25rem;
            border-top: 1px solid #3d2a15;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
.pg-card-footer span { font-size: .8rem; color: #8a7055; font-style: italic; }
.pg-card-arrow { color: #c9a227; }

.pg-empty { text-align: center; padding: 4rem 2rem; color: #8a7055; display: none; }
.pg-empty-icon { font-size: 3rem; margin-bottom: 1rem; }
.pg-empty-text { font-family: 'Cinzel', serif; font-size: 1rem; }

@@media (max-width: 768px) {
    .pg-grid { padding: 0 1rem 3rem; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); }
}
</style>
}

<div class="pg-hero">
    <span class="pg-hero-symbol">👑</span>
    <h1>@Html.L("Pharaoh_Hero_Title") <span>@Html.L("Pharaoh_Hero_Name")</span></h1>
    <p>@Html.L("Pharaoh_Hero_Subtitle")</p>
    <div class="pg-divider"></div>
    <div class="pg-search-wrap">
        <span class="pg-search-icon">🔍</span>
        <input class="pg-search" type="text" placeholder="@Html.L("Pharaoh_Search_Placeholder")"
               oninput="filterCards(this.value)" />
    </div>
</div>

<div class="pg-count" id="pgCount" data-unit="@Html.L("Pharaoh_Count_Label")">@Html.Digits(Model.Count) @Html.L("Pharaoh_Count_Label")</div>

<div class="pg-grid" id="pgGrid">
    @foreach (var p in Model)
    {
        var pName = (lang == "ar" && !string.IsNullOrEmpty(p.NameAr)) ? p.NameAr : p.Name;
        var pDynasty = Html.Digits((lang == "ar" && !string.IsNullOrEmpty(p.DynastyAr)) ? p.DynastyAr : p.Dynasty);
        var pPeriod = Html.Digits((lang == "ar" && !string.IsNullOrEmpty(p.PeriodAr)) ? p.PeriodAr : p.Period);
        var pDescription = (lang == "ar" && !string.IsNullOrEmpty(p.DescriptionAr)) ? p.DescriptionAr : p.Description;
        var pSearchName = $"{p.Name} {p.NameAr}".ToLower();
        var pSearchSub = $"{p.Dynasty} {p.DynastyAr}".ToLower();
        <a href="/Pharaoh/Details/@p.Id" class="pg-card"
           data-name="@pSearchName" data-sub="@pSearchSub">
            <div class="pg-card-img">
                <img src="@p.ImageUrl" alt="@pName"
                     onerror="this.src='https://via.placeholder.com/400x300/2d1a08/c9a227?text=@pName'" />
                <div class="pg-card-img-overlay"></div>
                <span class="pg-card-badge">@pDynasty</span>
            </div>
            <div class="pg-card-body">
                <span class="pg-card-tag">👑 @Html.L("Common_Pharaoh")</span>
                <div class="pg-card-name">@pName</div>
                <div class="pg-card-desc">@pDescription</div>
            </div>
            <div class="pg-card-footer">
                <span>@pPeriod</span>
                <span class="pg-card-arrow">@arrowNext</span>
            </div>
        </a>
    }
</div>

<div class="pg-empty" id="pgEmpty">
    <div class="pg-empty-icon">👑</div>
    <div class="pg-empty-text">@Html.L("Pharaoh_Empty_Text")</div>
</div>
@section Scripts {
<script>
var currentLang = '@lang';
var arabicDigitsMap = ['٠', '١', '٢', '٣', '٤', '٥', '٦', '٧', '٨', '٩'];
function toLocalDigits(input) {
    var str = String(input);
    if (currentLang !== 'ar') return str;
    return str.replace(/[0-9]/g, function (d) { return arabicDigitsMap[+d]; });
}

const pgCards = document.querySelectorAll('.pg-card');
const obs = new IntersectionObserver((entries) => {
    entries.forEach((e, i) => {
        if (e.isIntersecting) {
            setTimeout(() => e.target.classList.add('visible'), i * 60);
            obs.unobserve(e.target);
        }
    });
}, { threshold: 0.1 });
pgCards.forEach(c => obs.observe(c));

function filterCards(q) {
    q = q.toLowerCase();
    let visible = 0;
    pgCards.forEach(card => {
        const match = card.dataset.name.includes(q) || card.dataset.sub.includes(q);
        card.style.display = match ? '' : 'none';
        if (match) visible++;
    });
    const pgCountEl = document.getElementById('pgCount');
    pgCountEl.textContent = toLocalDigits(visible) + ' ' + pgCountEl.dataset.unit;
    document.getElementById('pgEmpty').style.display = visible === 0 ? 'block' : 'none';
}
</script>
}
