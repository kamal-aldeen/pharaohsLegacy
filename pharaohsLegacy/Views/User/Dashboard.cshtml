                    <div class="db-info-row">
                        <div class="db-info-icon">𓂋</div>
                        <div><div class="db-info-label">@Html.L("Dash_Stat_TotalSpent")</div><div class="db-info-value">@Html.Digits(Model.TotalSpent.ToString("N0")) @Html.L("Dash_EGP")</div></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>
</div>



@* {{-- ===== REMOVE FAV MODAL ===== --}} *@
<div id="removeFavModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.75); z-index:9999; align-items:center; justify-content:center;">
    <div style="background:var(--dark2); border:2px solid var(--gold); border-radius:16px; max-width:420px; width:90%; overflow:hidden; box-shadow:0 0 40px rgba(var(--gold-rgb),0.3);">
        <div style="background:linear-gradient(135deg,var(--dark2),var(--dark3)); padding:20px 24px; border-bottom:1px solid rgba(var(--gold-rgb),0.2); display:flex; align-items:center; gap:12px;">
            <span style="font-size:1.8rem;">𓂀</span>
            <div>
                <div style="color:var(--gold); font-family:'Cinzel',serif; font-weight:700;">@Html.L("Modal_RemoveFav_Title")</div>
                <div id="removeFavModalName" style="color:var(--text); font-size:0.85rem; opacity:0.8; margin-top:2px;"></div>
            </div>
        </div>
        <div style="padding:24px;">
            <div style="background:rgba(var(--dark-rgb),0.53); border:1px solid rgba(var(--gold-rgb),0.27); border-radius:8px; padding:12px 16px; display:flex; align-items:center; gap:10px; margin-bottom:24px;">
                <span style="font-size:1.1rem;">⚠️</span>
                <span style="color:var(--text); font-size:0.85rem;">@Html.L("Modal_RemoveFav_Desc")</span>
            </div>
            <div style="display:flex; gap:12px;">
                <button onclick="closeRemoveFavModal()"
                        style="flex:1; padding:12px; background:transparent; border:1px solid rgba(var(--gold-rgb),0.4); color:var(--gold); border-radius:8px; font-family:'Cinzel',serif; font-size:0.85rem; cursor:pointer;"
                        onmouseover="this.style.background='rgba(var(--gold-rgb),0.13)'" onmouseout="this.style.background='transparent'">
                    @Html.L("Modal_KeepIt")
                </button>
                <a id="removeFavConfirmBtn" href="#"
                   style="flex:1; padding:12px; background:linear-gradient(135deg,var(--red-dark),var(--red)); border:1px solid rgba(var(--red-rgb),0.4); color:#fff; border-radius:8px; font-family:'Cinzel',serif; font-size:0.85rem; text-align:center; text-decoration:none; display:flex; align-items:center; justify-content:center;">
                    @Html.L("Modal_YesRemove")
                </a>
            </div>
        </div>
    </div>
</div>

@* {{-- ===== CANCEL BOOKING MODAL ===== --}} *@
<div id="cancelBookingOverlay"
     style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.75); z-index:9999; align-items:center; justify-content:center; backdrop-filter:blur(4px);">
    <div style="background:var(--dark2); border:1px solid rgba(var(--gold-rgb),0.25); border-radius:16px; width:90%; max-width:420px; overflow:hidden; animation:fadeInUp .25s ease;">
        <div style="background:linear-gradient(135deg,var(--dark2),var(--dark3)); padding:24px 28px 20px; border-bottom:1px solid rgba(var(--red-rgb),0.2); position:relative;">
            <div style="font-family:'Cinzel',serif; font-size:17px; color:var(--red); letter-spacing:1px;">✖ @Html.L("Modal_CancelBooking_Title")</div>
            <div style="font-size:12px; color:var(--text-dim); margin-top:4px;">@Html.L("Modal_CancelBooking_Confirm")</div>
            <div onclick="closeCancelModal()" style="position:absolute; top:18px; right:18px; width:30px; height:30px; border-radius:50%; background:var(--surface-tint-strong); display:flex; align-items:center; justify-content:center; cursor:pointer; color:var(--muted); font-size:14px;" onmouseover="this.style.background='rgba(var(--red-rgb),0.2)'; this.style.color='var(--red)'" onmouseout="this.style.background='var(--surface-tint-strong)'; this.style.color='var(--muted)'">✕</div>
        </div>
        <div style="padding:24px 28px;">
            <div style="background:var(--surface-tint); border:1px solid rgba(var(--gold-rgb),0.15); border-radius:10px; padding:16px; margin-bottom:20px; display:flex; flex-direction:column; gap:10px;">
                <div style="display:flex; justify-content:space-between; align-items:center;">
                    <span style="color:var(--text-dim); font-size:12px;">@Html.L("Modal_Place")</span>
                    <span id="cancelPlaceName" style="color:var(--gold-light); font-weight:600; font-size:14px;"></span>
                </div>
                <div style="height:1px; background:rgba(var(--gold-rgb),0.08);"></div>
                <div style="display:flex; justify-content:space-between; align-items:center;">
                    <span style="color:var(--text-dim); font-size:12px;">@Html.L("Dash_VisitDate")</span>
                    <span id="cancelVisitDate" style="color:var(--muted); font-size:13px;"></span>
                </div>
                <div style="height:1px; background:rgba(var(--gold-rgb),0.08);"></div>
                <div style="display:flex; justify-content:space-between; align-items:center;">
                    <span style="color:var(--text-dim); font-size:12px;">@Html.L("Modal_RefundAmount")</span>
                    <span id="cancelAmount" style="color:var(--green); font-weight:700; font-size:15px;"></span>
                </div>
            </div>
            <div style="background:rgba(var(--red-rgb),0.08); border:1px solid rgba(var(--red-rgb),0.2); border-radius:8px; padding:12px 14px; display:flex; gap:10px; align-items:flex-start;">
                <span style="font-size:16px;">⚠️</span>
                <span style="color:var(--red); font-size:12px; line-height:1.6;">@Html.L("Modal_CancelBooking_Warning")</span>
            </div>
        </div>
        <div style="padding:16px 28px 24px; display:flex; gap:10px; justify-content:flex-end; border-top:1px solid var(--surface-tint-strong);">
            <button type="button" onclick="closeCancelModal()" style="padding:10px 22px; border-radius:8px; border:1px solid var(--surface-tint-strong); background:var(--surface-tint-strong); color:var(--muted); cursor:pointer; font-size:13px;" onmouseover="this.style.background='var(--surface-tint-strong)'" onmouseout="this.style.background='var(--surface-tint-strong)'">@Html.L("Modal_KeepBooking")</button>
            <form id="cancelBookingForm" action="/Booking/Cancel" method="post" style="margin:0;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="cancelBookingId" />
                <button type="submit" style="padding:10px 24px; border-radius:8px; border:none; background:linear-gradient(135deg,var(--red-dark),var(--red)); color:#fff; font-weight:700; font-size:13px; cursor:pointer; font-family:'Cinzel',serif; letter-spacing:.5px;" onmouseover="this.style.opacity='.85'" onmouseout="this.style.opacity='1'">✖ @Html.L("Modal_YesCancel")</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        var currentLang = '@lang';
        var arabicDigitsMap = ['٠', '١', '٢', '٣', '٤', '٥', '٦', '٧', '٨', '٩'];
        function toLocalDigits(input) {
            var str = String(input);
            if (currentLang !== 'ar') return str;
            return str.replace(/[0-9]/g, function (d) { return arabicDigitsMap[+d]; });
        }
        const dashCurrencyLabel = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Html.L("Dash_EGP")));
        // ===== CANCEL MODAL =====
        function openCancelModal(id, name, visitDate, amount) {
        document.getElementById('cancelBookingId').value = id;
        document.getElementById('cancelPlaceName').textContent = name;
        document.getElementById('cancelVisitDate').textContent = visitDate;
        document.getElementById('cancelAmount').textContent = toLocalDigits(amount.toLocaleString('en-US')) + ' ' + dashCurrencyLabel;
        document.getElementById('cancelBookingOverlay').style.display = 'flex';
        document.body.style.overflow = 'hidden';
        }
        function closeCancelModal() {
        document.getElementById('cancelBookingOverlay').style.display = 'none';
        document.body.style.overflow = '';
        }
        document.getElementById('cancelBookingOverlay').addEventListener('click', function(e) {
        if (e.target === this) closeCancelModal();
        });

        // ===== REMOVE FAV MODAL =====
        function openRemoveFavModal(name, url) {
        document.getElementById('removeFavModalName').textContent = name;
        document.getElementById('removeFavConfirmBtn').href = url;
        document.getElementById('removeFavModal').style.display = 'flex';
        }
        function closeRemoveFavModal() {
        document.getElementById('removeFavModal').style.display = 'none';
        }
        document.getElementById('removeFavModal').addEventListener('click', function(e) {
        if (e.target === this) closeRemoveFavModal();
        });

        // ===== SWITCH TAB =====
        function switchTab(name, btn) {
        document.querySelectorAll('.db-panel').forEach(p => p.classList.remove('active'));
        document.querySelectorAll('.db-tab').forEach(b => b.classList.remove('active'));
        document.getElementById('tab-' + name).classList.add('active');
        btn.classList.add('active');
        document.querySelectorAll('#tab-' + name + ' .fade-up').forEach((el, i) => {
        el.style.animation = 'none';
        el.offsetHeight;
        el.style.animation = '';
        el.style.animationDelay = (i * 0.06) + 's';
        });
        if (name === 'journey') initJourneyMap();
        }

        // ===== COUNTERS =====
        function animateCounter(el) {
        const target = parseInt(el.dataset.target) || 0;
        const duration = 1200;
        const step = target / (duration / 16);
        let current = 0;
        const timer = setInterval(() => {
        current = Math.min(current + step, target);
        el.textContent = toLocalDigits(Math.floor(current).toLocaleString('en-US'));
        if (current >= target) clearInterval(timer);
        }, 16);
        }
        function animateSpent() {
        const target = @Model.TotalSpent.ToString(System.Globalization.CultureInfo.InvariantCulture);
        const el = document.getElementById('totalSpent');
        const duration = 1400;
        const step = target / (duration / 16);
        let current = 0;
        const timer = setInterval(() => {
        current = Math.min(current + step, target);
        el.textContent = toLocalDigits(Math.floor(current).toLocaleString('en-US'));
        if (current >= target) { el.textContent = toLocalDigits(target.toLocaleString('en-US')); clearInterval(timer); }
        }, 16);
        }
        document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('.counter').forEach(animateCounter);
        animateSpent();
        });

        // ===== FILTER BOOKINGS =====
        function filterBookings(status, btn) {
        document.querySelectorAll('#bookingFilters .db-filter-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        document.querySelectorAll('#bookingCards .db-bcard').forEach(card => {
        card.style.display = (status === 'All' || card.dataset.status === status) ? '' : 'none';
        });
        }

        // ===== HASH ROUTING (يشمل journey دلوقتي) =====
        const hash = window.location.hash.replace('#', '');
        const tabIndex = { overview: 0, bookings: 1, favorites: 2, journey: 3, profile: 4 };
        if (tabIndex[hash] !== undefined) {
        switchTab(hash, document.querySelectorAll('.db-tab')[tabIndex[hash]]);
        }

        // ===== JOURNEY MAP =====
        const journeyPins = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(pins));
        let journeyMap = null;
        const journeyI18n = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new
        {
            viewDetails = Html.L("Dash_ViewDetails"),
            arrow = arrowNext,
            temple = Html.L("Common_Temple"),
            museum = Html.L("Common_Museum"),
            statusLabels = new
            {
                Confirmed = Html.L("Status_Confirmed"),
                Cancelled = Html.L("Status_Cancelled"),
                Refunded = Html.L("Status_Refunded"),
                Visited = Html.L("Status_Visited")
            }
        }));

        // ── Tile Layer — بيتبدّل تلقائي مع الدارك/لايت مود (نفس منطق Home/Map) ──
        function getJourneyTileUrl() {
        var isLight = document.documentElement.getAttribute('data-theme') === 'light';
        return isLight
        ? 'https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png'
        : 'https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png';
        }
        var journeyTileLayer = null;

        function initJourneyMap() {
        if (journeyMap || !document.getElementById('journeyMap') || journeyPins.length === 0) return;

        journeyMap = L.map('journeyMap').setView([26.5, 30.5], 6);
        journeyTileLayer = L.tileLayer(getJourneyTileUrl(), {
        attribution: '', maxZoom: 18
        }).addTo(journeyMap);

        // بيراقب تغيير data-theme (لما حد يدوس زرار التوجل) ويبدّل الـ tiles على طول
        new MutationObserver(function () {
        if (journeyTileLayer) journeyTileLayer.setUrl(getJourneyTileUrl());
        }).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

        journeyPins.forEach(pin => {
        const icon = L.divIcon({
        className: '',
        html: `<div class="journey-marker ${pin.PinType}">
        <i class="fas ${pin.Type === 'temple' ? 'fa-archway' : 'fa-landmark'}"></i>
        </div>`,
        iconSize: [38, 38], iconAnchor: [19, 38], popupAnchor: [0, -40]
        });
        const dateRow = pin.VisitDate
        ? `<div class="jp-date"><i class="fas fa-calendar-alt"></i> ${toLocalDigits(pin.VisitDate)}
        <span class="jp-status ${pin.Status.toLowerCase()}">${journeyI18n.statusLabels[pin.Status] || pin.Status}</span>
        </div>` : '';
        const pinName = (currentLang === 'ar' && pin.NameAr) ? pin.NameAr : pin.Name;
        const pinDescription = (currentLang === 'ar' && pin.DescriptionAr) ? pin.DescriptionAr : pin.Description;
        L.marker([pin.Latitude, pin.Longitude], { icon })
        .bindPopup(L.popup({ maxWidth: 260, className: 'journey-popup' }).setContent(`
        <div class="jp-card">
        <img src="${pin.ImageUrl}" onerror="this.src='/images/placeholder.jpg'" />
        <div class="jp-body">
        <span class="jp-type">${pin.Type === 'temple' ? journeyI18n.temple : journeyI18n.museum}</span>
        <h4>${pinName}</h4>
        <p>${pinDescription}</p>
        ${dateRow}
        <a href="/${pin.Type === 'temple' ? 'Temple' : 'Museum'}/Details/${pin.ItemId}" class="jp-link">${journeyI18n.viewDetails} ${journeyI18n.arrow}</a>
        </div>
        </div>
        `)).addTo(journeyMap);
        });

        if (journeyPins.length > 1) {
        journeyMap.fitBounds(journeyPins.map(p => [p.Latitude, p.Longitude]), { padding: [40, 40] });
        }
        }

        function focusPin(lat, lng) {
        if (!journeyMap) return;
        journeyMap.setView([lat, lng], 13, { animate: true });
        }
    </script>
}
