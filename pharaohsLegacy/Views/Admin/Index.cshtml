            <!-- REPORTS -->
            <div id="panel-reports" class="adm-panel @(activeTab == "reports" ? "active" : "")">
                <h2 class="adm-panel-title">🚩 Reported Reviews</h2>

                @if (!Model.Reports.Any())
                {
                    <p class="adm-empty">No reports yet.</p>
                }
                else
                {
                    <table class="adm-table">
                        <thead>
                            <tr>
                                <th>Reporter</th>
                                <th>Review</th>
                                <th>Reason</th>
                                <th>Date</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var rep in Model.Reports)
                            {
                                var review = Model.Reviews.FirstOrDefault(r => r.Id == rep.ReviewId);
                                <tr class="@(rep.IsResolved ? "resolved-row" : "")">
                                    <td>@rep.ReporterEmail</td>
                                    <td>@(review?.Comment ?? "Deleted")</td>
                                    <td>@rep.Reason</td>
                                    <td>@rep.CreatedAt.ToString("MMM dd, yyyy")</td>
                                    <td>
                                        @if (rep.IsResolved)
                                        {
                                            <span class="badge-resolved">✅ Resolved</span>
                                        }
                                        else
                                        {
                                            <span class="badge-pending">🔴 Pending</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!rep.IsResolved)
                                        {
                                            <button class="adm-btn-resolve"
                                                    onclick="resolveReport(@rep.Id, this)">
                                                ✅ Resolve
                                            </button>
                                        }
                                        @if (review != null)
                                        {
                                            <form method="post" action="/Review/DeleteAdmin?returnTab=reports">
                                                <input type="hidden" name="id" value="@review.Id" />
                                                <button type="button" class="adm-btn adm-btn-del"
                                                        onclick="showDeleteConfirm(this.closest('form'), '@(review?.Comment?.Length > 20 ? review.Comment.Substring(0, 20) + "..." : review?.Comment)')">
                                                    🗑️
                                                </button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>



