# انسخ الملف ده وسمّيه .env (بدون .example) وحط بياناتك الحقيقية جوه
# لو هتستخدم Gmail:
#   1. فعّل 2-Step Verification في حسابك: https://myaccount.google.com/security
#   2. اعمل App Password من هنا: https://myaccount.google.com/apppasswords
#   3. حط الـ App Password هنا (مش باسورد الجيميل العادي)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_EMAIL=youraccount@gmail.com
SMTP_PASSWORD=your_app_password_here
