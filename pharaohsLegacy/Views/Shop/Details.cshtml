@model pharaohsLegacy.Models.Product
@using pharaohsLegacy.Extensions
@using Microsoft.AspNetCore.Html
@{
    ViewData["Title"] = "Shop";
    var lang = Context.Session.GetString("Lang") ?? "en";
    var arrowBack = lang == "ar" ? "→" : "←";

    Func<string, IHtmlContent> js = key => Html.Raw(System.Text.Json.JsonSerializer.Serialize(Html.L(key)));
}

<div class="details-wrap">
    <a href="javascript:history.back()" class="btn-back">@arrowBack @Html.L("Common_Back")</a>

    <div class="details-card">
        @{
            var hasDiscount = Model.OriginalPrice.HasValue && Model.OriginalPrice.Value > Model.Price;
            var discountPct = hasDiscount ? (int)Math.Round((1 - (Model.Price / Model.OriginalPrice.Value)) * 100) : 0;
            const int lowStockThreshold = 5;
        }
        <div class="details-img">
            <img src="@ViewBag.ProductImage" alt="@ViewBag.ProductName" />
            <div class="details-badges">
                @if (hasDiscount)
                {
                    <span class="shop-badge badge-sale">-@discountPct%</span>
                }
                @if (Model.IsNew)
                {
                    <span class="shop-badge badge-new">@Html.L("Shop_Badge_New")</span>
                }
                @if (Model.IsBestSeller)
                {
                    <span class="shop-badge badge-bestseller">@Html.L("Shop_Badge_BestSeller")</span>
                }
                @if (Model.IsFeatured)
                {
                    <span class="shop-badge badge-featured">@Html.L("Shop_Badge_Featured")</span>
                }
            </div>
        </div>
        <div class="details-body">
            <span class="card-tag">@Html.L("Shop_Title")</span>
            <h1 class="details-title">@ViewBag.ProductName</h1>
            <p>@(lang == "ar" && !string.IsNullOrEmpty(Model.DescriptionAr) ? Model.DescriptionAr : Model.Description)</p>

            <div class="details-meta">
                <div class="meta-item">
                    <span class="meta-label">@Html.L("Shop_UnitPrice")</span>
                    <span class="meta-value">
                        @if (hasDiscount)
                        {
                            <span class="details-price-old">@Html.Digits((object)Model.OriginalPrice) @Html.L("Common_EGP")</span>
                        }
                        @Html.Digits((object)ViewBag.UnitPrice) @Html.L("Common_EGP")
                    </span>
                </div>
                <div class="meta-item">
                    <span class="meta-label">@Html.L("Shop_InStock")</span>
                    <span class="meta-value">
                        @Html.Digits((object)Model.StockQuantity)
                        @if (Model.StockQuantity > 0 && Model.StockQuantity <= lowStockThreshold)
                        {
                            <span class="details-lowstock">— @Html.L("Shop_LowStock")!</span>
                        }
                    </span>
                </div>
            </div>

            @{
                var material = lang == "ar" && !string.IsNullOrEmpty(Model.MaterialAr) ? Model.MaterialAr : Model.Material;
                var dimensions = lang == "ar" && !string.IsNullOrEmpty(Model.DimensionsAr) ? Model.DimensionsAr : Model.Dimensions;
                var origin = lang == "ar" && !string.IsNullOrEmpty(Model.OriginRegionAr) ? Model.OriginRegionAr : Model.OriginRegion;
                var hasSpecs = !string.IsNullOrEmpty(material) || !string.IsNullOrEmpty(dimensions) || !string.IsNullOrEmpty(origin);
            }
            @if (hasSpecs)
            {
                <div class="details-specs">
                    <span class="specs-title">@Html.L("Shop_Specs_Title")</span>
                    <div class="specs-grid">
                        @if (!string.IsNullOrEmpty(material))
                        {
                            <div class="spec-item"><span class="spec-label">@Html.L("Shop_Specs_Material")</span><span class="spec-value">@material</span></div>
                        }
                        @if (!string.IsNullOrEmpty(dimensions))
                        {
                            <div class="spec-item"><span class="spec-label">@Html.L("Shop_Specs_Dimensions")</span><span class="spec-value">@dimensions</span></div>
                        }
                        @if (!string.IsNullOrEmpty(origin))
                        {
                            <div class="spec-item"><span class="spec-label">@Html.L("Shop_Specs_Origin")</span><span class="spec-value">@origin</span></div>
                        }
                    </div>
                </div>
            }

            @if (Model.StockQuantity <= 0)
            {
                <p class="coupon-msg error">@Html.L("Shop_OutOfStock")</p>
            }
            else
            {
                <form method="post" action="/Shop/Confirm" id="shopForm" novalidate>
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" id="productId" value="@ViewBag.ProductId" />

                    <div class="book-field">
                        <label>@Html.L("Shop_Quantity_Label")</label>
                        <div class="ticket-counter">
                            <button type="button" onclick="changeQty(-1)">−</button>
                            <span id="qtyCount">@Html.Digits(1)</span>
                            <button type="button" onclick="changeQty(1)">+</button>
                        </div>
                        <input type="hidden" name="quantity" id="quantity" value="1" />
                    </div>

                    <div class="book-field">
                        <label>@Html.L("Booking_CardDetails_Label")</label>
                        <input type="text" name="cardNumber" id="cardNumber" placeholder="1234 5678 9012 3456" maxlength="19" required />
                    </div>

                    <div class="book-field card-row">
                        <div>
                            <label>@Html.L("Booking_CardHolder_Label")</label>
                            <input type="text" name="cardHolderName" id="cardHolderName" placeholder="John Doe" required />
                        </div>
                        <div>
                            <label>@Html.L("Booking_Expiry_Label")</label>
                            <input type="text" name="expiryDate" id="expiryDate" placeholder="MM/YY" maxlength="5" required />
                        </div>
                        <div>
                            <label>CVV</label>
                            <input type="text" name="cvv" id="cvv" placeholder="123" maxlength="3" required />
                        </div>
                    </div>

                    <div class="book-field">
                        <label>@Html.L("Booking_Coupon_Label")</label>
                        <div class="coupon-row">
                            <input type="text" name="couponCode" id="couponCode" placeholder="@Html.L("Booking_Coupon_Placeholder")" />
                            <button type="button" id="applyCouponBtn" class="btn-outline">@Html.L("Booking_Coupon_Apply")</button>
                        </div>
                        <div id="couponMsg" class="coupon-msg"></div>
                    </div>

                    <div class="book-field">
                        <label>@Html.L("Booking_Otp_Label")</label>
                        <div class="coupon-row">
                            <input type="text" name="otpCode" id="otpCode" placeholder="@Html.L("Booking_Otp_Placeholder")" maxlength="6" disabled />
                            <button type="button" id="sendOtpBtn" class="btn-outline">@Html.L("Booking_Otp_Send")</button>
                        </div>
                        <div id="otpMsg" class="coupon-msg"></div>
                        <input type="hidden" name="orderId" id="orderId" value="" />
                    </div>

                    <div class="total-price">
                        <span>@Html.L("Booking_Total_Label")</span>
                        <span id="totalPrice">@Html.Digits((object)ViewBag.UnitPrice) @Html.L("Common_EGP")</span>
                    </div>

                    <button type="submit" class="btn-gold" style="width:100%; margin-top:1rem;" id="confirmBtn" disabled>
                        ✓ @Html.L("Shop_BuyBtn")
                    </button>
                    <small id="confirmHint" class="confirm-hint">@Html.L("Booking_ConfirmDisabledHint")</small>
                </form>
            }
        </div>
    </div>

    @{
        var similarProducts = (List<pharaohsLegacy.Models.Product>)ViewBag.SimilarProducts;
    }
    @if (similarProducts != null && similarProducts.Any())
    {
        <div class="similar-products">
            <span class="specs-title">@Html.L("Shop_Similar_Title")</span>
            <div class="similar-grid">
                @foreach (var sp in similarProducts)
                {
                    var spName = (lang == "ar" && !string.IsNullOrEmpty(sp.NameAr)) ? sp.NameAr : sp.Name;
                    <a class="similar-card" href="/Shop/Details/@sp.Id">
                        <div class="similar-img">
                            <img src="@(sp.ImageUrl ?? "/images/placeholder.jpg")" alt="@spName" onerror="this.src='/images/placeholder.jpg'" />
                        </div>
                        <div class="similar-name">@spName</div>
                        <div class="similar-price">@Html.Digits((object)sp.Price) @Html.L("Common_EGP")</div>
                    </a>
                }
            </div>
        </div>
    }

    @await Html.PartialAsync("_Reviews", (
        Reviews: (List<pharaohsLegacy.Models.Review>)ViewBag.Reviews,
        Type: "product",
        ItemId: Model.Id,
        UserReviewed: (bool)ViewBag.UserReviewed
    ))
</div>

<style>
    /* نفس الأنماط المستخدمة في Booking/Create.cshtml — إبقاء الشكل موحّد على مستوى الموقع كله */
    .book-field { margin-bottom: 1.2rem; }
    .book-field label { display: block; font-family: 'Cinzel', serif; font-size: .65rem; letter-spacing: 2px; text-transform: uppercase; color: var(--muted); margin-bottom: .5rem; }
    .ticket-counter { display: flex; align-items: center; gap: 1rem; }
    .ticket-counter button { width: 36px; height: 36px; background: var(--dark3); border: 1px solid var(--border); border-radius: 50%; color: var(--gold); font-size: 1.2rem; cursor: pointer; transition: all .3s; display: flex; align-items: center; justify-content: center; }
    .ticket-counter button:hover { border-color: var(--gold); }
    .ticket-counter span { font-family: 'Cinzel', serif; font-size: 1.5rem; color: var(--text); min-width: 30px; text-align: center; }
    .total-price { display: flex; justify-content: space-between; align-items: center; padding: 1rem; background: rgba(var(--gold-rgb),.08); border: 1px solid var(--border); border-radius: 4px; font-family: 'Cinzel', serif; margin-top: 1rem; }
    .total-price span:first-child { color: var(--muted); font-size: .8rem; letter-spacing: 2px; }
    .total-price span:last-child  { color: var(--gold); font-size: 1.3rem; font-weight: 700; }
    .book-field input[type="text"] { width: 100%; background: var(--dark); border: 1px solid var(--border); border-radius: 4px; padding: .75rem 1rem; color: var(--text); font-family: 'Crimson Pro', serif; font-size: 1rem; outline: none; transition: border-color .3s; }
    .book-field input[type="text"]:focus { border-color: var(--gold); }
    .card-row { display: grid; grid-template-columns: 1.4fr 1fr .8fr; gap: .75rem; }
    .card-row label { margin-bottom: .5rem; }
    .coupon-row { display: flex; gap: .6rem; }
    .coupon-row input { flex: 1; }
    .coupon-row .btn-outline { padding: 0 1.2rem; white-space: nowrap; font-family: 'Cinzel', serif; font-size: .7rem; letter-spacing: 1px; border-radius: 4px; background: transparent; cursor: pointer; }
    .coupon-row .btn-outline:disabled { opacity: .5; cursor: not-allowed; }
    .coupon-msg { margin-top: .5rem; font-size: .85rem; min-height: 1.2em; }
    .coupon-msg.success { color: #3fae5a; }
    .coupon-msg.error { color: #c0392b; }
    .confirm-hint { display: block; text-align: center; margin-top: .5rem; font-size: .8rem; color: var(--muted); }
    @@media (max-width: 560px) { .card-row { grid-template-columns: 1fr; } }

    /* 🆕 المواصفات */
    .details-specs { margin: 1.2rem 0; padding: 1rem; background: rgba(var(--gold-rgb),.06); border: 1px solid var(--border); border-radius: 4px; }
    .specs-title { display: block; font-family: 'Cinzel', serif; font-size: .7rem; letter-spacing: 2px; text-transform: uppercase; color: var(--gold); margin-bottom: .8rem; }
    .specs-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: .8rem; }
    .spec-item { display: flex; flex-direction: column; gap: .2rem; }
    .spec-label { font-family: 'Cinzel', serif; font-size: .6rem; letter-spacing: 1px; text-transform: uppercase; color: var(--muted); }
    .spec-value { font-family: 'Crimson Pro', serif; font-size: 1rem; color: var(--text); }

    /* 🆕 منتجات مشابهة */
    .similar-products { margin-top: 2rem; }
    .similar-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 1rem; margin-top: .8rem; }
    .similar-card { display: block; background: var(--dark3); border: 1px solid var(--border); border-radius: 6px; overflow: hidden; text-decoration: none; transition: border-color .3s, transform .3s; }
    .similar-card:hover { border-color: var(--gold); transform: translateY(-3px); }
    .similar-img { width: 100%; aspect-ratio: 1 / 1; overflow: hidden; background: var(--dark); }
    .similar-img img { width: 100%; height: 100%; object-fit: cover; }
    .similar-name { padding: .6rem .7rem 0; font-family: 'Crimson Pro', serif; font-size: .9rem; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .similar-price { padding: .2rem .7rem .7rem; font-family: 'Cinzel', serif; font-size: .85rem; color: var(--gold); }

    /* 🆕 المرحلة 3 — عروض وخصومات وشارات */
    .details-img { position: relative; }
    .details-badges { position: absolute; top: 12px; left: 12px; display: flex; flex-direction: column; gap: 5px; z-index: 1; }
    .shop-badge { padding: 4px 10px; border-radius: 4px; font-size: .68rem; font-weight: 700; letter-spacing: .3px; color: #fff; text-transform: uppercase; }
    .badge-sale { background: #c0392b; }
    .badge-new { background: #3478f6; }
    .badge-bestseller { background: #2e8b57; }
    .badge-featured { background: var(--gold); color: #1a0a00; }
    .details-price-old { display: block; text-decoration: line-through; color: var(--muted); font-size: .85rem; font-weight: 400; }
    .details-lowstock { color: #d98c00; font-size: .85rem; margin-inline-start: .4rem; }
</style>

<script>
    var unitPrice = @ViewBag.UnitPrice;
    var maxQty = @ViewBag.MaxQuantity;
    var qty = 1;
    var currentLang = '@lang';
    var currencyLabel = @js("Common_EGP");
    var arabicDigitsMap = ['٠', '١', '٢', '٣', '٤', '٥', '٦', '٧', '٨', '٩'];
    var discountPercent = 0;

    function toLocalDigits(num) {
        var str = String(num);
        if (currentLang !== 'ar') return str;
        return str.replace(/[0-9]/g, function (d) { return arabicDigitsMap[+d]; });
    }

    function updateTotal() {
        var raw = unitPrice * qty;
        var finalTotal = discountPercent > 0 ? raw * (1 - discountPercent / 100) : raw;
        document.getElementById('totalPrice').textContent = toLocalDigits(Math.round(finalTotal * 100) / 100) + ' ' + currencyLabel;
    }

    function resetOtpStateIfChanged() {
        var otpInput = document.getElementById('otpCode');
        var confirmBtn = document.getElementById('confirmBtn');
        var msgEl = document.getElementById('otpMsg');

        if (!otpInput.disabled) {
            otpInput.disabled = true;
            otpInput.value = '';
            confirmBtn.disabled = true;
            msgEl.textContent = @js("Booking_ResendOtpHint");
            msgEl.className = 'coupon-msg error';
        }
        updateConfirmHint();
    }

    function updateConfirmHint() {
        var hintEl = document.getElementById('confirmHint');
        hintEl.style.display = document.getElementById('confirmBtn').disabled ? 'block' : 'none';
    }

    function changeQty(val) {
        qty = Math.max(1, Math.min(maxQty || 10, qty + val));
        document.getElementById('qtyCount').textContent = toLocalDigits(qty);
        document.getElementById('quantity').value = qty;
        updateTotal();
        resetOtpStateIfChanged();
    }

    document.getElementById('cardNumber').addEventListener('input', function (e) {
        var digits = e.target.value.replace(/\D/g, '').slice(0, 16);
        e.target.value = digits.replace(/(.{4})/g, '$1 ').trim();
    });
    document.getElementById('expiryDate').addEventListener('input', function (e) {
        var digits = e.target.value.replace(/\D/g, '').slice(0, 4);
        e.target.value = digits.length > 2 ? digits.slice(0, 2) + '/' + digits.slice(2) : digits;
    });
    document.getElementById('cvv').addEventListener('input', function (e) {
        e.target.value = e.target.value.replace(/\D/g, '').slice(0, 3);
    });

    document.getElementById('applyCouponBtn').addEventListener('click', async function () {
        var code = document.getElementById('couponCode').value.trim();
        var msgEl = document.getElementById('couponMsg');
        if (!code) {
            msgEl.textContent = @js("Booking_Coupon_Empty");
            msgEl.className = 'coupon-msg error';
            return;
        }
        msgEl.textContent = '...';
        msgEl.className = 'coupon-msg';
        try {
            var res = await fetch('/Shop/ValidateCoupon?code=' + encodeURIComponent(code));
            var data = await res.json();
            if (data.valid) {
                discountPercent = data.discountPercent;
                msgEl.textContent = @(js("Booking_Coupon_Applied")).replace('{0}', toLocalDigits(discountPercent));
                msgEl.className = 'coupon-msg success';
            } else {
                discountPercent = 0;
                msgEl.textContent = data.message || @js("Booking_Coupon_Invalid");
                msgEl.className = 'coupon-msg error';
            }
        } catch (err) {
            discountPercent = 0;
            msgEl.textContent = @js("Booking_Coupon_Error");
            msgEl.className = 'coupon-msg error';
        }
        updateTotal();
    });

    function otpCooldown(btn, seconds) {
        var originalText = btn.textContent;
        btn.disabled = true;
        var timer = setInterval(function () {
            seconds--;
            btn.textContent = originalText + ' (' + toLocalDigits(seconds) + ')';
            if (seconds <= 0) {
                clearInterval(timer);
                btn.textContent = originalText;
                btn.disabled = false;
            }
        }, 1000);
    }

    document.getElementById('sendOtpBtn').addEventListener('click', async function () {
        var btn = this;
        var msgEl = document.getElementById('otpMsg');
        var existingOrderId = document.getElementById('orderId').value;
        var otpBtnOriginalText = btn.textContent;

        btn.disabled = true;
        msgEl.textContent = '...';
        msgEl.className = 'coupon-msg';

        var body = new URLSearchParams();
        body.append('productId', document.getElementById('productId').value);
        body.append('quantity', qty);
        if (existingOrderId) body.append('existingOrderId', existingOrderId);
        body.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);

        try {
            var res = await fetch('/Shop/RequestOtp', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: body.toString()
            });
            var data = await res.json();

            if (data.orderId) document.getElementById('orderId').value = data.orderId;

            if (data.success) {
                document.getElementById('otpCode').disabled = false;
                document.getElementById('confirmBtn').disabled = false;
                msgEl.textContent = data.message;
                msgEl.className = 'coupon-msg success';
                otpCooldown(btn, 60);
            } else {
                msgEl.textContent = data.message || @js("Booking_Otp_Error");
                msgEl.className = 'coupon-msg error';
                btn.disabled = false;
                btn.textContent = otpBtnOriginalText;
            }
        } catch (err) {
            msgEl.textContent = @js("Booking_Otp_Error");
            msgEl.className = 'coupon-msg error';
            btn.disabled = false;
            btn.textContent = otpBtnOriginalText;
        }
        updateConfirmHint();
    });

    var formEl = document.getElementById('shopForm');
    if (formEl) {
        formEl.addEventListener('submit', function (e) {
            if (!document.getElementById('orderId').value || document.getElementById('confirmBtn').disabled) {
                e.preventDefault();
                var msgEl = document.getElementById('otpMsg');
                msgEl.textContent = @js("Booking_Otp_Required");
                msgEl.className = 'coupon-msg error';
                msgEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        });
        updateConfirmHint();
    }
</script>
