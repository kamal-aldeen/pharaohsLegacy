@using pharaohsLegacy.Extensions
@model List<pharaohsLegacy.Models.HistoricalEvent>
@{
    ViewData["Title"] = "Historical Events";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var lang = Context.Session.GetString("Lang") ?? "en";
    var arrowNext = lang == "ar" ? "←" : "→";
    var dynastyNameMap = ViewBag.DynastyNameMap as Dictionary<string, string> ?? new();
}
<link rel="stylesheet" href="~/css/events.css" />

<div class="events-page">
    <div class="events-hero">
        <h1>𓋹 @Html.L("Common_HistoricalEvents")</h1>
        <p>@Html.L("Event_Hero_Sub")</p>
    </div>

    <div class="events-filters">
        <a href="@Url.Action("Index")" class="filter-btn @(ViewBag.SelectedCategory == "All" ? "active" : "")">𓂀 @Html.L("Event_Filter_All")</a>
        @foreach (var cat in ViewBag.Categories as List<string>)
        {
            var catDisplay = Html.L("Category_" + cat);
            <a href="@Url.Action("Index", new { category = cat })"
               class="filter-btn cat-@cat.ToLower() @(ViewBag.SelectedCategory == cat ? "active" : "")">
                @GetIcon(cat) @catDisplay
            </a>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="events-empty"><p>@Html.L("Event_Empty_Text")</p></div>
    }
    else
    {
        <div class="timeline-container">
            <div class="timeline-line"></div>
            @for (int i = 0; i < Model.Count; i++)
            {
                var ev = Model[i];
                var side = i % 2 == 0 ? "left" : "right";
                var evTitle = (lang == "ar" && !string.IsNullOrEmpty(ev.TitleAr)) ? ev.TitleAr : ev.Title;
                var evCategory = (lang == "ar" && !string.IsNullOrEmpty(ev.CategoryAr)) ? ev.CategoryAr : ev.Category;
                var evDescription = (lang == "ar" && !string.IsNullOrEmpty(ev.DescriptionAr)) ? ev.DescriptionAr : ev.Description;
                var evDynastyTagDisplay = (!string.IsNullOrEmpty(ev.DynastyTag) && lang == "ar" && dynastyNameMap.TryGetValue(ev.DynastyTag, out var dTagAr))
                    ? dTagAr
                    : ev.DynastyTag;
                <div class="timeline-item @side reveal">
                    <div class="timeline-dot cat-dot-@ev.Category.ToLower()"></div>
                    <div class="timeline-card">
                        @if (!string.IsNullOrEmpty(ev.ImageUrl))
                        {
                            <img src="@ev.ImageUrl" alt="@evTitle" class="event-card-img"
                                 onerror="this.style.display='none'" />
                        }
                        <div class="event-card-body">
                            <div class="event-year-badge">@Html.YearLabel(ev.Year)</div>
                            <span class="cat-badge cat-badge-@ev.Category.ToLower()">@evCategory</span>
                            <h3>@evTitle</h3>
                            <p>@(evDescription.Length > 140 ? evDescription[..140] + "…" : evDescription)</p>
                            @if (!string.IsNullOrEmpty(ev.DynastyTag))
                            {
                                <div class="event-dynasty-tag">𓂀 @evDynastyTagDisplay</div>
                            }
                            <a href="@Url.Action("Details", new { id = ev.Id })" class="event-details-btn">@Html.L("Event_Explore_Link") @arrowNext</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@functions {
    string GetIcon(string cat) => cat switch
    {
        "Political" => "𓆓",
        "Military" => "𓀀",
        "Religious" => "𓋴",
        "Cultural" => "𓏏",
        "Scientific" => "𓇋",
        _ => "𓂀"
    };
}
<script src="~/js/events.js"></script>