@using pharaohsLegacy.ViewModels
@using pharaohsLegacy.Extensions
@model pharaohsLegacy.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "My Dashboard";
    var initials = string.Join("", Model.UserName.Split(' ').Take(2).Select(w => w[0]));
    var activeTab = ViewBag.ActiveTab as string ?? "overview";
    var lang = Context.Session.GetString("Lang") ?? "en";
    var arrowNext = lang == "ar" ? "←" : "→";
}

@section Styles {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>

        /* Dashboard used to define its own isolated color system here (fixed hex values
           that never reacted to the site-wide light/dark toggle). It now reuses the
           shared tokens from _Layout.cshtml's :root, only adding thin aliases for the
           class names this file already uses. --gold, --gold-light, --text, --dark,
           --dark2/3, --red/green/blue/purple, --on-gold all come from _Layout. */
        :root {
            --gold-dim: var(--gold-dark);
            --text-dim: var(--muted);
            --dark-2: var(--dark2);
            --dark-3: var(--dark3);
            --dark-4: var(--dark3);
            --dark-card: var(--dark3);
            --border-hover: rgba(var(--gold-rgb), 0.45);
            --shadow-gold: 0 0 30px rgba(var(--gold-rgb), 0.12);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        .db-wrap {
            min-height: 100vh;
            background: var(--dark);
            padding: 0 0 80px;
            font-family: 'Segoe UI', sans-serif;
            color: var(--text);
        }

        .db-hero {
            position: relative;
            background: linear-gradient(135deg, var(--dark) 0%, var(--dark3) 50%, var(--dark) 100%);
            border-bottom: 1px solid rgba(var(--gold-rgb),0.15);
            padding: 50px 40px 0;
            overflow: hidden;
        }

            .db-hero::before {
                content: '';
                position: absolute;
                inset: 0;
                background: radial-gradient(ellipse 60% 50% at 80% 50%, rgba(var(--gold-rgb),0.07) 0%, transparent 70%), url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23c9a84c' fill-opacity='0.03'%3E%3Cpath d='M30 0 L60 30 L30 60 L0 30z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
                pointer-events: none;
            }

        .db-hero-inner {
            position: relative;
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            align-items: flex-end;
            gap: 32px;
            padding-bottom: 0;
        }

        .db-avatar-wrap {
            flex-shrink: 0;
            position: relative;
        }

        .db-avatar {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--gold-dim), var(--gold));
            border: 3px solid var(--gold);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 36px;
            font-weight: 700;
            color: var(--on-gold);
            font-family: 'Cinzel', serif;
            box-shadow: 0 0 0 6px rgba(var(--gold-rgb),0.12), var(--shadow-gold);
            letter-spacing: 2px;
            margin-bottom: 6px;
        }

        .db-avatar-badge {
            position: absolute;
            bottom: 8px;
            right: -2px;
            width: 22px;
            height: 22px;
            background: var(--green);
            border-radius: 50%;
            border: 3px solid var(--dark-2);
           
        }

        .db-hero-info {
            flex: 1;
            padding-bottom: 28px;
        }

        .db-hero-greeting {
            font-size: 13px;
            color: var(--text-dim);
            letter-spacing: 2px;
            text-transform: uppercase;
            margin-bottom: 6px;
            font-family: 'Cinzel', serif;
        }

        .db-hero-name {
            font-size: 32px;
            font-weight: 700;
            color: var(--gold-light);
            font-family: 'Cinzel', serif;
            letter-spacing: 1px;
            margin-bottom: 4px;
            line-height: 1.2;
        }

        .db-hero-email {
            font-size: 14px;
            color: var(--text-dim);
        }

        .db-tabs {
            position: relative;
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            gap: 0;
            margin-top: 32px;
        }

        .db-tab {
            padding: 14px 28px;
            font-size: 14px;
            font-family: 'Cinzel', serif;
            letter-spacing: 1px;
            color: var(--text-dim);
            cursor: pointer;
            border-bottom: 3px solid transparent;
            transition: all 0.25s;
            display: flex;
            align-items: center;
            gap: 8px;
            background: none;
            border-top: none;
            border-left: none;
            border-right: none;
            position: relative;
        }

            .db-tab:hover {
                color: var(--gold-light);
            }

            .db-tab.active {
                color: var(--gold-light);
                border-bottom-color: var(--gold);
            }

            .db-tab .tab-badge {
                background: var(--gold);
                color: var(--on-gold);
                font-size: 11px;
                font-weight: 700;
                padding: 2px 7px;
                border-radius: 20px;
                font-family: 'Segoe UI', sans-serif;
            }

        .db-content {
            max-width: 1200px;
            margin: 36px auto 0;
            padding: 0 20px;
        }

        .db-panel {
            display: none;
        }

            .db-panel.active {
                display: block;
                padding: 0 20px;
            }

            .db-panel.active {
                display: block;
            }

        .db-stats {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 18px;
            margin-bottom: 36px;
        }

        .db-stat {
            background: var(--dark-card);
            border: 1px solid rgba(var(--gold-rgb),0.15);
            border-radius: 16px;
            padding: 24px 20px;
            display: flex;
            align-items: center;
            gap: 16px;
            transition: all 0.3s;
            position: relative;
            overflow: hidden;
        }

            .db-stat::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 2px;
                background: linear-gradient(90deg, transparent, var(--gold), transparent);
                opacity: 0;
                transition: opacity 0.3s;
            }

            .db-stat:hover {
                border-color: var(--border-hover);
                transform: translateY(-3px);
                box-shadow: var(--shadow-gold);
            }

                .db-stat:hover::before {
                    opacity: 1;
                }

        .db-stat-icon {
            width: 52px;
            height: 52px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            flex-shrink: 0;
        }

            .db-stat-icon.gold {
                background: rgba(var(--gold-rgb),0.12);
            }

            .db-stat-icon.green {
                background: rgba(var(--green-rgb),0.12);
            }

            .db-stat-icon.blue {
                background: rgba(var(--blue-rgb),0.12);
            }

            .db-stat-icon.red {
                background: rgba(var(--red-rgb),0.12);
            }

        .db-stat-val {
            font-size: 28px;
            font-weight: 700;
            color: var(--gold-light);
            font-family: 'Cinzel', serif;
            line-height: 1;
            margin-bottom: 4px;
        }

        .db-stat-label {
            font-size: 12px;
            color: var(--text-dim);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .db-section-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 20px;
        }

        .db-section-title {
            font-family: 'Cinzel', serif;
            font-size: 18px;
            color: var(--gold-light);
            letter-spacing: 1px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .db-section-title::before {
                content: '';
                display: block;
                width: 4px;
                height: 22px;
                background: linear-gradient(to bottom, var(--gold), var(--gold-dim));
                border-radius: 4px;
            }

        .db-see-all {
            font-size: 13px;
            color: var(--gold);
            text-decoration: none;
            letter-spacing: 1px;
            font-family: 'Cinzel', serif;
            transition: color 0.2s;
        }

            .db-see-all:hover {
                color: var(--gold-light);
            }

        .db-overview-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 28px;
        }

        .db-booking-list {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .db-booking-row {
            background: var(--dark-card);
            border: 1px solid rgba(var(--gold-rgb),0.15);
            border-radius: 14px;
            padding: 16px 18px;
            display: flex;
            align-items: center;
            gap: 16px;
            transition: all 0.25s;
        }

            .db-booking-row:hover {
                border-color: var(--border-hover);
                transform: translateX(4px);
            }

        .db-booking-thumb {
            width: 54px;
            height: 54px;
            border-radius: 10px;
            object-fit: cover;
            flex-shrink: 0;
            background: var(--dark-3);
            border: 1px solid rgba(var(--gold-rgb),0.15);
        }

        .db-booking-info {
            flex: 1;
            min-width: 0;
        }

        .db-booking-name {
            font-size: 14px;
            font-weight: 600;
            color: var(--text);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            margin-bottom: 4px;
        }

        .db-booking-meta {
            font-size: 12px;
            color: var(--text-dim);
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .db-booking-price {
            font-size: 15px;
            font-weight: 700;
            color: var(--gold);
            white-space: nowrap;
        }

        .db-fav-grid-mini {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
        }

        .db-fav-mini {
            background: var(--dark-card);
            border: 1px solid rgba(var(--gold-rgb),0.15);
            border-radius: 12px;
            overflow: hidden;
            position: relative;
            aspect-ratio: 4/3;
            transition: all 0.25s;
        }

            .db-fav-mini:hover {
                border-color: var(--border-hover);
                transform: scale(1.02);
            }

            .db-fav-mini img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                display: block;
            }

        .db-fav-mini-overlay {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, transparent 100%);
            padding: 20px 10px 10px;
        }

        .db-fav-mini-name {
            font-size: 11px;
            font-weight: 600;
            color: var(--gold-light);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .db-fav-mini-sub {
            font-size: 10px;
            color: var(--text-dim);
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }

            .status-badge.Confirmed {
                background: rgba(var(--green-rgb),0.15);
                color: var(--green);
                border: 1px solid rgba(var(--green-rgb),0.3);
            }

            .status-badge.Cancelled {
                background: rgba(var(--red-rgb),0.12);
                color: var(--red);
                border: 1px solid rgba(var(--red-rgb),0.25);
            }

            .status-badge.Refunded {
                background: rgba(var(--blue-rgb),0.12);
                color: var(--blue);
                border: 1px solid rgba(var(--blue-rgb),0.25);
            }

            .status-badge.Visited {
                background: rgba(var(--purple-rgb),0.15);
                color: var(--purple);
                border: 1px solid rgba(var(--purple-rgb),0.3);
            }

        .db-booking-cards {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
            gap: 20px;
        }

        .db-bcard {
            background: var(--dark-card);
            border: 1px solid rgba(var(--gold-rgb),0.15);
            border-radius: 18px;
            overflow: hidden;
            transition: all 0.3s;
            position: relative;
        }

            .db-bcard:hover {
                border-color: var(--border-hover);
                transform: translateY(-4px);
                box-shadow: var(--shadow-gold);
            }

        .db-bcard-img {
            width: 100%;
            height: 160px;
            object-fit: cover;
            display: block;
            background: var(--dark-3);
        }

        .db-bcard-body {
            padding: 18px;
        }

        .db-bcard-top {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            margin-bottom: 12px;
            gap: 10px;
        }

        .db-bcard-name {
            font-size: 16px;
            font-weight: 600;
            color: var(--gold-light);
            font-family: 'Cinzel', serif;
            line-height: 1.3;
        }

        .db-bcard-type {
            font-size: 12px;
            color: var(--text-dim);
            margin-top: 3px;
        }

        .db-bcard-meta {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-top: 14px;
        }

        .db-bcard-field-label {
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-dim);
            margin-bottom: 3px;
        }

        .db-bcard-field-val {
            font-size: 14px;
            color: var(--text);
            font-weight: 500;
        }

        .db-bcard-price-val {
            font-size: 18px;
            font-weight: 700;
            color: var(--gold);
        }

        .db-bcard-footer {
            padding: 14px 18px;
            border-top: 1px solid rgba(var(--gold-rgb),0.15);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
        }

        .db-fav-section {
            margin-bottom: 40px;
        }

        .db-fav-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 16px;
        }

        .db-fav-card {
            background: var(--dark-card);
            border: 1px solid rgba(var(--gold-rgb),0.15);
            border-radius: 16px;
            overflow: hidden;
            position: relative;
            transition: all 0.3s;
        }

            .db-fav-card:hover {
                border-color: var(--border-hover);
                transform: translateY(-4px);
                box-shadow: var(--shadow-gold);
            }

        .db-fav-card-img-wrap {
            position: relative;
            aspect-ratio: 3/2;
            overflow: hidden;
        }

        .db-fav-card img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.4s;
        }

        .db-fav-card:hover img {
            transform: scale(1.06);
        }

        .db-fav-card-type-badge {
            position: absolute;
            top: 10px;
            left: 10px;
            background: rgba(0,0,0,0.7);
            backdrop-filter: blur(4px);
            border: 1px solid rgba(var(--gold-rgb),0.15);
            border-radius: 20px;
            padding: 3px 10px;
            font-size: 11px;
            color: var(--gold);
            letter-spacing: 0.5px;
        }

        .db-fav-card-remove {
            position: absolute;
            top: 10px;
            right: 10px;
            width: 30px;
            height: 30px;
            background: rgba(var(--red-rgb),0.15);
            border: 1px solid rgba(var(--red-rgb),0.3);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            opacity: 0;
            transition: all 0.2s;
            color: var(--red);
            font-size: 14px;
            text-decoration: none;
        }

        .db-fav-card:hover .db-fav-card-remove {
            opacity: 1;
        }

        .db-fav-card-remove:hover {
            background: rgba(var(--red-rgb),0.3);
            transform: scale(1.1);
        }

        .db-fav-card-body {
            padding: 14px;
        }

        .db-fav-card-name {
            font-size: 14px;
            font-weight: 600;
            color: var(--text);
            margin-bottom: 4px;
            font-family: 'Cinzel', serif;
        }

        .db-fav-card-sub {
            font-size: 12px;
            color: var(--text-dim);
        }

        .db-fav-card-link {
            display: block;
            text-align: center;
            padding: 10px;
            border-top: 1px solid rgba(var(--gold-rgb),0.15);
            font-size: 12px;
            color: var(--gold);
            text-decoration: none;
            letter-spacing: 0.5px;
            transition: all 0.2s;
            font-family: 'Cinzel', serif;
        }

            .db-fav-card-link:hover {
                background: rgba(var(--gold-rgb),0.06);
                color: var(--gold-light);
            }

        .db-profile-grid {
            display: grid;
            grid-template-columns: 380px 1fr;
            gap: 28px;
            align-items: start;
        }

        .db-profile-card {
            background: var(--dark-card);
            border: 1px solid rgba(var(--gold-rgb),0.15);
            border-radius: 20px;
            padding: 36px 28px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

            .db-profile-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 3px;
                background: linear-gradient(90deg, transparent, var(--gold), transparent);
            }

        .db-profile-avatar-lg {
            width: 110px;
            height: 110px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--gold-dim), var(--gold));
            border: 3px solid var(--gold);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 40px;
            font-weight: 700;
            color: var(--on-gold);
            font-family: 'Cinzel', serif;
            letter-spacing: 2px;
            box-shadow: 0 0 0 8px rgba(var(--gold-rgb),0.1);
            margin: 0 auto 20px;
        }

        .db-profile-name-lg {
            font-size: 22px;
            font-family: 'Cinzel', serif;
            color: var(--gold-light);
            margin-bottom: 6px;
        }

        .db-profile-email-lg {
            font-size: 14px;
            color: var(--text-dim);
            margin-bottom: 28px;
        }

        .db-profile-divider {
            height: 1px;
            background: rgba(var(--gold-rgb),0.15);
            margin: 20px 0;
        }

        .db-profile-stat-row {
            display: flex;
            justify-content: space-around;
            text-align: center;
        }

        .db-profile-stat-item .val {
            font-size: 24px;
            font-weight: 700;
            color: var(--gold);
            font-family: 'Cinzel', serif;
        }

        .db-profile-stat-item .lbl {
            font-size: 11px;
            color: var(--text-dim);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-top: 3px;
        }

        .db-info-card {
            background: var(--dark-card);
            border: 1px solid rgba(var(--gold-rgb),0.15);
            border-radius: 20px;
            padding: 28px;
        }

        .db-info-row {
            display: flex;
            align-items: center;
            gap: 16px;
            padding: 16px 0;
            border-bottom: 1px solid rgba(var(--gold-rgb),0.15);
        }

            .db-info-row:last-child {
                border-bottom: none;
            }

        .db-info-icon {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            background: rgba(var(--gold-rgb),0.08);
            border: 1px solid rgba(var(--gold-rgb),0.15);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            flex-shrink: 0;
        }

        .db-info-label {
            font-size: 12px;
            color: var(--text-dim);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 4px;
        }

        .db-info-value {
            font-size: 15px;
            color: var(--text);
            font-weight: 500;
        }

        .db-bank-banner {
            display: flex;
            align-items: center;
            gap: 20px;
            background: linear-gradient(135deg, rgba(var(--gold-rgb), 0.09), rgba(var(--gold-rgb), 0.03));
            border: 1px solid rgba(var(--gold-rgb), 0.25);
            border-radius: 16px;
            padding: 22px 26px;
            position: relative;
            overflow: hidden;
            box-shadow: 0 10px 30px -12px rgba(0,0,0,0.35);
        }

            .db-bank-banner::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 2px;
                background: linear-gradient(90deg, transparent, var(--gold), transparent);
            }

            .db-bank-banner.is-error {
                background: linear-gradient(135deg, rgba(var(--red-rgb), 0.09), rgba(var(--red-rgb), 0.03));
                border-color: rgba(var(--red-rgb), 0.25);
            }

                .db-bank-banner.is-error::before {
                    background: linear-gradient(90deg, transparent, var(--red), transparent);
                }

        .db-bank-banner-icon {
            width: 52px;
            height: 52px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 21px;
            flex-shrink: 0;
            background: rgba(var(--gold-rgb), 0.14);
            border: 1px solid rgba(var(--gold-rgb), 0.3);
            color: var(--gold);
        }

            .db-bank-banner-icon svg {
                width: 24px;
                height: 24px;
            }

            .db-bank-banner.is-error .db-bank-banner-icon {
                background: rgba(var(--red-rgb), 0.14);
                border-color: rgba(var(--red-rgb), 0.3);
                color: var(--red);
            }

        .db-bank-banner-content {
            flex: 1;
            min-width: 0;
        }

        .db-bank-banner-title {
            font-family: 'Cinzel', serif;
            color: var(--gold-light);
            font-size: 15px;
            font-weight: 700;
            letter-spacing: 0.5px;
            display: block;
            margin-bottom: 5px;
        }

            .db-bank-banner.is-error .db-bank-banner-title {
                color: var(--red);
            }

        .db-bank-banner-body {
            color: var(--text-dim);
            font-size: 13.5px;
            line-height: 1.6;
        }

        .db-bank-banner-cta {
            flex-shrink: 0;
            white-space: nowrap;
        }

        @@media (max-width: 640px) {
            .db-bank-banner {
                flex-wrap: wrap;
            }

            .db-bank-banner-cta {
                margin-inline-start: 72px;
            }
