@using pharaohsLegacy.Extensions
@model pharaohsLegacy.Models.User

<h2>@Html.L("Common_Register")</h2>

<form asp-controller="User" asp-action="Register" method="post">

    <input asp-for="Name" class="form-control" placeholder="@Html.L("Common_Name")" />
    <br />
    <input asp-for="Email" class="form-control" placeholder="@Html.L("Common_Email")" />
    <br />

    <input asp-for="Password" type="password" class="form-control" placeholder="@Html.L("Common_Password")" />
    <br />

    <button type="submit" class="btn btn-success">@Html.L("Common_Register")</button>
</form>