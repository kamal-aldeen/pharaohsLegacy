        .db-empty {
            text-align: center;
            padding: 60px 20px;
            color: var(--text-dim);
        }

        .db-empty-icon {
            font-size: 52px;
            margin-bottom: 16px;
            opacity: 0.5;
        }

        .db-empty-text {
            font-size: 16px;
            font-family: 'Cinzel', serif;
            color: var(--text-dim);
        }

        .btn-gold {
            background: linear-gradient(135deg, var(--gold-dim), var(--gold));
            color: var(--on-gold);
            border: none;
            padding: 9px 20px;
            border-radius: 10px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: all 0.2s;
            font-family: 'Cinzel', serif;
            letter-spacing: 0.5px;
        }

            .btn-gold:hover {
                filter: brightness(1.15);
                transform: translateY(-1px);
                color: var(--on-gold);
            }

        .btn-outline {
            background: transparent;
            color: var(--text-dim);
            border: 1px solid rgba(var(--gold-rgb),0.15);
            padding: 9px 20px;
            border-radius: 10px;
            font-size: 13px;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: all 0.2s;
        }

            .btn-outline:hover {
                border-color: var(--border-hover);
                color: var(--text);
            }

        .cancel-form {
            display: inline;
        }

        .db-filter-bar {
            display: flex;
            gap: 8px;
            margin-bottom: 24px;
            flex-wrap: wrap;
        }

        .db-filter-btn {
            background: var(--dark-card);
            border: 1px solid rgba(var(--gold-rgb),0.15);
            color: var(--text-dim);
            padding: 8px 18px;
            border-radius: 25px;
            font-size: 13px;
            cursor: pointer;
            transition: all 0.2s;
            font-family: 'Cinzel', serif;
        }

            .db-filter-btn:hover, .db-filter-btn.active {
                background: rgba(var(--gold-rgb),0.12);
                border-color: var(--gold);
                color: var(--gold-light);
            }

        /* =================== MY JOURNEY TAB =================== */
        .journey-header {
            text-align: center;
            padding: 30px 20px 20px;
        }

            .journey-header h2 {
                color: var(--gold);
                font-size: 1.8rem;
                margin-bottom: 8px;
            }

            .journey-header p {
                color: var(--muted);
                font-size: 0.95rem;
            }

        .journey-legend {
            display: flex;
            justify-content: center;
            gap: 15px;
            margin-top: 15px;
            flex-wrap: wrap;
        }

        
        .journey-marker.Visited {
            background: var(--green);
            color: #fff;
        }

        .jcard.Visited {
            border-color: rgba(var(--green-rgb),.25);
        }

        .jcard-badge.Visited {
            background: var(--green);
            color: #fff;
        }

        .legend-item.Visited {
            background: rgba(var(--green-rgb),.15);
            color: var(--green);
            border: 1px solid rgba(var(--green-rgb),0.33);
        }


        .legend-item {
            display: flex;
            align-items: center;
            gap: 7px;
            font-size: 0.85rem;
            padding: 5px 14px;
            border-radius: 20px;
        }

            .legend-item.booking {
                background: rgba(var(--gold-rgb),.15);
                color: var(--gold);
                border: 1px solid rgba(var(--gold-rgb),0.33);
            }

            .legend-item.favorite {
                background: rgba(var(--red-rgb),.15);
                color: var(--red);
                border: 1px solid rgba(var(--red-rgb),0.33);
            }

            .legend-item.both {
                background: rgba(var(--purple-rgb),.15);
                color: var(--purple);
                border: 1px solid rgba(var(--purple-rgb),0.33);
            }

        .journey-empty {
            text-align: center;
            padding: 60px 20px;
        }

            .journey-empty .empty-icon {
                font-size: 4rem;
                color: var(--muted);
                margin-bottom: 20px;
            }

            .journey-empty h3 {
                color: var(--gold);
                margin-bottom: 10px;
            }

            .journey-empty p {
                color: var(--muted);
                margin-bottom: 25px;
            }

        .empty-actions {
            display: flex;
            gap: 15px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .journey-stats {
            display: flex;
            justify-content: center;
            gap: 15px;
            padding: 0 20px 25px;
            flex-wrap: wrap;
        }

        .jstat {
            background: rgba(var(--gold-rgb),.08);
            border: 1px solid rgba(var(--gold-rgb),.2);
            border-radius: 12px;
            padding: 16px 28px;
            text-align: center;
            min-width: 110px;
        }

        .jstat-num {
            display: block;
            font-size: 2rem;
            font-weight: 700;
            color: var(--gold);
        }

        .jstat-label {
            font-size: 0.78rem;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .journey-map-wrapper {
            padding: 0 20px 25px;
        }

        #journeyMap {
            height: 420px;
            border-radius: 14px;
            border: 1px solid rgba(var(--gold-rgb),.25);
            overflow: hidden;
        }

        .journey-marker {
            width: 38px;
            height: 38px;
            border-radius: 50% 50% 50% 0;
            transform: rotate(-45deg);
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 15px rgba(0,0,0,.5);
        }

            .journey-marker i {
                transform: rotate(45deg);
                font-size: 14px;
            }

            .journey-marker.booking {
                background: var(--gold);
                color: var(--on-gold);
            }

            .journey-marker.favorite {
                background: var(--red);
                color: #fff;
            }

            .journey-marker.both {
                background: var(--purple);
                color: #fff;
            }

        /* Popup — نفس منطق Map.cshtml، بيتبدّل مع الدارك/لايت مود لأنه بيستخدم متغيرات الـ Layout */
        .journey-popup .leaflet-popup-content-wrapper {
            background: var(--dark2);
            border: 1px solid rgba(var(--gold-rgb),.3);
            border-radius: 12px;
            padding: 0;
            overflow: hidden;
        }

        .journey-popup .leaflet-popup-tip {
            background: var(--dark2);
        }

        .journey-popup .leaflet-popup-content {
            margin: 0;
            width: 240px !important;
        }

        .jp-card img {
            width: 100%;
            height: 130px;
            object-fit: cover;
        }

        .jp-body {
            padding: 12px 14px;
        }

        .jp-type {
            font-size: 0.72rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--gold);
        }

        .jp-body h4 {
            color: var(--text);
            margin: 4px 0 6px;
            font-size: 0.95rem;
        }

        .jp-body p {
            color: var(--muted);
            font-size: 0.8rem;
            margin-bottom: 8px;
            line-height: 1.4;
        }

        .jp-date {
            font-size: 0.78rem;
            color: var(--muted);
            margin-bottom: 8px;
        }

        .jp-status {
            display: inline-block;
            padding: 2px 8px;
            border-radius: 10px;
            font-size: 0.7rem;
            margin-inline-start: 6px;
        }

            .jp-status.confirmed {
                background: rgba(var(--green-rgb),.2);
                color: var(--green);
            }

            .jp-status.pending {
                background: rgba(var(--gold-rgb),.2);
                color: var(--gold);
            }

            .jp-status.cancelled {
                background: rgba(var(--red-rgb),.2);
                color: var(--red);
            }

        .jp-link {
            display: inline-block;
            color: var(--gold);
            font-size: 0.82rem;
            font-weight: 600;
            text-decoration: none;
        }

            .jp-link:hover {
                text-decoration: underline;
            }

        .journey-cards {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 18px;
            padding: 0 20px 30px;
        }

        .jcard {
            background: var(--surface-tint);
            border-radius: 14px;
            overflow: hidden;
            border: 1px solid var(--surface-tint-strong);
            cursor: pointer;
            transition: transform .25s, border-color .25s;
        }

            .jcard:hover {
                transform: translateY(-4px);
            }

            .jcard.booking {
                border-color: rgba(var(--gold-rgb),.25);
            }

            .jcard.favorite {
                border-color: rgba(var(--red-rgb),.25);
            }

            .jcard.both {
                border-color: rgba(var(--purple-rgb),.25);
            }

        .jcard-img {
            position: relative;
            height: 170px;
            overflow: hidden;
        }

            .jcard-img img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                transition: transform .4s;
            }

        .jcard:hover .jcard-img img {
            transform: scale(1.05);
        }

        .jcard-badge {
            position: absolute;
            top: 10px;
            right: 10px;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.72rem;
            font-weight: 600;
        }

            .jcard-badge.booking {
                background: var(--gold);
                color: var(--on-gold);
            }

            .jcard-badge.favorite {
                background: var(--red);
                color: #fff;
            }

            .jcard-badge.both {
                background: var(--purple);
                color: #fff;
            }

        .jcard-body {
            padding: 14px 16px;
        }

        .jcard-type {
            font-size: 0.72rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--gold);
        }

        .jcard-body h4 {
            color: #fff;
            margin: 5px 0 8px;
            font-size: 1rem;
        }

        .jcard-body p {
            color: var(--muted);
            font-size: 0.83rem;
            line-height: 1.5;
            margin-bottom: 10px;
        }

        .jcard-date {
            font-size: 0.8rem;
            color: var(--muted);
            margin-bottom: 10px;
        }

        .jcard-link {
            color: var(--gold);
            font-size: 0.82rem;
            font-weight: 600;
            text-decoration: none;
        }

            .jcard-link:hover {
                text-decoration: underline;
            }

        @@media (max-width: 1024px) {
            .db-stats {
                grid-template-columns: repeat(2, 1fr);
            }

            .db-overview-grid {
                grid-template-columns: 1fr;
            }

            .db-profile-grid {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width: 768px) {
            .db-hero {
                padding: 32px 20px 0;
            }

            .db-hero-inner {
                flex-direction: column;
                align-items: flex-start;
                gap: 16px;
            }

            .db-hero-name {
                font-size: 24px;
            }

            .db-tabs {
                padding: 0 20px;
                overflow-x: auto;
            }

            .db-tab {
                white-space: nowrap;
            }

            .db-content {
                padding: 0 16px;
            }

            .db-stats {
                grid-template-columns: repeat(2, 1fr);
                gap: 12px;
            }

            .db-booking-cards {
                grid-template-columns: 1fr;
            }

            .db-fav-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @@media (max-width: 600px) {
            #journeyMap {
                height: 280px;
            }

            .journey-stats {
                gap: 10px;
            }

            .jstat {
                padding: 12px 18px;
                min-width: 85px;
            }

            .journey-cards {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width: 480px) {
            .db-stats {
                grid-template-columns: 1fr 1fr;
            }

            .db-fav-grid-mini {
                grid-template-columns: 1fr 1fr;
            }
        }

        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .fade-up {
            opacity: 0;
            animation: fadeUp 0.5s ease forwards;
        }

            .fade-up:nth-child(1) {
                animation-delay: 0.05s;
            }

            .fade-up:nth-child(2) {
                animation-delay: 0.10s;
            }

            .fade-up:nth-child(3) {
                animation-delay: 0.15s;
            }

            .fade-up:nth-child(4) {
                animation-delay: 0.20s;
            }

            .fade-up:nth-child(5) {
                animation-delay: 0.25s;
            }

            .fade-up:nth-child(6) {
                animation-delay: 0.30s;
            }

        .explorer-badge {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            margin-top: 16px;
            background: rgba(var(--gold-rgb),.08);
            border: 1px solid rgba(var(--gold-rgb),.3);
            border-radius: 12px;
            padding: 14px;
        }

        .badge-icon {
            font-size: 2rem;
        }

        .badge-title {
            color: var(--gold);
            font-family: 'Cinzel', serif;
            font-size: 0.95rem;
            font-weight: 700;
        }

        .badge-count {
            color: var(--text-dim);
            font-size: 0.78rem;
        }

    </style>
}

<div class="db-wrap">

    <div class="db-hero">
        <div class="db-hero-inner">
            <div class="db-avatar-wrap">
                <div class="db-avatar">@initials</div>
                <div class="db-avatar-badge"></div>
            </div>
            <div class="db-hero-info">
                <div class="db-hero-greeting">⸸ @Html.L("Dash_WelcomeBack")</div>
                <div class="db-hero-name">@Model.UserName</div>
                <div class="db-hero-email">@Model.UserEmail</div>
            </div>
        </div>

        <div class="db-tabs">
            <button class="db-tab active" onclick="switchTab('overview', this)">𓂀 @Html.L("Dash_Tab_Overview")</button>
            <button class="db-tab" onclick="switchTab('bookings', this)">
                📅 @Html.L("Dash_Tab_Bookings")
                @if (Model.TotalBookings > 0)
                {
                    <span class="tab-badge">@Html.Digits(Model.TotalBookings)</span>
                }
            </button>
            @* 🆕 Shop: مش تاب جوه الداشبورد زي Bookings/Favorites (بيوديك مباشرة لصفحة /Shop/MyOrders
               المستقلة بدل ما يبدّل تاب جوه نفس الصفحة) — لكن دلوقتي بيجيب العدد فعليًا من
               ViewBag.TotalOrders اللي الكنترولر بقى بيحسبه *@
            <a class="db-tab" href="/Shop/MyOrders">
                🛍️ @Html.L("Shop_MyOrders")
                @if ((int)(ViewBag.TotalOrders ?? 0) > 0)
                {
                    <span class="tab-badge">@Html.Digits((object)ViewBag.TotalOrders)</span>
                }
            </a>
            <button class="db-tab" onclick="switchTab('favorites', this)">
                𓆣 @Html.L("Dash_Tab_Favorites")
                @if (Model.TotalFavorites > 0)
                {
                    <span class="tab-badge">@Html.Digits(Model.TotalFavorites)</span>
                }
            </button>
            <button class="db-tab" onclick="switchTab('journey', this)">
                🗺️ @Html.L("Dash_Tab_Journey")
                @if (ViewBag.JourneyCount > 0)
                {
                    <span class="tab-badge">@Html.Digits((object)ViewBag.JourneyCount)</span>
                }
            </button>
            <button class="db-tab" onclick="switchTab('profile', this)">𓁹 @Html.L("Dash_Tab_Profile")</button>
        </div>
    </div>

    <div class="db-content">

        @* {{-- ===== OVERVIEW ===== --}} *@
        <div id="tab-overview" class="db-panel active">

            @if (!(bool)(ViewBag.HasBankAccount ?? false))
            {
                bool isConnError = (bool)(ViewBag.BankConnectionError ?? false);
                <div class="db-bank-banner fade-up @(isConnError ? "is-error" : "")" style="margin-top:32px;">
                    <div class="db-bank-banner-icon">
                        @if (isConnError)
                        {
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M12 9v4m0 4h.01M10.29 3.86 1.82 18a1.5 1.5 0 0 0 1.29 2.25h17.78A1.5 1.5 0 0 0 22.18 18L13.71 3.86a1.5 1.5 0 0 0-2.42 0Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                        }
                        else
                        {
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <rect x="2" y="5" width="20" height="14" rx="2.5" stroke="currentColor" stroke-width="1.8" />
                                <path d="M2 10h20" stroke="currentColor" stroke-width="1.8" />
                                <path d="M6 14.5h4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                            </svg>
                        }
                    </div>
                    <div class="db-bank-banner-content">
                        <span class="db-bank-banner-title">
                            @(isConnError ? @Html.L("Dash_BankUnavailable_Title") : @Html.L("Dash_NoBankAccount_Title"))
                        </span>
                        <div class="db-bank-banner-body">
                            @if (isConnError)
                            {
                                @Html.L("Dash_BankUnavailable_Body")
                            }
                            else
                            {
                                @Html.L("Dash_NoBankAccount_Body")
                            }
                        </div>
                    </div>
                    @if (!isConnError)
                    {
                        <a href="mailto:@ViewBag.BankContactEmail" class="btn-gold db-bank-banner-cta">
                            <svg viewBox="0 0 24 24" fill="none" width="14" height="14" xmlns="http://www.w3.org/2000/svg">
                                <path d="M3 6.5A1.5 1.5 0 0 1 4.5 5h15A1.5 1.5 0 0 1 21 6.5v11a1.5 1.5 0 0 1-1.5 1.5h-15A1.5 1.5 0 0 1 3 17.5v-11Z" stroke="currentColor" stroke-width="1.8" />
                                <path d="m4 6.5 8 6.25 8-6.25" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                            @Html.L("Dash_NoBankAccount_Cta")
                        </a>
                    }
                </div>
            }

            <div class="db-stats" style="margin-top:@(((bool)(ViewBag.HasBankAccount ?? false)) ? "32px" : "20px");">
                <div class="db-stat fade-up">
                    <div class="db-stat-icon gold">𓋹</div>
                    <div>
                        <div class="db-stat-val counter" data-target="@Model.TotalBookings">0</div>
                        <div class="db-stat-label">@Html.L("Dash_Stat_TotalBookings")</div>
                    </div>
                </div>
                <div class="db-stat fade-up">
                    <div class="db-stat-icon green">✅</div>
                    <div>
                        <div class="db-stat-val counter" data-target="@Model.ActiveBookings">0</div>
                        <div class="db-stat-label">@Html.L("Dash_Stat_ActiveVisits")</div>
                    </div>
                </div>
                <div class="db-stat fade-up">
                    <div class="db-stat-icon blue">𓆣</div>
                    <div>
                        <div class="db-stat-val counter" data-target="@Model.TotalFavorites">0</div>
                        <div class="db-stat-label">@Html.L("Dash_Stat_Saved")</div>
                    </div>
                </div>
                <div class="db-stat fade-up">
                    <div class="db-stat-icon green">🏛️</div>
                    <div>
                        <div class="db-stat-val counter" data-target="@Model.VisitedCount">0</div>
                        <div class="db-stat-label">@Html.L("Dash_Stat_PlacesVisited")</div>
                    </div>
                </div>
                <div class="db-stat fade-up">
                    <div class="db-stat-icon red">𓂋</div>
                    <div>
                        <div class="db-stat-val" id="totalSpent">0</div>
                        <div class="db-stat-label">@Html.L("Dash_Stat_TotalSpent")</div>
                    </div>
                </div>
                @if ((bool)(ViewBag.HasBankAccount ?? false))
                {
                    <div class="db-stat fade-up">
                        <div class="db-stat-icon gold">💳</div>
                        <div>
                            <div class="db-stat-val">@Html.Digits(((decimal)ViewBag.BankBalance).ToString("N0"))</div>
                            <div class="db-stat-label">@Html.L("Dash_Stat_WalletBalance")</div>
                        </div>
                    </div>
                }
            </div>

            <div class="db-overview-grid">
                <div>
                    <div class="db-section-head">
                        <div class="db-section-title">@Html.L("Dash_RecentBookings")</div>
                        <a class="db-see-all" href="#" onclick="switchTab('bookings', document.querySelectorAll('.db-tab')[1]); return false;">@Html.L("Dash_ViewAll") @arrowNext</a>
                    </div>
                    <div class="db-booking-list">
                        @if (!Model.Bookings.Any())
                        {
                            <div class="db-empty">
                                <div class="db-empty-icon">📅</div>
                                <div class="db-empty-text">@Html.L("Dash_NoBookingsYet")</div>
                            </div>
                        }
                        else
                        {
                            @foreach (var b in Model.Bookings.Take(5))
                            {
                                <div class="db-booking-row fade-up">
                                    <img class="db-booking-thumb" src="@(b.ImageUrl ?? "/images/placeholder.jpg")" alt="@b.PlaceName" onerror="this.src='/images/placeholder.jpg'" />
                                    <div class="db-booking-info">
                                        <div class="db-booking-name">@b.PlaceName</div>
                                        <div class="db-booking-meta">
                                            <span>📅 @Html.DateLoc(b.VisitDate, "MMM dd, yyyy")</span>
                                            <span>🎫 @Html.Digits(b.NumberOfTickets) @Html.L("Dash_Tickets")</span>
                                        </div>
                                    </div>
                                    <div>
                                        <div class="db-booking-price">@Html.Digits(b.TotalPrice.ToString("N0")) @Html.L("Dash_EGP")</div>
                                        <span class="status-badge @b.Status">@Html.L("Status_" + b.Status)</span>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>

                <div>
                    <div class="db-section-head">
                        <div class="db-section-title">@Html.L("Dash_Saved")</div>
                        <a class="db-see-all" href="#" onclick="switchTab('favorites', document.querySelectorAll('.db-tab')[2]); return false;">@Html.L("Dash_ViewAll") @arrowNext</a>
                    </div>
                    @{
