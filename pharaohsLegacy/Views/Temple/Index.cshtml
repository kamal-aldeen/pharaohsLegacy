@model List<pharaohsLegacy.Models.Temple>
@using pharaohsLegacy.Extensions

@{
    ViewData["Title"] = "Temples";
}

@section Styles {
<style>
.pg-hero {
    text-align: center; padding: 4rem 2rem 3rem;
    position: relative; overflow: hidden;
}
.pg-hero::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse 70% 60% at 50% 0%, rgba(201,162,39,.1) 0%, transparent 70%);
    pointer-events: none;
}
.pg-hero-symbol { font-size: 3rem; display: block; margin-bottom: 1rem; animation: floatSym 3s ease-in-out infinite; }
@@keyframes floatSym { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-8px); } }
.pg-hero h1 { font-family: 'Cinzel', serif; font-size: clamp(2rem, 5vw, 3.5rem); color: #e8d5b0; margin-bottom: .75rem; font-weight: 700; letter-spacing: 2px; }
.pg-hero h1 span { color: #c9a227; }
.pg-hero p { color: #8a7055; font-size: 1.1rem; font-style: italic; max-width: 500px; margin: 0 auto 2rem; }
.pg-divider { width: 120px; height: 1px; background: linear-gradient(90deg, transparent, #c9a227, transparent); margin: 0 auto; }

.pg-search-wrap { max-width: 480px; margin: 2rem auto 0; position: relative; }

        .pg-search {
            width: 100%;
            background: rgba(201,162,39,.05);
            border: 1px solid #3d2a15;
            border-radius: 50px;
            padding: .85rem 1.5rem .85rem 3rem;
            color: #e8d5b0;
            font-family: 'Crimson Pro', serif;
            font-size: 1rem;
            outline: none;
            transition: border-color .3s;
        }
.pg-search:focus { border-color: #c9a227; }
.pg-search::placeholder { color: #8a7055; }
.pg-search-icon { position: absolute; left: 1.1rem; top: 50%; transform: translateY(-50%); color: #8a7055; pointer-events: none; }

.pg-count { text-align: center; font-family: 'Cinzel', serif; font-size: .65rem; letter-spacing: 3px; text-transform: uppercase; color: #8a7055; margin: 2rem 0 .5rem; }

.pg-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; max-width: 1200px; margin: 0 auto; padding: 0 2rem 4rem; }

        .pg-card {
            background: #2d1a08;
            border: 1px solid #3d2a15;
            border-radius: 12px;
            overflow: hidden;
            text-decoration: none;
            color: inherit;
            display: block;
            position: relative;
            opacity: 0;
            transform: translateY(20px);
            transition: border-color .3s, box-shadow .3s, transform .3s;
        }
.pg-card.visible { opacity: 1; transform: translateY(0); }
.pg-card:hover { transform: translateY(-6px); border-color: #c9a227; box-shadow: 0 12px 40px rgba(201,162,39,.15); }

        .pg-card-img {
            position: relative;
            height: 220px;
            overflow: hidden;
            background: #1a0e05;
        }

.pg-card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform .5s; }
.pg-card:hover .pg-card-img img { transform: scale(1.08); }
.pg-card-img-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(13,7,2,.85) 0%, transparent 50%); }

.pg-card-location {
    position: absolute; bottom: 12px; left: 12px;
    background: rgba(13,7,2,.75); backdrop-filter: blur(4px);
    border: 1px solid rgba(201,162,39,.3); border-radius: 20px;
    padding: 4px 12px;
    font-family: 'Cinzel', serif; font-size: .6rem;
    letter-spacing: 1px; color: #c9a227;
}
.pg-card-ticket {
    position: absolute; top: 12px; right: 12px;
    background: rgba(201,162,39,.15); backdrop-filter: blur(4px);
    border: 1px solid rgba(201,162,39,.3); border-radius: 20px;
    padding: 4px 10px; font-size: .7rem; color: #c9a227;
}

.pg-card-body { padding: 1.25rem; }
.pg-card-tag { font-family: 'Cinzel', serif; font-size: .6rem; letter-spacing: 2px; text-transform: uppercase; color: #c9a227; margin-bottom: .4rem; display: block; }
.pg-card-name { font-family: 'Cinzel', serif; font-size: 1.1rem; color: #e8d5b0; margin-bottom: .4rem; font-weight: 600; }
.pg-card-desc { color: #8a7055; font-size: .9rem; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

        .pg-card-footer {
            padding: .75rem 1.25rem;
            border-top: 1px solid #3d2a15;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

.pg-card-footer span { font-size: .8rem; color: #8a7055; font-style: italic; }
.pg-card-arrow { color: #c9a227; }

.pg-empty { text-align: center; padding: 4rem 2rem; color: #8a7055; display: none; }
.pg-empty-icon { font-size: 3rem; margin-bottom: 1rem; }
.pg-empty-text { font-family: 'Cinzel', serif; font-size: 1rem; }

@@media (max-width: 768px) {
    .pg-grid { padding: 0 1rem 3rem; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); }
}
</style>
}

<div class="pg-hero">
    <span class="pg-hero-symbol">🛕</span>
    <h1>@Html.L("Temple_Hero_Title") <span>@Html.L("Temple_Hero_Subtitle_Span")</span></h1>
    <p>@Html.L("Temple_Hero_Subtitle")</p>
    <div class="pg-divider"></div>
    <div class="pg-search-wrap">
        <span class="pg-search-icon">🔍</span>
        <input class="pg-search" type="text" placeholder="@Html.L("Temple_Search_Placeholder")"
               oninput="filterCards(this.value)" />
    </div>
</div>

<div class="pg-count" id="pgCount">@Model.Count @Html.L("Temple_Count_Label")</div>

<div class="pg-grid" id="pgGrid">
    @foreach (var t in Model)
    {
        <a href="/Temple/Details/@t.Id" class="pg-card"
           data-name="@t.Name.ToLower()" data-sub="@t.Location.ToLower()">
            <div class="pg-card-img">
                <img src="@t.ImageUrl" alt="@t.Name"
                     onerror="this.src='https://via.placeholder.com/400x300/2d1a08/c9a227?text=@t.Name'" />
                <div class="pg-card-img-overlay"></div>
                <span class="pg-card-location">📍 @t.Location</span>
                <span class="pg-card-ticket">🎟 150 @Html.L("Common_EGP")</span>
            </div>
            <div class="pg-card-body">
                <span class="pg-card-tag">🛕 @Html.L("Common_Temple")</span>
                <div class="pg-card-name">@t.Name</div>
                <div class="pg-card-desc">@t.Description</div>
            </div>
            <div class="pg-card-footer">
                <span>@t.Period</span>
                <span class="pg-card-arrow">→</span>
            </div>
        </a>
    }
</div>

<div class="pg-empty" id="pgEmpty">
    <div class="pg-empty-icon">🛕</div>
    <div class="pg-empty-text">@Html.L("Temple_Empty_Text")</div>
</div>

@section Scripts {
<script>
const pgCards = document.querySelectorAll('.pg-card');
const obs = new IntersectionObserver((entries) => {
    entries.forEach((e, i) => {
        if (e.isIntersecting) {
            setTimeout(() => e.target.classList.add('visible'), i * 60);
            obs.unobserve(e.target);
        }
    });
}, { threshold: 0.1 });
pgCards.forEach(c => obs.observe(c));

function filterCards(q) {
    q = q.toLowerCase();
    let visible = 0;
    pgCards.forEach(card => {
        const match = card.dataset.name.includes(q) || card.dataset.sub.includes(q);
        card.style.display = match ? '' : 'none';
        if (match) visible++;
    });
    document.getElementById('pgCount').textContent = visible + ' TEMPLES';
    document.getElementById('pgEmpty').style.display = visible === 0 ? 'block' : 'none';
}
</script>
}
