@using pharaohsLegacy.Extensions

@model pharaohsLegacy.Models.Pharaoh
@{
    var userEmail = Context.Session.GetString("UserEmail");
    var isGuest   = userEmail == null || userEmail == "guest";
    var isFav     = ViewBag.IsFav as bool? ?? false;
    var lang = Context.Session.GetString("Lang") ?? "en";
    var arrowBack = lang == "ar" ? "→" : "←";
    var arrowNext = lang == "ar" ? "←" : "→";
    var pName = (lang == "ar" && !string.IsNullOrEmpty(Model.NameAr)) ? Model.NameAr : Model.Name;
    var pDynasty = Html.Digits((lang == "ar" && !string.IsNullOrEmpty(Model.DynastyAr)) ? Model.DynastyAr : Model.Dynasty);
    var pPeriod = Html.Digits((lang == "ar" && !string.IsNullOrEmpty(Model.PeriodAr)) ? Model.PeriodAr : Model.Period);
    var pDescription = (lang == "ar" && !string.IsNullOrEmpty(Model.DescriptionAr)) ? Model.DescriptionAr : Model.Description;
    ViewData["Title"] = pName;
}
<link rel="stylesheet" href="~/css/events.css" />

@section Styles {
<style>
.det-wrap { max-width: 1100px; margin: 0 auto; padding: 2rem 2rem 5rem; }

.det-banner {
    position: relative; height: 380px;
    border-radius: 16px; overflow: hidden;
            margin-bottom: 2rem;
            border: 1px solid var(--border);
}
.det-banner img { width: 100%; height: 100%; object-fit: cover; filter: brightness(.55); }
.det-banner-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(var(--dark-rgb),.95) 0%, rgba(var(--dark-rgb),.3) 60%, transparent 100%);
}
.det-banner-content {
    position: absolute; bottom: 2rem; left: 2rem; right: 2rem;
    display: flex; align-items: flex-end; justify-content: space-between; gap: 1rem;
}
.det-banner-tag {
    font-family: 'Cinzel', serif; font-size: .65rem;
    letter-spacing: 3px; text-transform: uppercase;
    color: var(--gold); margin-bottom: .5rem;
}
.det-banner-name {
    font-family: 'Cinzel', serif;
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 700; color: var(--text);
    line-height: 1.1; text-shadow: 0 2px 20px rgba(0,0,0,.5);
}

.det-content { display: grid; grid-template-columns: 1fr 320px; gap: 2rem; align-items: start; }

.det-section-title {
    font-family: 'Cinzel', serif; font-size: .65rem;
    letter-spacing: 3px; text-transform: uppercase;
    color: var(--gold); margin-bottom: .75rem;
    display: flex; align-items: center; gap: .75rem;
}

            .det-section-title::after {
                content: '';
                flex: 1;
                height: 1px;
                background: linear-gradient(90deg, var(--border), transparent);
            }
.det-description { color: var(--muted); font-size: 1.05rem; line-height: 1.9; margin-bottom: 2rem; }

.det-sidebar { display: flex; flex-direction: column; gap: 1rem; }

        .det-info-card {
            background: var(--dark3);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 1.5rem;
            box-shadow: var(--card-shadow);
        }
.det-info-card-title {
    font-family: 'Cinzel', serif; font-size: .65rem;
    letter-spacing: 2px; text-transform: uppercase;
    color: var(--gold); margin-bottom: 1rem;
            padding-bottom: .75rem;
            border-bottom: 1px solid var(--border);
}
.det-info-row { display: flex; align-items: center; gap: .75rem; padding: .6rem 0; border-bottom: 1px solid rgba(var(--border-rgb),.5); }
.det-info-row:last-child { border-bottom: none; }
.det-info-icon { font-size: 1.1rem; width: 24px; text-align: center; flex-shrink: 0; }
.det-info-label { font-size: .75rem; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; font-family: 'Cinzel', serif; }
.det-info-value { font-size: .95rem; color: var(--text); margin-top: 2px; }

.det-btn {
    width: 100%; padding: .9rem; border-radius: 8px;
    font-family: 'Cinzel', serif; font-size: .7rem;
    letter-spacing: 2px; text-transform: uppercase;
    cursor: pointer; transition: all .3s; border: 1px solid;
    display: flex; align-items: center; justify-content: center;
    gap: .6rem; text-decoration: none;
}
        .det-btn-fav {
            background: transparent;
            border-color: var(--border);
            color: var(--muted);
        }
.det-btn-fav:hover { border-color: #e74c3c; color: #e74c3c; }
.det-btn-fav.active { background: rgba(231,76,60,.08); border-color: #e74c3c; color: #e74c3c; }

.det-nav { display: flex; gap: 1rem; margin-top: 2rem; flex-wrap: wrap; }

@@media (max-width: 900px) {
    .det-content { grid-template-columns: 1fr; }
    .det-sidebar { order: -1; }
    .det-banner { height: 280px; }
    .det-banner-name { font-size: 2rem; }
}
@@media (max-width: 480px) {
    .det-wrap { padding: 1rem 1rem 4rem; }
    .det-banner { height: 220px; }
}
</style>
}

<div class="det-wrap">
    <a href="/Pharaoh/Index" class="btn-back">@arrowBack @Html.L("Pharaoh_Back_Link")</a>

    <div class="det-banner">
        <img src="@Model.ImageUrl" alt="@pName"
             onerror="this.src='https://via.placeholder.com/1200x400/2d1a08/c9a227?text=@pName'" />
        <div class="det-banner-overlay"></div>
        <div class="det-banner-content">
            <div>
                <div class="det-banner-tag">👑 @pDynasty</div>
                <div class="det-banner-name">@pName</div>
            </div>
        </div>
    </div>

    <div class="det-content">

        <div>
            <div class="det-section-title">@Html.L("Common_About") @pName</div>
            <p class="det-description">@pDescription</p>
            <div class="det-nav">
                <a href="/Pharaoh/Index" class="btn-outline">@arrowBack @Html.L("Pharaoh_AllPharaohs_Link")</a>
            </div>
        </div>

        <div class="det-sidebar">
            <div class="det-info-card">
                <div class="det-info-card-title">@Html.L("Common_QuickFacts")</div>
                <div class="det-info-row">
                    <span class="det-info-icon">👑</span>
                    <div>
                        <div class="det-info-label">@Html.L("Common_Name")</div>
                        <div class="det-info-value">@pName</div>
                    </div>
                </div>
                <div class="det-info-row">
                    <span class="det-info-icon">𓋹</span>
                    <div>
                        <div class="det-info-label">@Html.L("Common_Dynasty")</div>
                        <div class="det-info-value">@pDynasty</div>
                    </div>
                </div>
                <div class="det-info-row">
                    <span class="det-info-icon">📅</span>
                    <div>
                        <div class="det-info-label">@Html.L("Common_Period")</div>
                        <div class="det-info-value">@pPeriod</div>
                    </div>
                </div>
                <div class="det-info-row">
                    <span class="det-info-icon">🏛️</span>
                    <div>
                        <div class="det-info-label">@Html.L("Common_Origin")</div>
                        <div class="det-info-value">@Html.L("Common_AncientEgypt")</div>
                    </div>
                </div>
            </div>

            @if (!isGuest)
            {
                <a href="@(isFav ? $"/Favorite/Remove/{ViewBag.FavId}?returnUrl=/Pharaoh/Details/{Model.Id}" : $"/Favorite/Add?type=Pharaoh&itemId={Model.Id}&returnUrl=/Pharaoh/Details/{Model.Id}")"
                   class="det-btn det-btn-fav @(isFav ? "active" : "")">
                    @(isFav ? "❤️ " + Html.L("Common_RemoveFavorite") : "🤍 " + Html.L("Common_AddFavorite"))
                </a>
            }
            else
            {
                <a href="/User/Login" class="det-btn det-btn-fav">🔒 @Html.L("Common_LoginToSave")</a>
            }
        </div>
    </div>

    @await Html.PartialAsync("_Reviews", (
    Reviews: (List<pharaohsLegacy.Models.Review>)ViewBag.Reviews,
    Type: "pharaoh",
    ItemId: Model.Id,
    UserReviewed: (bool)ViewBag.HasReviewed
))

    @{
        var pharaohEvents = ViewBag.HistoricalEvents as List<pharaohsLegacy.Models.HistoricalEvent> ?? new();
    }
    @if (pharaohEvents.Any())
    {
        <div class="dynasty-events-section">
            <h2>𓋹 @Html.L("Common_KeyEvents")</h2>
            <div class="dynasty-events-list">
                @foreach (var ev in pharaohEvents)
                {
                    var evTitle = (lang == "ar" && !string.IsNullOrEmpty(ev.TitleAr)) ? ev.TitleAr : ev.Title;
                    var evCategory = (lang == "ar" && !string.IsNullOrEmpty(ev.CategoryAr)) ? ev.CategoryAr : ev.Category;
                    <a href="@Url.Action("Details", "HistoricalEvent", new { id = ev.Id })"
                       class="dynasty-event-item cat-@ev.Category.ToLower()">
                        <span class="dynasty-event-year">@Html.YearLabel(ev.Year)</span>
                        <span class="dynasty-event-badge cat-@ev.Category.ToLower()">@evCategory</span>
                        <span class="dynasty-event-title">@evTitle</span>
                        <span class="dynasty-event-arrow">@arrowNext</span>
                    </a>
                }
            </div>
        </div>
    }

</div>
