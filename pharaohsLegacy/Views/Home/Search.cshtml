@using pharaohsLegacy.Extensions

@{
    ViewData["Title"] = "Search Results";
    var pharaohs = ViewBag.Pharaohs as List<pharaohsLegacy.Models.Pharaoh>;
    var temples = ViewBag.Temples as List<pharaohsLegacy.Models.Temple>;
    var gods = ViewBag.Gods as List<pharaohsLegacy.Models.God>;
    var museums = ViewBag.Museums as List<pharaohsLegacy.Models.Museum>;
    var artifacts = ViewBag.Artifacts as List<pharaohsLegacy.Models.Artifact>;
    var dynasties = ViewBag.Dynasties as List<pharaohsLegacy.Models.Dynasty>;
    var products = ViewBag.Products as List<pharaohsLegacy.Models.Product>;
    var lang = Context.Session.GetString("Lang") ?? "en";
}

<div class="section">
    <div class="section-header">
        <span class="section-tag">@Html.L("Search_SectionTag")</span>
        <h2 class="section-title">@Html.L("Search_ResultsFor_Prefix") "@ViewBag.Query"</h2>
        <div class="section-line"></div>
    </div>

    @if (pharaohs != null && pharaohs.Count > 0)
    {
        <h3 style="font-family:'Cinzel',serif; color:var(--gold); margin-bottom:1rem;">@Html.L("Common_PharaohsPlural")</h3>
        <div class="cards-grid">
            @foreach (var p in pharaohs)
            {
                var pName = (lang == "ar" && !string.IsNullOrEmpty(p.NameAr)) ? p.NameAr : p.Name;
                var pDynasty = (lang == "ar" && !string.IsNullOrEmpty(p.DynastyAr)) ? p.DynastyAr : p.Dynasty;
                <a href="/Pharaoh/Details/@p.Id" class="card">
                    <div class="card-img"><img src="@p.ImageUrl" alt="@pName" /></div>
                    <div class="card-body">
                        <span class="card-tag">@pDynasty</span>
                        <h3 class="card-title">@pName</h3>
                    </div>
                </a>
            }
        </div>
    }

    @if (temples != null && temples.Count > 0)
    {
        <h3 style="font-family:'Cinzel',serif; color:var(--gold); margin:2rem 0 1rem;">@Html.L("Common_TemplesPlural")</h3>
        <div class="cards-grid">
            @foreach (var t in temples)
            {
                var tName = (lang == "ar" && !string.IsNullOrEmpty(t.NameAr)) ? t.NameAr : t.Name;
                var tLocation = (lang == "ar" && !string.IsNullOrEmpty(t.LocationAr)) ? t.LocationAr : t.Location;
                <a href="/Temple/Details/@t.Id" class="card">
                    <div class="card-img"><img src="@t.ImageUrl" alt="@tName" /></div>
                    <div class="card-body">
                        <span class="card-tag">@tLocation</span>
                        <h3 class="card-title">@tName</h3>
                    </div>
                </a>
            }
        </div>
    }

    @if (gods != null && gods.Count > 0)
    {
        <h3 style="font-family:'Cinzel',serif; color:var(--gold); margin:2rem 0 1rem;">@Html.L("Common_GodsPlural")</h3>
        <div class="cards-grid">
            @foreach (var g in gods)
            {
                var gName = (lang == "ar" && !string.IsNullOrEmpty(g.NameAr)) ? g.NameAr : g.Name;
                var gRole = (lang == "ar" && !string.IsNullOrEmpty(g.RoleAr)) ? g.RoleAr : g.Role;
                <a href="/God/Details/@g.Id" class="card">
                    <div class="card-img"><img src="@g.ImageUrl" alt="@gName" /></div>
                    <div class="card-body">
                        <span class="card-tag">@gRole</span>
                        <h3 class="card-title">@gName</h3>
                    </div>
                </a>
            }
        </div>
    }

    @if (museums != null && museums.Count > 0)
    {
        <h3 style="font-family:'Cinzel',serif; color:var(--gold); margin:2rem 0 1rem;">@Html.L("Common_MuseumsPlural")</h3>
        <div class="cards-grid">
            @foreach (var m in museums)
            {
                var mName = (lang == "ar" && !string.IsNullOrEmpty(m.NameAr)) ? m.NameAr : m.Name;
                var mLocation = (lang == "ar" && !string.IsNullOrEmpty(m.LocationAr)) ? m.LocationAr : m.Location;
                <a href="/Museum/Details/@m.Id" class="card">
                    <div class="card-img"><img src="@m.ImageUrl" alt="@mName" /></div>
                    <div class="card-body">
                        <span class="card-tag">@mLocation</span>
                        <h3 class="card-title">@mName</h3>
                    </div>
                </a>
            }
        </div>
    }

    @if (artifacts != null && artifacts.Count > 0)
    {
        <h3 style="font-family:'Cinzel',serif; color:var(--gold); margin:2rem 0 1rem;">@Html.L("Common_Artifacts")</h3>
        <div class="cards-grid">
            @foreach (var a in artifacts)
            {
                var aName = (lang == "ar" && !string.IsNullOrEmpty(a.NameAr)) ? a.NameAr : a.Name;
                var aCategory = (lang == "ar" && !string.IsNullOrEmpty(a.CategoryAr)) ? a.CategoryAr : a.Category;
                <a href="/Artifact/Details/@a.Id" class="card">
                    <div class="card-img"><img src="@a.ImageUrl" alt="@aName" /></div>
                    <div class="card-body">
                        <span class="card-tag">@aCategory</span>
                        <h3 class="card-title">@aName</h3>
                    </div>
                </a>
            }
        </div>
    }

    @if (dynasties != null && dynasties.Count > 0)
    {
        <h3 style="font-family:'Cinzel',serif; color:var(--gold); margin:2rem 0 1rem;">@Html.L("Common_DynastiesPlural")</h3>
        <div class="cards-grid">
            @foreach (var d in dynasties)
            {
                var dName = (lang == "ar" && !string.IsNullOrEmpty(d.NameAr)) ? d.NameAr : d.Name;
                <a href="/Dynasty/Details/@d.Id" class="card">
                    <div class="card-img"><img src="@d.ImageUrl" alt="@dName" /></div>
                    <div class="card-body">
                        <span class="card-tag">@Html.YearLabel(d.StartYear) – @Html.YearLabel(d.EndYear)</span>
                        <h3 class="card-title">@dName</h3>
                    </div>
                </a>
            }
        </div>
    }

    @if (products != null && products.Count > 0)
    {
        <h3 style="font-family:'Cinzel',serif; color:var(--gold); margin:2rem 0 1rem;">@Html.L("Common_ProductsPlural")</h3>
        <div class="cards-grid">
            @foreach (var pr in products)
            {
                var prName = (lang == "ar" && !string.IsNullOrEmpty(pr.NameAr)) ? pr.NameAr : pr.Name;
                var prTag = pr.Category != null
                    ? ((lang == "ar" && !string.IsNullOrEmpty(pr.Category.NameAr)) ? pr.Category.NameAr : pr.Category.Name)
                    : $"{pr.Price} {Html.L("Common_EGP")}";
                <a href="/Shop/Details/@pr.Id" class="card">
                    <div class="card-img"><img src="@pr.ImageUrl" alt="@prName" /></div>
                    <div class="card-body">
                        <span class="card-tag">@prTag</span>
                        <h3 class="card-title">@prName</h3>
                    </div>
                </a>
            }
        </div>
    }

    @if ((pharaohs == null || pharaohs.Count == 0) &&
         (temples == null || temples.Count == 0) &&
         (gods == null || gods.Count == 0) &&
         (museums == null || museums.Count == 0) &&
         (artifacts == null || artifacts.Count == 0) &&
         (dynasties == null || dynasties.Count == 0) &&
         (products == null || products.Count == 0))
    {
        <div style="text-align:center; padding:3rem; color:var(--muted); font-style:italic;">
            <p style="font-size:3rem; margin-bottom:1rem;">𓂀</p>
            <p>@Html.L("Search_NoResults_Prefix") "@ViewBag.Query"</p>
        </div>
    }
</div>