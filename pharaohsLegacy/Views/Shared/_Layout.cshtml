        // غير أي View بيعرضهم فعليًا، فكانوا بيضيعوا صامتين.
        var flashMessage = TempData["Message"] as string;
        var flashError = TempData["Error"] as string;
    }
    @if (!string.IsNullOrEmpty(flashMessage) || !string.IsNullOrEmpty(flashError))
    {
        <div class="pl-toast @(string.IsNullOrEmpty(flashError) ? "success" : "error")" id="plToast">
            <span class="pl-toast-icon">@(string.IsNullOrEmpty(flashError) ? "✓" : "⚠")</span>
            <span class="pl-toast-text">@(flashError ?? flashMessage)</span>
            <button class="pl-toast-close" onclick="document.getElementById('plToast').remove()" aria-label="Close">✕</button>
        </div>
    }

    <div class="main-content">
        @RenderBody()
    </div>


